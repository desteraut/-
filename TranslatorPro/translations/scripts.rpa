    imagebutton auto "images/desert/gas/knob4_%s.png" focus_mask True style "vendingbutton" hovered play_lever_hover action [SetVariable("vending_slot", 4), Call("vending_outcome")]
    imagebutton auto "images/desert/gas/knob5_%s.png" focus_mask True style "vendingbutton" hovered play_lever_hover action [SetVariable("vending_slot", 5), Call("vending_outcome")]
    imagebutton auto "images/desert/gas/knob6_%s.png" focus_mask True style "vendingbutton" hovered play_lever_hover action [SetVariable("vending_slot", 6), Call("vending_outcome")]
    textbutton "Stop and leave" xalign 0.95 yalign 0.95 action Jump("game_loop")


label bridgetteinvestigate:
    if quest_bridgettebreakdown in questlog.quest_list:
        scene gaslore1 with dissolve
        detentiongirl "What is he doing here? I thought you said you wouldn't tell anyone."
        scene gaslore2 with dissolve
        bffsis "[name] is his stepbrother, Emma."
        detentiongirl "Oh..."
        pause 0.5
        detentiongirl "Sorry [name], I didn't mean to-"
        mc "It's alright, I don't want to be here longer than necessary. Let's go inside."
        scene gaslore3 with dissolve
        pause 0.5
        scene gaslore4 with dissolve
        pause 0.5
        scene gaslore5 with dissolve
        "Just like last time, this place gives you the creeps."
        mc "Ugh, can we turn on the lights in this place? It's creepy enough as is."
        bffsis "Yeah, hold on."
        scene gaslore6 with dissolve
        mc "Much better."
        mc "So, what are we looking for exactly?"
        detentiongirl "Something, anything that gives us a lead."      
        scene gaslore7 with dissolve
        bffsis "Are you sure you're going to find it in the trash, Emma?"
        detentiongirl "This wasn't here before, so it's the first place I wanted to look at."
        mc "That... makes sense, I guess?"
        mc "So what's in the trash?"
        scene gaslore8 with dissolve
        detentiongirl "Nothing much, just plain old trash."
        detentiongirl "See for yourself."
        scene gaslore9 with dissolve
        detentiongirl "Just paper, empty cans, some cheese..."
        mc "(Wait... Cheese?)"
        mc "(No, it must be a coincidence...)"
        pause 0.5
        mc "(Right?)"
        pause 0.5
        scene gaslore10 with dissolve
        bffsis "So what do we do now, Emma?"
        detentiongirl "I don't know, but last time we were here... I felt watched the entire time."
        detentiongirl "I haven't felt the same so far, what about you guys?"
        bffsis "The place does creep me out, but I haven't seen or felt anything weird."
        "While they're chatting amongst themselves, you're too pre-occupied to pay attention."
        scene gaslore11 with dissolve
        mc "(Hmmm, half eaten cheese...)"
        mc "(It smells... fresh.)"
        mc "Could it be?"
        detentiongirl "Could what be?" with vpunch
        scene gaslore12 with dissolve
        mc "Oh, I'm sorry. I didn't mean to say that out loud."
        detentiongirl "Could what be, [name]? Out with it."
        play sound "audio/sigh.ogg"
        mc "(I guess I should tell them about what exactly happened, no point denying the truth at this point.)"
        pause 1.0
        mc "The cheese... It might be relevant."
        detentiongirl "Relevant, how?"
        scene black with fade
        "You tell her about your investigation back in the desert, the strange lady and how cheese became Justin's death."
        pause 3.0
        scene gaslore13 with dissolve
        bffsis "Wait, if we never buried his actual body..."
        pause 0.7
        bffsis "Does that mean?"
        detentiongirl "Come on, do you honestly believe this tale?"
        scene gaslore14 with dissolve
        detentiongirl "I think [name] is trying to make fun of us."
        mc "What??" with vpunch
        bffsis "You wouldn't joke about Justin's death, would you [name]?"
        mc "Of course not!"
        mc "Look, if you want proof I can take you somewhere."
        mc "There's a cave, something down there... reacted when I was near it."
        mc "It's deeper in the desert, but once we're there everything will become more clear."
        detentiongirl "Alright fine, we'll meet you there."
        detentiongirl "But [name], if this is some kind of sick joke..."
        mc "It isn't, I promise."
        bffsis "I believe him, let's go already."
        detentiongirl "Fine."
        $ questlog.EndQuest(quest_bridgettebreakdown)
        $ questlog.StartQuest(quest_taketothecave)
        scene black with slow_fade
        "The three of you decide to get out of here, the girls will meet you at the cave."
        if not desert_caveunlocked:
            $ desert_caveunlocked = True
        return
    else:
        return

label emmapickup:
    play music "audio/ambience.ogg" fadein 0.5
    scene emmascare1 with dissolve
    "As you arrive at the gas station, you notice Emma running out of the building in a hurry."
    mc "(Did something spook her?)"
    mc "(I wouldn't be surprised, this place still creeps me out.)"
    scene emmascare2 with dissolve
    play sound "audio/caropen.ogg"
    detentiongirl "(panting) Oh god... You're right on time..."
    mc "What's going on?"
    scene emmascare3 with dissolve
    play sound "audio/carstart.ogg"
    detentiongirl "Drive. Just drive."
    mc "Whoa, okay. Calm down."
    scene emmascare4 with dissolve
    "You slowly pull out of the area, Emma is frantically looking around."
    mc "(She looks terrified...)"
    scene emmascare5 with dissolve
    detentiongirl "I... don't want to talk about it."
    detentiongirl "Just take me to the motel."
    mc "Alright, hang tight."
    mc "(Whatever happened, whatever is this place... it's best left alone.)"
    scene emmascare6 with dissolve
    "And without another word said, you drive off towards the motel."
    pause 0.5
    scene emmascare7 with dissolve
    play sound "audio/brother.ogg"
    sbro "Bro...ther..."
    pause 2.0
    scene black with slow_fade
    "You arrive at the motel."
    "You drop Emma off safely and park the truck before following her inside."
    $ current_location = "motel"
    $ questlog.EndQuest(quest_detentiongirlpickup)
    $ pickedupemma = True
    scene emmaarrive1 with dissolve
    play music "audio/motel.ogg" fadein 0.5
    "When you enter the motel's lobby, Emma and Amy seem to be talking about what happened back there."
    detentiongirl "I... I don't know what that was."
    amy "Are you sure you're okay?"
    mc "Hey guys."
    scene emmaarrive2 with dissolve
    detentiongirl "I am, thanks to him."
    mc "No problem."
    mc "Though I'm still curious what happened back there."
    scene emmaarrive3 with dissolve
    amy "Maybe it's best if we don't talk about it right now."
    detentiongirl "Yeah... Let's just get some rest."
    scene emmaarrive4 with dissolve
    detentiongirl "This doesn't mean you're off the hook, [name]."
    play sound "audio/sigh.ogg"
    mc "*sighs*, I figured as much."
    detentiongirl "But... thank you."
    mc "Anytime."
    $ detentiongirllove += 10
    pause 0.5
    jump game_loop

label gaswitch:
    scene witchgas1 with dissolve
    "The bathroom feels... wrong. Too still. Too quiet."
    witch "You came."
    mc "What?! How are youŌĆö?"
    scene witchgas2 with dissolve
    witch "Do not be alarmed, [name]."
    witch "As long as I am with you, you will be safe."
    mc "What are we doing in the bathroom of a gas station?"
    scene witchgas4 with dissolve
    witch "This place... you may not realize it, but it is a rare thing."
    mc "Yeah. No kidding. What even is this?"
    scene witchgas1 with dissolve
    witch "These are the places where the world grows thin."
    mc "Thin?"
    scene witchgas2 with dissolve
    witch "Where two realities brush shoulders. Where a door can open... even when it shouldn't."
    mc "So this is... special?"
    scene witchgas4 with dissolve
    pause 0.2
    witch "Words will not open your eyes."
    witch "Mortals trust what they can see."
    witch "Very well..."
    scene witchgas3 with dissolve
    "The witch snaps her fingers."
    scene witchgas3blur with dissolve
    "Your body feels weightless, dragged, stretched, falling in every direction at once."
    play sound "audio/snapsmall.ogg"
    pause 0.1
    scene white with fade
    play sound "audio/mirrorbreak.ogg"
    "The bathroom shatters like glass, light and sand swallowing everything."
    pause 0.5
    scene black with dissolve
    "You black out."
    $ questlog.EndQuest(quest_meetwitch)
    jump veilreveal2
    

label gasininvestigate:
    scene skinwalker0 with dissolve
    "You take one last look around to see if you find anything else."
    mc "Nothing... I'll just turn the lights off and get out of here."
    scene skinwalker1 with dissolve
    mc "(Holy shit..)"
    mc "Oh, you scared me there."
    mc "I didn't see you."
    mc "(Wait.. Was she there just a second ago, or not?)"
    mc "Can I help you?"
    lady "..."
    "She remains static, staring at you... Through you."
    scene skinwalker2 with dissolve
    mc "Can I help you, miss?"
    "She looks at you as if she just got out of a trance."
    lady "You don't look like your brother at all."
    mc "My brother? What do you know about Justin?"
    scene skinwalker4 with dissolve
    "She starts cackling, the kind of excagerated cackle you've only ever heard of in fairytale witches."
    lady "I think you know what happened, deep down."
    lady "You're simply not ready to face it yet."
    mc "Tell me..."
    scene skinwalker3 with dissolve
    lady "I can't help you."
    lady "In fact, I shouldn't even be talking to you."
    lady "If you want to know more..."
    lady "You'll have to traverse the desert."
    lady "But be warned, boy."
    lady "The desert has its own secrets."
    scene skinwalker5 with dissolve
    "Before you can say anything, you catch a glimpse of her as she dissapears with inhuman speed, yet looks like she is casually walking off."
    mc "(WTF??!!)"
    mc "Traverse the desert?"
    mc "What the fuck happened here?!"
    "Her silhouette fades in the distance and the desert's dust, as your voice gets lost in the wind."
    mc "..."
    mc "I guess I'll need a car if I want to go deeper into the desert."
    $ questlog.EndQuest(quest_gasinvestigate)
    $ questlog.StartQuest(quest_roadtrip)
    $ questlog.StartQuest(quest_goodbye)
    scene mcinvestigate4 with dissolve
    "You decide to call the bus and get out of here."
    scene mcinvestigate6 with dissolve
    "As you're about to leave, you get the feeling of being watched."
    scene mcinvestigate4 with dissolve
    "You get out of here and don't look back."
    $ current_location = "stephome"
    return

label bathinvestigate:
    scene mcmirror1 with dissolve
    mc "*sighs*"
    mc "What happened to you Justin?"
    mc "The weird rules, the creepy vibe around here, the jacket, the way you talked about your shift..."
    mc "This doesn't look good."
    mc "But where does it lead?"
    mc "Hmpf, I guess I'll take one quick look around before I go home."
    scene mcmirror4 with dissolve
    "Unannounced to you, your reflection does not reflect you anymore."
    "It is staring, a wide, inhuman smile stretches from ear to ear."
    jump gasininvestigate

label justinjob:
    "You arrive at the gas station, where Justin has the job interview."
    "A man in dirty overalls greets you."
    scene interview with dissolve
    "As you walk over, Justin immediatly takes over the conversation."
    sbro "Hey, I'm here for the job interview."
    sbro "Saw the ad in the paper, it's perfect for a guy like me."
    clerk "Well the offer is still open, if you're interested I can give you a tour. It ain't much."
    scene black with fade
    "You wait outside, as Justin goes inside for another interview and a tour."
    "Surprisingly, it takes only 10 minutes before they come back out."
    scene interview with dissolve
    sbro "I'll take it!"
    clerk "Alright, welcome aboard."
    clerk "Your shift starts tonight, 10 PM."
    clerk "Don't be late, they hate that."
    mc "(I guess he got the job.)"
    mc "(But something feels off about this place.)"
    mc "(I mean, all of this... gas station, the guy, everything.)"
    mc "(It's so simple.. yet the pay is good.)"
    scene interview2 with dissolve
    sbro "So, what do you say huh?"
    mc "Justin..."
    mc "I don't know..."
    sbro "What? You don't like it?"
    mc "I mean I'm very happy for you, but this place gives me the creeps."
    sbro "Ahh, come on. It's just a gas station."
    sbro "Maybe some oddball here and there, but nothing to worry about."
    mc "You're probably right."
    mc "(I just hope nothing bad happens.)"
    sbro "Come on, let's go home and tell dad."
    "Excited, Justin holds the bus and you go back home."
    scene traveljustin with dissolve
    "You arrive at your dad's place."
    $ questlog.EndQuest(quest_visitgas)
    $ justinjobstart = True
    $ current_location = "stephome"
    return

label gasinvestigate:
    "You arrive at the gas station, the door is wide open there is signs of broken glass everywhere."
    "No one in sight."
    scene mcinvestigate1 with dissolve
    mc "(This is strange, the door is open.. But where is Justin?)"
    mc "(I should probably go inside and check.)"
    "As you're about to enter, you notice the freezer door is open."
    scene mcinvestigate2 with dissolve
    mc "(What the hell?)"
    mc "(Is that... Justin's jacket?)"
    "Ripped to shreds, with blood all over it."
    mc "(Oh no, this is not good.)"
    scene mcinvestigate3 with dissolve
    "You enter the gas station, a dense smell of old gasoline and damp air hits you."
    "You notice the same, odd unmarked crates on the shelves."
    mc "(Those crates again, what the hell is going on here?)"
    mc "(I need to find out what happened to Justin.)"
    $ current_location = "gasin"
    return

