        textbutton "­¤ŹĮ Menu" background None focus_mask True action [ Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_marketing"), Hide("cafe_events"), Hide("cafe_upgrades"), Hide("cafe_menu"), Show("cafe_menu") ]

    # RIGHT NAV
