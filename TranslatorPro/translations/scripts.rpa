label mallflyers:
    scene mallflyers with dissolve
    "You spend several hours at the mall handing out flyers to everyone."
    mc "*sighs*"
    mc "Just a few more flyers, then I can finally get out of here."
    idk "Ahem..."
    scene guard01 with dissolve
    guard "Nobody told me about you being here today."
    guard "Care to explain yourself?"
    scene guard02 with dissolve
    mc "Just... Handing out flyers for the coffeeshop, sir."
    guard "Flyers huh?"
    scene guard03 with dissolve
    guard "Well... Alright, but don't go bothering people and especially-"
    guard "-leave the ladies alone!"
    scene guard04 with dissolve
    mc "Jeez, he sure likes being a mall cop."
    $ havemet_guard = True
    scene mallflyers02 with dissolve
    "You continue to give out your flyers and finish quickly."
    mc "Miss, perhaps you'd like to get a coffee there?"
    idk "Thank you!"
    mc "Welcome!"
    scene mallflyers03 with dissolve
    mc "(Alright, time to go home.)"
    bff "[name]!!!"
    mc "huh?"
    scene mallflyers04 with dissolve
    mc "Oh hey Tim."
    mc "What are you doing here?"
    bff "Oh heheh, my mom took me shopping."
    mc "Shes here?"
    bff "Yeah shes getting a coffee, she'll be out in a minute."
    bff "Hows school?"
    mc "It's fine..."
    mc "(if you'd actually care to show up for once you'd know that.)"
    scene mallflyers05 with dissolve
    bffmom "Hey guys!"
    if havemet_bffmom == False:
        $ meet_character("havemet_bffmom", "images/mall/Bffmommeet.webm", 3.0)

    bffmom "Good to see you, [name]!"
    mc "Hey Naomi!"
    bff "Btw, dude!!"
    $ havemet_bff = True
    bff "Things must be great at your workplace right now huh?"
    mc "Huh? What are you talking about?"
    bff "The new drug!"
    mc "Wait, what drug?"
    mc "I have no idea what you're talking about..."
    bff "It was even on the news! Some kind of erectile enhancer?"
    "(Wtf? I didnt know we were making something like that...)"
    bff "I mean it's pretty cool though right?"
    scene mallflyers06 with dissolve
    bffmom "Yeah from what I've heard it's a wonder drug."
    bff "Sounds like something you could use, am I right?"
    mc "*sighs*"
    mc "But seriously..."
    mc "This is the first I hear about it."
    bff "Oh don't worry, its probably going to be all over the news this week."
    mc "hmmm..."
    mc "(Mr. Dictonic must want to keep it quiet...)"
    mc "(It sounds a little shady..)"
    bffmom "Sweetie, we should go."
    bffmom "Don't want to keep your sister waiting."
    bff "Alright mom."
    bff "Cya dude!"
    scene mallflyers07 with dissolve
    bffmom "Bye [name]!"
    bffmom "You should come by sometime!"
    mc "Will do."
    mc "Bye Naomi!"
    scene mallclose with dissolve
    mc "(So if Mr. Dictonic is making a new drug..)"
    mc "(What does that mean for my work place?)"
    mc "(I probably should check the news tonight.)"
    $ calendar.addtime(120)
    $ questlog.EndQuest(quest_cshophelp8, calendar.day)
    $ questlog.StartQuest(quest_newswatch)
    $ questlog.StartQuest(quest_rewardclaire)
    return

label quest_maihubby_1700_event:
    if calendar.hours == 17:
        scene robertspy01 with dissolve
        mc "(There he is, he is about to leave.)"
        "You follow robert at a safe distance."
        scene robertspy02 with dissolve
        mc "(Wait, he is not leaving the mall...)"
        mc "(Where is he going?)"
        "You stay on Robert's trail, and notice that he sneaks into a back room behind his store."
        scene repairshop08 with dissolve
        "The room is cluttered with parts, screens and wires."
        mc "(Oh so this is the repair room he was talking about.)"
        mc "(Perfect, this is my chance.)"

        $ repairroomunlocked = True
        $ calendar.addtime(60)
        $ store.travel_context_done = True
        $ store.mai_hubby_17_running = False
        $ current_location = "repairroom"
        return
    else:
        $ store.mai_hubby_17_running = False   
        return



