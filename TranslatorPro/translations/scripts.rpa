                scene stockroom04 with dissolve
                "You grab a box of Vitalis."
                scene stockroom05 with dissolve
                pause 1.0
                return
            "Leave.":
                mc "(I'm better than this...)"
                return

label warehouseclosed:
    hide screen worldmap
    scene stockroom with dissolve
    "You hear voices echoing through the warehouse."
    mc "(Shit, I should come back later.)"
    show screen worldmap
    returnMade with Ren'Py.default asked_midnight_following = False
default asked_midnight_cat = False
default asked_midnight_witch = False
default asked_midnight_powers = False
default asked_midnight_weather = False
default asked_midnight_want = False
default asked_midnight_save = False


screen witchscreen:
    tag witchshack
    $ present = get_characters_at_location("witchshack")
    add "images/witchshack/witchscreen.webp"
    on "show" action [Function(renpy.music.play, "audio/witch.ogg", loop=True, fadein=0.5), SetVariable("current_location", "witchshack")]
    imagebutton auto "images/witchshack/witch_%s.png" focus_mask True action Call("witchdialogue")
    imagebutton auto "images/witchshack/pic_%s.png" focus_mask True action Call("viewpic")

screen witchscreenout:
    tag witchshack
    if get_time_of_day() in ("morning", "afternoon"):
        on "show" action [Function(renpy.music.play, "audio/witchday.ogg", loop=True, fadein=0.5), SetVariable("current_location", "witchshackout")]
        on "hide" action Function(renpy.music.stop, fadeout=0.5)
        add "images/witchshack/witchshack.webp"
        imagebutton auto "images/witchshack/door_%s.png" focus_mask True style "worldbutton" action Function(renpy.music.stop, fadeout=0.5), [Hide("witchscreenout"), Show("witchscreen")]
    if get_time_of_day() in ("evening", "night"):
        on "show" action [Function(renpy.music.play, "audio/witchnight.ogg", loop=True, fadein=0.5), SetVariable("current_location", "witchshackout")]
        on "hide" action Function(renpy.music.stop, fadeout=0.5)
        add "images/witchshack/witchshack3.webp"
        imagebutton auto "images/witchshack/door2_%s.png" focus_mask True style "worldbutton" action Function(renpy.music.stop, fadeout=0.5), [Hide("witchscreenout"), Show("witchscreen")]

label witchintro:
    play music "audio/witchnight.ogg" fadein 0.5
    mc "(This isn't where I wanted to go...)"
    scene witchshack3 with dissolve
    mc "(It's been awfully quiet since the whole Dictonic mess...)"
    mc "(Midnight hasn't shown up in a while either...)"
    mc "(Hopefully I can get some answers from the witch.)"
    scene realmidnight with dissolve
    "As you approach the shack, you notice that Midnight is sitting right in front of the door, as if expecting you."
    scene realmidnight2 with dissolve
    mc "Hey Midnight, it's been awhile."
    mc "I was wondering what happened after... you know."
    scene realmidnight3 with dissolve
    midnight "Why don't you come inside and find out?"
    "You start feeling drowsy again..."
    scene black with fade
    pause 1.0
    $ current_location = "witchshack"
    return

label midnightintro:
    scene backhome1 with dissolve
    "On your way home, your mind drifts off thinking about Justin's unfortunate fate."
    mc "(Damn it Justin...)"
    mc "(It just wasn't meant to be, was it?)"
    scene backhome1 with dissolve
    pause 1.0
    scene backhome3 with dissolve
    mc "(At least we're back in the city...)"
    mc "(I wonder what everyone is up to.)"
    scene backhome4 with dissolve
    mc "Hey! What?!"
    "You get caught off-guard by midnight jumping off the roof of the truck."
    scene backhome5 with dissolve
    mc "Did you hitch a ride, you sneaky devil?"
    play sound "audio/midnightmeow.ogg"
    midnight "*meow meow meow*"
    mc "What are you trying to say here?"
    mc "(I wish I understood cat...)"
    scene backhome6 with dissolve
    mc "(I wonder where she's going...)"
    mc "(She has been showing up everywhere, I'm really curious where she comes from.)"
    menu:
        "ŌŁÉ Follow her.":
            scene black with fade
            "You decide to follow Midnight."
            "She guides you through a narrow path deep into the forest."
            scene witchshack3 with dissolve
            mc "Damn, slow down already!"
            mc "(I wonder who lives here...)"
            scene realmidnight with dissolve
            "As you approach the shack, you notice that midnight's eyes are glowing."
            "The air around you feels more dense."
            mc "(What...)"
            scene realmidnight2 with dissolve
            mc "Alright, you're creeping me out now."
            scene realmidnight3 with dissolve
            "You start feeling light headed as the door opens."
            "Before you black out, a soft female voice sounds through the haze."
            idk "Poor thing..."
            idk "Don't worry, she doesn't mean harm."
            scene black with fade
            pause 1.0
            jump witchdialogue
        "Don't follow.":
            mc "I have more important things to do right now."
            scene black with fade
            $ renpy.restart_interaction()
            return

label witchdialogue:
    if quest_witchshack in questlog.quest_list:
        scene witch1 with dissolve
        witch "Good, you're awake."
        mc "Uh... yeah, is this going to be a regular thing now?"
        scene witch3 with dissolve
        witch "Perhaps."
        mc "So... uh, I was wondering..."
        scene witch4 with dissolve
        witch "Why you haven't heard back from Midnight?"
        witch "What happened to Dictonic?"
        mc "(She knows...)"
        witch "Answers are coming. In time."
        mc "Right..."
        scene witch1 with dissolve
        witch "You don't need to worry about this world soon enough."
        mc "What does that even mean?"
        scene witch2 with dissolve
        witch "I can't say yet."
        mc "(Great, more cryptic nonsense...)"
        menu:
            "ŌŁÉ Keep pushing.":
                mc "Look, I need answers. Can you at least tell me what happened to Dictonic?"
                scene witch3 with dissolve
                witch "Dictonic is... safe. For now."
                mc "Safe? What do you mean?"
                scene witch4 with dissolve
                witch "The world is changing, [name]. Things are shifting."
                witch "But you can't stop it. This world is not yours to save. Or control."
                mc "(Ugh, this is going nowhere...)"
                scene witch2 with dissolve
                witch "Perhaps, it's time I showed you more."
                mc "More? Like what?"
                scene witch3 with dissolve
                witch "Meet me at the gas station tonight. I will wait for you in the bathroom with the broken mirror."
                mc "...Alright. I'll be there, I guess."
                $ questlog.EndQuest(quest_witchshack, calendar.day)
                $ questlog.StartQuest(quest_meetwitch)
                witch "Now go."
                scene black with fade
                "A sudden wave washes over you, like slipping under anesthesia."
                $ calendar.skipday()
                scene witchshack with dissolve
                "When you wake up, the world feels... different. As if a new day has begun, but something is missing."
                mc "(Damn it, I hate when she does that...)"
                $ current_location = "witchshackout"
                return
    if not havemet_witch:
        scene witch1 with dissolve
        with Pause(1.0)
        witch "So you've come to your senses."
        mc "Uh... yeah, sorry. I was just... following the cat."
        scene witch3 with dissolve
        witch "And yet you arrived here."
        mc "She just ran off into the woods. I thought maybe she was lost, orŌĆö"
        scene witch4 with dissolve
        witch "She's never lost. Only... leading."
        mc "...Right."
        with Pause(0.5)
        scene witch3 with dissolve
        witch "Do you feel it?"
        mc "Feel what?"
        witch "The edge of something. Like the world is thinner here."
        with Pause(0.5)
        mc "Honestly, I just feel like I'm trespassing."
        witch "You are."
        with Pause(1.0)
        witch "And still... she let you in."
        mc "Who is she?"
        scene witch2 with dissolve
        witch "...The question isn't who. It's *why*."
        with Pause(0.5)
        witch "But we're not ready for answers yet."
        mc "We?"
        witch "You. And the part of her still watching through that window."
        with Pause(1.0)
        scene witch3 with dissolve
        witch "Pay attention. Listen. And maybe next time... she'll speak."
        witch "Now go."
        scene black with fade
        "A sudden wave washes over you ŌĆö like slipping under anesthesia."
        $ calendar.skipday()
        scene witchshack with dissolve
        "When you wake up, the world feels... different. As if a new day has begun, but something is missing."
        mc "(Damn. How long was I out?)"
        mc "(What even happened?)"
        mc "(And what the hell does any of it mean?)"
        $ havemet_witch = True
        $ witchshackunlocked = True
        $ renpy.restart_interaction()
        return
    else:
        scene witch1 with dissolve
        witch "Not now, I'm busy."
        mc "Alright..."
        $ current_location = "witchshackout"
        return

label midnightmenu:
    scene midnightrooftop4 with dissolve
    midnight "Go ahead [name], ask away."
    menu:
        "­¤Æ¼ About her following you." if not asked_midnight_following:
            mc "You've been showing up a lot lately... the trailer park, the desert, now here."
            mc "You're not just wandering around, are you?"
            scene midnightrooftop5 with dissolve
            midnight "Perceptive."
            midnight "I'm not lost, [name]. I go where the ripples are strongest."
            mc "Ripples?"
            midnight "Stirrings in the veil. Threads of chaos, stretched thin. You tug on a lot of them."
            mc "So you're... watching me?"
            scene midnightrooftop6 with dissolve
            midnight "Watching? No. Guiding."
            midnight "You're interesting. Things break when you're nearby. Rules bend. People shift."
            mc "Is that a compliment or a warning?"
            midnight "Why not both?"
            mc "(This is so weird... but she's not denying it.)"
            mc "Why me?"
            scene midnightrooftop4 with dissolve
            midnight "Because you're fun."
            midnight "And chaos, [name]... chaos is fun."
            $ asked_midnight_following = True
            jump midnightmenu
        "­¤Æ¼ About the cat." if not asked_midnight_cat:
            mc "So... the cat. That was you, wasn't it?"
            scene midnightrooftop5 with dissolve
            midnight "Mhm. That was me... at least, the part of me you could see."
            mc "You were always there. Watching. Silent."
            midnight "Cats are good at that. People don't question them. They don't see them as a threat."
            scene midnightrooftop6 with dissolve
            mc "So why keep showing up like that? Why not just... be this version of you?"
            midnight "Because the cat isn't just a disguise, [name]. It's where I was put."
            mc "Put?"
            midnight "I wasn't born like this. I was... carved out."
            scene midnightrooftop5 with dissolve
            midnight "Tha... The witch, she feared what she might become. So she took her mischief, her desire, her chaos... and stored it somewhere safe."
            midnight "In me."
            mc "You were her familiar?"
            midnight "I am her mirror. Her leash. Her failsafe."
            scene midnightrooftop4 with dissolve
            midnight "The cat was never for stealth. It was a cage."
            mc "But you're not caged anymore."
            midnight "Perhaps you don't perceive it as such, but I was, still am and always will be the witch's familiar."
            $ asked_midnight_cat = True
            pause 1.0
            jump midnightmenu
        "­¤Æ¼ About the witch." if not asked_midnight_witch:
            mc "This witch you keep talking about... who is she, really?"
            scene midnightrooftop5 with dissolve
            midnight "She is... older than this world remembers."
            mc "That's not an answer."
            midnight "It's the only one you're ready for."
            scene midnightrooftop6 with dissolve
            mc "You said she split you from herself. That you were part of her once."
            midnight "I was."
            midnight "But she feared what she might become... what her chaos would do if left unchecked."
            scene midnightrooftop4 with dissolve
            midnight "So she carved it out. Locked it away. A shard of mischief sealed into a form no one would notice."
            mc "A cat."
            midnight "A cat."
            scene midnightrooftop5 with dissolve
            mc "And now?"
            midnight "Now... the world stirs. And her silence grows heavier."
            mc "She doesn't speak?"
            midnight "She has no reason to."
            mc "...Does she have a name?"
            scene midnightrooftop6 with dissolve
            midnight "..."
            midnight "Names have power. Hers especially."
            mc "So she does."
            midnight "*softly* Tha... the witch."
            mc "(She hesitated. Like she wasn't allowed to say it...)"
            scene midnightrooftop4 with dissolve
            midnight "Don't go chasing names, [name]. Some truths stay buried for a reason."
            $ asked_midnight_witch = True
            jump midnightmenu
        "­¤Æ¼ About her powers." if not asked_midnight_powers:
            mc "You put that guy to sleep. Just like that."
            mc "Back at the warehouse, you saved me. That wasn't luck."
            scene midnightrooftop5 with dissolve
            midnight "Oh? Maybe I just have really good timing."
            mc "You stopped him cold, Midnight. I didn't even hear a struggle."
            midnight "Maybe he tripped. Maybe I whispered in just the right way."
            scene midnightrooftop6 with dissolve
            mc "So what can you actually do?"
            midnight "..."
            midnight "Enough."
            mc "Not an answer."
            midnight "Good. Because I'm not giving one."
            scene midnightrooftop5 with dissolve
            midnight "Let's just say... I can nudge things."
            midnight "Turn down the volume of time. Make someone nap through a storm. Hide you from eyes that should have seen you."
            mc "That's more than a nudge."
            midnight "Then maybe you're more important than you think."
            scene midnightrooftop4 with dissolve
            mc "And you're just here to help?"
            midnight "Not help. Stir."
            midnight "You make waves, [name]. I like that."
            $ asked_midnight_powers = True
            jump midnightmenu
        "­¤Æ¼ About the weather girl." if not asked_midnight_weather:
            mc "Okay... this might sound weird butŌĆö the weather girl on TV?"
            mc "She says the strangest things. Like she's talking to me."
            scene midnightrooftop5 with dissolve
            midnight "She is."
            mc "...Seriously?"
            midnight "Not in the way you think."
            scene midnightrooftop6 with dissolve
            midnight "She's part of a very... specialized broadcast. Designed to test reaction thresholds."
            mc "You mean... the moaning, the twitching, theŌĆö"
            midnight "Mhm. That."
            scene midnightrooftop5 with dissolve
            mc "So what is it? A show? A punishment? A science experiment?"
            midnight "Yes."
            mc "...That's not helpful."
            midnight "She's not real. But she's not fake either. She's... programmed stimulation, wrapped in flesh."
            scene midnightrooftop4 with dissolve
            mc "And the controls?"
            midnight "That part's your doing. I'm just here for the entertainment."
            mc "(She's really not gonna explain this, huh?)"
            midnight "Don't overthink it, [name]. Just enjoy the forecast."
            $ asked_midnight_weather = True
            jump midnightmenu
        "­¤Æ¼ What do you want from me?" if not asked_midnight_want:
            mc "You've been following me, saving me, guiding me..."
            mc "Why?"
            scene midnightrooftop5 with dissolve
            midnight "Mm. Now we're asking the real questions."
            mc "Seriously. What do you want from me?"
            midnight "Want?"
            scene midnightrooftop6 with dissolve
            midnight "I want to see what you'll do when the rules break."
            mc "...That's it?"
            midnight "You're a storm in a bottle, [name]. You don't even see it yet."
            midnight "You bend people. You ruin patterns. You make things... interesting."
            scene midnightrooftop4 with dissolve
            mc "So I'm just entertainment to you?"
            midnight "Not just."
            midnight "You're the first ripple I've felt in ages. You're not just breaking things, you're waking them up."
            scene midnightrooftop5 with dissolve
            mc "...Waking what up?"
            midnight "Shh. Not yet."
            midnight "Just keep going. Keep stirring."
            mc "You're not going to tell me anything straight, are you?"
            scene midnightrooftop4 with dissolve
            midnight "I already have. You just don't understand it yet."
            $ asked_midnight_want = True
            jump midnightmenu
        "­¤Æ¼ Why did you save me?" if not asked_midnight_save:
            mc "You didn't have to step in back there."
            mc "You could've let them take me."
            scene midnightrooftop5 with dissolve
            midnight "I could have."
            mc "But you didn't."
            midnight "No."
            scene midnightrooftop6 with dissolve
            mc "So why?"
            midnight "Because it would've been boring if they won."
            mc "That's it?"
            midnight "That's what I told myself."
            scene midnightrooftop4 with dissolve
            midnight "But watching them drag you away... hearing you yell..."
            midnight "I felt something twist."
            mc "Like guilt?"
            midnight "No. Like... irritation."
            mc "You were mad they took me?"
            midnight "I was mad they didn't earn it."
            scene midnightrooftop5 with dissolve
            midnight "You're mine, [name]."
            midnight "Not theirs. Not yet."
            scene midnightrooftop4 with dissolve
            mc "...What does that mean?"
            midnight "Ask me again when the world's burning."
            $ asked_midnight_save = True
            jump midnightmenu
        "No more questions.":
            midnight "Alright then [name], until we meet again."
            scene midnightrooftop7 with dissolve
            "She climbs onto the ledge ready to jump."
            mc "Wait!-"
            scene midnightrooftop8 with dissolve
            "But it's too late, she already jumped off."
            scene midnightrooftop9 with dissolve
            "She looks back at you, her eyes glowing as she stares back at you."
            "The voice returns in your head..."
            midnight "Do not worry, you'll hear from me soon."
            mc "Uhh.. okay?"
            scene rooftop_idle2 with dissolve
            mc "(Man... that was... something else.)"
            mc "(I guess i should go back down the normal way...)"
            scene rooftop_idle with dissolve
            pause 1.0
            $ questlog.EndQuest(quest_captivatingscience, calendar.day)
            $ questlog.StartQuest(quest_timloop)
            $ mischief_activated = True
            $ current_location = None
            return

label midnight_easteregg_unlocked:
    scene rooftop_idle2 with dissolve
    "You open your eyes and realise you're back on the rooftop where you first met Midnight in human-form."
    mc "Ugh... i must be dreaming."
    midnight "Tsk. Still so confused."
    mc "Uhh, Midnight?"
    scene midnightrooftop with dissolve
    midnight "Relax, no one is chasing you... this time."
    mc "Why did you uhh.."
    mc "'Invite' me here?"
    scene midnightrooftop3 with dissolve
    midnight "Because this isn't the only question you've been asking yourself lately."
    mc "Meaning?"
    scene midnightrooftop4 with dissolve
    midnight "What are you gonna do with Dictonic, [name]?"
    mc "I don't know."
    midnight "I mean, taking it to the authorities?"
    midnight "Please."
    mc "Well it seemed like a decent option."
    midnight "And then the idea of leaking the information... Again?"
    midnight "Picking the people? Sweetheart... the people picked this drug. Look around."
    pause 0.5
    midnight "You're really going to let the world decide how this ends?"
    mc "..."
    "For a moment, you stare at each other. The only sound being the wind blowing around you."
    pause 0.5
    scene midnightrooftop5 with dissolve
    midnight "What if i were to offer you a third choice?"
    mc "What do you have in mind?"
    scene midnightrooftop6 with dissolve
    midnight "Me."
    mc "You? What are you going to do?"
    scene midnightrooftop5 with dissolve
    midnight "I'll put Dictonic in a cage so deep he'll need a flashlight to read his own regrets."
    mc "(...Charming.)"
    midnight "That is, of course if you're willing to play one last game with me before it's all over."
    mc "(Hmmm...)"
    scene midnightrooftop6 with dissolve
    midnight "Ohh.. Look at you."
    midnight "Don't worry so much, kitty!"
    midnight "I promise i will let you enjoy it with me!"
    mc "Somehow, that feels more like a threat."
    scene midnightrooftop5 with dissolve
    midnight "On the contrary, i offer you nothing but pleasure and chaos."
    mc "I see..."
    scene midnightrooftop4 with dissolve
    midnight "So what do you say?"
    midnight "Ready to play judge, jury and executioner with little old midnight?"
    menu:
        "ŌŁÉ Give her the information.":
            $ drugcontent_unlocked = True
            $ questlog.StartQuest(quest_act2finale)
            mc "Alright, i'm in."
            scene midnightrooftop7 with dissolve
            midnight "Good choice. I can't wait."
            scene midnightrooftop8 with dissolve
            mc "(Somehow i feel like i'm in for a wild ride...)"
            scene midnightrooftop9 with dissolve
            midnight "Ohh, you have no idea what this city has in store for you."
            play sound "audio/midnightcute.ogg"
            midnight "*meow*"
            mc "*sighs*"
            scene rooftop_idle with dissolve
            mc "I just hope i didn't sign a contract with the devil herself."
            scene black with slow_fade
            "You drift off to sleep."
            $ calendar.skipday()
            scene h112 with dissolve
            mc "*yawns*"
            $ current_location = "home"
            $ current_hub = "home"
            menu:
                "Start your day.":
                    $ current_location = "homebedroom"
                    return
                "­¤Ģ¢ Go back to bed. (Skip the day)":
                    jump homesleep
        "ŌŁÉ I don't think so.":
            $ questlog.StartQuest(quest_act2finale)
            scene midnightrooftop7 with dissolve
            midnight "Such a shame."
            scene midnightrooftop8 with dissolve
            mc "I'm sorry, me and chaos don't get along too well."
            scene midnightrooftop9 with dissolve
            midnight "I'll find someone else who is willing to play."
            play sound "audio/midnightcute.ogg"
            midnight "*meow*"
            play sound "audio/sigh.ogg"
            mc "*sighs*"
            scene rooftop_idle with dissolve
            mc "Somehow I feel like I missed an opportunity here..."
            scene black with slow_fade
            "You drift off to sleep."
            $ calendar.skipday()
            scene h112 with dissolve
            mc "*yawns*"
            $ current_location = "home"
            $ current_hub = "home"
            menu:
                "Start your day.":
                    $ current_location = "homebedroom"
                    return
                "­¤Ģ¢ Go back to bed. (Skip the day)":
                    jump homesleep
label viewpic:
    scene witchpic2 with dissolve
    "You decide to take a closer look at the picture of the witch."
    "She is smiling, leaning into a man who looks uncannily familiar."
    if asked_who:
        mc "(Man, is that really me?!)"
        mc "(Something about this feels so... tragic.)"
        mc "(We looked so happy together.)"
    mc "1997... that's... more than 25 years ago."
    return

label witchshackclosed:
    hide screen worldmap
    scene witchshackbg with dissolve
    "The witch is not here right now."
