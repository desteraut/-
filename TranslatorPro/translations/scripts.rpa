            spacing 40
            xalign 0.5
            yalign 0.5
            textbutton "Answer" action [Hide("incoming_call_screen"), Call("dispatch_event", event_label=call["label"], restore_worldmap=False, event_data=call)] style "phone_rel_textbutton"
            textbutton "Ignore" action Function(_reschedule_call, call) style "phone_rel_textbutton"

init python:
    def _reschedule_call(call, delay_hours=2, delay_minutes=0):
        """
        Reschedule an incoming call for 'now + delay', preserving extra fields.
        Always stores an absolute Y/M/D/H/M to avoid instant re-fire.
        """
        import renpy.store as store
        cal = store.calendar

        # Current time
        Y, M, D = cal.year, cal.month, cal.day
        H = int(getattr(cal, "hours", getattr(cal, "hour", 0)))
        Min = int(getattr(cal, "minutes", getattr(cal, "minute", 0)))

        # Compute new absolute time
        total = H * 60 + Min + delay_hours * 60 + delay_minutes
        add_h, new_min = divmod(total, 60)
        new_h = add_h % 24
        add_d = add_h // 24

        # Day/month/year rollover using your calendar table
        days_in_month = cal.days_count  # dict-like: {1:31, 2:28/29, ...}
        y, m, d = Y, M, D
        while add_d > 0:
            d += 1
            if d > days_in_month[m]:
                d = 1
                m += 1
                if m > 12:
                    m = 1
                    y += 1
            add_d -= 1

        # Build the new call payload: keep extra custom keys, but override schedule fields.
        new_call = dict(call)
        new_call["year"] = y
        new_call["month"] = m
        new_call["day"] = d
        new_call["hours"] = new_h
        new_call["minutes"] = new_min

        # Remove the fuzzy weekday 'time' key (prevents "fire now if same weekday")
        if "time" in new_call:
            del new_call["time"]

        # Append (skip only if an identical dict is already queued)
        if new_call not in store.incoming_calls:
            store.incoming_calls.append(new_call)


label handle_no_call:
    if selected_contact_label:
        call expression selected_contact_label from _call_expression
    return

screen phone_app(title, block_name, data=None, call=None, photo=None):
    modal True
    tag phone
    zorder 101
    frame:
        background "images/phone/phonescralt2.png"
        xalign 0.5
        yalign 0.5
        xsize 900
        ysize 900
        style "no_border_frame"

        fixed:
            xysize (900, 900)

            # --- HEADER (always same position)
            frame:
                background None
                yalign 0.05
                xalign 0.5
                text title size 36 color "#7ecbff" xalign 0.5

            # --- CONTENT AREA (always starts below header)
            frame:
                background None
                ypos 80
                xsize 900
                ysize 780  # leaves room for header and close button

                # Special case: relationships block gets scrolling
                if block_name == "relationships_block":
                    use relationships_block(data)
                # All other blocks just render normally in same safe area
                elif block_name == "phone_call_block":
                    use phone_call_block(data)
                elif block_name == "phone_gallery_block":
                    use phone_gallery_block(data)
                elif block_name == "incoming_call_block":
                    use incoming_call_block(call=call, photo=photo)
                elif block_name == "phone_gallery_pictures_block":
                    use phone_gallery_pictures_block(data)
                elif block_name == "gallery_character_block":
                    use gallery_character_block(data)
                elif block_name == "mischief_block":
                    use mischief_block(data)
                elif block_name == "phone_cheats_block":
                    use phone_cheats_block(data)
                else:
                    text "Error: Could not find block [block_name]"

        # --- CLOSE BUTTON
        imagebutton auto "images/gui/cross_%s.png" action ShowTransient("phone_popup") xalign 0.97 yalign 0.05




screen phone_call():
    modal True
    use phone_app("Contacts", "phone_call_block")
## Phone call/contact screen
