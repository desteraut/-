init python:

    MAINMENU_FRAMES = 141
    MAINMENU_FPS = 24.0
    MAINMENU_DT = 1.0 / MAINMENU_FPS
    CROSSFADE_FRAMES = 30
    CROSSFADE_DURATION = CROSSFADE_FRAMES * MAINMENU_DT
    TOTAL_DURATION = MAINMENU_FRAMES * MAINMENU_DT

    def mainmenu_anim(st, at):
        t = (st % (TOTAL_DURATION - CROSSFADE_DURATION)) + CROSSFADE_DURATION
        frame = int(t * MAINMENU_FPS)
        frame = min(frame, MAINMENU_FRAMES - 1)

        crossfade_start = MAINMENU_FRAMES - CROSSFADE_FRAMES

        if frame < crossfade_start:
            return f"images/sandstorm/sandstorm{frame:02}.webp", MAINMENU_DT

        else:
            cf_progress = frame - crossfade_start
            alpha_top = 1.0 - (cf_progress / float(CROSSFADE_FRAMES - 1))
            incoming_frame = cf_progress

            d = Fixed(
                f"images/sandstorm/sandstorm{incoming_frame:02}.webp",
                Transform(
                    f"images/sandstorm/sandstorm{frame:02}.webp",
                    alpha=alpha_top
                ),
                fit_first=True
            )
            return d, MAINMENU_DT

image mainmenu_bg = DynamicDisplayable(mainmenu_anim)

init 1 python:
    for i in range(CROSSFADE_FRAMES):
        renpy.image(
            f"_mainmenu_precache_{i}",
            f"images/sandstorm/sandstorm{i:02}.webp"
        )

