init 10 python:
    import renpy.store as store

    def poker_cleanup():
        # Use the exports API (has hide_screen/show_screen/etc.)
        from renpy import exports as renpy
        from renpy.audio import music

        renpy.hide_screen("poker_table_screen")
        renpy.hide_screen("poker_actions")

        store.poker_message = None
        store.poker_active = False
        store.poker_quit = True
        if hasattr(store, "bet_amount"):
            store.bet_amount = 10

        music.stop(channel="music", fadeout=0.5)

init python:
    import random
    from collections import Counter

    if "bet_tokens" not in globals():
        bet_tokens = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}

    CARD_IMAGES = {}
    SUITS = ["c", "d", "h", "s"]
    RANKS = ["2","3","4","5","6","7","8","9","T","J","Q","K","A"]

    for r in RANKS:
        for s in SUITS:
            code = f"{r}{s}"
            CARD_IMAGES[code] = f"images/poker/{code}.png"
    CARD_IMAGES["back"] = "images/poker/back.png"

    # Card positions
    hand_positions_mc = [(860, 870), (980, 870)]
    hand_positions_npc = [(920, 330), (980, 330)]
    community_positions = [(640, 570), (780, 570), (920, 570), (1060, 570), (1200, 570)]

    RANK_NAMES = {
        14: "Ace",
        13: "King",
        12: "Queen",
        11: "Jack",
        10: "Ten",
        9: "Nine",
        8: "Eight",
        7: "Seven",
        6: "Six",
        5: "Five",
        4: "Four",
        3: "Three",
        2: "Two",
    }

    HAND_NAMES = {
        9: "Royal Flush",
        8: "Straight Flush",
        7: "Four of a Kind",
        6: "Full House",
        5: "Flush",
        4: "Straight",
        3: "Three of a Kind",
        2: "Two Pair",
        1: "One Pair",
        0: "High Card",
    }

    NAOMI_REACTIONS = {
        "idle": "poker_idle",
        "win": "pokerreaction04",
        "lose": "pokerreaction02",
        "fold": "pokerreaction03",
        "shock": "pokerreaction01",
        "call": "pokerreaction01",
        "rebuy": "pokerrebuy",
        "raise": "pokerreaction04",
    }

    NAOMI_LINES = {
        "win": "Told you I'd take this one.",
        "lose": "UghŌĆ” I'll get you next hand.",
        "fold": "Smart choice.",
        "shock": "Oh, really now?",
        "call": "I'll call that bluff.",
        "raise": "Let's see what you do now.",
        "rebuy": "One more round, then.",
    }

    ELI_REACTIONS = {
        "idle": "elireaction01",
        "win": "elireaction02",
        "lose": "elireaction04",
        "fold": "elireaction03",
        "shock": "elireaction05",
        "call": "elireaction04",
        "rebuy": "pokerrebuy",
        "raise": "elireaction05",
    }

    ELI_LINES = {
        "win": "I got you this time!",
        "lose": "Yeah, keep laughing while you can!",
        "fold": "I just don't have the cards.",
        "shock": "Wow, bold!",
        "call": "You better have something this time.",
        "raise": "Let's see what you got, hotshot!",
        "rebuy": "Alright, one more.",
    }

    MAI_REACTIONS = {
        "idle": "maireaction05",
        "win": "maireaction04",
        "lose": "maireaction03",
        "fold": "maireaction02",
        "shock": "maireaction02",
        "call": "maireaction01",
        "rebuy": "pokerrebuy",
        "raise": "maireaction01",
    }

    MAI_LINES = {
        "win": "You underestimated me, didn't you?",
        "lose": "Hmph...",
        "fold": "You happy?",
        "shock": "Really?!",
        "call": "Oh, I'm calling that, sweetie.",
        "raise": "You're up, heh..",
        "rebuy": "Okay, one more.",
    }

    def set_npc_reaction(npc, key, reset=True):
        if npc == "naomi":
            store.naomi_reaction = key if key in NAOMI_REACTIONS else "idle"
        elif npc == "eli":
            store.eli_reaction = key if key in ELI_REACTIONS else "idle"
        elif npc == "mai":
            store.mai_reaction = key if key in MAI_REACTIONS else "idle"
        renpy.with_statement(naomi_fade)
        if reset and key != "idle":
            renpy.queue_event(f"reset_{npc}") # reuse your existing reset to fall back to idle

    def npc_line(npc, key):
        if npc == "naomi" and key in NAOMI_LINES:
            renpy.say(bffmom, NAOMI_LINES[key])
        elif npc == "eli" and key in ELI_LINES:
            renpy.say(eli, ELI_LINES[key])
        elif npc == "mai" and key in MAI_LINES:
            renpy.say(mai, MAI_LINES[key])

    def hand_name(eval_result):
        return HAND_NAMES.get(eval_result[0], "Unknown")

    def build_deck():
        return [r+s for r in RANKS for s in SUITS]

    def deal(deck, n):
        return [deck.pop() for _ in range(n)]

    def rank_to_value(rank):
        order = {r:i for i,r in enumerate(RANKS, start=2)}
        return order[rank]

    def evaluate_hand(cards):
        ranks = [c[:-1] for c in cards]
        suits = [c[-1] for c in cards]
        values = [rank_to_value(r) for r in ranks]

        if 14 in values:  # Ace low straights
            values.append(1)

        def straight(vals):
            vals = sorted(set(vals))
            for i in range(len(vals) - 4):
                seq = vals[i:i+5]
                if seq == list(range(seq[0], seq[0]+5)):
                    return seq[-1]
            return None

        counts = {}
        for v in values:
            counts[v] = counts.get(v, 0) + 1
        sorted_counts = sorted(counts.items(), key=lambda x: (x[1], x[0]), reverse=True)

        flush_suit = None
        for s in set(suits):
            if suits.count(s) >= 5:
                flush_suit = s
                break

        straight_high = straight(values)
        flush_cards = [c for c in cards if c[-1] == flush_suit] if flush_suit else []

        # Royal / Straight flush
        if flush_suit and straight_high:
            flush_vals = [rank_to_value(c[:-1]) for c in flush_cards]
            if straight(flush_vals):
                high = straight(flush_vals)
                best = [c for c in flush_cards if rank_to_value(c[:-1]) in range(high-4, high+1)]
                if high == 14:
                    return (9, best[:5])  # Royal
                return (8, best[:5])      # Straight Flush

        # Four of a kind
        if sorted_counts[0][1] == 4:
            quad_val = sorted_counts[0][0]
            best = [c for c in cards if rank_to_value(c[:-1]) == quad_val]
            kickers = sorted([c for c in cards if rank_to_value(c[:-1]) != quad_val],
                            key=lambda x: rank_to_value(x[:-1]), reverse=True)
            return (7, best + kickers[:1])

        # Full House
        if sorted_counts[0][1] == 3 and len(sorted_counts) > 1 and sorted_counts[1][1] >= 2:
            trips_val = sorted_counts[0][0]
            pair_val = sorted_counts[1][0]
            trips = [c for c in cards if rank_to_value(c[:-1]) == trips_val][:3]
            pair = [c for c in cards if rank_to_value(c[:-1]) == pair_val][:2]
            return (6, trips + pair)

        # Flush
        if flush_suit:
            flush_sorted = sorted(flush_cards, key=lambda c: rank_to_value(c[:-1]), reverse=True)
            return (5, flush_sorted[:5])

        # Straight
        if straight_high:
            best_vals = list(range(straight_high-4, straight_high+1))
            best = []
            for v in reversed(best_vals):
                for c in cards:
                    if rank_to_value(c[:-1]) == v and c not in best:
                        best.append(c)
                        break
            return (4, best)

        # Three of a Kind
        if sorted_counts[0][1] == 3:
            trips_val = sorted_counts[0][0]
            best = [c for c in cards if rank_to_value(c[:-1]) == trips_val][:3]
            kickers = sorted([c for c in cards if rank_to_value(c[:-1]) != trips_val],
                            key=lambda x: rank_to_value(x[:-1]), reverse=True)
            return (3, best + kickers[:2])

        # Two Pair
        if sorted_counts[0][1] == 2 and len(sorted_counts) > 1 and sorted_counts[1][1] == 2:
            pair1_val = sorted_counts[0][0]
            pair2_val = sorted_counts[1][0]
            pair1 = [c for c in cards if rank_to_value(c[:-1]) == pair1_val][:2]
            pair2 = [c for c in cards if rank_to_value(c[:-1]) == pair2_val][:2]
            kickers = sorted([c for c in cards if rank_to_value(c[:-1]) not in (pair1_val, pair2_val)],
                            key=lambda x: rank_to_value(x[:-1]), reverse=True)
            return (2, pair1 + pair2 + kickers[:1])

        # One Pair
        if sorted_counts[0][1] == 2:
            pair_val = sorted_counts[0][0]
            best = [c for c in cards if rank_to_value(c[:-1]) == pair_val][:2]
            kickers = sorted([c for c in cards if rank_to_value(c[:-1]) != pair_val],
                            key=lambda x: rank_to_value(x[:-1]), reverse=True)
            return (1, best + kickers[:3])

        # High card
        sorted_cards = sorted(cards, key=lambda c: rank_to_value(c[:-1]), reverse=True)
        return (0, sorted_cards[:5])
    
    def mark_open_or_raise(who):
        """
        If 'who' has just opened or raised, only increase current_bet.
        Short all-ins that don't reach the current bet do NOT change it.
        """
        s = renpy.store
        new_total = s.committed.get(who, 0)
        if new_total > s.current_bet:
            s.current_bet = new_total
            s.last_raiser = who


    def draw_cards(cards, positions):
        result = []
        for i, c in enumerate(cards):
            if i < len(positions):
                x, y = positions[i]
                result.append((CARD_IMAGES[c], x, y))
        return result

    def npc_decision(npc, strength, faced_raise=False):
        bluff = random.random()
        pot_size_factor = random.choice([0.5, 0.66, 1.0])  # vary raise sizing

        # Map NPC ŌåÆ their hand
        hand_map = {
            "naomi": naomi_hand,
            "eli": eli_hand,
            "mai": mai_hand
        }
        npc_hand = hand_map.get(npc, [])

        # --- All-in check ---
        if ((npc == "naomi" and naomi_all_in) or
            (npc == "eli" and eli_all_in) or
            (npc == "mai" and mai_all_in)):
            return None

        # --- Top Pair Detection ---
        board_ranks = [c[0] for c in community] if community else []
        highest_board = max(board_ranks, key=lambda r: RANKS.index(r)) if board_ranks else None
        has_top_pair = (strength >= 1 and highest_board and 
                        any(card[0] == highest_board for card in npc_hand))

        # --- Naomi (tight/aggressive) ---
        if npc == "naomi":
            if strength >= 6:  # monsters
                return ("raise", pot_size_factor)
            elif strength >= 2 or has_top_pair:  # strong or top pair
                return ("raise", pot_size_factor) if not faced_raise else (("raise", 0.5) if bluff > 0.5 else "call")
            elif strength == 1:  # weak pair
                return "call" if not faced_raise else ("fold" if bluff < 0.3 else "call")
            else:
                return "fold" if faced_raise else "check"

        # --- Mai (loose/fishy) ---
        elif npc == "mai":
            if strength >= 5:
                return ("raise", pot_size_factor)
            elif strength >= 3 or bluff > 0.7:
                return ("raise", pot_size_factor)
            elif strength >= 1 or bluff > 0.2:
                return "call"
            else:
                return "check"

        elif npc == "eli":  # calling station, occasionally clueless
            if strength >= 6:  
                # monsters: always raise
                return ("raise", pot_size_factor)
            elif strength >= 4:  
                # strong made hands (straight, flush, trips+): raise half pot or more
                return ("raise", 0.5 if bluff < 0.7 else 1.0)
            elif strength >= 2:  
                # decent hand: mostly calls, sometimes raises
                return "call" if faced_raise else (("raise", 0.5) if bluff > 0.8 else "call")
            elif strength == 1:  
                # weak pair: calls too much, folds rarely
                return "call" if not faced_raise else ("fold" if bluff < 0.2 else "call")
            else:
                # high card logic ŌåÆ she chases overcards or broken straights
                board_ranks = [c[0] for c in community] if community else []
                if board_ranks:
                    max_rank = max(RANKS.index(r) for r in board_ranks)
                    has_overcards = any(RANKS.index(card[0]) > max_rank for card in eli_hand)
                else:
                    has_overcards = False

                if has_overcards and bluff > 0.3:
                    return "call"  # stubborn with overs
                elif bluff > 0.85:
                    # broken straight/flush ŌåÆ Eli bluffs hard
                    return ("raise", 0.5)
                return "fold" if faced_raise else "check"


        # --- Default fallback ---
        else:
            if strength >= 6:
                return ("raise", pot_size_factor)
            elif strength >= 2:
                return "call"
            else:
                return "check"


    def _refund_excess_after_round():
        """
        If the highest committed amount is not matched by at least two live players,
        refund the unmatched remainder to the top stack(s) until the top is matched.
        Adjusts chips, committed, hand_committed, bet_tokens, and pots[-1]['amount'].
        """
        s = renpy.store

        # Live players (not folded). Player is always considered live in this context.
        live = ["player"]
        if s.naomi_in: live.append("naomi")
        if s.eli_in:   live.append("eli")
        if s.mai_in:   live.append("mai")

        # Local working copy of current street commitments
        commits = {p: s.committed.get(p, 0) for p in live}

        while True:
            ranked = sorted(commits.items(), key=lambda kv: kv[1], reverse=True)
            if not ranked:
                break

            top_player, top_amt = ranked[0]
            second_amt = ranked[1][1] if len(ranked) > 1 else 0

            # If at least two players share the top, or nothing to refund, stop.
            top_count = sum(1 for _, a in ranked if a == top_amt)
            if top_count >= 2 or top_amt <= second_amt:
                break

            excess = top_amt - second_amt
            if excess <= 0:
                break

            # Refund 'excess' to top_player
            if top_player == "player":
                s.player_chips += excess
            elif top_player == "naomi":
                s.naomi_chips += excess
            elif top_player == "eli":
                s.eli_chips += excess
            elif top_player == "mai":
                s.mai_chips += excess

            # Reduce commitments (street + hand), bet tokens and the current pot bucket
            s.committed[top_player] -= excess
            s.hand_committed[top_player] = max(0, s.hand_committed.get(top_player, 0) - excess)
            s.bet_tokens[top_player] = max(0, s.bet_tokens.get(top_player, 0) - excess)

            if getattr(s, "pots", None):
                s.pots[-1]["amount"] = max(0, s.pots[-1]["amount"] - excess)

            # Update local view and continue until the top is matched
            commits[top_player] -= excess


    def post_bet(chips, amount):
        if chips <= amount:
            bet = chips
            chips = 0
        else:
            bet = amount
            chips -= amount
        return chips, bet
    
    def deal_sfx(times=2, delay=0.25):
        for i in range(times):
            renpy.play("audio/deal.ogg", channel="sound")
            renpy.pause(delay, hard=True)

    def force_reveal_to_river():
        s = renpy.store
        # Deal and show cards until there are 5 on board.
        while len(s.community) < 5:
            new = deal(s.deck, 1)[0]
            s.community.append(new)

            if len(s.community) == 4:
                s.poker_message = f"The turn card: {new}"
            else:
                s.poker_message = f"The river card: {new}"

            # Update the on-table text for the playerŌĆÖs hand while revealing
            try:
                s.player_hand_text = describe_hand(s.mc_hand + s.community)
            except Exception:
                pass

            renpy.restart_interaction()     # refresh the screen so the card shows
            renpy.pause(1.0, hard=True)     # short beat so you see each card

    def get_raise_bounds():
        # Minimum raise: 5 if nothing to call, otherwise current_bet + 5 (your UI is step=5)
        minimum = (current_bet + 5) if current_bet > 0 else 5
        # Maximum: all-in target when facing a bet; otherwise your stack
        maximum = (committed["player"] + player_chips) if current_bet > 0 else player_chips
        if minimum > maximum:
            minimum = maximum
        return (minimum, maximum)

    
    def post_blind(who, amt):
        posted = commit_bet(who, amt)
        return posted



    def eval_for(npc):
        s = renpy.store
        if npc == "naomi": return evaluate_hand(s.naomi_hand + s.community)
        if npc == "eli":   return evaluate_hand(s.eli_hand   + s.community)
        if npc == "mai":   return evaluate_hand(s.mai_hand   + s.community)
        return (0, [])


    def chips_ref(npc):
        return {"naomi": "naomi_chips", "eli": "eli_chips", "mai": "mai_chips"}[npc]
    
    def reset_street():
        store.current_bet = 0
        store.bet_tokens = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}
        store.committed = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}

    def post_for(who, amount):
        s = renpy.store
        # Deduct chips & check all-in state
        if who == "naomi":
            s.naomi_chips, bet = post_bet(s.naomi_chips, amount)
            s.naomi_all_in = (s.naomi_chips == 0)
        elif who == "eli":
            s.eli_chips, bet = post_bet(s.eli_chips, amount)
            s.eli_all_in = (s.eli_chips == 0)
        elif who == "mai":
            s.mai_chips, bet = post_bet(s.mai_chips, amount)
            s.mai_all_in = (s.mai_chips == 0)
        elif who == "player":
            s.player_chips, bet = post_bet(s.player_chips, amount)
            s.player_all_in = (s.player_chips == 0)
        else:
            bet = 0

        # Track committed chips
        s.committed[who] += bet

        # --- NEW: Side pot handling ---
        # Always work on the last (active) pot
        while bet > 0:
            current_pot = s.pots[-1]

            if who in current_pot["eligible"]:
                current_pot["amount"] += bet
                bet = 0
            else:
                # If theyŌĆÖre not eligible for the last pot, create a new side pot
                s.pots.append({"amount": bet, "eligible": [who]})
                bet = 0

        return bet



    def add_to_pots(player, amount):
        s = renpy.store
        while amount > 0:
            current_pot = s.pots[-1]
            if player in current_pot["eligible"]:
                current_pot["amount"] += amount
                amount = 0
            else:
                s.pots.append({"amount": amount, "eligible": [player]})
                amount = 0




    def react_face(npc, what):
        set_npc_reaction(npc, what)
        npc_line(npc, what)
    
    def poker_cashout():
        # Convert chips to cash and reset hand state so nothing leaks.
        cash = store.player_chips or 0
        store.bag.cash += cash
        store.player_chips = 0
        store.pot = 0
        store.current_bet = 0
        # if you're tracking per-street commits:
        try:
            store.committed = {"player":0, "naomi":0, "eli":0, "mai":0}
        except Exception:
            pass

    def compare_key(ev):
        """Turn evaluate_hand result into a sortable tuple: (rank, [values...])"""
        rank, cards = ev
        values = [rank_to_value(c[:-1]) for c in cards]
        return (rank, values)


    def describe_hand(cards):
        rank, best = evaluate_hand(cards)

        if rank == 0:
            return f"High Card {best[0][:-1]}"
        elif rank == 1:
            return f"One Pair of {best[0][:-1]}s"
        elif rank == 2:
            return f"Two Pair {best[0][:-1]}s and {best[2][:-1]}s"
        elif rank == 3:
            return f"Three of a Kind {best[0][:-1]}s"
        elif rank == 4:
            return f"Straight to {best[-1][:-1]}"
        elif rank == 5:
            return f"Flush, {best[0][:-1]} high"
        elif rank == 6:
            return f"Full House: {best[0][:-1]}s full of {best[-1][:-1]}s"
        elif rank == 7:
            return f"Four of a Kind {best[0][:-1]}s"
        elif rank == 8:
            return f"Straight Flush to {best[-1][:-1]}"
        elif rank == 9:
            return "Royal Flush"
        else:
            return "Unknown Hand"

    def deal_remaining_if_all_in():
        s = renpy.store

        # Never fast-forward if there's still an outstanding bet this street.
        if s.current_bet > 0:
            return False
        if not (s.player_all_in or s.naomi_all_in or s.eli_all_in or s.mai_all_in): 
            return False

        # Count players who can still take betting actions (not folded AND not all-in).
        actionable = []
        if s.naomi_in and not s.naomi_all_in: actionable.append("naomi")
        if s.eli_in   and not s.eli_all_in:   actionable.append("eli")
        if s.mai_in   and not s.mai_all_in:   actionable.append("mai")
        if not s.player_all_in:               actionable.append("player")

        # Only fast-forward if there is <= 1 actionable player left.
        if len(actionable) > 1:
            return False

        # Deal up to river with beats so the cards show on table.
        while len(s.community) < 5:
            s.community += deal(s.deck, 1)
            card = s.community[-1]
            if len(s.community) == 4:
                s.poker_message = f"The turn card: {card}"
            elif len(s.community) == 5:
                s.poker_message = f"The river card: {card}"
            s.player_hand_text = describe_hand(s.mc_hand + s.community)
            renpy.pause(1.2, hard=True)

        return True


    def table_pot():
        s = renpy.store
        pots = getattr(s, "pots", None)
        if not pots:
            return 0
        return sum(p["amount"] for p in pots)

    def commit_bet(who, amount):
        """
        Deduct from stack, set all-in flag, bump committed/hand_committed & bet_tokens,
        and add to (main) pot. Returns the actual posted amount.
        """
        s = renpy.store

        # current stack
        if who == "player":
            stack = s.player_chips
        elif who == "naomi":
            stack = s.naomi_chips
        elif who == "eli":
            stack = s.eli_chips
        elif who == "mai":
            stack = s.mai_chips
        else:
            return 0

        posted = min(amount, max(0, stack))

        # deduct & all-in flag
        if who == "player":
            s.player_chips -= posted
            s.player_all_in = (s.player_chips == 0)
        elif who == "naomi":
            s.naomi_chips -= posted
            s.naomi_all_in = (s.naomi_chips == 0)
        elif who == "eli":
            s.eli_chips -= posted
            s.eli_all_in = (s.eli_chips == 0)
        elif who == "mai":
            s.mai_chips -= posted
            s.mai_all_in = (s.mai_chips == 0)

        # track commitments (street + whole hand)
        s.committed[who] += posted
        s.hand_committed[who] = s.hand_committed.get(who, 0) + posted
        s.bet_tokens[who] += posted

        # ensure pot structure exists (single main pot during betting)
        if not getattr(s, "pots", None):
            s.pots = [{"amount": 0, "eligible": ["player","naomi","eli","mai"]}]

        s.pots[-1]["amount"] += posted
        return posted


    def maybe_close_betting():
        """
        If all live players have matched the current_bet (or are all-in), close the round.
        """
        s = renpy.store
        if s.current_bet == 0:
            return True

        target = s.current_bet
        live = []
        live.append("player")
        if s.naomi_in: live.append("naomi")
        if s.eli_in:   live.append("eli")
        if s.mai_in:   live.append("mai")

        ok = True
        for p in live:
            # player uses player_all_in, NPCs use <npc>_all_in
            all_in_flag = getattr(s, f"{p}_all_in", False)
            if not (s.committed.get(p, 0) >= target or all_in_flag):
                ok = False
                break

        if ok:
            s.current_bet = 0
            # NEW: refund unmatched excess immediately (e.g., shove vs short call)
            _refund_excess_after_round()
            return True
        return False






# --------------------------------------------------------
# SCREENS
# --------------------------------------------------------
screen bet_slider():
    frame:
        xalign 0.5
        yalign 0.9
        has vbox
        text "Bet: [bet_amount] chips"
        bar value FieldValue(store, "bet_amount", 10, player_chips, step=10)

screen poker_actions():
    hbox:
        spacing 40
        xalign 0.5
        yalign 0.97

        textbutton "Fold" style "poker_button" action Return("fold")

        if current_bet == 0:
            textbutton "Check" style "poker_button" action Return("check")

            hbox:
                spacing 10
                xalign 0.5

                textbutton ("All-In" if bet_amount >= max_raise else "Bet [bet_amount]") style "poker_button" action Return("bet")

                # IMPORTANT: VariableValue(range, max, step, offset)
                # range = (max_raise - min_raise), offset = min_raise
                $ _range = max(0, max_raise - min_raise)
                # When there's no bet to call
                bar value VariableValue("bet_amount", min=min_raise, max=max_raise, step=5) style "slider" xmaximum 200

        else:
            # Compute actual amount you need to call (can be 0 if you're the BB, etc.)
            $ call_needed = max(0, current_bet - committed["player"])

            if call_needed == 0:
                textbutton "Check" style "poker_button" action Return("check")
            else:
                textbutton "Call [call_needed]" style "poker_button" action Return("call")

            hbox:
                spacing 10
                xalign 0.5

                textbutton ("Go All-In" if bet_amount >= max_raise else "Raise [bet_amount]") style "poker_button" action Return("raise")

                $ _range = max(0, max_raise - min_raise)
                # Use the computed bounds so short stacks can shove even if they canŌĆÖt meet min-raise
                bar value VariableValue("bet_amount", min=min_raise, max=max_raise, step=5) style "slider" xmaximum 200



    # Leave Table button aligned right
    textbutton "Leave Table" style "poker_button":
        xalign 0.98
        yalign 0.97
        action [
            Function(poker_cashout),
            Function(poker_cleanup),
            Jump("game_loop")
        ]







screen poker_table_screen():
    # Reaction cutouts (pre-cropped to sit in their chairs)
    add "images/poker/[NAOMI_REACTIONS[naomi_reaction]].png"
    add "images/poker/[ELI_REACTIONS[eli_reaction]].png"
    add "images/poker/[MAI_REACTIONS[mai_reaction]].png"

    # Player hole cards
    for img, x, y in draw_cards(mc_hand, hand_positions_mc):
        add img xpos x ypos y

    # NPC hole cards (backs while hand is live)
    # Seat Naomi (top-center as before, slight spread)
    for img, x, y in draw_cards(naomi_display, [(900, 338), (960, 338)]):
        add img xpos x ypos y zoom 0.6
    # Mai (top-left)
    $ _mai_pos = [(555, 482), (615, 472)]     # +60px spread, +4px y on second card
    $ _mai_tf  = [card_left_a, card_left_b]
    for i, (img, x, y) in enumerate(draw_cards(mai_display, _mai_pos)):
        add img at _mai_tf[i] xpos x ypos y zoom 0.7

    # Eli (top-right)
    $ _eli_pos = [(1354, 522), (1424, 522)]   # +60px spread, +4px y on second card
    $ _eli_tf  = [card_right_a, card_right_b]
    for i, (img, x, y) in enumerate(draw_cards(eli_display, _eli_pos)):
        add img at _eli_tf[i] xpos x ypos y zoom 0.7



    # Community
    for img, x, y in draw_cards(community, community_positions):
        add img xpos x ypos y

    # Pot and stacks
    $ total_pot = sum(p["amount"] for p in pots) if pots else 0
    text "Pot: [total_pot] chips" size 24 color "#fff" xpos 0.5 ypos 0.46 xanchor 0.5 yanchor 0.5

    # Show side pots (if any)
    if len(pots) > 1:
        $ idx = 1
        for side in pots[1:]:
            text f"Side pot {idx}: {side['amount']} chips" size 18 color "#aaa" xpos 0.5 ypos 0.46+(idx*0.03) xanchor 0.5 yanchor 0.5
            $ idx += 1

    text "You: [player_chips] chips" size 20 color "#009207" xpos 0.70 ypos 0.80

    # NPC stacks (you had 'Naomi: npc_chips'; keep that for b/w compatibility, plus per-NPC)
    text "Naomi: [naomi_chips] chips" size 20 color "#a70000" xpos 0.6 ypos 0.28
    text "Eli: [eli_chips] chips" size 20 color "#a70000" xpos 0.85 ypos 0.5
    text "Mai: [mai_chips] chips" size 20 color "#a70000" xpos 0.25 ypos 0.33
    text "Hand strength - [player_hand_text]" xpos 0.80 ypos 0.68 color "#ffffff" size 22
    # Player bet tokens
    if bet_tokens["player"] > 0:
        add "images/poker/stack.png" xpos 550 ypos 680
        text f"{bet_tokens['player']} chips" xpos 610 ypos 780 size 18 color "#fff" xanchor 0.5

    # Naomi
    if bet_tokens["naomi"] > 0:
        add "images/poker/stack.png" xpos 750 ypos 380
        text f"{bet_tokens['naomi']} chips" xpos 810 ypos 480 size 18 color "#fff" xanchor 0.5

    # Eli
    if bet_tokens["eli"] > 0:
        add "images/poker/stack.png" xpos 1440 ypos 580
        text f"{bet_tokens['eli']} chips" xpos 1500 ypos 680 size 18 color "#fff" xanchor 0.5

    # Mai
    if bet_tokens["mai"] > 0:
        add "images/poker/stack.png" xpos 360 ypos 520
        text f"{bet_tokens['mai']} chips" xpos 420 ypos 620 size 18 color "#fff" xanchor 0.5

    $ BLIND_POS = {
    "player": (1120, 800),
    "naomi":  (1120, 400),
    "eli":    (1300, 550),
    "mai":    (520,  500),
    }

    # Small blind marker
    if sb_seat:
        $ x, y = BLIND_POS[sb_seat]
        add "images/poker/SB.png" xpos x ypos y

    # Big blind marker
    if bb_seat:
        $ x, y = BLIND_POS[bb_seat]
        add "images/poker/BB.png" xpos x ypos y

    if poker_message:
        frame:
            background None
            padding (15, 10)
            xalign 0.5
            yalign 0.7
            text poker_message size 30 color "#FFD700" xalign 0.5 yalign 0.5



# --------------------------------------------------------
# FLOW
# --------------------------------------------------------

label reset_naomi:
    $ renpy.pause(0.3, hard=True)
    $ naomi_reaction = "idle"
    return

label reset_eli:
    $ renpy.pause(0.3, hard=True)
    $ eli_reaction = "idle"
    return

label reset_mai:
    $ renpy.pause(0.3, hard=True)
    $ mai_reaction = "idle"
    return

label poker_table:
    if poker_quit:
        hide screen poker_table_screen
        hide screen poker_actions
        stop music fadeout 0.5
        $ poker_quit = False
        call screen pokerroom

    scene expression "images/poker/pokerbg.png"
    show screen poker_table_screen
    play music bass_vibes loop fadein 0.5
    if first_poker_hand:
        $ renpy.notify("Music: ŌĆ£Bass VibesŌĆØ by Kevin MacLeod (incompetech.com) | CC BY 4.0")


    # --- Buy-ins ---
    # --- New day? Force NPCs to buy in fresh ---
    if poker_stacks_day != calendar.day:
        $ naomi_chips = 0
        $ eli_chips = 0
        $ mai_chips = 0
        $ poker_stacks_day = calendar.day

    if player_chips == 0:
        if bag.cash < 100:
            $ set_npc_reaction("naomi", "win")
            $ poker_message = "You don't have enough cash to buy back in."
            call screen pokerroom
        $ bag.cash -= 100
        $ player_chips = 100
        $ poker_message = "You buy in for $100."
        $ set_npc_reaction("naomi", "idle")

    if naomi_chips == 0:
        $ naomi_chips = 100
        $ npc_chips = naomi_chips
        $ poker_message = "Naomi buys in for 100 chips."

    if eli_chips == 0:
        $ eli_chips = 100
        $ poker_message = "Eli buys in for 100 chips."

    if mai_chips == 0:
        $ mai_chips = 100
        $ poker_message = "Mai buys in for 100 chips."

    # Fresh hand state
    $ naomi_in = True
    $ eli_in = True
    $ mai_in = True
        # --- Fresh hand state (add these) ---
    $ naomi_all_in = False
    $ eli_all_in = False
    $ mai_all_in = False
    $ player_all_in = False
    $ committed = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}
    $ pots = [{"amount": 0, "eligible": ["player", "naomi", "eli", "mai"]}]
    $ hand_committed = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}
    $ bet_tokens = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}
    $ player_excess_refunded = False
    $ deck = build_deck()
    $ random.shuffle(deck)
    $ deal_sfx(5, 0.25)

    $ mc_hand = deal(deck, 2)
    $ player_hand_text = describe_hand(mc_hand)
    $ naomi_hand = deal(deck, 2)
    $ naomi_display = ["back","back"]
    $ npc_hand = naomi_hand
    $ npc_display = naomi_display

    $ eli_hand = deal(deck, 2)
    $ eli_display = ["back","back"]

    $ mai_hand = deal(deck, 2)
    $ mai_display = ["back","back"]

    $ community = []
    $ pot = 0

    # --- Blinds ---
    $ dealer_index = (dealer_index + 1) % len(seats)
    $ dealer = seats[dealer_index]
    $ sb_index = (dealer_index + 1) % len(seats)
    $ sb_seat = seats[sb_index]
    $ bb_index = (sb_index + 1) % len(seats)
    $ bb_seat = seats[bb_index]
    $ small_blind = 5
    $ big_blind = 10
    $ sb = post_blind(sb_seat, small_blind)
    $ bb = post_blind(bb_seat, big_blind)
    $ current_bet = big_blind
    $ last_raiser = bb_seat
    $ poker_message = f"[sb_seat.capitalize()] posts SB ({sb}). [bb_seat.capitalize()] posts BB ({bb})."
    $ renpy.pause(0.6, hard=True)
    # --- PREFLOP ---
    $ bet_amount = max(10, current_bet + 5)
    $ calendar.addtime(10)
    if get_time_of_day() == "morning":
        $ poker_end_after_hand = True  


    if first_poker_hand:
        $ poker_message = "You sit at the table..."
        $ first_poker_hand = False
    $ poker_message = f"Your hole cards: {mc_hand}"
    $ renpy.pause(1.2, hard=True)
    $ player_hand_text = describe_hand(mc_hand)
    call poker_betting_round from _call_poker_betting_round

    # If everyone except you folded, award the pot immediately (no showdown)
    if not (naomi_in or eli_in or mai_in):
        $ won = table_pot()
        $ player_chips += won
        $ poker_message = f"Everyone folds. You win {won} chips."
        $ renpy.pause(1.0, hard=True)
        jump poker_hand_end


    # --- FLOP ---
    $ reset_street()
    $ bet_tokens = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}
    $ last_raiser = None
    $ community = deal(deck, 3)
    $ poker_message = f"The flop comes: {community}"
    $ player_hand_text = describe_hand(mc_hand + community)
    $ renpy.pause(1.2, hard=True)
    call poker_betting_round from _call_poker_betting_round_1

    # All-in fast path
    $ _auto = deal_remaining_if_all_in()
    if _auto:
        jump poker_showdown

    if poker_quit:
        hide screen poker_table_screen
        hide screen poker_actions
        stop music fadeout 0.5
        $ poker_quit = False
        call screen pokerroom
    if (naomi_chips == 0 and eli_chips == 0 and mai_chips == 0):
        jump poker_showdown

    # --- TURN ---
    $ last_raiser = None
    if len(community) == 3:
        $ community += deal(deck, 1)
        $ poker_message = f"The turn card: {community[-1]}"
        $ renpy.pause(1.2, hard=True)
    $ reset_street()
    $ bet_tokens = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}
    call poker_betting_round from _call_poker_betting_round_2

    $ _auto = deal_remaining_if_all_in()
    if _auto:
        jump poker_showdown

    if poker_quit:
        hide screen poker_table_screen
        hide screen poker_actions
        stop music fadeout 0.5
        $ poker_quit = False
        call screen pokerroom

    # --- RIVER ---
    $ last_raiser = None
    if len(community) == 5:
        jump poker_showdown
    if len(community) == 4:
        $ community += deal(deck, 1)
        $ poker_message = f"The river card: {community[-1]}"
        $ renpy.pause(1.2, hard=True)
    $ reset_street()
    $ bet_tokens = {"player": 0, "naomi": 0, "eli": 0, "mai": 0}
    call poker_betting_round from _call_poker_betting_round_3
    if poker_quit:
        hide screen poker_table_screen
        hide screen poker_actions
        stop music fadeout 0.5
        $ poker_quit = False
        call screen pokerroom

    jump poker_showdown






label poker_betting_round:
    # Slider bounds (true all-in target when facing a bet)
    $ min_raise = (current_bet + 5) if current_bet > 0 else 5
    $ max_raise = (committed["player"] + player_chips) if current_bet > 0 else player_chips
    if min_raise > max_raise:
        $ min_raise = max_raise
    $ bet_amount = min_raise

    # Decide if it is actually the player's turn
    $ need = max(0, current_bet - committed["player"])
    $ your_turn = (not player_all_in) and ((current_bet == 0) or (need > 0) or (last_raiser == "player"))

    if player_all_in:
        $ action = "npc_pass"
    elif your_turn:
        $ action = renpy.call_screen("poker_actions")
    else:
        # Not your turn (e.g., you already matched a raise and NPCs still owe action)
        $ action = "npc_pass"


    if action == "leave":
        $ poker_message = "You stand up from the table."
        hide screen poker_table_screen
        hide screen poker_actions
        scene naomitalk05 with dissolve
        $ poker_message = None
        bffmom "Already giving up?"
        $ poker_quit = True
        stop music fadeout 0.5
        $ bet_amount = 10
        jump poker_hand_end
    if action == "fold":
        play sound sfx_fold
        $ poker_message = "You fold."
        $ renpy.pause(0.6, hard=True)
        # ... (fold resolution stays as you had it)
        jump poker_hand_end
    if action == "check":
        $ poker_message = "You check."
        $ renpy.pause(0.8, hard=True)
    elif action == "bet":
        $ bet = commit_bet("player", bet_amount)
        python:
            mark_open_or_raise("player")
        play sound sfx_chip
        $ poker_message = "You bet [bet] chips."
        $ renpy.pause(0.8, hard=True)
    elif action == "call":
        $ need = current_bet - committed["player"]
        $ call_amt = commit_bet("player", need)
        play sound sfx_chip
        $ poker_message = "You call with [call_amt] chips."
        $ renpy.pause(0.8, hard=True)
        python:
            if maybe_close_betting():
                renpy.jump("poker_showdown")
            else:
                renpy.call("poker_betting_round")
    elif action == "raise":
        # slider is "raise TO" ŌĆö post only the difference
        $ to_amount = bet_amount
        $ delta = max(0, to_amount - committed["player"])
        $ posted = commit_bet("player", delta)
        python:
            mark_open_or_raise("player")
        play sound sfx_chip
        $ poker_message = "You raise to [to_amount] chips."
        $ renpy.pause(0.8, hard=True)



    python:
        # If player checked and no bet on the table, first NPC may open
        someone_bet = (renpy.store.current_bet > 0 and action in ("bet", "raise"))
        opener_set = bool(someone_bet)

        chip_refs = {
            "naomi": renpy.store.naomi_chips,
            "eli":   renpy.store.eli_chips,
            "mai":   renpy.store.mai_chips,
        }

        for npc in ["naomi", "eli", "mai"]:
            # --- skip absent / already all-in
            in_flag = getattr(renpy.store, f"{npc}_in", False)
            allin_flag = getattr(renpy.store, f"{npc}_all_in", False)
            if (not in_flag) or allin_flag:
                continue

            # --- skip if npc has no chips ---
            npc_chips = getattr(renpy.store, f"{npc}_chips", 0)
            if npc_chips <= 0:
                continue
            
            # If player is all-in heads-up, NPC cannot raise (only call/fold)
            if renpy.store.player_all_in:
                still_in_npcs = sum([renpy.store.naomi_in, renpy.store.eli_in, renpy.store.mai_in])
                if still_in_npcs == 1 and isinstance(npc_act, tuple) and npc_act[0] == "raise":
                    # Heads-up vs all-in player, convert raise to call
                    npc_act = "call"

            # --- compute decision
            strength = eval_for(npc)[0]
            faced = (renpy.store.committed[npc] < renpy.store.current_bet)
            npc_act = npc_decision(npc, strength, faced_raise=faced)

            # SAFETY: if decision returns None, skip cleanly
            if npc_act is None:
                continue

            # --- opener case (no bet on table, player checked, this NPC may open)
            if action == "check" and not faced and not opener_set:
                if npc_act in ("check", "call"):
                    renpy.store.poker_message = f"{npc.capitalize()} checks."
                    set_npc_reaction(npc, "idle")
                    renpy.pause(0.5, hard=True)
                else:
                    # Determine opener raise amount
                    if isinstance(npc_act, tuple) and npc_act[0] == "raise":
                        pct = float(npc_act[1])
                        desired_raise = max(10, int(table_pot() * pct))
                    else:
                        desired_raise = max(10, int(renpy.store.bet_amount))

                    posted = commit_bet(npc, desired_raise)
                    mark_open_or_raise(npc)

                    renpy.store.poker_message = f"{npc.capitalize()} opens betting with {renpy.store.current_bet} chips."
                    set_npc_reaction(npc, "raise")
                    renpy.play(sfx_chip, channel="sound")
                    renpy.pause(0.8, hard=True)
                    renpy.store.last_raiser = npc
                    opener_set = True
                continue  # opener handled; move to next NPC

            # --- responding to an existing bet/raise
            if renpy.store.current_bet == 0:
                # nothing to face -> check
                renpy.store.poker_message = f"{npc.capitalize()} checks."
                set_npc_reaction(npc, "idle")
                renpy.pause(0.5, hard=True)
                continue
            
            # If NPC has already matched current bet, they should check not call
            if renpy.store.committed[npc] >= renpy.store.current_bet:
                renpy.store.poker_message = f"{npc.capitalize()} checks."
                set_npc_reaction(npc, "idle")
                renpy.pause(0.5, hard=True)
                continue

            # facing a bet:
            if npc_act == "fold":
                renpy.store.poker_message = f"{npc.capitalize()} folds."
                set_npc_reaction(npc, "fold")
                renpy.play(sfx_fold, channel="sound")
                renpy.pause(0.6, hard=True)
                if npc == "naomi":
                    renpy.store.naomi_in = False
                elif npc == "eli":
                    renpy.store.eli_in = False
                else:
                    renpy.store.mai_in = False

            elif npc_act == "call":
                needed = renpy.store.current_bet - renpy.store.committed[npc]
                call_amt = commit_bet(npc, needed)
                renpy.store.poker_message = f"{npc.capitalize()} calls with {call_amt} chips."
                set_npc_reaction(npc, "call")
                renpy.play(sfx_chip, channel="sound")
                renpy.pause(0.6, hard=True)
                maybe_close_betting()

            elif isinstance(npc_act, tuple) and npc_act[0] == "raise":
                try:
                    pct = float(npc_act[1])
                except Exception:
                    pct = None

                prev_target = renpy.store.current_bet
                # If they can't even cover the call, treat as all-in call
                need = max(0, prev_target - renpy.store.committed[npc])
                stack_before = getattr(renpy.store, f"{npc}_chips")

                if stack_before <= need or pct is None:
                    call_amt = commit_bet(npc, need if stack_before > need else stack_before)
                    if getattr(renpy.store, f"{npc}_all_in", False):
                        renpy.store.poker_message = f"{npc.capitalize()} calls all-in for {call_amt} chips."
                    else:
                        renpy.store.poker_message = f"{npc.capitalize()} calls with {call_amt} chips."
                    set_npc_reaction(npc, "call")
                    renpy.play(sfx_chip, channel="sound")
                    renpy.pause(0.6, hard=True)
                    # maybe close betting if everyone matched or is all-in
                    maybe_close_betting()
                else:
                    desired_raise = max(10, int(table_pot() * pct))
                    posted = commit_bet(npc, desired_raise)
                    if renpy.store.committed[npc] > prev_target:
                        mark_open_or_raise(npc)
                        renpy.store.poker_message = f"{npc.capitalize()} raises to {renpy.store.committed[npc]} chips."
                        set_npc_reaction(npc, "raise")
                    else:
                        # short-stack ŌĆ£raiseŌĆØ didnŌĆÖt beat the target ŌåÆ itŌĆÖs just an all-in call
                        if getattr(renpy.store, f"{npc}_all_in", False):
                            renpy.store.poker_message = f"{npc.capitalize()} goes all-in for {renpy.store.committed[npc]} chips."                        
                        else:
                            renpy.store.poker_message = f"{npc.capitalize()} raises to {renpy.store.committed[npc]} chips."

                        set_npc_reaction(npc, "call")
                        maybe_close_betting()
                    renpy.play(sfx_chip, channel="sound")
                    renpy.pause(0.8, hard=True)

            else:
                # Fallback: treat anything odd as a CALL
                needed = renpy.store.current_bet - renpy.store.committed[npc]
                call_amt = commit_bet(npc, needed)
                renpy.store.poker_message = f"{npc.capitalize()} calls with {call_amt} chips."
                set_npc_reaction(npc, "call")
                renpy.play(sfx_chip, channel="sound")
                renpy.pause(0.6, hard=True)
    # --- Player decision if an NPC's bet/raise is outstanding ---
    if current_bet > committed["player"] and not player_all_in and last_raiser != "player":
        $ poker_message = "Action back to you."
        $ renpy.pause(0.5, hard=True)
        $ min_raise = current_bet + 5
        $ max_raise = player_chips
        if min_raise > max_raise:
            $ min_raise = max_raise
        $ bet_amount = min_raise
        $ action = renpy.call_screen("poker_actions")

        if action == "fold":
            play sound sfx_fold
            $ poker_message = "You fold."
            $ renpy.pause(0.8, hard=True)

            # Finish the board for remaining NPCs
            while len(community) < 5:
                $ community += deal(deck, 1)

            # Determine winner among NPCs
            $ results = []
            python:
                surv = []
                if renpy.store.naomi_in: surv.append(("naomi", renpy.store.naomi_hand))
                if renpy.store.eli_in:   surv.append(("eli",   renpy.store.eli_hand))
                if renpy.store.mai_in:   surv.append(("mai",   renpy.store.mai_hand))
                for npc, hand in surv:
                    strength, desc = evaluate_hand(hand + renpy.store.community)
                    results.append((strength, npc))
                if results:
                    best = max(r[0] for r in results)
                    winners = [n for (s, n) in results if s == best]
                    share = sum(p["amount"] for p in pots) // len(winners)

                    for w in winners:
                        if w == "naomi": renpy.store.naomi_chips += share
                        elif w == "eli": renpy.store.eli_chips += share
                        elif w == "mai": renpy.store.mai_chips += share
                    renpy.store.poker_message = f"{' and '.join([w.capitalize() for w in winners])} win(s) the pot!"
                    renpy.pause(1.0, hard=True)
            python:
                for p in bet_tokens:
                    bet_tokens[p] = 0
            $ current_bet = 0
            $ bet_amount = 10
            jump poker_hand_end

        elif action == "call":
            $ need = current_bet - committed["player"]
            $ call_amt = commit_bet("player", need)
            play sound sfx_chip
            $ poker_message = "You call with [call_amt] chips."
            $ renpy.pause(0.8, hard=True)
            python:
                if not maybe_close_betting():
                    renpy.call("poker_betting_round")

        elif action == "raise":
            # slider is "raise TO" ŌĆö post only the difference
            $ to_amount = bet_amount
            $ delta = max(0, to_amount - committed["player"])
            $ posted = commit_bet("player", delta)
            $ mark_open_or_raise("player")
            play sound sfx_chip
            $ poker_message = "You raise to [to_amount] chips."
            $ renpy.pause(0.8, hard=True)
            # One quick response loop: remaining live NPCs react once
            python:
                for npc in ["naomi","eli","mai"]:
                    alive = getattr(renpy.store, f"{npc}_in")
                    all_in = getattr(renpy.store, f"{npc}_all_in")
                    if not alive or all_in:
                        continue

                    faced = (renpy.store.committed[npc] < renpy.store.current_bet)
                    strength = eval_for(npc)[0]
                    npc_act = npc_decision(npc, strength, faced_raise=faced)

                    if npc_act == "fold":
                        renpy.store.poker_message = f"{npc.capitalize()} folds."
                        set_npc_reaction(npc, "fold")
                        renpy.play(sfx_fold, channel="sound")
                        renpy.pause(0.6, hard=True)
                        setattr(renpy.store, f"{npc}_in", False)

                    elif npc_act == "call":
                        need = renpy.store.current_bet - renpy.store.committed[npc]
                        call_amt = commit_bet(npc, need)
                        renpy.store.poker_message = f"{npc.capitalize()} calls with {call_amt} chips."
                        set_npc_reaction(npc, "call")
                        renpy.play(sfx_chip, channel="sound")
                        renpy.pause(0.6, hard=True)
                        maybe_close_betting()
                    elif isinstance(npc_act, tuple) and npc_act[0] == "raise":
                        prev_target = renpy.store.current_bet
                        need = max(0, prev_target - renpy.store.committed[npc])
                        stack_before = getattr(renpy.store, f"{npc}_chips")

                        try:
                            pct = float(npc_act[1])
                        except Exception:
                            pct = None

                        if stack_before <= need or pct is None:
                            call_amt = commit_bet(npc, need if stack_before > need else stack_before)
                            if getattr(renpy.store, f"{npc}_all_in", False):
                                renpy.store.poker_message = f"{npc.capitalize()} calls all-in for {call_amt} chips."
                            else:
                                renpy.store.poker_message = f"{npc.capitalize()} calls with {call_amt} chips."
                            set_npc_reaction(npc, "call")
                            renpy.play(sfx_chip, channel="sound")
                            renpy.pause(0.6, hard=True)
                            maybe_close_betting()
                        else:
                            size = max(10, int(table_pot() * pct))
                            # snap to 5-chip step so calls/slider line up with the table target
                            size -= (size % 5)
                            if size < 5:
                                size = 5
                            rbet = commit_bet(npc, size)
                            if renpy.store.committed[npc] > prev_target:
                                mark_open_or_raise(npc)
                                renpy.store.poker_message = f"{npc.capitalize()} raises to {renpy.store.committed[npc]} chips."
                                set_npc_reaction(npc, "raise")
                            else:
                                if getattr(renpy.store, f"{npc}_all_in", False):
                                    renpy.store.poker_message = f"{npc.capitalize()} goes all-in for {renpy.store.committed[npc]} chips."                                
                                else:
                                    renpy.store.poker_message = f"{npc.capitalize()} calls with {renpy.store.committed[npc]} chips."

                                set_npc_reaction(npc, "call")
                                maybe_close_betting()
                            renpy.play(sfx_chip, channel="sound")
                            renpy.pause(0.8, hard=True)
            python:
                if not maybe_close_betting():
                    renpy.call("poker_betting_round")
                else:
                    renpy.jump("poker_showdown")
    return



label poker_showdown:
    python:
        # If at least one NPC is still in with you AND the board isn't complete,
        # force the turn+river reveal right here.
        live_npcs = int(naomi_in) + int(eli_in) + int(mai_in)
        if live_npcs >= 1 and len(community) < 5:
            force_reveal_to_river()

        # Flip cards face up
        naomi_display = naomi_hand if naomi_in else ["back","back"]
        eli_display   = eli_hand   if eli_in   else ["back","back"]
        mai_display   = mai_hand   if mai_in   else ["back","back"]

        # Build contender dictionary {player: (rank, best_hand, hole_cards)}
        contenders = {}
        contenders["player"] = evaluate_hand(mc_hand + community), mc_hand
        if naomi_in: contenders["naomi"] = evaluate_hand(naomi_hand + community), naomi_hand
        if eli_in:   contenders["eli"]   = evaluate_hand(eli_hand   + community), eli_hand
        if mai_in:   contenders["mai"]   = evaluate_hand(mai_hand   + community), mai_hand

        # Reveal everyoneŌĆÖs hands
        for who, (ev, hand) in contenders.items():
            rank, best = ev
            who_label = "You" if who=="player" else who.capitalize()
            msg = f"{who_label} shows {describe_hand(best)}."
            renpy.store.poker_message = msg
            renpy.pause(1.2, hard=True)

        # 1) Build layers from total contributions (folded chips still count toward pot)
        seating = list(renpy.store.seats)  # e.g., ["player","mai","naomi","eli"]
        everyone = ["player","naomi","eli","mai"]
        contrib = dict(renpy.store.hand_committed)

        # Unique contribution thresholds (exclude zeros), ascending
        levels = sorted({amt for amt in contrib.values() if amt > 0})
        prev = 0
        pot_layers = []

        for L in levels:
            # Amount added in this layer = sum( min(c, L) - min(c, prev) )
            layer_amount = 0
            for p in everyone:
                c = contrib.get(p, 0)
                layer_amount += max(0, min(c, L) - min(c, prev))

            # Eligible = players who did NOT fold (i.e., are in contenders) AND have contrib >= L
            eligible = [p for p in contenders.keys() if contrib.get(p, 0) >= L]

            if layer_amount > 0 and eligible:
                pot_layers.append({"amount": layer_amount, "eligible": eligible})

            prev = L

        # Fallback: if no layers, make a single pot from all contributions of live players
        if not pot_layers:
            total_amt = sum(contrib.values())
            eligible = list(contenders.keys())
            if total_amt > 0 and eligible:
                pot_layers = [{"amount": total_amt, "eligible": eligible}]

        # Update pots for UI (so the side-pot lines match what weŌĆÖre actually paying)
        renpy.store.pots = pot_layers[:]

        # 2) Payout each pot, with fair remainder distribution by seat order
        for idx, pot in enumerate(renpy.store.pots):
            eligible = pot["eligible"]
            amt = pot["amount"]
            if not eligible or amt <= 0:
                continue

            # Choose the best hand among eligible for this pot
            elig_results = [(who, contenders[who][0]) for who in eligible if who in contenders]
            if not elig_results:
                continue

            best_eval = max(elig_results, key=lambda x: compare_key(x[1]))[1]
            best_key  = compare_key(best_eval)
            winners = [who for who, ev in elig_results if compare_key(ev) == best_key]

            base = amt // len(winners)
            rem  = amt %  len(winners)

            # Pay base share
            for w in winners:
                if w == "player": renpy.store.player_chips += base
                elif w == "naomi": renpy.store.naomi_chips += base
                elif w == "eli": renpy.store.eli_chips += base
                elif w == "mai": renpy.store.mai_chips += base

            # Distribute remainder by seat order (first in order gets first odd chip)
            winners_sorted = sorted(winners, key=lambda w: seating.index(w))
            for i in range(rem):
                w = winners_sorted[i]
                if w == "player": renpy.store.player_chips += 1
                elif w == "naomi": renpy.store.naomi_chips += 1
                elif w == "eli": renpy.store.eli_chips += 1
                elif w == "mai": renpy.store.mai_chips += 1

            renpy.store.poker_message = f"{' and '.join(['You' if w=='player' else w.capitalize() for w in winners])} win(s) {'side pot' if idx>0 else 'the pot'} of {amt} chips!"
            renpy.pause(1.5, hard=True)

    $ current_bet = 0
    $ bet_amount = 10
    jump poker_hand_end






label poker_hand_end:
    if poker_quit:
        $ poker_cashout()
        $ poker_cleanup()
        $ poker_quit = False
        stop music fadeout 0.5
        call screen pokerroom
        return

    if poker_end_after_hand:
        stop music fadeout 0.5
        $ poker_cashout()
        $ poker_end_after_hand = False
        $ poker_message = "It's morning! Poker night has ended."
        $ poker_cleanup()
        call screen laundromatscreen
        return

    if player_chips == 0:
        $ poker_cleanup()
        scene naomitalk05 with dissolve
        $ poker_message = None
        "You are out of chips!"
        if bag.cash >= 100:
            menu:
                "Rebuy for $100":
                    $ bag.cash -= 100
                    $ player_chips = 100
                    $ poker_quit = False
                    $ set_npc_reaction("naomi","idle")
                    jump poker_table
                "Leave":
                    $ poker_quit = True
                    stop music fadeout 0.5
                    $ poker_cashout()
                    $ poker_cleanup()
                    jump game_loop
        else:
            "You don't have enough money to rebuy."
            $ poker_quit = True
            stop music fadeout 0.5
            $ poker_cashout()
            $ poker_cleanup()
            call screen pokerroom
            return

    # NPC rebuys
    elif naomi_chips == 0:
        $ poker_message = "Naomi is out of chips and rebuying."
        $ npc_line("naomi","rebuy")
        $ naomi_chips = 100
        jump poker_table

    elif eli_chips == 0:
        $ poker_message = "Eli is out of chips and rebuying."
        $ npc_line("eli","rebuy")
        $ eli_chips = 100
        jump poker_table

    elif mai_chips == 0:
        $ poker_message = "Mai is out of chips and rebuying."
        $ npc_line("mai","rebuy")
        $ mai_chips = 100
        jump poker_table

    else:
        $ set_npc_reaction("naomi","idle")
        $ set_npc_reaction("eli","idle")
        $ set_npc_reaction("mai","idle")
        jump poker_table

Made with Ren'Py.
screen policeout:
    tag police
    add "images/police/30.webp"
    on "show" action [Function(renpy.music.play, "audio/police.ogg", loop=True, fadein=0.5), SetVariable("current_location", "policeout")]
    on "hide" action Function(renpy.music.stop, fadeout=0.5)
    imagebutton auto "images/police/policeentrance_%s.png" style "worldbutton" focus_mask True action Function(renpy.music.stop, fadeout=0.5), [Hide("policeout"), Show("policestation")]

screen policestation:
    tag police
    add "images/police/policeinside.webp"
    on "show" action [Function(renpy.music.play, "audio/police2.ogg", loop=True, fadein=0.5), SetVariable("current_location", "policestation")]
    on "hide" action Function(renpy.music.stop, fadeout=0.5)
    if quest_findcuckoo in questlog.quest_list:
        imagebutton auto "images/police/cuffs_%s.png" focus_mask True action Call("grabcuckoo")
    imagebutton auto "images/police/policedoor_%s.png" style "worldbutton" focus_mask True action [
        Hide("policestation"),
        Show("policeoffice") 
    ]
    imagebutton auto "images/police/policedoor2_%s.png" style "worldbutton" focus_mask True action [
            Hide("policestation"),
            Show("policeout")
        ]  

screen policeoffice:
    tag police
    $ present = get_characters_at_location("policestation")  
    add "images/police/225.webp"
    on "show" action [Function(renpy.music.play, "audio/police3.ogg", loop=True, fadein=0.5), SetVariable("current_location", "policeoffice")]
    for char_id in present:
        imagebutton auto "images/police/%s_%%s.png" % char_id focus_mask True action Call("%smenu" % char_id)

label grabcuckoo:
