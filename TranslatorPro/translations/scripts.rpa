label mayorleave2:
    scene mayorhousebg with dissolve
    if brenda_departed:
        mc "Nobody's home. Brenda left, and the mayor is in jail."
        mc "(I wonder if she locked up.)"
        menu:
            "Try to open the door.":
                $ brendapic_images = [
                    "images/mayorshouse/brendagoodbye.png"
                ]
                scene mcbreakin1 with dissolve
                $ mccorruption += 5
                "You try the handle."
                play sound "audio/dooropen.ogg"
                "The door gives way immediately."
                mc "(... Of course it does.)"
                mc "(She didn't even lock it.)"
                scene mayorhouse_inside with dissolve
                "Everything seems untouched. Neatly organized as always."
                mc "(It's like she just stepped out for a moment...)"
                pause 0.2
                "You walk further into the house."
                "You notice something on the table."
                "Theres a sealed envelope on the table."
                mc "(Hmm... strange...)"
                scene mayorhouse_inside2 with dissolve
                "The letter is addressed to you."
                mc "(Did she know I would come here?)"
                scene mayorhouse_inside2blur with dissolve
                call screen brenda_letter_screen
                mc "(Right...)"
                "Something else is tucked behind the letter."
                show brendagoodbye
                pause 0.4
                mc "(Wow!)"
                mc "(She took a picture of herself...)"
                python:
                    for img in brendapic_images:
                        if img not in unlocked_pictures:
                            unlocked_pictures.append(img)
                "You've unlocked a new picture in your gallery!"
                mc "(I should probably go.)"
                scene mcbreakin1 with dissolve
                "You close the door behind you and leave quietly."
                mc "(I wonder when she'll be back.)"
                return
            "Leave.":
                return
    else:
        "You knock on the door, but nobody answers."
        "You decide to leave."
        return


screen brenda_letter_screen():

    modal True
    zorder 200

    # Dim the background
    add Solid("#00000099")

    # Letter container
    frame:
        style "empty"
        xalign 0.5
        yalign 0.5

        add "images/mayorshouse/brendaletter.png"

    # Click anywhere / press key to close
    key "dismiss" action Return()
    key "K_RETURN" action Return()
    key "K_ESCAPE" action Return()

    button:
        background None
        focus_mask None
        action Return()



