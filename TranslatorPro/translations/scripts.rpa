        bffmom "That was quite resourceful of you, [name]."
        $ bffmomlove += 10
        mc "So you-"
        scene bffdean7 with dissolve
        bffmom "Don't worry, I'm happy with the way things worked out."
        scene bffdean6 with dissolve
        bffmom "To tell you the truth, this drama between me and my sister has become quite tiresome."
        mc "Yeah, no kidding."
        scene bffdean8 with dissolve
        bffmom "So, thank you [name]. You gave me back my sister."
        mc "Heh, I'm glad things worked out in the end."
    $ questlog.EndQuest(quest_meetdean)
    scene black with fade
    "For the first time in a long time, peace has returned in Tim's place."
    pause 2.0
    "But just as you're about to leave, Bridgette comes rushing downstairs in a panic."
