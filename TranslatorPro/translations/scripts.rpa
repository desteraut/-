# --- AFTER-LOAD MINI SYNC ---

init python:
    import renpy.store as store
    _sync_running = False

    # Simple character for system messages
    if not hasattr(store, "system_voice"):
        store.system_voice = Character(None, what_color="#cccccc")

    def check_save_version():
        import renpy.store as store
        global shown_save_version_warning

        saved   = getattr(store, "save_version", None)
        current = config.version

        if saved != current and not shown_save_version_warning:
            store.crash_version_note = f"{saved or 'None'} ŌåÆ {current}"
            store.system_voice("{color=#ff5555}ŌÜĀ Loaded save from version %s (current is %s){/color}" % (saved or 'None', current))
            store.system_voice("Please consider starting a new save for the smoothest experience.")
            shown_save_version_warning = True

    def fix_missing_bag_bank():
        # Runs on load of any save.
        global bag
        if bag is not None:
            if not hasattr(bag, "bank"):
                bag.bank = 0

    def run_after_load_sync():
        global _sync_running
        if _sync_running:
            return
        _sync_running = True
        try:
            try:
                ensure_relationship_stats_wrapped()
            except Exception:
                pass

            # Safety defaults
            if not hasattr(store, "incoming_calls"):
                store.incoming_calls = []
            if not hasattr(store.persistent, "cheese_call_today"):
                store.persistent.cheese_call_today = False

            # Daily reset bookkeeping (NO side effects)
            cal = store.calendar
            if not hasattr(store, "_last_reset_day"):
                store._last_reset_day = cal.day

            # Rebuild markers (pure state rebuild)
            for fn in ("rebuild_all_markers", "rebuild_worldmap_markers", "rebuild_desert_markers"):
                try:
                    getattr(store, fn)()
                except Exception:
                    pass

        finally:
            _sync_running = False


label after_load:
    $ _in_after_load = True
    $ in_game_flag = True
    $ store.floater_suppressed = True
    $ store.floaters[:] = []

    # Kill all legacy context intent (one-time migration safety)
    $ active_context = None
    $ pending_resume = None
    $ pending_args = None
    $ _ctx_args = ()
    $ persistent.pending_resume = None
    $ persistent.pending_args = None
    $ pending_random_event = None

    # Healing only
    call _after_load_sync from _call__after_load_sync
    $ fix_missing_bag_bank()
    $ auto_register_quests()
    $ heal_quests()
    $ heal_midnight_dares()
    $ heal_inventory_services()
    $ heal_spirit_eligibility()

    $ _in_after_load = False
    $ store.floaters[:] = []
    $ renpy.restart_interaction()
    $ store.floater_suppressed = False
    return






label _after_load_sync:
    $ run_after_load_sync()

    # Only touch quest_askjustinshift if it exists and is a stray bool
    python:
        import renpy.store as store
        if hasattr(store, "quest_askjustinshift") and isinstance(store.quest_askjustinshift, bool):
            # Remove ghosted bool entries cleanly
            try:
                store.questlog.quest_list = [q for q in store.questlog.quest_list if not isinstance(q, bool)]
            except Exception:
                pass

            store.quest_askjustinshift = Quest(
                "Ask Justin about his shift.",
                "Justin has been working the night shift, ask him how his night was.",
                category="Main",
            )

        if not hasattr(store, "flag_askjustinshift"):
            store.flag_askjustinshift = False

    return


label mc_rename:
