label fraud_travel_event:
    scene black with fade
    "You follow officer sadie as she escorts you off the bus."
    scene mcpulledover3 with dissolve
    mc "Excuse me, officer? What's going on?"
    pclerk "[name], we've recently made an arrest in connection to fraudulent activity."
    pclerk "Your name came up during our investigation."
    mc "What? There must be some mistake!"
    scene mcpulledover4 with dissolve
    pclerk "I'm going to have to ask you to come with me to the station for questioning."
    mc "This is ridiculous..."
    scene mcpulledover5 with dissolve
    pclerk "Unless of course, you consent to forfeit the amount in question right now."
    mc "..."
    pclerk "It's your choice, [name]. You decide how hard I make this for you."
    menu:
        "­¤ÆĄ Agree to forfeit your money.":
            $ bag.spend(bag.cash)
            $ pending_fraud_amount = 0
            $ fraud_case_open = False
            $ mccorruption -= 5
            mc "(I guess I could've kept some of it in my bank...)"
            scene mcpulledover3 with dissolve
            pclerk "Thank you for your cooperation, [name]. You may go now."
            return
        "­¤Ü© Refuse to pay.":
            $ bag.spend(bag.cash)
            $ pending_fraud_amount = 0
            $ fraud_case_open = False
            $ active_context = None
            $ persistent.pending_resume = None
            scene mcpulledover4 with dissolve
            pclerk "Very well. You're under arrest."
            scene black with slow_fade
            "You are handcuffed and taken to the police station for processing."
            pause 0.5
            $ calendar.skipday()
            "You spend the rest of the day in a holding cell."
            scene policeblackout1 with dissolve
            pclerk2 "Sleep well, [name]?"
            mc "(Ugh...)"
            pclerk "Looks like you have some time to think about your choices."
            scene policeblackout4 with dissolve
            pclerk2 "Maybe next time you'll think twice before committing fraud."
            mc "(Great... just great...)"
            $ current_location = "policestation"
            return

