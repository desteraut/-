label spiritactivation:
    $ mc_unstable = False
    scene mcenterspirit with dissolve
    pause 0.5
    scene mcenterspirit2 with dissolve
    pause 0.5
    if quest_enterspirit in questlog.quest_list:
        $ questlog.EndQuest(quest_enterspirit)
        $ questlog.StartQuest(quest_dailyspirit)
        scene fortunehover2 with dissolve
        fortune "Listen closely."
        fortune "To walk with us, you must shed what binds you here."
        fortune "Your body. Your certainty."
        fortune "Only then may you enter our circle."
        scene fortunehover3 with dissolve
        fortune "One more thing."
        fortune "You will be evaluated."
        fortune "Fail, and you will be cast out."
        fortune "The veil will never accept you, tokens or not."
        pause 1.0
        scene fortunehover2 with dissolve
        fortune "Do you understand?"
        mc "I... I think so."
        mc "(This feels like crossing a line I can't come back from.)"
        fortune "The more souls you save, the more likely it is for you to pass."
        scene fortunehover1 with dissolve
        "The fortune teller begins to murmur, her voice slipping into a low chant."
        "Slowly, her feet lift off the ground."
        fortune "Now go."
        fortune "And show us who you truly are."
    scene mcenterspirit3 with dissolve
    pause 0.5
    scene mcenterspirit4 with dissolve
    pause 0.2
    scene mcenterspirit5 with dissolve
    pause 1.0
    scene white with flash
    $ _init_spirit_choices()
    $ current_location = "spiritrealm"
    jump game_loop
    Made with Ren'Py.# This file is for everyone's sanity.
default persistent.seen_quest_tracker_tutorial = False
default tutorial_step = 0

transform pulse:
    alpha 1.0
    linear 0.3 alpha 0.1
    linear 0.6 alpha 1.0
    repeat


# Quest tracker introduction tutorial ---
label tracker_intro:
    $ renpy.block_rollback()
    show screen quest_tracker_hint

screen quest_tracker_hint():
    modal True
    zorder 100
    add "#00000069"
    if tutorial_step == 0:
        frame:
            xpos 933
            ypos 155
            xsize 50
            ysize 50
            background "#ffffff40"
            at pulse
    elif tutorial_step == 1:
        frame:
            xpos 1670
            ypos 55
            xsize 50
            ysize 50
            background "#ffffff40"
            at pulse
    elif tutorial_step == 2:
        frame:
            xpos 12
            ypos 457
            xsize 20
            ysize 20
            background "#ffffffff"
            at pulse

    # Text info
    frame:
        xalign 0.5
        yalign 0.9
        padding (30, 20)
        background "#222c"
        vbox:
            spacing 10
            if tutorial_step == 0:
                text "Colored markers on the map indicate a quest location!" size 24
            elif tutorial_step == 1:
                text "Open the questlog." size 24
            elif tutorial_step == 2:
                text "Every quest has a checkbox that you can use to track any quest you're currently following and see the marked locations." size 24
                text "Try it for yourself, you will see the markers update in real time."
            elif tutorial_step == 3:
                text "This will help you find the right location for your quest."
    if tutorial_step <= 2:
        textbutton "Next" action SetVariable("tutorial_step", tutorial_step + 1) xalign 0.5 yalign 0.98
    else:
        textbutton "Got it!" action [Hide("quest_tracker_hint"), SetField(persistent, "seen_quest_tracker_tutorial", True)] xalign 0.5 yalign 0.98
Made with Ren'Py.default asked_what = False
default asked_where = False
default asked_who = False
default asked_midnight = False

screen veilscreen():
    tag veil
    on "show" action [Function(renpy.music.play, "audio/veil.ogg", loop=True, fadein=0.5), SetVariable("current_location", "veil")]
    if quest_theveil in questlog.quest_list:
        add "images/witchshack/veil2.webp"
        imagebutton auto "images/witchshack/witch2_%s.png" focus_mask True action Call("witchmenu")
    else:
        add "images/witchshack/veil.webp"
    
label witchmenu:
    if quest_theveil in questlog.quest_list and quest_timetotalk.completed:
        scene witchveil3 with dissolve
        witch "It called you, didn't it?"
        mc "How did you-"
        scene witchveil6 with dissolve
        witch "-Oh please."
        witch "Your brush with the veil tore loose more than you were ready to carry."
        mc "How do i fix it?"
        scene witchveil9 with dissolve
        witch "You can't."
        witch "This is not an illness, it's time itself remembering you... faster than your mind can bear."
        mc "That doesn't sound too good..."
        scene witchveil10 with dissolve
        pause 0.5
        "She looks visibly agitated with how you're reacting to all of this."
        scene witchveil13 with dissolve
        witch "Your mind is young, but your body is not. That conflict was always going to surface once the veil recognized you."
        mc "So... what now?"
        scene witchveil7 with dissolve
        witch "As long as the veil remains wounded, the bleed will worsen."
        witch "Visions, echoes, fractures between who you were and who you are."
        scene witchveil13 with dissolve
        witch "A body cannot hold two lives at once, [name]. Not for long."
        mc "So we have to fix it. Restore the veil, right?"
        scene witchveil8 with dissolve
        witch "Yes. But restoration is not a matter of will. It requires form. Structure."
        witch "The veil was never meant to be held open. Not without its anchors."
        mc "Anchors?"
        scene witchveil12 with dissolve
        witch "Three pieces you once carried."
        witch "Three reflections of your choices across lives."
        pause 0.5
        witch "Greed."
        pause 0.5
        witch "Lust."
        pause 0.5
        witch "Power."
        pause 0.5
        mc "Wait a minute..."
        mc "You aren't talking about the tokens... right?"
        scene witchveil3 with dissolve
        witch "Names you gave her. Symbols."
        witch "Each holding power older than language."
        mc "I offered them to the fortune teller... She doesn't take money."
        scene witchveil9 with dissolve
        witch "She never did."
        pause 0.2
        mc "You know her?"
        scene witchveil13 with dissolve
        witch "I know what she is."
        witch "A collector of echoes. A scavenger of what slips between lives."
        witch "She keeps what others discard."
        mc "So, how do I get them back?"
        scene witchveil12 with dissolve
        witch "She holds them. But she does not own them."
        witch "They are still yours... though dimmed by her touch."
        scene witchveil7 with dissolve
        witch "She will not give them freely."
        witch "To reclaim what you lost, you must offer something greater than what she took."
        mc "...Greater than-what does that even mean?"
        scene witchveil10 with dissolve
        pause 0.2
        scene witchveil13 with dissolve
        witch "A trade of spirits. Of choice."
        witch "She deals not in coin, but in hunger. In weakness. In desire."
        witch "She will test yours."
        mc "What kind of test?"
        scene witchveil6 with dissolve
        witch "One tailored to the fractures you carry."
        witch "She sees the cracks. She will widen them... unless you resist."
        mc "So... either I stand firm, or I break?"
        scene witchveil11 with dissolve
        pause 0.2
        witch "As you have in other lives..."
        pause 0.2
        mc "And.. if I fail?"
        scene witchveil13 with dissolve
        witch "Then she will keep what is yours."
        witch "And the veil will remain as it is... fractured."
        pause 1.0
        scene witchveil5 with dissolve
        witch "Go."
        witch "Before the fracture deepens."
        $ questlog.EndQuest(quest_theveil)
        $ questlog.StartQuest(quest_veilrepair)
        return
    scene witchveil9 with dissolve
    witch "Was I not clear enough?"
    mc "I... just wanted to check."
    scene witchveil13 with dissolve
    witch "There is nothing else I can give you today."
    witch "Knowledge must settle before it is swallowed. Otherwise it poisons."
    scene witchveil7 with dissolve
    witch "Go. Live your days. You will know when it is time."
    scene witchveil13 with dissolve
    witch "And [name]..."
    witch "Do not linger here longer than you must."
    if not quest_explorecity in questlog.quest_list and not quest_explorecity.completed:
        $ questlog.StartQuest(quest_explorecity)
    return

label veilreveal:
    play music "audio/wind.ogg"
    scene veilday3 with dissolve
    "Brenda is already on sight, inspecting some kind of artifact gleaming in the sunlight."
    mc "(Holy shit, what is that?)"
    mc "Is that thing what we came here for?!"
    brenda "I think so, but something feels off about it..."
    scene veilday4 with dissolve
    mc "Wait, is it... humming?"
    brenda "It seems so, but I can't tell where the sound is coming from."
    brenda "Is it coming from this thing, or is it the environment?"
    scene veilday4blur with dissolve
    play sound "audio/dizzy.ogg"
    "A strange sensation washes over your body, like the world briefly tilted sideways."
    mc "Brenda..."
    mc "I feel strange..."
    brenda "Not now, [name]."
    scene veilday4 with dissolve
    mc "(That's odd... the feeling is gone?)"
    mc "(No. No, something is wrong.)"
    brenda "Do you see that?"
    mc "See what?"
    brenda "It's not reflecting us... It's showing something else."
    mc "Uhh... Brenda..."
    scene veilday5 with dissolve
    brenda "Let me take a closer look. This is fascinating."
    mc "I don't think you should-"
    "Too late. Brenda reaches out toward the artifact."
    play sound "audio/rumble.ogg"
    scene black with fade
    "The artifact trembles, rising from the sand as if pulled by invisible strings."
    scene veilday7 with dissolve
    brenda "What the... it's levitating!"
    mc "Brenda, we need to get out of here!"
    brenda "Wait, I want to study this more!"
    brenda "Do you see that? It's like it's showing a different place..."
    mc "Brenda... I don't see anything."
    mc "It's a weird mirror, let's go!"
    "The humming intensifies until the ground beneath you vibrates."
    play sound "audio/veilwhoosh.ogg"
    scene veilday8 with dissolve
    brenda "It's... reacting to us!"
    mc "Brenda, please! This doesn't feel right!"
    brenda "I can't look away..."
    play music "audio/veilactive.ogg"
    scene veilday9 with dissolve
    pause 0.1
    scene veilday10 with dissolve
    pause 0.1
    scene veilday11 with dissolve
    play sound "audio/warp.ogg"
    brenda "Wow! Look at that place!"
    mc "Brendaaaa!!!"
    stop music fadeout 1.0
    play sound "audio/highpitch.ogg"
    scene white with dissolve
    pause 1.0
    "Your body feels weightless, dragged, stretched, falling in every direction at once."
    scene black with fade
    "You pass out."
    pause 1.0
    play music "audio/veil.ogg"
    scene witchveil2 with dissolve
    "When you come to, it's night time and the veil is softly humming in front of you."
    mc "The witch??!"
    witch "You're awake, good. We need to talk."
    mc "Y-Yeah... no kidding..."
    "Still out of balance due to what just happened, you stumble your way towards her and the veil."
    $ questlog.EndQuest(quest_portal)
    scene witchveil5 with dissolve
    witch "You have questions. I will answer some. But listen carefully."
    mc "Uhh, alright?"
    jump witchreveal

label veilreveal2:
    play music "audio/veil.ogg"
    scene witchveil2 with dissolve
    "When you come to, it's night time and a giant mirror is softly humming in front of you."
    witch "You're awake, good. We need to talk."
    mc "Y-Yeah... no kidding..."
    "Still out of balance due to what just happened, you stumble your way towards her and the veil."
    scene witchveil5 with dissolve
    witch "You have questions. I will answer some. But listen carefully."
    mc "Uhh, alright?"
    jump witchreveal

label witchreveal:
    $ drugcontent_unlocked = True
    $ mc_unstable = True
    scene witchveil5
    menu:
        "­¤Æ¼ What is this thing?" if not asked_what:
            $ asked_what = True
            scene witchveil7 with dissolve
            witch "A mirror only shows you what stands in front of it."
            pause 0.2
            scene witchveil8 with dissolve
            witch "This is not a mirror."
            mc "Then what is it?"
            witch "A doorway. A fracture between one reality and the next. A tether to a place your world forgot."
            mc "A doorway to where?"
            scene witchveil13 with dissolve
            witch "To the place you came from."
            mc "What?! I... I grew up here, in Brightmoor."
            scene witchveil6 with dissolve
            witch "Brightmoor is where you lived."
            witch "Not where you are from."
            mc "I don't understand."
            scene witchveil7 with dissolve
            witch "Long ago, this threshold was whole. A perfect arch between this world and the one you were meant to die in."
            witch "Your life was ending. Unfairly. Too soon."
            witch "And I-"
            scene witchveil3 with dissolve
            "She pauses."
            pause 0.2
            witch "-I refused to accept that."
            mc "What are you saying?"
            scene witchveil11 with dissolve
            witch "I moved you. Hid you. Folded your soul into another reality where time was kinder."
            pause 0.2
            mc "You... moved me? Into another life?!"
            witch "Many times."
            witch "Quietly. Carefully. Watching what kind of man you would become in each new life."
            "She pauses again."
            pause 0.2
            scene witchveil11 with dissolve
            witch "I fell in love with each version of you."
            mc "Wait... What?!"
            mc "So... you and me were...lovers?"
            scene witchveil13 with dissolve
            witch "But love is a fragile thing... even for an immortal."
            scene witchveil8 with dissolve
            witch "Eventually, the veil fractured and the world as you know it... became more and more corrupt."
            mc "You mean like Dictonic?"
            witch "I'm talking about weird anomalies, such as the skinwalkers, weird dissapearances, places that should not exist in this world."
            pause 0.2
            witch "You asked what this 'thing' is."
            scene witchveil11 with dissolve
            witch "It is the scar left by my mistakes."
            jump witchreveal
        "­¤Æ¼ Where are we?" if not asked_where:
            scene witchveil3 with dissolve
            $ asked_where = True
            witch "Right now, you're nowhere and everywhere at the same time."
            mc "...What does that even mean?"
            scene witchveil13 with dissolve
            witch "You're between worlds."
            witch "This realm bends for me. It answers to me. The blue light you see... You have seen it before."
            mc "The shack..."
            scene witchveil12 with dissolve
            witch "My threshold. My mark on the places where your world and mine briefly touch."
            mc "Does this mean i'm... you know... dead?"
            scene witchveil10 with dissolve
            witch "You're not dead."
            witch "Not yet."
            jump witchreveal
        "­¤Æ¼ Who are you?" if not asked_who:
            $ asked_who = True
            scene witchveil12 with dissolve
            witch "Mortals have given me many names."
            witch "Witch. Shade. Curse. Guardian. None of them are wrong..."
            pause 0.2
            scene witchveil11 with dissolve
            witch "And none of them are right."
            mc "Then what should I call you?"
            scene witchveil9 with dissolve
            witch "Not my true name."
            mc "Why not?"
            scene witchveil13 with dissolve
            witch "Because names hold weight. A shape. A history."
            witch "And mine was forged long before your world learned to speak."
            mc "That still doesn't tell me who you are."
            scene witchveil9 with dissolve
            witch "If you spoke my name, this realm would shake."
            witch "If you carried it in your heart, it would hollow you."
            mc "So... You're dangerous."
            scene witchveil13 with dissolve
            witch "Names are dangerous, [name]."
            witch "Mine most of all."
            mc "Alright, then who are you to me?"
            scene witchveil12 with dissolve
            witch "The one who refused to let you die."
            witch "In another life... you called me-"
            pause 0.2
            scene witchveil11 with dissolve
            witch "Beloved."
            witch "But the name you once whispered? It has long since been forgotten."
            jump witchreveal
        "­¤Æ¼ About midnight." if not asked_midnight:
            $ asked_midnight = True
            scene witchveil3 with dissolve
            witch "She is the part of me that refused to fade."
            mc "What does that mean?"
            scene witchveil13 with dissolve
            witch "Immortality is not strength, [name]. It is weight. And too much weight cracks even the oldest mind."
            witch "When grief grew sharp, when memory grew heavy, when the centuries began to drown me... I tore a fragment of myself free."
            mc "A fragment?"
            scene witchveil12 with dissolve
            witch "My mischief. My warmth. My hope. My hunger for chaos and curiosity."
            witch "Everything I could no longer afford to carry."
            scene witchveil7 with dissolve
            witch "Stored in the safest place I could think of, my familiar."
            mc "So Midnight is... you?"
            scene witchveil12 with dissolve
            witch "A piece of me."
            witch "Pulled from my own shadow and given shape so I would not break."
            mc "Does she know?"
            scene witchveil11 with dissolve
            witch "She knows enough."
            witch "And she fears the rest."
            mc "She's been helping me."
            scene witchveil12 with dissolve
            witch "Of course she has. My fragment always adored you."
            mc "...Adored?"
            witch "If I loved you in every lifeŌĆö"
            witch "ŌĆöthen she loved you in every possibility."
            mc "Does that bother you?"
            scene witchveil11 with dissolve
            witch "Midnight is what remains of the part of me I lost."  
            witch "I do not begrudge her anything."
            jump witchreveal
        "I have no more questions.":
            scene witchveil6 with dissolve
            witch "Then it is goodbye for now."
            mc "What do you mean... goodbye?"
            scene witchveil7 with dissolve
            witch "Our paths will cross again soon."
            witch "When the veil stirs, you will feel it."
            scene black with slow_fade
            $ questlog.StartQuest(quest_explorecity)
            $ current_location = "veil"
            return




    





