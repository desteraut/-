screen workoffice:
    tag workoffice
    $ present = get_characters_at_location("officework")
    add "images/workoffice/officeworkidle.webp"
    on "show" action [Function(renpy.music.play, "audio/office.ogg", loop=True, fadein=0.5), SetVariable("current_location", "officework")]
    if "coworker" in present:
        add "images/workoffice/159.webp"
        imagebutton auto "images/workoffice/judith_%s.png" focus_mask True action Call("judithworking")
