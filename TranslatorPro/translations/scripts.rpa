screen local_nav(hub=None):
    tag localnav
    layer "nav"
    modal False
    
    # Always get fresh values from store
    $ current_hub_live = getattr(renpy.store, "current_hub", None)
    $ current_room = getattr(renpy.store, "current_room", None)
    $ rooms = compound_locations.get(current_hub_live, []) if current_hub_live else []
    
    frame:
        background "#0008"
        xalign 1.0
        yalign 0.5
        vbox:
            spacing 2
            text "Quick Travel" size 22 bold True color "#edff47" xalign 0.5
            add Solid("#fff3", xysize=(240, 1)) 
            for loc_key, screen_name in rooms:
                if loc_key == current_location:
                    continue

                $ loc_obj = globals().get(loc_key)
                if loc_key + "unlocked" in globals() and not globals()[loc_key + "unlocked"]:
                    continue

                $ pretty_name = loc_obj.name if isinstance(loc_obj, Location) else loc_key

                textbutton pretty_name:
                    action [
                        Function(stop_music_on_room_switch, loc_key),
                        SetVariable("current_location", loc_key),
                        SetVariable("current_room", loc_key),
                        Hide("local_nav"),
                        Show(screen_name),
                    ]


screen local_nav_button_inline(tooltip_var="tooltip", tooltip_pos_var="tooltip_pos", tooltip_portrait_var="tooltip_portrait"):
    imagebutton auto "images/gui/localnav_%s.png" focus_mask True style "uibutton":
        action ToggleScreen("local_nav")
        hovered [
            SetScreenVariable(tooltip_var, "Local Navigation"),
            SetScreenVariable(tooltip_pos_var, renpy.get_mouse_pos()),
        ]
        unhovered [
            SetScreenVariable(tooltip_var, None),
            SetScreenVariable(tooltip_portrait_var, None),
        ]

