    def get_staff_efficiency():
        # Returns total efficiency (sum of ratings)
        total = 0
        for s in store.cafe_staff:
            for c in staff_candidates:
                if c["name"] == s:
                    total += c["rating"]
        return total

    def get_staff_salary():
        # Returns total salary cost
        total = 0
        for s in store.cafe_staff:
            for c in staff_candidates:
                if c["name"] == s:
                    total += c["salary"]
        return total

