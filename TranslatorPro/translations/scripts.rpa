screen unskippable_movie(moviefile, duration):
    zorder 500
    add Movie(play=moviefile, loop=False, channel="movie", size=(1920, 1080))
    timer duration action Hide("unskippable_movie")

screen looped_adult_movie(moviefile, min_duration=8.0):
    zorder 500
    default can_skip = False
    add Movie(play=moviefile, loop=True, channel="movie", size=(1920, 1080))
    timer min_duration action SetScreenVariable("can_skip", True)
    if can_skip:
        key "mouseup_1" action Hide("looped_adult_movie")

screen nav_buttons_overlay():
    
    zorder 300
    if hasattr(store, "current_room"):
        $ _dummy = current_room
    if hasattr(store, "current_hub"):
        $ _dummy2 = current_hub
    default tooltip = None
    default tooltip_portrait = None
    default tooltip_pos = (0, 0)

    $ block_worldmap = getattr(renpy.store, 'block_worldmap', False)
    $ calendar_obj = renpy.store.calendar if hasattr(renpy.store, 'calendar') else None
    $ get_tooltip_func = GetTooltip if 'GetTooltip' in globals() else None

    fixed:
        xalign 1.0
        yalign 0.0
        xoffset -10
        yoffset 6

        hbox:
            xalign 1.0
            yalign 0.0
            spacing 10
            # ----------------------------
            #     LOCAL NAV (conditional)
            # ----------------------------
            if should_show_local_nav() and not renpy.get_screen("worldmap"):
                use local_nav_button_inline("tooltip", "tooltip_pos", "tooltip_portrait")

            # ----------------------------
            #       INVENTORY
            # ----------------------------
            imagebutton auto "images/gui/basket_%s.png" focus_mask True action ToggleScreen("inventory") style "uibutton":
                hovered [
                    SetScreenVariable("tooltip", "Inventory"),
                    SetScreenVariable("tooltip_pos", renpy.get_mouse_pos()),
                ]
                unhovered [
                    SetScreenVariable("tooltip", None),
                    SetScreenVariable("tooltip_portrait", None)
                ]

            # ----------------------------
            #        QUEST LOG
            # ----------------------------
            imagebutton auto "images/gui/menuList_%s.png" focus_mask True action ToggleScreen("myquests") style "uibutton":
                hovered [
                    SetScreenVariable("tooltip", "Quests"),
                    SetScreenVariable("tooltip_pos", renpy.get_mouse_pos()),
                ]
                unhovered [
                    SetScreenVariable("tooltip", None),
                    SetScreenVariable("tooltip_portrait", None)
                ]

            # ----------------------------
            #       SKIP 1 HOUR
            # ----------------------------
            if calendar_obj and hasattr(calendar_obj, 'addtime'):
                imagebutton auto "images/gui/fastForward_%s.png" focus_mask None action Function(calendar_obj.addtime, 60) style "uibutton":
                    hovered [
                        SetScreenVariable("tooltip", "Skip 1 hour"),
                        SetScreenVariable("tooltip_pos", renpy.get_mouse_pos()),
                    ]
                    unhovered [
                        SetScreenVariable("tooltip", None),
                        SetScreenVariable("tooltip_portrait", None)
                    ]

            # ----------------------------
            #    WORLD MAP
            # ----------------------------
            if block_worldmap:
                imagebutton auto "images/gui/door_%s.png" focus_mask True action None style "uibutton":
                    hovered SetScreenVariable("tooltip", "Check PC first.")
                    unhovered SetScreenVariable("tooltip", "")
            else:
                imagebutton auto "images/gui/door_%s.png" focus_mask True style "uibutton":
                    action [
                        Show("date_overlay"),
                        If(
                            current_location in [m[2] for m in worldmap_markers_desert],
                            ToggleScreen("desertmap"),
                            ToggleScreen("worldmap")
                        )
                    ]
                    hovered [
                        SetScreenVariable("tooltip", "Worldmap"),
                        SetScreenVariable("tooltip_pos", renpy.get_mouse_pos()),
                    ]
                    unhovered [
                        SetScreenVariable("tooltip", None),
                        SetScreenVariable("tooltip_portrait", None),
                    ]

            # ----------------------------
            #         PHONE
            # ----------------------------
            imagebutton auto "images/gui/phone_%s.png" focus_mask True action Show("phone_popup") style "uibutton":
                hovered [
                    SetScreenVariable("tooltip", "Phone"),
                    SetScreenVariable("tooltip_pos", renpy.get_mouse_pos()),
                ]
                unhovered [
                    SetScreenVariable("tooltip", None),
                    SetScreenVariable("tooltip_portrait", None)
                ]


    # Tooltip + midnight stuff
    use global_tooltip(tooltip, tooltip_portrait)
    use midnight_popup_manager

screen game_overlay():
    zorder 100

    # Check both dialogue and if we're in a transition/scene
    $ in_transition = (renpy.get_mode() != "screen")
    $ hud_visible = not dialogue_active and not in_transition

    fixed at ui_fade(1.0 if hud_visible else 0.0):
        use nav_buttons_overlay
        use date_overlay




    

screen patch_notes_screen():
    tag menu
    add get_splash_image()
    add Solid("#0008")

    frame:
        align (0.5, 0.5)
        background Frame("gui/dialoguebox.png", 40, 40)
        xsize 950
        ysize 700
        padding (40, 40)

        vbox:
            spacing 20

            text "Patch Notes v[config.version]" size 32 color "#82a1ff" xalign 0.5

            viewport:
                draggable True
                mousewheel True
                yinitial 0.0

                vbox:
                    spacing 15
                    text u"ŌĆó Story Progression." size 20 color "#ffd000"
                    text u"     - Added 2 new main quests for Act III."
                    text u"     - Added 4 new custom voice overs for the AI."
                    text u"     - Added 1 new gallery entry for Mai with a new animation."
                    text u"     - Added 1 new gallery entry for Karen."
                    text u"     - Added 1 new NPC and location: Karen at the Shack shack."

                    #text u"ŌĆó Midnight's Mischief." size 20 color "#8b0097"

                    text u"ŌĆó System Updates & Quality of Life." size 20 color "#82d1ff"

        
                    text u"ŌĆó Balance & Fixes." size 20 color "#00ff0d"
                    text u"     - Fixed a crash caused by the content filters silently corrupting the call stack after the v2.7.x changes."
                    text u"     - Fixed a UI conflict causing a crash when the worldmap is hovered while trying to answer incoming calls."
                    text u"     - Fixed an issue with floaters disapearing off the screen after longer sessions."
                   
            textbutton "Back" action [Hide("patch_notes_screen"), ShowMenu("splash_menu")] xalign 0.5


screen splash_menu():
    tag menu
    add get_splash_image()
    on "show" action SetVariable("in_game_flag", False)
    on "show" action Function(renpy.music.play, "audio/splashscreen.ogg", loop=True, fadein=0.5)
    on "hide" action Function(renpy.music.stop, fadeout=0.5)
    imagebutton auto "images/patreon_%s.png" focus_mask True action OpenURL("https://www.patreon.com/c/Xeratios")

    vbox:
        align (0.08, 0.7)
        spacing 20

        hbox:
            align (0.25, 0.7)
            spacing 40
            textbutton "New Game" action [SetVariable("in_game_flag", True), Function(renpy.music.stop, fadeout=1.5), Start()]
            textbutton "Load Game" action [SetVariable("in_game_flag", True), Function(renpy.music.stop, fadeout=1.5), ShowMenu("load")]
            textbutton "Patch Notes" action Show("patch_notes_screen")
            textbutton "Settings" action ShowMenu("preferences")
            textbutton "Quit" action Quit(confirm=True)

    text "v[config.version]" size 16 color "#888" xalign 0.01 yalign 0.99


screen patchend():

    tag patch
    zorder 1000
    add "midnight_blink"

    on "show" action Function(renpy.music.play, "audio/splashscreen.ogg", loop=True, fadein=0.5)
    on "hide" action Stop("music", fadeout=0.5)

    frame:
        background None
        xsize 1085
        ysize 430
        xalign 0.5
        yalign 0.65
        xpadding 60
        ypadding 50

        vbox:
            spacing 25
            xalign 0.5
            yalign 0.5

            text "Thank you for playing!" size 48 xalign 0.5 color "#ffffffb4"

            text "End of content for patch v[config.version]" size 24 xalign 0.5 color "#ccccccb4" 

            text "There is still plenty to explore." size 24 xalign 0.5 color "#ccccccb4" 

            null height 20

            hbox:
                spacing 20
                xalign 0.5
                yalign 0.5
                textbutton "Main Menu":
                    xalign 0.5
                    style "midnight_button"
                    action MainMenu()
                textbutton "Continue playing":
                    xalign 0.5
                    style "midnight_button"
                    action Return()
                textbutton "Patreon":
                    xalign 0.5
                    style "midnight_button"
                    action OpenURL("https://www.patreon.com/c/Xeratios")
                


label main_menu:
    if not splash_done:
        $ splash_done = True
        scene black
        call screen splash_menu
    return

label start:
    scene black with slow_fade
    pause 0.5
    "{color=#FF0000}This game contains adult themes, strong language, and mature situations intended for audiences aged 18 and over.{/color}"
    "By continuing, you confirm that you are at least 18 years old."
    menu:
        "­¤¤ó Continue.":
            jump gameintro
        "­¤ö┤ Leave.":
            return

label gameintro:
    $ save_version = config.version
    play music "audio/living.ogg    "
    scene intro3 with slow_fade
    "You're spending the afternoon at your dad's place."
    "You and your stepmom are waiting on your stepbrother Justin who is late... Again."
    "While we wait, shall we get the introductions over with?"
    scene intro2 with dissolve
    call mc_rename from _call_mc_rename
    "Do you wish to skip to act 2 right away?"
    menu:
        "Skip to Act II.":
            jump devskipact1
        "No, start from the beginning.":
            pass
    scene 223 with dissolve
    call smom_rename from _call_smom_rename
    play sound "audio/phone_vibrate.ogg"
    "You're interrupted by the sound of a phone vibrating."
    scene intro1 with dissolve
    mc "(Ugh, it's not me.)"
    mc "(Guess it's [stepmom_name]'s phone.)"
    scene black with dissolve
    smom "Hello?"
    smom "Police? Yes, this is [stepmom_name]."
    smom "What? No, I don't know where he is."
    scene intro4 with dissolve
    "[stepmom_name] is talking on the phone with what seems to be the police."
    mc "(Oh no, don't tell me...)"
    smom "No, I haven't seen him in a while."
    scene intro5 with dissolve
    smom "Oh god, what did he do this time?"
    mc "(Yup, it's about my stepbrother.)"
    mc "(I guess Justin got himself into trouble again.)"
    play sound "audio/sigh.ogg"
    pause 0.1
    scene intro6 with dissolve
    smom "200 dollars? Seriously?"
    smom "Ughh, fine."
    smom "I'll have [name] come and get him."
    scene 223 with dissolve
    smom "Hey [name], can you do me a favor?"
    mc "What is it?"
    scene 221 with dissolve
    smom "Can you go to the police station?"
    smom "They just called, Justin got arrested again."
    mc "You're kidding. What did he do this time?"
    smom "He got caught with some stolen weed."
    smom "Apparently he tried to talk his way out of it, but... well, you know Justin."
    mc "Ugh.. Will he ever learn?"
    scene 223 with dissolve
    smom "I don't know honey, but your dad's still at work, and I can't leave the house right now."
    smom "Here honey, take this to get him out."
    $ bag.earn(200)
    mc "*sighs*"
    mc "I guess I'll go then."
    smom "Bring him home right away!"
    mc "Alright."
    mc "(Somehow I always end up cleaning up Justin's messes...)"
    mc "(Mom's going to love hearing about this when I get homeŌĆ”)"
    $ questlog.StartQuest(quest_sbrobail)
    $ policeoutunlocked = True
    "{color=#FFD700}New location unlocked: Police Station{/color}."
    stop music
    scene black with dissolve
    pause 0.5
    play music "audio/worldmap.ogg"
    scene map with dissolve
    mc "This is Brightmoor, I've lived here for 18 years now. I go to school here, and after my mom and dad divorced he moved out and came to live with the lady who is now my stepmom."
    mc "A lot has happened since then, but there isn't any bad blood between them anymore. Though... Mom still struggles with her drinking sometimes."
    play sound "audio/sigh.ogg"
    mc "Ugh, I hate it when she drinks."
    mc "Anyway, let's get this over with." 
    mc "Let's go to the police station."
    $ calendar.addtime(60)
    $ stephomeunlocked = True
    $ current_location = None
    jump game_loop

# --- Dev skips ---

label devskipact1:
    $ devskipact1_used = True
    # world state
    $ aftermath = True
    $ momdrunk = True
    $ has_car = True
    $ desert_dinerunlocked = True
