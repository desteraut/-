init python:
    def unlock_all_locations():
        for entry in store.worldmap_markers:
            loc = entry[2]  # 3rd element is the loc_key (e.g. "mall", "school")
            flag = f"{loc}unlocked"
            if hasattr(store, flag):
                setattr(store, flag, True)

