# --- BRENDA ---
label brenda_dictonicexpose(call=None):
    hide screen phone_popup
    hide screen phone_contacts
    scene mccall with dissolve
    brenda "[name], come by my house as soon as you can."
    brenda "I got something on that boss of yours."
    mc "Got it, I'll see you soon."
    $ questlog.StartQuest(quest_dictonictalk)
    return

label brenda_incoming_call(call=None):
    if quest_mayormeeting3.completed:
        hide screen phone_popup
        hide screen phone_contacts
        scene mccall with dissolve
        brenda "Hello [name], it's Brenda."
        mc "Hey Brenda, what's up?"
        brenda "I'm calling to let you know that I spoke to my husband."
        brenda "He agreed to retract the permit for the coffeeshop."
        mc "That's great news! Thank you so much."
        brenda "You kept your end of the deal, so I kept mine."
        mc "Elke will be happy to hear that the coffeeshop will be shutting down soon."
        brenda "Wait..."
        brenda "Claire? The coffeeshop owner?"
        mc "Yes, that one."
        brenda "You're doing this to sabotage her?"
        mc "Well..."
