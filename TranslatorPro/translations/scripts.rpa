label cuckoocuffs:
    scene black with fade
    $ cuckoocuffs_unlocked = True
    "You're wandering through the mall when you hear a familiar voice shouting from the electronics store."
    "And groaning. Lots of groaning."
    scene robertdemon1 with dissolve
    "You peek inside."
    rob "Ladies and gentlemen, may I have your attention, please!"
    rob "Today, I present to you the future of law enforcement... bedroom-style!"
    "You already regret stopping."
    scene robertdemon2 with dissolve
    rob "Introducing... the Cuckoo Cuffs!"
    "He holds up a pair of fuzzy handcuffs like they're the Ark of the Covenant."
    rob "No key. No app. Just a simple, elegant safeword: 'Cuckoo.'"
    "He slaps the cuffs onto his own wrists with dramatic flair."
    rob "ObserveŌĆösecure and locked. Now watch the magic."
    rob "CUCKOO!"
    "Nothing happens."
    scene robertdemon3 with vpunch
    "He glances at the cuffs. Tugs once. Nothing."
    rob "CUCKOO! CUCKOOOO!"
    "He flaps his arms wildly like an injured bird."
    "Some shoppers are already giggling. A few are recording."
    scene olddemon1 with dissolve
    "An old man walks by behind the crowd, squinting at his shopping list."
    idk "Let's see... pasta, mayo, onions, tofu..."
    pause 0.5
    "The cuffs click open."
    scene maidemon3 with dissolve
    rob "...Tofu?"
    rob "Not Cuckoo?"
    "He looks down at the cuffs, utterly betrayed."
    mai "I'm going to fake my own death."
    "She mutters into her hand while you hear Robert clanking behind her."
    rob "I-uhh..."
    scene officerdemon1 with dissolve
    "A nearby police officer strolls in, chewing gum and clearly amused."
    rob "Officer! I'm demonstrating a product here!"
    pclerk "Is that what this is?"
    mai "Product? More like you were making a fool out of yourself."
    scene robertdemon5 with dissolve
    mai "Another one of your inventions, is it."
    rob "Look honey, they just need a drip of oil. Honest!"
    mai "No, *you* need a drip of oil, you lunatic."
    scene black with slow_fade
    "You back away slowly as the store erupts in laughter."
    mc "(These cuffs sound like the perfect gift for Tim.)"
    mc "(Maybe I should talk to Robert and buy him a pair...)"
    $ questlog.StartQuest(quest_buycuckoo)
    return

Made with Ren'Py.# Helper to calculate a date N days in the future
init python:
    def get_future_date(days_to_add):
        import renpy.store as store
        day = store.calendar.day
        month = store.calendar.month
        year = store.calendar.year
        days_in_month = store.calendar.days_count
        day += days_to_add
        while day > days_in_month[month]:
            day -= days_in_month[month]
            month += 1
            if month > 12:
                month = 1
                year += 1
        return day, month, year

screen mayorhouse:
    tag mayorhouse
    $ present = get_characters_at_location("mayorhouse")
    on "show" action [Function(renpy.music.play, "audio/suburban.ogg", loop=True, fadein=0.5), SetVariable("current_location", "mayorhouse")]
    add "images/mayorshouse/mayorhousebg.png"
    if "brenda" in present and not brenda_departed:
        imagebutton auto "images/mayorshouse/brenda_%s.png" focus_mask True action Function(renpy.music.stop, fadeout=0.5), Call("brendatalk")
    else:
        imagebutton auto "images/mayorshouse/door_%s.png" focus_mask True action Function(renpy.music.stop, fadeout=0.5), Call("mayorleave2")


