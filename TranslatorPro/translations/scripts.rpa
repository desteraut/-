label churchclosed:
    hide screen worldmap
    scene churchpray4 with dissolve
    nun "Hey [name], I'm gonna have to ask you to leave now."
    nun "Come back later, alright?"
    show screen worldmap
    return

                               

    Made with Ren'Py.

screen cityhall:
    tag cityhall
    $ present = get_characters_at_location("cityhall")
    add "images/cityhall/253.webp"
    on "show" action [Function(renpy.music.play, "audio/cityhall.ogg", loop=True, fadein=0.5), SetVariable("current_location", "cityhall")]
    if "mayorsec" in present:
        imagebutton auto "images/cityhall/mayorsec_%s.png" focus_mask True action Call("mayorsecmenu")
    imagebutton auto "images/cityhall/elevator_%s.png" focus_mask True style "worldbutton" action Call("parkinglot2")


screen mayorsoffice:
    tag cityhall
    $ present = get_characters_at_location("cityhall")
    add "images/cityhall/mayor_office.webp"
    on "show" action [Function(renpy.music.play, "audio/mayorsoffice.ogg", loop=True, fadein=0.5), SetVariable("current_location", "mayorsoffice")]
    if "mayor" in present:
        imagebutton auto "images/cityhall/mayor_%s.png" focus_mask True action Call("mayortalk")



label mayorsecmenu:
    scene 256 with dissolve
    $ havemet_mayorsec = True
    mayorsec "Hi sir!"
    mayorsec "What can I do for you?"
    if quest_exposed12 in questlog.quest_list and calendar.day > quest_exposed12.start_day:
        menu:
            "ŌŁÉ Attend the event.":
                jump publicdebate          
    elif quest_mayormeeting in questlog.quest_list:
        mayorsec "You go on right ahead, I need to be somewhere else."
        "She leaves in a rush."
        mc "Guess I'm in luck..."
        jump mayormeeting
    elif quest_cshophelp5 in questlog.quest_list:
        menu:
            "ŌŁÉ I wish to speak to the mayor.":
                jump mayorsecmenu1
            "I'm just looking around.":
                jump mayorsecmenu2
            "Nevermind.":
                return
    elif quest_cshophelp in questlog.quest_list:
        menu:
            "ŌŁÉ About a permit.":
                jump permitrequest
            "I'm just looking around.":
                jump mayorsecmenu2
            "Nevermind.":
                return
    else:
        menu:
            "I would like to talk to the mayor.":
                jump mayorsecmenu1
            "I'm just looking around.":
                jump mayorsecmenu2
            "Ask about the parking lot.":
                jump parkinglot1
            "Nevermind.":
                return

