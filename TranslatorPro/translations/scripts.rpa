        $ gasstationunlocked = True
        $ questlog.EndQuest(quest_visitsmom)
        $ questlog.StartQuest(quest_visitgas)
        return
    if quest_justintrouble in questlog.quest_list:
        scene 221 with dissolve
        smom "Hey [name], have you seen Justin?"
        mc "I haven't, I came by to ask him about his shift."
        mc "Is he not around?"
        scene 223 with dissolve
        smom "He..."
        smom "He didn't come home this morning..."
        mc "(Oh no...)"
        mc "Okay, I'll go over there and find him."
        mc "(Something's wrong. I can feel it.)"
        scene 221 with dissolve
        smom "Thanks sweetie."
        $ smomlove += 2
        $ questlog.StartQuest(quest_gasinvestigate)
        $ questlog.EndQuest(quest_justintrouble)
        return
    if quest_goodbye in questlog.quest_list:
        scene 221 with dissolve
        smom "And?"
        smom "Tell me you found him..."
        mc "I didn't."
        scene 223 with dissolve
        smom "This can't be good."
        mc "I did find some clues... Some very... Unsettling ones."
        smom "...Don't tell me he..?"
        mc "I don't know."
        mc "I will have to go deeper into the desert to find him."
        mc "Everything leads into that direction."
        scene 222 with dissolve
        smom "No you're not going alone!"
        mc "I have to, he is my brother after all."
        scene 221 with dissolve
        smom "Sweetie... That's the first time you didnt call him your step-brother."
        mc "I have to find him, [stepmom_name]."
        mc "All I need is a car."
        scene 223 with dissolve
        smom "Fine."
        smom "I have a friend at the trailer park..."
        smom "I'm not sure if she will be able to lend you a car..."
        smom "But you can try."
        mc "Thanks, [stepmom_name]."
        scene 221 with dissolve
        smom "and [name], please be careful."
        $ questlog.EndQuest(quest_goodbye)
        $ questlog.StartQuest(quest_trailerparkintro)
        $ trailerparkunlocked = True
        return
    else:
        scene 221 with dissolve
        smom "Hey sweetie, what can I do for you?"
        menu:
            "ŌŁÉ Give her a espresso." if havemet_smom and bag.has_item("espresso"):
                scene smomcoffee with dissolve
                smom "Ohh, thank you sweetie!"
                $ bag.remove_item("espresso")
                mc "You're welcome, [stepmom_name]!"
                $ questlog.EndQuest(quest_smomcoffee, calendar.day)
                scene smomcoffee2 with dissolve
