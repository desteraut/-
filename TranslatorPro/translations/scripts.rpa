    def calculate_cafe_day(staff, menu_prices, inventory, marketing, event, upgrade, reputation, base_customers):
        """
        Core calculation shared by both simulate_day and end_day.
        (Replaces previous implementation with robust inventory handling
        and explicit inventory_used + inventory_warning output.)
        """

        results = {
            "customers": 0,
            "served": 0,
            "income": 0.0,
            "costs": 0.0,
            "profit": 0.0,
            "reputation": int(reputation),
            "inventory_used": {},
            "inventory_warning": ""
        }

        # --- Step 1: Customers from reputation + marketing + staff efficiency
        eff = get_staff_efficiency()  # your existing helper (no args)
        if reputation < 20:
            cust = int(base_customers + reputation * 1.0)
        elif reputation < 40:
            cust = int(base_customers + reputation * 2.0)
        else:
            cust = int(base_customers + reputation * 3.0)
        cust = int(cust * (1.0 + 0.1 * eff))
        results["customers"] = cust

        # Marketing effects
        if marketing is not None and marketing != 'None':
            for opt in marketing_options:
                if opt["name"] == marketing:
                    cust += int(opt.get("customers", 0))
                    results["reputation"] += int(opt.get("reputation", 0))
                    results["costs"] += float(opt.get("cost", 0.0))
                    break

        # Event effects
        if event is not None and event != 'None':
            for ev in event_options:
                if ev["name"] == event:
                    cust += int(ev.get("customers", 0))
                    results["reputation"] += int(ev.get("reputation", 0))
                    results["costs"] += float(ev.get("cost", 0.0))
                    break

        # Upgrades (temporary effect if pending)
        if upgrade is not None and upgrade != 'None':
            for up in upgrade_options:
                if up["name"] == upgrade:
                    cust = int(cust * (1.0 + float(up.get("cust_mult", 0.0))))
                    results["costs"] += float(up.get("cost", 0.0))
                    break

        # --- Step 1.5: Price penalty (applies BEFORE inventory check)
        if menu_prices:
            try:
                avg_price = float(sum(menu_prices.values()) / len(menu_prices))
            except Exception:
                avg_price = 2.5
        else:
            avg_price = 2.5

        price_threshold = 5.0
        if avg_price > price_threshold:
            overcharge = avg_price - price_threshold
            penalty_factor = max(0.05, 1.0 - (overcharge * 0.20))  # -20% customers per $1 over
            cust = int(cust * penalty_factor)
            # Optional rep hit
            results["reputation"] = max(0, results["reputation"] - int(overcharge * 2))

        # Cap after penalties
        CAFE_MAX_DAILY_CUSTOMERS = 1000
        cust = min(cust, CAFE_MAX_DAILY_CUSTOMERS)
        results["customers"] = cust

        # --- Step 2: Inventory check (coerce to ints, guard empty dict)
        inv = inventory or {}
        inv_numeric = {}
        for k, v in inv.items():
            try:
                inv_numeric[k] = int(v)
            except Exception:
                try:
                    inv_numeric[k] = int(float(v))
                except Exception:
                    inv_numeric[k] = 0

        # Only ingredients that make one drink
        recipe_items = ["Coffee Beans", "Milk", "Sugar", "Cups"]

        if inv_numeric:
            # Capacity = smallest available stock among the recipe items
            smallest_stock = min(inv_numeric.get(i, 0) for i in recipe_items)
            max_served = min(cust, smallest_stock)
        else:
            max_served = cust

        results["served"] = int(max_served)

        # record per-item usage (1 unit per customer per item, but not exceeding available stock)
        results["inventory_used"] = {}
        for item in recipe_items:
            qty = inv_numeric.get(item, 0)
            used = min(qty, results["served"])
            results["inventory_used"][item] = int(used)

        # inventory warning (only when any tracked item is zero or negative)
        missing_items = [item for item, qty in inv_numeric.items() if qty <= 0]
        if missing_items:
            results["inventory_warning"] = f"Warning: Out of stock for: {', '.join(missing_items)}. Only {results['served']} customers can be served."
        else:
            results["inventory_warning"] = ""

        # --- Step 3: Income
        results["income"] = round(avg_price * results["served"], 2)

        # --- Step 4: Costs (staff salary + inventory cost)
        results["costs"] += float(get_staff_salary())  # your helper expects no args
        inv_cost = 0.0
        for item, used in results["inventory_used"].items():
            inv_cost += float(inventory_prices.get(item, 0.0)) * int(used)
        results["costs"] += round(inv_cost, 2)

        # --- Step 5: Profit
        results["profit"] = round(results["income"] - results["costs"], 2)

        # Ensure numeric types are tidy
        results["income"] = float(round(results["income"], 2))
        results["costs"] = float(round(results["costs"], 2))
        results["profit"] = float(round(results["profit"], 2))

        return results



    def end_cafe_day():
        res = calculate_cafe_day(
            cafe_staff_pending,
            menu_prices_pending,
            cafe_inventory_pending,
            cafe_marketing_pending,
            cafe_event_pending,
            cafe_upgrade_pending,
            cafe_reputation,
            cafe_customers
        )

        # Commit states
        store.cafe_staff = list(cafe_staff_pending)
        store.menu_prices = dict(menu_prices_pending)
        store.cafe_inventory = {k: max(0, v - res["inventory_used"].get(k, 0)) for k, v in cafe_inventory_pending.items()}
        store.cafe_marketing = cafe_marketing_pending
        store.cafe_event = cafe_event_pending
        store.cafe_upgrade = cafe_upgrade_pending

        # Update money, rep, profit
        store.cafe_money_pending += res["profit"]
        store.cafe_profit = res["profit"]
        store.cafe_income = res["income"]
        store.cafe_costs = res["costs"]
        store.cafe_reputation = res["reputation"]

        return res

    def finalize_inventory():
        global cafe_inventory, cafe_inventory_pending, cafe_money, cafe_money_pending
        cafe_inventory.clear()
        cafe_inventory.update(cafe_inventory_pending)
        cafe_money = cafe_money_pending

    def use_inventory(item, amount):
        if cafe_inventory_pending[item] >= amount:
            cafe_inventory_pending[item] -= amount
            return True
        else:
            renpy.notify(f"Not enough {item} in stock!")
            return False

    def get_cafe_owner():
        if sidedwithclaire:
            return "Claire (Owner)"
        else:
            return "Elke (Owner)"

    def get_candidates():
        return [c for c in staff_candidates if c["name"] == get_cafe_owner() or "Owner" not in c["name"]]

init python:
    import renpy
    import renpy.store as store

    def declare_insolvency():
        import renpy.store as store

        # Reset money
        store.cafe_money = 5000
        store.cafe_money_pending = 5000

        # Reset reputation
        store.cafe_reputation = 5

        # Clear debt
        store.cafe_debt = 0

        # Reset upgrades
        store.bought_upgrades = []
        store.cafe_upgrade = "None"
        store.cafe_upgrade_pending = "None"

        # Reset staff
        owner = get_cafe_owner()
        store.cafe_staff = [owner]
        store.cafe_staff_pending = [owner]

        # Reset inventory
        base_inventory = {
            "Coffee Beans": 50,
            "Milk": 25,
            "Sugar": 15,
            "Cups": 100,
        }
        store.cafe_inventory = dict(base_inventory)
        store.cafe_inventory_pending = dict(base_inventory)

        renpy.notify("Caf├® operations have been restructured.")
        renpy.restart_interaction()

    def trigger_bankruptcy_recovery():
        store.cafe_auto_mode = False

        bailout_amount = 500

        store.cafe_money_pending = round(store.cafe_money_pending + bailout_amount, 2)
        store.cafe_money = store.cafe_money_pending

        # Add debt
        store.cafe_debt += bailout_amount

        # Reputation penalty
        store.cafe_reputation = max(0, store.cafe_reputation - 5)

        store.show_floater("­¤Å” Emergency Loan +$500", "#ffaa00")
        store.show_floater("­¤ōē Reputation -5", "#cc0000")
        store.show_floater("­¤Æ│ Debt +$500", "#ff5555")

        renpy.notify("The bank steps in. Debt must be repaid.")
        renpy.restart_interaction()

    def _finalize_cafe_day():
        
        # Snapshot pending BEFORE finalize so we can consume from what player actually stocked
        pre_pending = dict(getattr(store, "cafe_inventory_pending", {}))

        # Snapshot money to detect whether end_cafe_day() already applied profit
        old_pending_money = float(getattr(store, "cafe_money_pending", 0.0))

        # Run canonical finalizer
        res = end_cafe_day()
        # --- Bankruptcy Protection (Liquidity Floor: 200) ---
        projected_money = round(old_pending_money + res.get("profit", 0.0), 2)

        if projected_money < 200:
            trigger_bankruptcy_recovery()
            return
        # Normalize numeric results
        income = round(res.get("income", 0.0), 2)
        costs  = round(res.get("costs",  0.0), 2)
        profit = round(res.get("profit", 0.0), 2)
        if cafe_auto_mode:
            profit = round(profit * 0.75, 2)
        served = int(res.get("served", 0))
        rep    = int(res.get("reputation", getattr(store, "cafe_reputation", 0)))

        # Ensure we have inventory_used; if not, recompute from the pre-finalize snapshot
        inv_used = res.get("inventory_used") or {}
        if not inv_used:
            try:
                recompute = calculate_cafe_day(
                    store.cafe_staff_pending,
                    store.menu_prices_pending,
                    pre_pending,
                    store.cafe_marketing_pending,
                    store.cafe_event_pending,
                    store.cafe_upgrade_pending,
                    store.cafe_reputation,
                    store.cafe_customers
                )
                inv_used = recompute.get("inventory_used", {})
                served = recompute.get("served", served)
            except Exception:
                inv_used = {}

        # --- Consume inventory ---
        new_stock = dict(pre_pending)
        for item, used in (inv_used or {}).items():
            try:
                new_stock[item] = max(0, int(new_stock.get(item, 0)) - int(used))
            except Exception:
                pass

        store.cafe_inventory = dict(new_stock)
        store.cafe_inventory_pending = dict(new_stock)

        # Write results for UI
        store.cafe_income     = income
        store.cafe_costs      = costs
        store.cafe_profit     = profit
        store.cafe_customers  = served
        store.cafe_reputation = rep

        # ----- MONEY HANDLING (float-safe) -----
        new_pending_money = float(getattr(store, "cafe_money_pending", old_pending_money))
        if abs(new_pending_money - old_pending_money) < 0.005:
            new_pending_money = old_pending_money + profit

        # Clamp everything to 2 decimals
        new_pending_money = round(new_pending_money, 2)
        store.cafe_money_pending = new_pending_money
        store.cafe_money = new_pending_money
        store.cafe_profit = round(profit, 2)
        # ---------------------------------------

        # Player cut (10% of profit) once
        if profit > 0:
            player_cut = int(round(profit * 0.10))

            # If in debt, reduce player income
            if store.cafe_debt > 0:
                repayment = min(player_cut, store.cafe_debt)
                store.cafe_debt -= repayment
                player_cut -= repayment

                store.show_floater(f"­¤Æ│ Loan Payment -${repayment:,}", "#ff5555")

            if player_cut > 0:
                store.bag.earn(player_cut)
                store.show_floater(f"ŌśĢ You +${player_cut:,}", "#0066cc")

        # Caf├® result floater
        if profit > 0:
            store.show_floater(f"ŌśĢ Caf├® +${profit:,.2f}", "#009900")
        elif profit < 0:
            store.show_floater(f"ŌśĢ Caf├® -${abs(profit):,.2f}", "#cc0000")

        # Clear/propagate inventory warning text if present
        if "inventory_warning" in res:
            persistent.inventory_empty_warning = res.get("inventory_warning") or ""

        # Lock in result view
        store.last_end_day = store.calendar.day
        store.persistent.end_day_results_shown = True
        if "quest_gardenmanagement" in globals():
            try:
                questlog.EndQuest(quest_gardenmanagement, store.calendar.day)
            except Exception as e:
                renpy.log(f"Quest end failed: {e}")
        # Refresh UI
        renpy.restart_interaction()





       

