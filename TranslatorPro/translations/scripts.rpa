                                    unlocked_pictures.append(img)
                        "New photos were added to your phone's gallery."
                        $ mathpicsunlocked = True
                        return
            else:
                scene studio6 with dissolve
                mc "I can't afford that."
                scene studio7 with dissolve
                photolady "Alright if you change your mind, come see me."
                mc "Alright."
                return
        "Nevermind.":
            return

label mairepair:
    if quest_aioverride in questlog.quest_list:
        scene aimai1 with dissolve
        "Mai and Robert seem to be in the middle of an argument as you walk in."
        rob "But butterfly, I swear... It worked when I made it."
        mai "That's your problem, it always works once and it doesn't when it counts."
        scene aimai2 with dissolve
        mc "Uhh, guys have you got a minute?"
        mc "It's kind of important."
        mai "Oh hey [name], what's up?"
        scene black with fade
        "You quickly explain everything to Mai and Robert. the bunker, the hidden server room, and the artificial intelligence locked inside."
        pause 1.0
        scene aimai3 with dissolve
        mai "Wait, hold up. You're saying you broke your way into some kind of hidden server room with a live A.I?"
        rob "Curious..."
        mc "We were trying to ask questions but it denied us access. I was wondering if you guys could help us get in."
        scene aimai4 with dissolve
        rob "This sounds like a bad idea, kid."
        mai "What do you know about bad ideas, Robert? Every idea you've ever had was a bad one."
        scene aimai5 with dissolve
        mai "If [name] needs our help, we're going to help. Or have you forgotten what he did for us?"
        rob "..."
        scene aimai6 with dissolve
        rob "Of course, my little strawberry... I was only saying..."
        mai "Start packing stuff, we're leaving right away."
        scene aimai7 with dissolve
        rob "Oh alright..."
        mai "Give us the exact location, we'll prepare everything and meet you there."
        mai "Whatever it is, we'll figure it out."
        mc "Thanks Mai, I appreciate it."
        $ questlog.EndQuest(quest_aioverride)
        $ questlog.StartQuest(quest_meetmaiai)
        $ mailove += 5
        scene black with fade
        pause 0.5
        return
    if quest_phonerepair in questlog.quest_list:
