Made with Ren'Py.init python:

    def content_blocked(tag):
        """
        Returns True if a content type is disabled in preferences.
        tag = "lesbian", "bdsm", "ntr", "bukkake", "drug"
        """
        if tag == "lesbian":
            return not persistent.allow_lesbian
        if tag == "bdsm":
            return not persistent.allow_bdsm
        if tag == "ntr":
            return not persistent.allow_ntr
        if tag == "bukkake":
            return not persistent.allow_bukkake
        if tag == "drug":
            return not persistent.allow_drugs
        if tag == "pregnancy":
            return not persistent.allow_pregnancy
        
        return False
    
    def run_filtered(tag, allowed_label, skip_label):
        """
        If content allowed ŌåÆ jump to the real scene.
        If disabled ŌåÆ jump to a clean alternative.
        """
        if content_blocked(tag):
            renpy.call(skip_label)
        else:
            renpy.call(allowed_label)Made with Ren'Py.default posternoticed = False
default talkedtodad = False

screen barscreen:
    tag bardrink
    $ present = get_characters_at_location("bar")
    if quest_findtim.completed_day == store.calendar.day:
        add "images/bar/timgfbf.png"
    else:
        add "images/bar/barbg.png"
    on "show" action [Function(renpy.music.play, "audio/bar.ogg", loop=True, fadein=0.5), SetVariable("current_location", "bar")]
    if "barkeep" in present:
        imagebutton auto "images/bar/barkeep_%s.png" focus_mask True action Call("barkeepdialogue")
    if "mom" in present and "mombf" in present and mom_spirit_done:
        imagebutton auto "images/bar/momelke_%s.png" focus_mask True action Call("mombardialogue")
    if not brendatakeover and not quest_findtim in questlog.quest_list:
        imagebutton auto "images/bar/brenda_%s.png" focus_mask True action Call("brendabardialogue")
    if askeddean:
        imagebutton auto "images/bar/poster_%s.png" focus_mask True action Call("posternotice")
    if "smom" in present and quest_startjazz.completed and calendar.can_perform_action("jazzperform"):
        imagebutton auto "images/bar/smom_%s.png" focus_mask True action Call("smombardialogue")
    if "dad" in present:
        imagebutton auto "images/bar/dad_%s.png" focus_mask True action Call("dadbardialogue")
    imagebutton auto "images/bar/door_%s.png" focus_mask True style "worldbutton" action [Hide("barscreen"), Show("worldmap")]


