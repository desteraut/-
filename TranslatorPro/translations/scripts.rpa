                    "title": "Make someones day by giving them a little extra.",
                    "desc": "Midnight dares you to enhance someone's coffee.",
                    "tier": 1,
                    "loc_key": "gstore",
                    "timeband": "any",
                    "requirements": ["gstoreunlocked"],
                    "reward_points": 25,
