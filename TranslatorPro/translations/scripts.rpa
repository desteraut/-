    $ present = get_characters_at_location("desert_military")
    on "show" action [Function(renpy.music.play, "audio/military.ogg", loop=True, fadein=0.5), SetVariable("current_location", "desert_military")]
    if get_time_of_day() == "night" or get_time_of_day() == "evening":
        add "images/desert/military/militarybasenight.png"
        imagebutton auto "images/desert/military/keypadnight_%s.png" focus_mask True action Call("jaildoor")
        if not bag.has_item(keycard) and quest_findkeycard in questlog.quest_list:
            imagebutton auto "images/desert/military/cratesnight_%s.png" focus_mask True action Call("cratecheck")
    else:
