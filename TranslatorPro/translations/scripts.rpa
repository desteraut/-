                    bff "It's better to let them keep pretending."
                    mc "Hmmmm..."
                    mc "(I wonder if Mrs. Brown would tell me what's going on...)"
                    $ questlog.EndQuest(quest_asktim)
                    $ questlog.StartQuest(quest_askthedean)
                    return
                "ŌØż’ĖÅ Sure, let's hang out.":
                    scene bffhome02 with dissolve
                    bff "Awesome!"
                    bff "Let's play some games."
                    mc "Sure, let's do it."
                    scene bffhome04 with dissolve
                    "You and Tim spend some time playing video games."
                    "You have a lot of fun and forget about your worries for a while."
                    "You lost, and he made sure to rub it in your face."
                    $ calendar.addtime (120)
                    $ bfflove += 5
                    return
                "­¤Äü Gift cuckoo cuffs." if quest_givecuckoo in questlog.quest_list and bag.has_item(cuckoocuffs):
                    scene bffhome02 with dissolve
                    mc "Hey Tim, I got you something."
                    $ bag.remove_item(cuckoocuffs)
                    "You give Tim the cuckoo cuffs you found at the police station."
                    mc "It's a gag-"
                    scene bffhome03 with dissolve
                    bff "Bro, these are awesome!"
                    bff "My girlfriend will love these!"
                    mc "But they're-"
                    scene bffhome04 with dissolve
