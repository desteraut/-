    play sound "audio/crowdlaugh.ogg"
    scene jazz5 with dissolve
    bff "I would be stuck on there aswell, my poor nerves..."
    laura "Don't be silly, love."
    laura "We all know you'd run out of here faster than anyone can say 'Jazz'"
    bff "Seriously?!"
    bffmom "Haha, you know I like her already!"
    scene pianist with dissolve
    "After a short while, the pianist finally takes his place behind the piano."
    pause 0.5
    scene jazz3 with dissolve
    mc "Alright, it's starting."
    play music "audio/smomjazz.ogg"
    mc "Oh god, why am I so nervous?"
    mom "Because you want her to succeed, sweetie."
    pause 7.0
    scene pianist4 with dissolve
    pause 7.0
    scene jazz8 with dissolve
    "The room grows quieter, like everyone leaned in at once."
    pause 5.5
    scene jazz10 with dissolve
    pause 7.5
    scene jazz11 with dissolve
    pause 6.0
    scene pianist2 with dissolve
    pause 5.0
    scene jazz3 with dissolve
    mombf "She sounds completely at ease up there."
    pause 6.5
    scene jazz9 with dissolve
    pause 7.0
    scene pianist4 with dissolve
    pause 6.0
    scene jazz11 with dissolve
    pause 5.5
    scene jazz12 with dissolve
    pause 7.0
    scene pianist2 with dissolve
    pause 7.0
    scene pianist3 with dissolve
    pause 7.0
    scene pianist4 with dissolve
    pause 7.0
    scene pianist5 with dissolve
    "For a moment, nothing else in the room seems to matter."
    pause 5.0
    scene jazz11 with dissolve
    pause 7.0
    scene pianist2 with dissolve
    pause 7.0
    scene jazz3 with dissolve
    pause 7.0
    scene jazz9 with dissolve
    pause 7.0
    stop music fadeout 1.5
    scene jazz12 with dissolve
    smom "Thank you, Brightmoor!"
    pause 2.0
    play sound "audio/applause.ogg"
    scene black with slow_fade
    mc "(That was incredible!)"
    mc "(I should go check on her.)"
    $ _skipping = True
    $ jazzperformance_done = True
    $ changingroomunlocked = True
    $ questlog.StartQuest(quest_visitchangingroom)
    return
