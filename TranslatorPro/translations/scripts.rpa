screen inventory():
    tag inventory
    zorder 200

    $ in_transition = (renpy.get_mode() != "screen")
    $ should_hide = dialogue_active or in_transition

    fixed at ui_fade(0.0 if should_hide else 1.0):
        frame:
            style "overlay_bg"
            xalign 0.5
            yalign 0.5
            padding (30, 40)

            vbox:
                spacing 30

                # --- Title row ---
                vbox:
                    xalign 0.5
                    spacing 10

                    hbox:
                        xalign 0.5
                        spacing 12
                        text "­¤Æ╝" size 36
                        text "Inventory" size 32

                    add Solid("#ffffff40", xysize=(600, 1)) xalign 0.5

                
                # --- Content ---
                if bag.items:
                    $ item_counts_list = bag.get_item_counts()

                    viewport:
                        xmaximum 700
                        ymaximum 360
                        mousewheel True
                        draggable True
                        scrollbars None
                        xalign 0.5
                        xinitial 0.5
                        vbox:
                            xalign 0.5
                            xfill False
                            xsize 700
                            # --- Content area: Items + Quantities ---
                            hbox:
                                spacing 40
                                xalign 0.5
                                # --- Quantities Column ---
                                vbox:
                                    spacing 12

                                    text "Qty" size 22 color "#ffffffaa" bold True xalign 0.5

                                    for item, count in item_counts_list:
                                        text "[count]" size 24 xalign 0.5

                                # --- Vertical Divider ---
                                add Solid("#ffffff20", yfill=True, xsize=3)

                                # --- Item Names Column ---
                                vbox:
                                    spacing 12

                                    text "Item" size 22 color "#ffffffaa" bold True xalign 0.0

                                    for item, count in item_counts_list:

                                        hbox:
                                            spacing 10
                                            yalign 0.5

                                            $ icon = item.get_icon()

                                            if item.name == "Embarrassing pictures of Mr. Mayor":
                                                text icon
                                                textbutton item.name action [
                                                    Hide("inventory"),
                                                    SetVariable("pending_inventory_action", "show_embpics_slideshow"),
                                                    Call("inventory_dispatch")
                                                ] style "inv_clickable_button" text_size 24 xalign 0.0


                                            elif item.name == "Note in latin":
                                                text icon
                                                textbutton item.name action [
                                                    Hide("inventory"),
                                                    SetVariable("pending_inventory_action", "show_notes"),
                                                    Call("inventory_dispatch")
                                                ] style "inv_clickable_button" text_size 24 xalign 0.0

                                            elif item.name == "School pass":
                                                text icon
                                                textbutton item.name action [
                                                    Hide("inventory"),
                                                    SetVariable("pending_inventory_action", "show_schoolpass_info"),
                                                    Call("inventory_dispatch")
                                                ] style "inv_clickable_button" text_size 24 xalign 0.0

                                            else:
                                                text icon
                                                text item.name size 24 xalign 0.0

label inventory_dispatch:
    if store.pending_inventory_action:
        $ lbl = store.pending_inventory_action
        $ store.pending_inventory_action = None
        call expression lbl from _call_expression_6
    return


init python:
    import datetime

    def date_from_completed_day(day):
        if day is None:
            return "ŌĆö"

        # Game start date from your calendar defaults
        start_date = datetime.date(
            calendar.year,
            calendar.month,
            1
        )

        real_date = start_date + datetime.timedelta(days=day)

        return real_date.strftime("%B %d, %Y")


