label game_loop:
    while True:
        show screen game_overlay

        if current_location is None:
            call screen worldmap
            jump game_loop

        if handle_special_travel(current_location):
            jump game_loop
        $ check_event()

        $ loc = current_location
        $ location_data = get_location_data(loc)

        if not location_data:
            "ERROR: Unknown location [loc]"
            $ current_location = "stephome"
            jump game_loop
        else:
            $ screen_name = location_data.get("screen_name")

            if screen_name:
                call screen expression screen_name
                if current_location == "spiritrealm" and _return:
                    call expression f"spiritarc_{_return}" from _call_expression_8
                jump game_loop
            else:
                "ERROR: No screen for location [loc]"
                $ current_location = "stephome"
                jump game_loop




