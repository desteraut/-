init python:
    DAY_NAMES = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"]
    DAY_ABBR  = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"]
    DAY_INDEX = {name:i for i,name in enumerate(DAY_NAMES)}

    def normalize_day(day):
        # Accept int 0..6, "Mon", "Monday"
        if isinstance(day, int):
            return DAY_NAMES[day % 7]
        if day in DAY_NAMES:
            return day
        if day in DAY_ABBR:
            return DAY_NAMES[DAY_ABBR.index(day)]
        return str(day)

    def normalize_period(p):
        return (p or "").strip().lower()

    def day_variants(day):
        """Try a few representations for dict lookups."""
        dn = normalize_day(day)
        di = DAY_INDEX.get(dn, None)
        ab = DAY_ABBR[di] if di is not None else None
        variants = [dn]
        if ab: variants.append(ab)
        if di is not None: variants.append(di)
        return variants

    def resolve_location(character, day, hour, schedules, hourly, default="unknown", tod_override=None):
        import renpy.store as store
        dn = normalize_day(day)
        tod = normalize_period(tod_override) if tod_override else normalize_period(get_time_of_day())

        # 1) Hourly schedule check first (exact match)
        hour_map = hourly.get(character, {})
        for dk in day_variants(day):
            entry = hour_map.get((dk, int(hour)))
            if entry:
                loc = check_schedule_entry(entry)
                if loc:
                    return loc

        # 2) Period schedule fallback
        sch_map = schedules.get(character, {})
        for dk in day_variants(day):
            entry = sch_map.get((dk, tod))
            if entry:
                loc = check_schedule_entry(entry)
                if loc:
                    return loc

        # 3) Day wildcard fallback
        for dk in (dn, None, "Any"):
            entry = sch_map.get((dk, None))
            if entry:
                loc = check_schedule_entry(entry)
                if loc:
                    return loc

        # 4) Character default
        entry = sch_map.get("default")
        if entry:
            loc = check_schedule_entry(entry)
            if loc:
                return loc

        # 5) Global default
        return default

    def check_schedule_entry(entry):
        import renpy.store as store

        # Plain string ŌåÆ unconditional
        if isinstance(entry, str):
            return entry

        # Tuple shorthand
        if isinstance(entry, tuple):
            loc = entry[0]
            cond = entry[1] if len(entry) > 1 else None

            if cond is None:
                return loc

            # --- Single condition ---
            if isinstance(cond, str):
                # Negative flag: "!flag"
                if cond.startswith("!"):
                    flag = cond[1:]
                    return loc if not getattr(store, flag, False) else None
                # Positive flag: "flag"
                return loc if getattr(store, cond, False) else None

            # --- Multiple conditions ---
            if isinstance(cond, (list, tuple)):
                for c in cond:
                    if isinstance(c, str):
                        if c.startswith("!"):
                            flag = c[1:]
                            if getattr(store, flag, False):
                                return None  # blocked
                        else:
                            if not getattr(store, c, False):
                                return None  # required flag missing
                return loc

        # Dict full form still works
        if isinstance(entry, dict):
            loc = entry.get("loc")
            flag = entry.get("flag")
            not_flag = entry.get("not_flag")
            if flag and not getattr(store, flag, False):
                return None
            if not_flag and getattr(store, not_flag, False):
                return None
            return loc

        return None



    def get_scheduled_location(character):
        day  = calendar.weekday()
        hour = int(calendar.hours)

        # normal schedule location
        loc = resolve_location(character, day, hour, character_schedules, character_hourly, default="unknown")

        # run through overrides
        loc = get_override_location(character, loc)

        return loc

    def get_characters_at_location(location):
        present = []
        all_chars = set(character_schedules.keys()) | set(character_hourly.keys())

        # If hub, expand to sublocations
        if location in compound_locations:
            location_ids = [room[0] for room in compound_locations[location]]
        else:
            location_ids = [location]

        for character in all_chars:
            if get_scheduled_location(character) in location_ids:
                present.append(character)

        return present

    def check_schedule_flags(flags):
        import renpy.store as S
        for flag in flags:
            if flag == "act2" and not S.quest_momcheckin.completed:
                return False
            if flag == "post_elke" and not S.quest_elke.completed:
                return False
            # Add more custom flags as needed
        return True

    def action_happened_today(action_name):
        last = action_timestamps.get(action_name)

        if last is None:
            return False

        # Backward compatibility: old format stored as int
        if isinstance(last, int):
            return last == calendar.day

        # Expected format: (day, ...)
        return last[0] == calendar.day


        # 2) If not found in timestamps, check for a quest with that name
        quest_obj = getattr(store, f"quest_{action_name}", None)
        if quest_obj and getattr(quest_obj, "completed_day", None) == calendar.day:
            return True

        return False

    def get_override_location(npc, scheduled_loc):
        if npc in schedule_override_rules:
            for rule in schedule_override_rules[npc]:
                # Skip if override expired
                if "until_hour" in rule and calendar.hours >= rule["until_hour"]:
                    continue

                # Check if flag is active AND location is blocked
                if action_happened_today(rule["flag"]) and scheduled_loc in rule["block"]:
                    return rule.get("force") or "unknown"
        return scheduled_loc

