Made with Ren'Py.default dislike_jazz = False

screen stephome:
    tag stephome
    add "images/stepfam/stephouse1_idle.webp"
    on "show" action [Function(renpy.music.play, "audio/suburban.ogg", loop=True, fadein=0.5), SetVariable("current_location", "stephome")]
    on "hide" action Function(renpy.music.stop, fadeout=0.5)
    imagebutton auto "images/stepfam/stepentrance_%s.png" style "worldbutton" focus_mask True action Function(renpy.music.stop, fadeout=0.5), [
    Hide("stephome"),
    Show("stephomescreen"),
]

screen stephomescreen():
    tag stephome
    add "images/stepfam/smomhome.webp"
    on "show" action [Function(renpy.music.play, "audio/living.ogg", loop=True, fadein=0.5), SetVariable("current_location", "stephomescreen")]
    $ present = get_characters_at_location("stephome")  
    if "dad" in present:
        imagebutton auto "images/stepfam/dad_%s.png" focus_mask True action Call("dadmenu")
    if "smom" in present:
        imagebutton auto "images/stepfam/smom_%s.png" focus_mask True action Call("smommenu")
    if "sbro" in present and not justingone:
        imagebutton auto "images/stepfam/sbro_%s.png" focus_mask True action Call("sbromenu")

label dadmenu:
    scene daddialogue1 with dissolve
    dad "Yes [name]?"
    menu:
        "­¤”» About a crowbar." if not bag.has_item(crowbar) and quest_getcrowbar in questlog.quest_list:
            scene daddialogue2 with dissolve
            dad "It's in the garage, I'll go fetch it for you."
            scene black with fade
            pause 1.0
            scene daddialogue3 with dissolve
            dad "Here."
            scene daddialogue1 with dissolve
            dad "Don't do anything stupid."
            mc "I won't."
            $ bag.add_item(crowbar)
            $ questlog.EndQuest(quest_getcrowbar)
            $ questlog.StartQuest(quest_pryopen)
            return
        "Nevermind.":
            return

label sbromenu:
    if quest_visitgas.completed == False and quest_visitgas.started:
        scene dadpaper 
        dad "Look here guys..."
        dad "There is an ad saying $300 per night, no experience required. Night shift at the gas station on route 6."
        dad "I think this is perfect for you, Justin."
        sbro "Really? 300 bucks?? That's a lot of money!"
        smom "I don't know, honey."
        smom "Sounds too good to be true."
        menu:
            "ŌŁÉ Agree with stepmom.":
                $ smomlove += 5
                scene dadpaper2 with dissolve
                mc "Yeah, I agree with [stepmom_name]."
                mc "It sounds too good to be true."
                dad "I don't know, it sounds like a good deal to me."
                sbro "It is, I'm going to apply for it!"
                scene dadpaper with dissolve
            "ŌŁÉ Stay silent.":
                scene dadpaper with dissolve
        smom "Why don't you let [name] go with you?"
        smom "He can help you."
        dad "Yeah, that's a good idea."
        dad "You can go with him, right [name]?"
        mc "Sure, I can do that."
        sbro "Well let's go then."
        $ gasstationunlocked = True
        $ questlog.EndQuest(quest_visitsmom)
        $ questlog.StartQuest(quest_visitgas)
        return
    elif aftermath and quest_askjustinshift in questlog.quest_list:
        scene sbrother01
        if gasday == 1:
            menu:
                "ŌŁÉ Ask about his day at work.":
                    scene sbrother02 with dissolve
                    $ calendar.record_action("flag_askjustinshift")
                    sbro "A little weird."
                    mc "How so?"
                    scene sbrother03 with dissolve
                    sbro "There was this piece of paper with a strange rule..."
                    mc "What rule?"
                    sbro "If the light at pump 2 gives out, go to the bathroom and wait until you hear a voice saying 'You can come out now, I'm leaving'."
                    mc "That sounds... Creepy."
                    scene sbrother02 with dissolve
                    sbro "Yeah, it was."
                    sbro "Other than that, it was pretty normal."
                    mc "Alright, well keep it up. I'm proud of you."
                    $ questlog.EndQuest(quest_askjustinshift, calendar.day)
                    $ gasday += 1
                    return
        elif gasday == 2:
            menu:
                "ŌŁÉ Ask about his day at work.":
                    $ calendar.record_action("flag_askjustinshift")
                    scene sbrother04 with dissolve
                    sbro "It was a little weird today."
                    mc "How so?"
                    scene sbrother05 with dissolve
                    sbro "A new rule appeared."
                    sbro "If the phone rings more than once, don't answer."
                    mc "What?"
                    sbro "I don't know, how do I even pick up the phone?"
                    mc "Did you?"
                    scene sbrother06 with dissolve
                    sbro "No, I didn't."
                    mc "Alright, well keep it up. I'm proud of you."
                    $ questlog.EndQuest(quest_askjustinshift, calendar.day)
                    $ gasday += 1
                    return
        elif gasday == 3:
            menu:
                "ŌŁÉ Ask about his day at work.":
                    $ calendar.record_action("flag_askjustinshift")
                    "Justin clearly looks tired."
                    scene sbrother07 with dissolve
                    sbro "Same as usual, I guess."
                    mc "Nothing weird happened last night??"
                    scene sbrother06 with dissolve
                    sbro "There was this boy coming into the store.."
                    mc "And?"
                    scene sbrother05 with dissolve
                    sbro "Well the rule said I had to pretend that he wasn't there, and he would leave."
                    mc "Did he say anything else?"
                    sbro "No, he just left."
                    mc "Alright, well keep it up. I'm proud of you for pushing through."
                    mc "(I'm not sure if I should be worried or not.)"
                    $ questlog.EndQuest(quest_askjustinshift, calendar.day)
                    $ gasday += 1
                    return
        elif gasday == 4:
            menu:
                "ŌŁÉ Ask about his day at work.":
                    $ calendar.record_action("flag_askjustinshift")
                    "Justin seems distracted, exhausted... Maybe a little paranoid."
                    scene sbrother07 with dissolve
                    sbro "Hmmm."
                    mc "Well?"
                    scene sbrother06 with dissolve
                    sbro "Bro, it just keeps getting weirder."
                    mc "How so?"
                    scene sbrother05 with dissolve
                    sbro "*sighs* New rule."
                    sbro "When customers ask what happened to the old scrapyard, say it burned down in 1947."
                    mc "Old scrapyard?"
                    sbro "Yeah, I don't know."
                    sbro "But let's not talk about it."
                    sbro "I'll get some rest and go back there tonight."
                    mc "Alright, well keep it up. I'm proud of you for pushing through."
                    mc "(Weird rules, I wonder what they're about.)"
                    $ questlog.EndQuest(quest_askjustinshift, calendar.day)
                    $ gasday += 1
                    return
        elif gasday == 5:
            menu:
                "ŌŁÉ Ask about his day at work.":
                    $ calendar.record_action("flag_askjustinshift")
                    "Justin has barely said anything today, perhaps something spooked him."
                    scene sbrother04 with dissolve
                    sbro "Ahh!?"
                    sbro "[name]!"
                    mc "Whoa, you alright?"
                    scene sbrother06 with dissolve
                    sbro "I'm fine."
                    mc "Anything weird happen?"
                    scene sbrother05 with dissolve
                    sbro "Nothing that we haven't discussed before. Except..."
                    sbro "The hounds... They were..."
                    sbro "Nevermind, I don't want to talk about it."
                    mc "Justin, I'm starting to think this place is bad news."
                    mc "(I mean, the rules, the hounds, everything.)"
                    scene sbrother07 with dissolve
                    sbro "It's fine, it's just a gas station."
                    sbro "Besides... The money's good."
                    mc "I guess so."
                    mc "But you should be careful."
                    mc "Look at for yourself, alright?"
                    sbro "Yeah, yeah."
                    mc "Alright, well you seem determined. I just hope you know what you're doing."
                    $ justingone = True
                    $ questlog.EndQuest(quest_askjustinshift, calendar.day)
                    $ gasday += 1
                    return
    else:
        scene sbrother01 with dissolve
        mc "Hey, what's up?"
        sbro "What do you want?"
        menu:
            "Nevermind.":
                return

label confrontjustin:
    scene sbrother02 with dissolve
    mc "I saw you at the trailer park."
    sbro "What are you talking about?"
    mc "Don't play dumb with me, I saw you there!"
    sbro "I don't know what you're talking about."
    mc "You were dealing drugs, weren't you?"
    scene sbrother03 with dissolve
    sbro "What? No! I would never do that!"
    mc "I don't believe you."
    sbro "Whatever, I don't care what you think."
    mc "You better stop doing that, Justin."
    scene sbrother01 with dissolve
    sbro "Or what?"
    mc "Look, I don't want to get you in trouble."
    mc "I just need to know what's going on over there."
    sbro "Why do you care?"
    scene sbrother05 with dissolve
    mc "Call it a favor, for a friend."
    sbro "A favor? For who?"
    mc "Mai, my neighbor."
    sbro "So what is it you're after?"
    mc "The guy you run errands for, Robert.."
    sbro "What about him?"
    mc "I need to know what he's up to."
    sbro "And why should I tell you that?"
    mc "Because if you don't, I will tell [stepmom_name] about your activities."
    scene sbrother04 with dissolve
    sbro "Oh you little..."
    mc "I know you don't want to get in trouble with her."
    sbro "Fine, I'll tell you what I know."
    scene sbrother06 with dissolve
    sbro "But you better not tell her about this!"
    mc "I won't, I promise."
    sbro "Alright, Robert is the go to guy for tech equipment."
    sbro "Anything from phones, to computers, to cameras."
    sbro "He's got it all."
    scene sbrother07 with dissolve
    mc "And what do you do with it?"
    sbro "We sell it to people who need it."
    sbro "And sometimes we use it ourselves."
    sbro "Hes just in it for the money."
    sbro "Or sometimes.. for the hookers."
    mc "Hookers?"
    scene sbrother05 with dissolve
    sbro "Yeah, he has a thing for them."
    mc "I see..."
    sbro "So now you know, can I go?"
    mc "Sure, thanks Justin."
    $ questlog.EndQuest(quest_confrontjustin, calendar.day)
    $ questlog.StartQuest(quest_maihubby3)
    $ quest_maihubby2.started = True
    return

label smommenu:
    if quest_startjazz in questlog.quest_list:
        $ smomjazzpics_images = [
            "images/stepfam/smomsinging.png",
        ]
        scene smom22 with dissolve
        smom "[name]! Come here, look at these!"
        "[stepmom_name] seems excited to show you what looks to be a dusty old photo album."
        mc "Photos? What is this?"
        scene smom23 with dissolve
        smom "It's... from a past life at this point."
        smom "Come sit with me for a moment."
        scene smom24 with dissolve
        "You and [stepmom_name] go through her photo album, she shows you old pictures of when she was on stage when she was younger."
        mc "Oh man, you look absolutely stunning."
        if smom_spirit_done:
            mc "(And now I know where I've seen that dress before...)"
            mc "(The spirit circle showed her wearing this very dress.)"
        smom "Yes I was a lot younger back then."
        scene smom25 with dissolve
        mc "Don't worry [stepmom_name], the years look good on you too."
        smom "Oh [name]..."
        $ smomlove += 5
        pause 1.0
        "The two of you share a moment of silence."
        pause 0.5
        scene smom23 with dissolve
        smom "You know what?"
        show smomsinging
        pause 2.0
        smom "Here, take it. It's yours."
        mc "Really?"
        smom "I don't need it anymore, I am done sulking in what could've been [name]. I'm going to start fresh."
        mc "And I'll be rooting for you every step of the way."
        scene smomhug01 with dissolve
        smom "Thank you sweetie, for believing in me."
        scene smomhug02 with dissolve
        pause 1.0
        scene smomkiss02 with dissolve
        pause 1.0
        scene smomhug01 with dissolve
        smom "Alright, go now. before I lose my cool."
        mc "Would that really be so bad?"
        smom "Oh you little..."
        smom "Go!"
        mc "(Heh, teasing her is so much fun now.)"
        scene black with fade
        python:
            for img in smomjazzpics_images:
                if img not in unlocked_pictures:
                    unlocked_pictures.append(img)
        "New photos were added to your phone's gallery."
        $ questlog.EndQuest(quest_startjazz)
        $ questlog.StartQuest(quest_jazzconcert)
        return
    if quest_backhome in questlog.quest_list:
        scene 223 with dissolve
        smom "[name] did you find him?"
        smom "Where is he?"
        mc "[stepmom_name]..."
        mc "I don't know how to tell you this."
        scene smomhug01 with dissolve
        smom "no [name]... no!"
        scene smomhug02 with dissolve
        mc "I'm sorry..."
        smom "No..."
        "She holds onto you tightly as she breaks down."
        "For several minutes, you hold her as she sobs."
        scene black with slow_fade
        $ calendar.skipday()
        $ calendar.skipday()
        $ calendar.skipday()
        "Several days later at the church..."
        jump justinsfuneral
    if quest_sbrohome in questlog.quest_list:
        scene 221 with dissolve
        smom "Oh hey you guys are back!"
        smom "How did it go?"
        mc "He screwed it up."
        scene 223 with dissolve
        smom "Oh Justin..."
        smom "Why can't you just get your act together?"
        scene 231 with dissolve
        sbro "I'm sorry, ma."
        smom "I don't want to hear it."
        smom "I told you to get a job, and you didn't even try."
        scene 239 with dissolve
        smom "Did you forget what I said?"
        sbro "No, I didn't forget."
        smom "You're out of here, go pack your things."
        scene 245 with dissolve
        sbro "What? No!"
        smom "Ughhh..."
        $ timed_menu_jump([
                ("ŌŁÉ Step in and convince her to give him another chance.", "smomintervened", True),
                ("ŌŁÉ Let her do what she wants.", "smomnointervene", False)
            ], timeout=2.0)
    if quest_familyreunion in questlog.quest_list and havemet_smom == False:
        $ meet_character("havemet_smom", "images/stepfam/smommeet.webm", 4.0)
        scene 221 with dissolve
        smom "Is he alright?"
        mc "Yeah, he's fine."
        "As soon as you tell her that, she gets very angry."
        "She starts yelling at your stepbrother."
        scene 222 with dissolve
        smom "You're in big trouble, mister!"
        menu:
            "ŌŁÉ Listen to the conversation." if quest_familyreunion.started:
                scene 239 with dissolve
                smom "What were you thinking?!"
                sbro "What? I don't know..."
                smom "What were you doing with the drugs??"
                sbro "Noth.."
                smom "Quiet! And sit your ass down!"
                scene 231 with dissolve
                smom "You're a grown ass man, I don't have to tell you what kind of trouble drugs can get you into."
                smom "Nor do I want to get up in your business."
                smom "Just know this."
                smom "If you're going to continue doing drugs, you better find your own place to live."
                sbro "What are you saying?"
                sbro "I'm no longer welcome here?!"
                smom "That's right."
                scene 245 with dissolve
                sbro "That's bullshit!"
                sbro "It wasn't even mine!"
                smom "Ugh..."
                smom "I am so tired of your lies."
                pause 1
                dad "Honey, I'm home!"
                smom "You explain it to him now."
                scene 244 with dissolve
                dad "Trouble again?!"
                sbro "Hey dad..."
                smom "Don't you 'hey dad' him, tell him what you just told me why don't you?"
                scene black with fade
                "As your step brother explains what's happened, you can see your dad getting angrier, and angrier by the minute."
                "You ought it best to take your leave, before the bomb really explodes."
                scene shomedad01 with dissolve
                smom "Honey, before you go.."
                scene 221 with dissolve
                smom "Can you do me another favor?"
                mc "Sure [stepmom_name], what is it?"
                scene shomedad07 with dissolve
                smom "Your dad and I think that Justin needs to get his life together."
                smom "Right, honey?"
                dad "Uhh.. yes."
                dad "It wouldn't hurt him to get a job."
                scene shomedad04 with dissolve
                smom "See?"
                mc "Yeah, I guess it would be a good idea."
                mc "(Or another way for him to get into more trouble.)"
                smom "So, I was wondering if you know of any places that are hiring?"
                mc "Oh, uhm... There is the new coffeeshop that opened up near the school."
                scene shomedad06 with dissolve
                smom "Oh, that's a great idea!"
                dad "A coffeeshop?"
                mc "Yeah, it's pretty modern and getting popular."
                mc "Half the school goes there after classes."
                smom "Oh, that sounds perfect!"
                smom "Sweetie, can you take your stepbrother there and get him a interview?"
                scene shomedad04 with dissolve
                mc "Fine."
                mc "I guess I can do that."
                dad "What kind of answer is that?"
                smom "Oh stop it, honey."
                smom "I'm glad he is willing to help."
                scene shomedad05 with dissolve
                smom "And you...!"
                "She points at your stepbrother."
                smom "You better get your act together, or you're out of here!"
                dad "Hes just a kid, honey."
                smom "He's 20 years old, he can take care of himself."
                scene sbrother01 with dissolve
                sbro "So [name], you think you can help me out?"
                mc "I can arrange an interview for you."
                mc "The rest is up to you."
                scene sbrother02 with dissolve
                sbro "Thanks, I guess."
                sbro "Well let's go then."
                mc "Alright, alright."
                scene shomedad07 with dissolve
                mc "I'll take him to the coffeeshop."
                mc "But I can't promise anything."
                smom "That's all I ask, honey."
                scene 221 with dissolve
                smom "Oh and honey, can you bring me back an espresso from there?"
                mc "Sure, no problem."
                smom "Thank you so much!"
                mc "Bye!"
                smom "Bye sweetheart."
                "{color=#FFD700}New location unlocked: Coffeeshop{/color}."
                $ smomlove += 5
                $ coffeeshopunlocked = True
                $ questlog.EndQuest(quest_familyreunion, calendar.day)
                $ questlog.StartQuest(quest_initcshophelp)
                $ questlog.StartQuest(quest_getcoffee)
                return
            "ŌŁÉ Avoid confrontation and go out." if quest_familyreunion.started:
                scene shomedad01 with dissolve
                smom "Honey, before you go.."
                scene 221 with dissolve
                smom "Can you do me another favor?"
                mc "Sure [stepmom_name], what is it?"
                scene shomedad07 with dissolve
