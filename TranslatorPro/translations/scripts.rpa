    if not key_taken:
        imagebutton auto "images/desert/cheese/key_%s.png" focus_mask True action Call("keynarrate")
    if key_taken and picture_taken and plush_taken:
        textbutton "Close the chest." xalign 0.5 yalign 0.5 action Jump("game_loop")

label glyphunlock:
    if quest_taketothecave in questlog.quest_list:
        scene bridgettecave1 with dissolve
        mc "Hey Bridgette, what are you doing?"
        bffsis "[name]! You weren't kidding, look at this!"
        mc "I know, I was in shock when I found this place too."
        bffsis "But... cheese? What's the link?"
        mc "I don't know..."
        scene bridgettecave2 with dissolve
        mc "Where is Emma?"
        bffsis "Oh, she is checking out stuff behind the pillars over there."
        scene bridgettecave3 with dissolve
        detentiongirl "Hmmmm, this is pretty cool."
        mc "Hey Emma, what are you doing?"
        scene bridgettecave4 with dissolve
        detentiongirl "Looking for clues, duhh. What are you doing?"
        mc "Uhh, I just got here." 
        detentiongirl "Right."
        pause 1.0
        detentiongirl "Anyway, I must say I'm not sure what to make of any of this yet."
        detentiongirl "Did you setup that cheese platter over there by any chance?"
        mc "Come on, I-"
        scene bridgettecave5 with dissolve
        bffsis "Shh, guys! Someone's he."
        stop music fadeout 0.2
        mc "... finish your sentence, Bridgette."
        pause 1.0
        mc "Bridgette?"
        pause 0.5
        scene bridgettecave4 with dissolve
        mc "Emma?"
        pause 1.0
        midnight "They don't hear you." with vpunch
        pause 0.5
        scene bridgettecave6 with dissolve
        mc "Midnight!"
        midnight "I thought it best to pause this."
        mc "Uhh... What do you mean?"
        scene bridgettecave7 with dissolve
        midnight "You. Bringing friends. To this place."
        midnight "To do what... exactly? Find out the truth?"
        mc "I guess they were doing their own investigation, I just needed them to see this so they'd believe me."
        pause 1.0
        midnight "I see. But tell me kitten..."
        scene bridgettecave8 with dissolve
        midnight "Do you really think you're ready for the truth?"
        midnight "Are *they* ready for the truth?"
        mc "What are you doing? Why is your amulet..."
        midnight "Don't worry, [name]. You trust me, don't you?"
        scene bridgettecave9 with dissolve
        "She closes her eyes, and starts humming something under her breath. It's inaudible, it doesn't even sound human."
        mc "Midnight, I-"
        scene bridgettecave10 with dissolve
        mc "What is that?!"
        scene glyphescalate
        show glyphescalate at zoom_pull

        show glyphescalatealt:
            alpha 0.0
            xalign 0.5
            yalign 0.5
            xanchor 0.5
            yanchor 0.5
            zoom 1.0
            linear 2.5 alpha 1.0

        play sound "audio/lowrumble.ogg"
        pause 3.0
        scene white with flash
        pause 0.5
        scene justinpov
        play music "audio/heartbeat.ogg"
        lady "And now, you're going to eat it all!"
        sbro "N-no, please!"
        mc "(What the hell?)"
        scene white with flash
        stop music
        play sound "audio/lowrumble.ogg"
        pause 0.6
        scene white
        "{color=#82a1ff}You've unlocked Justin's spirit arc. Visit the spirit circle to learn about his fate.{/color}"
        pause 0.5
        show glyphescalate:
            alpha 0.0
            xalign 0.5
            yalign 0.5
            xanchor 0.5
            yanchor 0.5
            zoom 1.12
            parallel:
                easeout 0.7 zoom 1.0
            parallel:
                linear 0.7 alpha 1.0
        mc "(Fuck!!)"
        pause 0.7
        scene bridgettecave11 with dissolve
        play sound "audio/watersplash.ogg"
        play music "audio/cave.ogg" fadein 0.5
        "You're pulled back out of the vision by an unseen force, causing you to lose your footing and fall in the water."
        scene bridgettecave12 with dissolve
        bffsis "Oh my god, [name]!"
        bffsis "What the hell happened?"
        mc "I... I don't know."
        bffsis "Come on, come here!"
        scene bridgettecave13 with dissolve
        bffsis "Let me help you up."
        mc "Yeah, thanks."
        scene bridgettecave14 with dissolve
        mc "Guys, I uhh.. I think we should get out of here."
        bffsis "What happened to you?"
        mc "I don't know... I need to find out, I promise I'll keep you guys up-to-date... Once i'm sure."
        detentiongirl "Hmmmm..."
        scene black with slow_fade
        "You get yourself dry before heading out."
        pause 1.0
        $ questlog.EndQuest(quest_taketothecave)
        mc "(Whatever just happened, that was Justin...)"
        mc "(I felt him...)"
        mc "(Is that what happened to him?)"
        mc "(As in, his last moments?!)"
        mc "(I need to find out more about this.)"
        mc "(If Midnight has anything to do with this...)"
        mc "(Actually, if this is about the dead...)"
        pause 1.0
        mc "(The fortune teller.)"
        mc "(I need to see her right away.)"
        $ desert_caveglyph = False
        $ sbro_spirit_eligible = True
        $ questlog.StartQuest(quest_fortuneglyphs)
        return
    else:
        return

label plushnarrate:
    $ plush_taken = True
    $ bag.add_item(plush)
    scene chest6 with dissolve
    mc "(Hmmm, I wonder whose plush toy that is.)"
    call screen identitychest

label picturenarrate:
    scene chest6 with dissolve
    $ picture_taken = True
    $ masseusepics_images = [
        "images/desert/cheese/masseusepic.png"
    ]
    show masseusepic
    if havemet_spamas1:
        mc "Wait, isn't that..."
        midnight "Kyrie?" with vpunch
    else:
        mc "Hmmm, what a beautiful girl."
        midnight "Awe, I thought you'd never say it." with vpunch
    hide masseusepic
    mc "Midnight!"
    midnight "Hey kitty."
    midnight "Surprised?"
    mc "You have to stop doing this telepatic thing."
    midnight "And you have to stop snooping!"
    mc "Wait... is this yours?"
    midnight "Not technically."
    mc "What is that supposed to mean?"
    midnight "This was never mine, though it's not hers anymore either."
    midnight "This is what's left after the ritual."
    mc "Ugh, you're talking in riddles again. What ritual?"
    midnight "Fine. Blunt then. I needed her body, so I did a eenie-weenie-tiny ritual to transfer myself into a new vessel."
    mc "..."
    mc "Are you... Is she..."
    mc "What?!" with vpunch
    midnight "Happy you asked, hmm?"
    midnight "Don't worry kitty, it's not my first. And it won't be my last."
    mc "Wait, so what happens to her after you're... done?"
    midnight "Not much. She returns to her usual self and life goes on. Though..."
    pause 0.5
    mc "Though... what?!"
    midnight "Part of her will never be the same."
    midnight "Humans aren't meant to endure this type of thing, she for one doesn't remember who she was before it happened."
    midnight "She only remembers what I told her."
    midnight "The real part of her? Only the veil knows."
    if not act3:
        mc "The veil?"
        midnight "Whoops, I think I hear tha.. the witch calling for me. Gotta go!"
    else:
        mc "So is she a skinwalker?"
        midnight "Not fully. And not in the scary way you humans like to tell stories about."
        midnight "Think of it as the world remembering her before she does."
        mc "That's... somehow more terrifying to think of."
    python:
        for img in masseusepics_images:
            if img not in unlocked_pictures:
                unlocked_pictures.append(img)
    call screen identitychest

label keynarrate:
    $ key_taken = True
    $ bag.add_item(key)
    mc "(A key...)"
    mc "A key to what?"
    midnight "To nothing that concerns you, kitten."
    mc "Midnight! Tell me!"
    midnight "This key only represents her future. It is merely an object I needed to perform the ritual."
    midnight "It is of no value to you."
    mc "I see."
    call screen identitychest

label chestcheck:
    if not bag.has_item(crowbar):
        scene chest1 with dissolve
        mc "(Has this thing always been here? I don't recall...)"
        scene chest2 with dissolve
        mc "(Anyway, let's see what's inside.)"
        pause 0.5
        play sound "audio/chestlocked.ogg"
        pause 0.5
        scene chest3 with dissolve
        mc "(Damn it, I guess I need to find something to open this with.)"
        mc "(I wonder if dad could give me his crowbar...)"
        $ questlog.StartQuest(quest_getcrowbar)
        return
    else:
        scene chest2 with dissolve
        mc "(Let's try this again.)"
        play sound "audio/chestunlocked.ogg"
        pause 1.0
        mc "Yes!!"
        scene chest4 with dissolve
        mc "Let's see, what's in here?"
        $ questlog.EndQuest(quest_pryopen)
        call screen identitychest
        return

label caveintro:
    $ cheesecave_seen = True
    scene black with fade
    "Exhaustion weighs heavy as you wander the desert night."
    "The stars blur. Your eyes shut. The sand swallows you whole."
    $ calendar.advance_to_next_period("morning")
    "When you wake, the desert is gone. The air is damp, cool... and filled with a scent you know all too well."
    mc "ŌĆ”Cheese?"
    scene cavecheese with dissolve
    mc "(What the hellŌĆ” this isn't the desert.)"
    play sound "audio/midnightcute.ogg"
    midnight "*Meow*"
    mc "(Oh god, the cat againŌĆ”)"
    mc "What do you want from me?"
    scene cavecheese2 with dissolve
    "A shaft of light pours from the cracks above, striking the altar. Upon it rests a massive wheel of cheese, gleaming like a relic."
    mc "No way."
    mc "Why here? Why now?"
    "Her eyes catch the glow. And for the first timeŌĆ” you don't hear her with your ears."
    midnight "(ŌĆ”the boy is gone. The desert took him.)"
    with vpunch
    mc "(ŌĆöwhat the fuck??)"
    mc "(Did thatŌĆ” come from the cat?)"
    "The whisper echoes through your skull, cold and alien."
    mc "No. No, that's impossible."
    scene cavecheese3 with dissolve
    midnight "(Chase shadows if you must, but know you hunt a ghost.)"
    "The cheese looms larger the closer you step, as though space itself bends around it."
    mc "(This is insaneŌĆ” first the cheese, now a talking cat in my head?)"
    "Your vision swims..."
    scene interview3 with flash
    "You see Justin inside the station, arguing with a man who hides his face in his hands."
    scene mcinvestigate6 with flash
    "A figure by the empty bus, waving at nothing. The scene shifts like heat-haze."
    scene skinwalker1 with flash
    "A woman stands at the pump, too still, too perfect. Her smile stretches wider... wider..."
    "Her skin begins to ripple like wet cloth."
    scene cheeseencounter2 with flash
    "Headlights split the desert dark."
    "A crashed truck on the roadside, its logo glowing faintly ŌĆö *Say When Creamery.*"
    "Behind it, another vehicle waits in silenceŌĆ” watching."
    "The image collapses back into the cheese."
    scene cavecheese4 with dissolve
    mc "I don'tŌĆ” understand."
    midnight "(You're not meant to. Not yet.)"
    midnight "(But remember: the desert feeds. The diner is only the mouth. The cave is the stomach. And he was swallowed whole.)"
    "The smell grows stronger, suffocating, until your stomach twists with hungerŌĆöor dread."
    mc "This can't be real."
    scene cavecheese5 with dissolve
    midnight "(Does it matter?)"
    scene cavecheese6 with dissolve
    "Her eyes blaze an unnatural blue. The cave vanishes into darkness."
    scene black with slow_fade
    pause 1.0
    "You collapse, and when you wakeŌĆ” the desert sun burns your skin again."
    "It takes you a moment to realize that an entire day is gone."
    mc "(Man... WTF was that?!)"
    "Your stomach still turns at the phantom taste of cheese."
    mc "(At least i know exactly what to look for now.)"
    $ calendar.advance_to_next_period("night")
    $ questlog.EndQuest(quest_findjustin, completed_day=calendar.day)
    $ questlog.StartQuest(quest_finishjustinarc)
    return

