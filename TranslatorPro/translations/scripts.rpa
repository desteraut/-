init python:

    ## This increases the size of the quick buttons to make them easier to touch
    ## on tablets and phones.
    @gui.variant
    def touch():

        gui.quick_button_borders = Borders(60, 21, 60, 0)

    ## This changes the size and spacing of various GUI elements to ensure they
    ## are easily visible on phones.
    @gui.variant
    def small():

        ## Font sizes.
        gui.text_size = 40
        gui.name_text_size = 54
        gui.notify_text_size = 38
        gui.interface_text_size = 45
        gui.button_text_size = 45
        gui.label_text_size = 51

        ## Adjust the location of the textbox.
        gui.textbox_height = 160
        gui.name_xpos = 120
        gui.dialogue_xpos = 135
        gui.dialogue_width = 1650

        ## Change the size and spacing of various things.
        gui.slider_size = 54

        gui.choice_button_width = 1860
        gui.choice_button_text_size = 45

        gui.navigation_spacing = 30
        gui.pref_button_spacing = 15

        gui.history_height = 285
        gui.history_text_width = 1035

        gui.quick_button_text_size = 30

        ## File button layout.
        gui.file_slot_cols = 2
        gui.file_slot_rows = 2

        ## NVL-mode.
        gui.nvl_height = 255

        gui.nvl_name_width = 458
        gui.nvl_name_xpos = 488

        gui.nvl_text_width = 1373
        gui.nvl_text_xpos = 518
        gui.nvl_text_ypos = 8

        gui.nvl_thought_width = 1860
        gui.nvl_thought_xpos = 30

        gui.nvl_button_width = 1860
        gui.nvl_button_xpos = 30
Made with Ren'Py.default park_truth = False
default park_lied = False
default saw_home_cam = False
default saw_school_cam = False
default saw_cshop_cam = False
default bath_dim = False
default bed_dim = False

screen homeout:
    tag home
    $ current_hub = "home"
    add "images/home/homeout_idle.webp"
    on "show" action [Function(renpy.music.play, "audio/suburban.ogg", loop=True, fadein=0.5), SetVariable("current_hub", "home"), SetVariable("current_location", "home")]
    on "hide" action Function(renpy.music.stop, fadeout=0.5)
    if funeral_seen and quest_momcare in questlog.quest_list:
        imagebutton auto "images/home/homeoutdoor_%s.png" style "worldbutton" focus_mask True action [SetVariable("current_hub", "home"), Call("momdrunkadult")]
    elif quest_timetotalk in questlog.quest_list:
        imagebutton auto "images/home/homeoutdoor_%s.png" style "worldbutton" focus_mask True action [SetVariable("current_hub", "home"), Call("timetotalk")]
    else:
        imagebutton auto "images/home/homeoutdoor_%s.png" style "worldbutton" focus_mask True action [SetVariable("current_hub", "home"), Hide("homeout"), Show("homescreen")]

screen homescreen:
    tag home
    $ present = get_characters_at_location("homescreen")  
    add "images/home/homebg2.webp"
    on "show" action [Function(renpy.music.play, "audio/living.ogg", loop=True, fadein=0.5), SetVariable("current_hub", "home"), SetVariable("current_location", "homescreen")]
    on "hide" action Function(renpy.music.stop, fadeout=0.5)
    imagebutton auto "images/home/door_%s.png" style "worldbutton" focus_mask True action Call("homeoutchoice")
    if laptopunlocked:
        imagebutton auto "images/home/laptop_%s.png" focus_mask True action Call("laptopmenu")
    for char_id in present:
        if momdrunk == False and not helpedmomtobed:
            imagebutton auto "images/home/%s_%%s.png" % char_id focus_mask True action [
                Hide("homescreen"),
                Call("%stalkmenu" % char_id)
            ]
        if momdrunk == True and not helpedmomtobed:
            imagebutton auto "images/home/%sdrunk_%%s.png" % char_id focus_mask True action [
                Hide("homescreen"),
                Call("%sdrunk" % char_id)
            ] 

    
    if quest_elkehome1 in questlog.quest_list:
        imagebutton auto "images/home/elke_%s.png" focus_mask True action Call("elketalk")


screen homepool:
    tag home
    $ present = get_characters_at_location("homepool")
    add "images/home/pool/homepoolbg.webp"
    on "show" action [Function(renpy.music.play, "audio/suburban.ogg", loop=True, fadein=0.5), SetVariable("current_hub", "home"), SetVariable("current_location", "homepool")]
    if "mom" in present:
        imagebutton auto "images/home/pool/mom_%s.png" focus_mask True action Call("mompool")


screen homekitchen:
    tag home
    $ present = get_characters_at_location("homekitchen")
    add "images/home/16.webp"
    on "show" action [Function(renpy.music.play, "audio/kitchen.ogg", loop=True, fadein=0.5), SetVariable("current_hub", "home"), SetVariable("current_location", "homekitchen")]
    if "mom" in present and calendar.hours >= 12 and calendar.hours < 16:
        add "images/home/17.webp"
        imagebutton auto "images/home/momreading_%s.png" focus_mask True action Call("momtalk2")
    elif "mom" in present and not "mombf" in present:
        imagebutton auto "images/home/momcooking_%s.png" focus_mask True action Call("momtalk2")
    elif "mom" in present or "mombf" in present:
        imagebutton auto "images/home/momcooking_%s.png" focus_mask True action Call("elkebreakfast")
        imagebutton auto "images/home/elke2_%s.png" focus_mask True action Call("elkebreakfast")
        

screen homebathroom:
    tag home
    add ConditionSwitch(
        "bath_dim",  "images/home/bathroom/bathroom_on.png",
        "True",    "images/home/bathroom/bathroom_off.png"
    )
    $ present = get_characters_at_location("homebathroom")
    on "show" action [
        SetVariable("bath_dim", False),
        Function(renpy.music.play, "audio/bathroom.ogg", loop=True, fadein=0.5), 
        SetVariable("current_hub", "home"), 
        SetVariable("current_location", "homebathroom")
    ]
    if "mom" in present:
        imagebutton auto "images/home/bathroom/mombath_%s.png" focus_mask True action Call("momtalkbath")
    else:
        imagebutton auto "images/home/bathroom/bathtub_%s.png" focus_mask True hovered SetVariable("bath_dim", True) unhovered SetVariable("bath_dim", False) action Call("homeshower")


screen homebedroom:
    tag home

    add ConditionSwitch(
        "bed_dim",  "images/home/bedroom/bedroom_off.png",     # lights off render
        "True",     "images/home/bedroom/bedroom_on.png"       # lights on render (fallback)
    )

    $ present = get_characters_at_location("homebedroom")

    on "show" action [
        SetVariable("bed_dim", False),
        Function(renpy.music.play, "audio/bedroom.ogg", loop=True, fadein=0.5),
        SetVariable("current_hub", "home"),
        SetVariable("current_location", "homebedroom")
    ]

    imagebutton auto "images/home/bedroom/bed_%s.png" focus_mask True:
        hovered SetVariable("bed_dim", True)
        unhovered SetVariable("bed_dim", False)
        action [Hide("homebedroom"), Call("homesleep")]

    if quest_watchtv in questlog.quest_list:
        imagebutton auto "images/home/bedroom/tv_%s.png" focus_mask True action Call("tvcommercial")
    elif quest_checktv in questlog.quest_list:
        imagebutton auto "images/home/bedroom/tv_%s.png" focus_mask True action Call("act3aftermath")
    else:
        imagebutton auto "images/home/bedroom/tv_%s.png" focus_mask True action Call("homemasturbate")




screen mombedroom:
    tag home
    $ present = get_characters_at_location("mombedroom")
    add "images/home/bedroom2/mombedroom.webp"
    on "show" action [Function(renpy.music.play, "audio/bedroom.ogg", loop=True, fadein=0.5), SetVariable("current_hub", "home"), SetVariable("current_location", "mombedroom")]
    if "mom" in present:
        imagebutton auto "images/home/bedroom2/momsleep_%s.png" focus_mask True action Call("mombedroom")

screen spywareviewer():
    tag spywareviewer
    modal True
    frame:
        yalign 0.5
        xalign 0.5
        style "popup_frame"
        vbox:
            text "Spyware Viewer" size 30 xalign 0.5
            add Solid("#ffd311dc", xysize=(240, 1)) xalign 0.5
            if homecaminstalled and calendar.day > quest_installspy.completed_day and not saw_home_cam:
                textbutton "Home Bathroom Camera" xalign 0.5 background None action Call("cam_home")
            if schoolcaminstalled and calendar.day > quest_installspy.completed_day and not saw_school_cam:
                textbutton "School Stall Camera" xalign 0.5 background None action Call("cam_school")
            if cshopofficecaminstalled and calendar.day > quest_installspy.completed_day and not saw_cshop_cam:
                textbutton "Coffee Shop Office Camera" xalign 0.5 background None action Call("cam_cshop")
            
            textbutton "Close" xalign 0.5 background None action [Hide("spywareviewer"), Show("homescreen")]

label act3aftermath:
    if leaked_dictonic:
        scene bosscommercial04 with dissolve
        boss "And I guarantee each and every one of you..."
        boss "Vitalis is NOT the problem here!"
        scene bosscommercial06 with dissolve
        boss "YOU ARE!"
        mc "(Wow, I guess he has received a lot of backlash since the tests leaked.)"
        scene dicarrest1 with dissolve 
        pclerk "I'm afraid you're your own problem now, buddy."
        pclerk2 "You have the right to remain silent, anything you say can and WILL be used against you in the court of law."
        pclerk "Any questions?"
        mc "(Holy shit, he is getting arrested live on air!)"
        boss "I wish to speak to your superior officer!"
        pclerk2 "Heh.. Yeah, and I want an 8 inch dick. It wont happen, now turn around!"
        mc "(This is huge, I should attend his court case.)"
        mc "(If the city wasn't boiling already, this will set it on fire.)"
        $ courtunlocked = True
        $ judgechamberunlocked = True
        $ daofficeunlocked = True
        "{color=#FFD700}New location unlocked: Court.{/color}"
        $ questlog.EndQuest(quest_checktv, calendar.day)
        $ questlog.StartQuest(quest_visitcourt)
        return
    elif justice_dictonic:
        scene dicarrest1 with dissolve 
        "You turn on the TV and watch Dictonic getting arrested by Roxy and Sadie"
        pclerk2 "You have the right to remain silent, anything you say can and WILL be used against you in the court of law."
        pclerk "Any questions?"
        boss "You will hear from my lawyers."
        mc "(His lawyers... I have a bad feeling about this.)"
        mc "(Maybe I should attend the court case...)"
        $ courtunlocked = True
        $ judgechamberunlocked = True
        $ daofficeunlocked = True
