                action Hide("cafe_auto_tutorial")
                   


init python:
    import random

    def simulate_cafe_day():
        # Core calculation already applies staff, marketing, events,
        # upgrades, AND the new price penalty logic.
        res = calculate_cafe_day(
            cafe_staff_pending,
            menu_prices_pending,
            cafe_inventory_pending,
            cafe_marketing_pending,
            cafe_event_pending,
            cafe_upgrade_pending,
            cafe_reputation,
            cafe_customers
        )

        # Apply fuzz to make simulation an estimate only
        fuzz = random.uniform(0.85, 1.15)
        income = res.get("income", 0.0) * fuzz
        costs  = res.get("costs", 0.0) * fuzz
        profit = res.get("profit", 0.0) * fuzz

        # Clamp to two decimals
        res["income"] = round(income, 2)
        res["costs"]  = round(costs, 2)
        res["profit"] = round(profit, 2)

        # Propagate inventory warning to persistent so UI can read it
        persistent.inventory_empty_warning = res.get("inventory_warning", "")

        return res


screen confirm_insolvency():

