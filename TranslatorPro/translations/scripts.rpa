            scene aprilcompany0 with dissolve
            mc "(I can't believe I'm doing this...)"
            scene aprilcompany2 with dissolve
            april "Oh fuck [name], you're driving me nuts."
            pause 0.5
            scene aprilcompany3 with dissolve
            april "Oh god, OH FUCK! It's too much!!" with vpunch
            scene aprilcompany4 with dissolve
            "While April has orgasm after orgasm, fingering herself silly, you watch and reach your climax soon after."
            mc "Mmmmmhhh!" with vpunch
            april "Yes! Yes! YES!!!"
            pause 0.5
            scene aprilcompany5 with dissolve
            "After several minutes of aftershocks, April finally collapses onto her bed, completely exhausted."
            mc "That was... intense."
            mc "(I better let her be now.)"
            scene black with fade
            pause 0.5
            return

label militarybossdialogue:
    if not talkedabout_april:
        if calendar.can_perform_action("militarybosstalk"):
            $ calendar.record_action("militarybosstalk")
            $ havemet_militaryboss = True
            scene militarybossdialogue9 with dissolve
            militaryboss "Hey! Who let you in here? This area is off-limits to civilians, you know."
            militaryboss "Explain yourself, or I'll have you escorted out!"
            menu:
                "ŌŁÉ About your dream." if quest_redheadintro in questlog.quest_list:
                    scene militarybossdialogue4 with dissolve
                    mc "I had a dream about this place."
                    mc "In the dream, there was this girl... a redhead..."
                    militaryboss "A dream, huh?"
                    scene militarybossdialogue2 with dissolve
                    militaryboss "Is that it? You just wandered in here because of a dream?"
                    menu:
                        "­¤Æ¼ Tell her more.":
                            mc "She guided me here."
                            mc "All she said was..."
                            menu:
                                "­¤Æ¼ 'Find me in the military camp.'":
                                    mc "'Find me in the military camp.'"
                                    scene militarybossdialogue5 with dissolve
                                    militaryboss "What a waste of time..."
                                    militaryboss "Leave, or I'll have you escorted out."
                                    mc "(Damn, I wish I could remember the line...)"
                                    scene black with fade
                                    pause 0.5
                                    return
                                "­¤Æ¼ 'Meet me where the soldiers train.'":
                                    mc "'Meet me where the soldiers train.'"
                                    scene militarybossdialogue5 with dissolve
                                    militaryboss "What a waste of time..."
                                    militaryboss "Leave, or I'll have you escorted out."
                                    mc "(Damn, I wish I could remember the line...)"
                                    scene black with fade
                                    pause 0.5
                                    return
                                "­¤Æ¼ 'Tea time is in April.'":
                                    $ talkedabout_april = True
                                    $ questlog.EndQuest(quest_redheadintro)
                                    mc "'Tea time is in April.'"
                                    scene militarybossdialogue3 with dissolve
                                    militaryboss "Wait... how did you know that?"
                                    militaryboss "Only I know that phrase."
                                    mc "What do you mean?"
                                    scene militarybossdialogue1 with dissolve
                                    militaryboss "It's a phrase used between me and the camp nurse."
                                    militaryboss "Only the two of us are supposed to know it."
                                    mc "What does it mean?"
                                    scene militarybossdialogue2 with dissolve
                                    militaryboss "If I told you that, it wouldn't be much of a secret code phrase now would it?"
                                    mc "Fair point..."
                                    scene militarybossdialogue3 with dissolve
                                    militaryboss "But since your dream seems to have some significance, it could be beneficial to us."
                                    militaryboss "In the meantime, I'm afraid I can't let you leave."
                                    mc "Wait, what? Why not?"
                                    scene militarybossdialogue4 with dissolve
                                    militaryboss "Isn't it obvious? You just revealed to me that you know our secret code phrase."
                                    mc "But..."
                                    "Before you can say anything else, she calls over one of her sergeants."
                                    scene militarybossdialogue6 with dissolve
                                    militaryboss "Sergeant, take this civilian into custody."
                                    mc "Wait, I can explain!"
                                    scene black with slow_fade
                                    "The sergeant grabs you and escorts you to a holding cell."
                                    #continue here
                                    return
                        "­¤Æ¼ Keep quiet.":
                            $ questlog.EndQuest(quest_redheadintro)
                            mc "(Better not say anything more...)"
                            scene militarybossdialogue5 with dissolve
                            militaryboss "I see. the silent treatment."
                            militaryboss "You youngsters think you can just waltz into a military camp and start running your mouth about your wet dreams."
                            militaryboss "I-"
                            militarynurse "Rose, tea time is in April." with vpunch
                            $ havemet_militarynurse = True
                            scene militarybossdialogue7 with dissolve
                            militaryboss "What? Already?!"
                            militaryboss "Ugh... I lost track of time thanks to all this nonsense."
                            scene militarybossdialogue8 with dissolve
                            militaryboss "Leave, now. This isn't a place for civilians."
                            mc "(Jeez, it seems like I need to find another way in...)"
                            mc "(That line she said... 'Tea time is in April'... it must be important.)"
                            mc "(I wonder what's going on out here...)"
                            mc "(Maybe I should come back later when it's night...)"
                            $ questlog.StartQuest(quest_infiltratemilitary)
                            scene black with fade
                            pause 0.5
                            return
                "ŌŁÉ About the gear." if quest_bringbackgear in questlog.quest_list:
                    scene militarybossdialogue4 with dissolve
                    mc "We've found a crate that was left behind in one of your vehicles that crashed nearby."
                    mc "I'm just bringing it back, because whoever was in the car left it there."
                    scene militarybossdialogue3 with dissolve
                    militaryboss "I am not aware of any crashed vehicles of ours in the neighbourhood."
                    mc "It was clearly military, if it's not yours then... Who was it?"
                    scene militarybossdialogue1 with dissolve
                    militaryboss "Look, young man."
                    militaryboss "I have no idea what you're talking about, so unless you have the gear with you..."
                    mc "I do have it with me, if you want to check it out."
                    scene gearcheck with dissolve
                    "Jessy scans the serial codes of all three helmets, but the results return negative."
                    militaryboss "That's odd..."
                    militaryboss "According to our records, this type of gear was decommissioned in the early 90s." with vpunch
                    mc "What? But, how?"
                    scene militarybossdialogue1 with dissolve
                    militaryboss "Beats me."
                    militaryboss "Wherever you found that crate, it didn't come from this camp."
                    mc "(Hmmmm, none of this sits well with me.)"
                    mc "(First the car crashing with no driver.)"
                    mc "(Now this...)"
                    pause 1.0
                    mc "So, what do I do with it then?"
                    scene militarybossdialogue2 with dissolve
                    militaryboss "As far as I'm concerned..."
                    pause 0.5
                    militaryboss "Finders keepers."
                    mc "Alright then."
                    mc "(At least I tried.)"
                    scene militarybossdialogue4 with dissolve
                    mc "Thank you, I'll stop wasting more of your time then."
                    $ questlog.EndQuest(quest_bringbackgear)
                    $ questlog.StartQuest(quest_conquerthestorm)
                    scene black with fade
                    pause 0.5
                    return
                "ŌØż’ĖÅ Flirt with her.":
                    scene militarybossdialogue9 with dissolve
                    militaryboss "Listen here, young man."
                    militaryboss "I've locked up plenty of civilians who wandered into this camp without permission."
                    militaryboss "If you want to avoid that fate, you'll find it wise to leave now."
                    $ militarybosslove -= 5
                    mc "(I guess flirting didn't help...)"
                    scene black with fade
                    pause 0.5
                    return
                "Nevermind.":
                    scene militarybossdialogue5 with dissolve
                    militaryboss "Hmph. I don't have time for this."
                    militaryboss "Leave now, or I'll have you escorted out."
                    scene black with fade
                    pause 0.5
                    return
        else:
            scene militarybossdialogue1 with dissolve
            militaryboss "You again?!"
            militaryboss "I told you this area is off-limits to civilians. I have no choice but to escort you out."
            scene black with slow_fade
            "The military personnel escort you out of the camp."
            show screen militaryscreen
            mc "I guess I'll have to come back later or find another way in..."
            return
    else:
        scene militarybossdialogue1 with dissolve
        militaryboss "You again?!"
        militaryboss "I told you this area is off-limits to civilians. I have no choice but to escort you out."
        scene black with slow_fade
        "The military personnel escort you out of the camp."
        show screen militaryscreen
        mc "I guess I'll have to come back later or find another way in..."
        return
        
label cratecheck:
    if get_time_of_day() == "evening":
        if not bag.has_item(keycard):
            scene cratefind with dissolve
            mc "(I should check out these crates while nobody is watching...)"
            scene cratefind2 with dissolve
            "You search through the crates and find a keycard inside one of them."
            $ bag.add_item(keycard)
            $ questlog.EndQuest(quest_findkeycard)
            $ questlog.StartQuest(quest_jailaccess)
            mc "(Got a keycard! This might come in handy.)"
    elif get_time_of_day() == "night":
        if not bag.has_item(keycard):
            scene cratefind with dissolve
            mc "(I should check out these crates while nobody is watching...)"
            idk "Hey you! What do you think you're doing?" with vpunch
            scene mccaught with dissolve
            mc "(Oh shit! I've been caught!)"
            idk "Get the hell out of here, this is a restricted area!"
            scene black with fade
            "You have been caught and escorted out of the restricted area."
    else:
        show screen militaryscreen
        mc "(It's too risky to search the crates now. I should come back in the evening.)"
    scene black with fade
    pause 0.5
    return

    
label jaildoor:
    if quest_jailaccess in questlog.quest_list and bag.has_item(keycard) and get_time_of_day() == "evening":
        scene accessjail with dissolve
        mc "(Alright, I've got the keycard. Let's see if it works.)"
        $ questlog.EndQuest(quest_jailaccess)
        $ questlog.StartQuest(quest_talktoapril)
        $ jail_access_unlocked = True
        $ current_location = "containment"
        scene black with fade
        pause 0.5
        return
    elif jail_access_unlocked and bag.has_item(keycard) and get_time_of_day() == "evening":
        scene accessjail with dissolve
        $ current_location = "containment"
        scene black with fade
        pause 0.5
        return
    elif jail_access_unlocked and bag.has_item(keycard) and get_time_of_day() == "night":
        scene accessjail with dissolve
        mc "(Alright, I've got the keycard. Let's see if it works.)"
        scene mccaught with dissolve
        mc "(Oh shit! I've been caught!)"
        idk "Get the hell out of here, this is a restricted area!"
        scene black with fade
        "You have been caught and escorted out of the restricted area."
        scene black with fade
        pause 0.5
        return
    elif not bag.has_item(keycard):
        show screen militaryscreen
        mc "(This door is locked electronically.)"
        mc "(Seems like I need some kind of keycard to open it.)"
        mc "(I wonder what's inside...)" 
        return
    else:
        show screen militaryscreen
        mc "(Too many eyes on sight, I should come back later.)"
        return
    
label infiltratemilitary:
    scene militarysneak1 with dissolve
    mc "(It looks quiet, I should proceed carefully.)"
    "Suddenly, you hear footsteps approaching."
    mc "(Shit...)"
    scene infiltrate2 with dissolve
    militaryboss "I'm leaving, I trust you know your routine for the night?"
    idk "Yes ma'am."
    idk "Patrol at midnight till morning."
    militaryboss "Good."
    militaryboss "I'll be back in the morning."
    idk "Yes ma'am."
    mc "(So, the guards only patrol at night...)"
    mc "(That means the evenings are my safe windows.)"
    $ questlog.EndQuest(quest_infiltratemilitary)
    $ questlog.StartQuest(quest_findkeycard)
    scene black with fade
    pause 0.5
    returnMade with Ren'Py.default wanthooker = False
default motelvend_dim = True
default motelvend_bright = False
default emmaasked = False
default emmatruth = False
default emmanotruth = False
default deaninterfere_seen = False
default motel_dim = False
default motel_bright = False
default vm_input = ""
default vm_display = "$0.00"

init python:
    def add_digit(d):
        if len(store.vm_input) < 3:
            store.vm_input += d
            store.vm_display = store.vm_input.zfill(3)



screen motelscreen:
    tag motel
    $ present = get_characters_at_location("motel")

    on "show" action [
        SetVariable("motelvend_dim", True),  # reset hover-driven state
        Function(renpy.music.play, "audio/motel.ogg", loop=True, fadein=0.5),
        SetVariable("current_location", "motel")
    ]
    
    if get_time_of_day() == "night":
        add ConditionSwitch(
            "motelvend_dim", "images/motel/motelreceptionbgnighthovervend.png",
            "True",          "images/motel/motelreceptionbgnight.png"
        )

        imagebutton auto "images/motel/motelvendingnight_%s.png" focus_mask True:
            hovered SetVariable("motelvend_dim", False)
            unhovered SetVariable("motelvend_dim", True)
            action [Hide("motelscreen"), Call("motelvending")]

        imagebutton auto "images/motel/moteldoornight_%s.png" focus_mask True style "worldbutton" action [Hide("motelscreen"), Call("motelchoice")]
    else:
        add "images/motel/amybg_idle.png"
        imagebutton auto "images/motel/motelvendingday_%s.png" focus_mask True action [Hide("motelscreen"), Call("motelvending")]

        if "amy" in present:
            imagebutton auto "images/motel/moteldoorday_%s.png" focus_mask True style "worldbutton" action [Hide("motelscreen"), Call("motelchoice")]
            imagebutton auto "images/motel/amy_%s.png" focus_mask True action [Hide("motelscreen"), Call("amydialogue")]

            
    
screen motelroomscreen: 
    tag motelroom
    $ present = get_characters_at_location("motel")

    on "show" action [
        SetVariable("motel_dim", False),  # reset hover-driven state
        Function(renpy.music.play, "audio/motel.ogg", loop=True, fadein=0.5),
        SetVariable("current_location", "motelroom")
    ]

    add ConditionSwitch(
        "motel_dim",        "images/motel/motel_off.webp",     # lights off render
        "True",     "images/motel/motel_on.webp"       # lights on render (fallback)
    )

    imagebutton auto "images/motel/bed_%s.png" focus_mask True:
        hovered SetVariable("motel_dim", True)
        unhovered SetVariable("motel_dim", False)
        action Call("motelporn")

    imagebutton auto "images/motel/door_%s.png" focus_mask True style "worldbutton":
        action [Hide("motelroomscreen"), SetVariable("current_location", "motel"), Return()]

screen motelvendingscreen:
    tag motel
    add "images/motel/motelvendingmachine1.png"

    if vm_input == "":
        text vm_display:
            xalign 0.78
            yalign 0.348
            size 58
            color "#cdfd6b"
            font "fonts/digital-7.ttf"
    else:
        text vm_input.zfill(3):
            xalign 0.78
            yalign 0.348
            size 58
            color "#cdfd6b"
            font "fonts/digital-7.ttf"

    imagebutton auto "images/motel/1_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "1")
    imagebutton auto "images/motel/2_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "2")
    imagebutton auto "images/motel/3_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "3")
    imagebutton auto "images/motel/4_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "4")
    imagebutton auto "images/motel/5_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "5")
    imagebutton auto "images/motel/6_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "6")
    imagebutton auto "images/motel/7_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "7")
    imagebutton auto "images/motel/8_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "8")
    imagebutton auto "images/motel/9_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "9")
    imagebutton auto "images/motel/0_%s.png" focus_mask True style "motelvendingbutton" action Function(add_digit, "0")
    imagebutton auto "images/motel/hash_%s.png" focus_mask True style "motelvendingbutton" action SetVariable("vm_input", vm_input[:-1])
    imagebutton auto "images/motel/star_%s.png" focus_mask True style "motelvendingbutton" action SetVariable("vm_input", "")

    if len(vm_input) == 3:
        timer 1.2 action Return()

screen emmaroom: 
    tag emmamotelroom
    $ present = get_characters_at_location("motel")
    on "show" action [Function(renpy.music.play, "audio/motel.ogg", loop=True, fadein=0.5), SetVariable("current_location", "emmaroom")]
    add "images/motel/emmaroombg.png"
    if "detentiongirl" in present:
        imagebutton auto "images/motel/emma_%s.png" focus_mask True action Call("emmamoteldialogue")
    imagebutton auto "images/motel/door_%s.png" focus_mask True style "worldbutton" action [Hide("emmaroom"), SetVariable("current_location", "motel"), Return()]

screen emma_rule():
    tag emma_rule
    zorder 300
    add "images/motel/emmarule.png" xalign 0.5 yalign 0.5
    key "dismiss" action Return()
    key "mouseup_1" action Return()

label motelchoice:
    $ present = get_characters_at_location("motel")
    menu:
        "­¤ŚØ’ĖÅ Enter Motel Room" if bag.has_item(motelkey):
            $ current_location = "motelroom"
            return
        "Visit Emma." if "detentiongirl" in present and emmaroomunlocked:
            $ current_location = "emmaroom"
            return
        "Stay in Lobby":
            return
        "Leave Motel":
            jump motelleave
        

label emmamoteldialogue:
    scene emmamoteldialogue1 with dissolve
    menu:
        "ŌŁÉ About the bunker." if quest_permissiongranted in questlog.quest_list:
            scene black with fade
            "You explain everything to Bridgette and Emma about the military granting you permission to use the AI."
            scene justinalt2 with dissolve
            bffsis "Oh god, the military is involved now?"
            detentiongirl "And from the sound of it, they learned something they weren't ready for."
            mc "Yeah..."
            mc "At least they're not blocking us from asking questions, right?"
            scene justinalt3 with dissolve
            bffsis "Yeah, but it seems out of character for the military to just allow us to use some secret, hidden AI bunker."
            mc "Well I..."
            scene justinalt4 with dissolve
            detentiongirl "She's right, [name]."
            mc "I guess it is a bit strange..."
            mc "Rose, the sergeant... She mentioned even she didn't have clearance. Maybe she's just curious?"
            scene justinalt5 with dissolve
            detentiongirl "If that's the case, what do you think happens once you wake it up?"
            bffsis "And what happens to us after it talks?"
            scene justinalt1 with dissolve
            detentiongirl "Exactly."
            detentiongirl "Getting answers is one thing."
            detentiongirl "Walking away with them is another."
            mc "Rose didn't sound like she was in control of this."
            mc "She sounded... uneasy."
            scene justinalt6 with dissolve
            bffsis "Then we go in with a plan."
            bffsis "You talk to the AI. We stay close, eyes open."
            bffsis "If anything feels wrong, we leave. No debate."
            detentiongirl "Agreed. Too many parts don't fit."
            mc "You're making it sound like an ambush."
            scene justinalt5 with dissolve
            detentiongirl "I'm making it sound like survival."
            pause 1.0
            mc "Alright, alright."
            mc "If it makes you guys feel better, we'll do it your way."
            scene justinalt1 with dissolve
            detentiongirl "I'm really curious to see if we're finally going to get an answer to any of this."
            mc "Me too."
            bffsis "Just be careful, [name]."
            scene black with fade
            pause 0.5
            $ questlog.EndQuest(quest_permissiongranted)
            $ questlog.StartQuest(quest_waitformaicall)
            $ schedule_call("mai", "maioverride", day=calendar.day + 1, hours=9)
            return
        "ŌŁÉ About skinwalkers." if quest_learnaboutskinwalkers in questlog.quest_list:
            mc "What do you know about skinwalkers, Emma?"
            scene emmamoteldialogue3 with dissolve
            detentiongirl "Skinwalkers are really dangerous. They can take the form of people you know, or even animals. The similarities are uncanny, though some are more unsettling than others."
            mc "Don't ask me how I know, but I have information that suggests Justin might still be alive..."
            scene emmamoteldialogue1 with dissolve
            detentiongirl "Wait, really? Justin is alive? I thought he disappeared after working at the gas station for a week..."
            mc "Yes, and I went to find out what happened to him after he disapeared. I met this lady..."
            mc "I don't know her though, she was just... there. She spoke in riddles when I first encountered her at the gas station."
            mc "Then later, my investigation led me to her house deeper in the desert."
            mc "And she told me what happened to Justin, but now I realised it was a half truth."
            mc "She said he 'became one with the cheese.' "
            mc "And well... Let's just say I went back there to talk to her."
            mc "This time she mentioned Justin being 'a fine offering' "
            scene emmamoteldialogue5 with dissolve
            detentiongirl "An offering..."
            detentiongirl "That's really bad."
            detentiongirl "It means he wasn't just taken, he was used for something."
            detentiongirl "And whatever it is they did, cheese is a part of it."
            mc "You know what I find strange?"
            scene emmamoteldialogue1 with dissolve
            detentiongirl "What, [name]?"
            mc "I've been to the gas station a few times now. And in all of my visits, I've never once spoken to the clerk about any of this."
            mc "Yet, he was the one who came up with those strange rules that keep circling around this whole thing."
            mc "I wonder where he got the information from. And I wonder if he is willing to talk about it."
            scene emmamoteldialogue1 with dissolve
            detentiongirl "That's a good point. Maybe you should ask him about it."
            detentiongirl "If anything, he's the only lead we still have on this whole thing."
            mc "Alright, I'll ask him about it next time I see him."
            pause 1.0
            $ questlog.EndQuest(quest_learnaboutskinwalkers)
            $ questlog.StartQuest(quest_talktoclerk)
            return
        "­¤Æ¼ About what happened at the gas station." if not emmaasked:
            scene emmamoteldialogue1 with dissolve
            detentiongirl "Hey [name], what brings you here?"
            mc "I wanted to talk to you about what happened at the gas station."
            scene emmamoteldialogue5 with dissolve
            "Emma looks a bit nervous."
            detentiongirl "Yeah... about that."
            scene emmamoteldialogue6 with dissolve
            "She takes a deep breath and takes something from her night stand."
            pause 0.5
            scene emmamoteldialogue1 with dissolve
            detentiongirl "I... I found this note."
            call screen emma_rule
            mc "(This is the same kind of rule Justin was talking about when he worked at the gas station...)"
            mc "Emma, where did you find this?"
            scene emmamoteldialogue3 with dissolve
            detentiongirl "Someone left it on the bus that night."
            detentiongirl "I figured, since I was stuck there for a while, I might as well check it out for myself."
            mc "That's when it happened... didn't it?"
            scene emmamoteldialogue5 with dissolve
            detentiongirl "Yes..."
            detentiongirl "I didn't want to talk about it because..."
            scene emmamoteldialogue1 with dissolve
            detentiongirl "I was scared. I don't even know if what I saw was real."
            mc "(Poor Emma, she has no idea what she's dealing with.)"
            mc "(Should I tell her the truth?)"
            menu:
                "­¤Æ¼ Tell her the truth.":
                    scene emmamoteldialogue3 with dissolve
                    mc "Emma, I think you should know the truth."
                    mc "It's not just in your head, I've seen similar things myself."
                    scene emmamoteldialogue1 with dissolve
                    detentiongirl "What do you mean?"
                    mc "Justin, my step brother, has also experienced similar things while working the night shift there."
                    mc "He disappeared after a week, I investigated and found out that there is something far older and far more dangerous at the gas station than we could understand."
                    scene emmamoteldialogue5 with dissolve
                    detentiongirl "Skinwalkers..."
                    pause 0.5
                    mc "Yes. They can take the form of people you know, or even animals. The similarities are uncanny, though some are more unsettling than others."
                    scene emmamoteldialogue1 with dissolve
                    detentiongirl "So I'm not going crazy?"
                    mc "No, you're not. But..."
                    mc "If I were you, I wouldn't go back there on your own."
                    scene emmamoteldialogue2 with dissolve
                    detentiongirl "Thank you for telling me the truth, [name]."
                    pause 0.5
                    scene emmamoteldialogue6 with dissolve
                    "She takes the note and puts it back in her night stand."
                    $ emmaasked = True
                    $ emmatruth = True
                    return
                "­¤Æ¼ Don't tell her.":
                    scene emmamoteldialogue4 with dissolve
                    mc "Maybe it's best if we don't dig too deep into this right now."
                    mc "We should focus on staying safe."
                    scene emmamoteldialogue1 with dissolve
                    detentiongirl "Yeah... you're probably right."
                    scene emmamoteldialogue6 with dissolve
                    "She takes the note and puts it back in her night stand."
                    $ emmaasked = True
                    $ emmanotruth = True
                    return
        "ŌŁÉ About owing her." if bag.has_item(schoolpass) and not deaninterfere_seen and not quest_deaninterfere in questlog.quest_list:
            scene emmamoteldialogue3 with dissolve
            detentiongirl "Yes, [name], you still owe me."
            scene emmamoteldialogue2 with dissolve
            detentiongirl "If you want me to keep your secret, that is."
            play sound "audio/sigh.ogg"
            mc "(*sighs*, will I ever get a break from this?)"
            $ questlog.StartQuest(quest_deaninterfere)
            mc "Fine, Emma. We'll do it your way."
            scene emmamoteldialogue1 with dissolve
            detentiongirl "Great! Meet me at school later, I have an idea."
