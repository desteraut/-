# Fix: Separate style definitions and function definition into valid init python blocks
init python:
    style.menu_button_black_text = Style(style.menu_button_text)
    style.menu_button_black_text.color = "#000"
    style.menu_button_black_text.idle_color = "#000"
    style.menu_button_black_text.hover_color = "#ff0"
    style.menu_button_black_text.insensitive_color = "#000"

    style.menu_button_black = Style(style.menu_button)

init python:
    def reset_pending_choices():
        global cafe_marketing_pending, cafe_event_pending, cafe_upgrade_pending, cafe_staff_pending, cafe_menu_pending, cafe_inventory_pending, cafe_money_pending
        if cafe_marketing_pending != 'None':
            cafe_marketing_pending = cafe_marketing
        if cafe_event_pending != 'None':
            cafe_event_pending = cafe_event
        cafe_upgrade_pending = cafe_upgrade
        cafe_staff_pending = list(cafe_staff)
