init python:
    # Global, canonical mapping: Display Name -> internal id
    name_map = {
        'Mom': 'mom', 'Dad': 'dad', 'Tim': 'bff', 'Naomi': 'bffmom', 'Elke': 'mombf', 'Vanessa': 'smom', 'Justin': 'sbro', 'Mai': 'mai',
        'Mrs. Burley': 'mathteach', 'Mrs. Russell': 'scienceteach', 'Mrs. brown': 'dean', 'Mr. Mayor (John Winfield)': 'mayor',
        'Brenda (Mrs. Winfield)': 'brenda', 'Ashley': 'mayorsec', 'Claire': 'coffeeowner', 'Fathima': 'coffeegirl', 'Judith': 'coworker',
        'Bailey': 'nursesec', 'Dr. Amber Nightingale': 'doc', 'Elizabeth': 'eli',
    }

    # Fast lowercase lookup for names (keeps ids like "mom", "mai" working too)
    _name_map_lower = { k.lower(): v for k, v in name_map.items() }

    def gallery_canon_id(x):
        s = str(x).strip()
        low = s.lower()
        # If already an internal id used by the registry, keep it.
        if 'GALLERY_SCENES' in globals() and low in GALLERY_SCENES:
            return low
        # Map display name -> id via name_map (case-insensitive)
        return _name_map_lower.get(low, low)

    def resolve_contact_portrait(who):
        """
        Returns (photo_path, cid) for a contact, using the same sources as
        Relationships/Gallery. Falls back to the phone fallback image.
        """
        import renpy.store as store

        cid = store.gallery_canon_id(who)  # uses the case-insensitive map first

        # 1) Try the CHARACTERS registry (many projects keep 'photo' or 'portrait' there)
        photo = None
        characters = getattr(store, "CHARACTERS", {})
        if cid in characters:
            photo = characters[cid].get("photo") or characters[cid].get("portrait")

        # 2) Fall back to whatever Relationships uses (the 5th tuple item)
        if not photo:
            for name, char, love, corruption, pic, _ in store.get_relationships_data():
                if store.gallery_canon_id(char) == cid:
                    photo = pic
                    break

        # 3) Final safety: fallback image
        if not photo or not renpy.loadable(photo):
            photo = "images/phone/fallback.png"

        return photo, cid


init python:
    import renpy.store as store

    # re-entrancy guard for check_calls
    _checking_calls = False

    def _days_in_month(y, m):
        return store.calendar.days_count[m]

    def _add_days(y, m, d, n):
        d += n
        while d > _days_in_month(y, m):
            d -= _days_in_month(y, m)
            m += 1
            if m > 12:
                m = 1
                y += 1
        return y, m, d

    def _now_tuple():
        cal = store.calendar
        Y, M, D = cal.year, cal.month, cal.day
        H = getattr(cal, "hours", getattr(cal, "hour", 0))
        Min = getattr(cal, "minutes", getattr(cal, "minute", 0))
        return (Y, M, D, H, Min)

    def _tuple_le(a, b):
        return a <= b

    def _normalize_call_to_when_tuple(call):
        cal = store.calendar
        Y, M, D = cal.year, cal.month, cal.day
        H = getattr(cal, "hours", getattr(cal, "hour", 0))
        Min = getattr(cal, "minutes", getattr(cal, "minute", 0))

        # Full date (already normalized by schedule_call)
        if all(k in call for k in ("year","month","day","hours")):
            return (call["year"], call["month"], call["day"], call["hours"], call.get("minutes", 0))

        # Weekday name (use your calendar.weekday() string)
        if isinstance(call.get("time"), str):
            if call["time"] == cal.weekday():
                return (Y, M, D, H, Min)

        # Absolute day (legacy) - treat as current month day
        if isinstance(call.get("time"), int):
            d = call["time"]
            y, m = Y, M
            while d > _days_in_month(y, m):
                d -= _days_in_month(y, m)
                m += 1
                if m > 12:
                    m = 1
                    y += 1
            return (y, m, d, H, Min)

        # No time => now
        if call.get("time") is None:
            return (Y, M, D, H, Min)

        return None

    def schedule_call(who, label, time=None, day=None, month=None, year=None, hours=None, minutes=0):
        """
        Schedule a call. If 'day' is provided, it's treated as an absolute day number
        that will be properly normalized across month/year boundaries.
        """
        call = {"who": who, "label": label}

        # If day is provided, normalize it properly from the current date
        if day is not None:
            cal = store.calendar
            current_year = cal.year
            current_month = cal.month
            target_day = int(day)
            
            # Normalize the day across month boundaries
            y, m, d = current_year, current_month, target_day
            while d > _days_in_month(y, m):
                d -= _days_in_month(y, m)
                m += 1
                if m > 12:
                    m = 1
                    y += 1
            
            # Store as absolute date
            call["year"] = y
            call["month"] = m
            call["day"] = d
        
        if time is not None:
            call["time"] = time
        if month is not None:
            call["month"] = int(month)
        if year is not None:
            call["year"] = int(year)
        if hours is not None:
            call["hours"] = int(hours)
        if minutes:
            call["minutes"] = int(minutes)

        incoming_calls.append(call)

    # Optional sugar: schedule relative
    def schedule_call_in(hours=0, minutes=0, who=None, label=None):
        cal = store.calendar
        Y, M, D = cal.year, cal.month, cal.day
        H = getattr(cal, "hours", getattr(cal, "hour", 0))
        Min = getattr(cal, "minutes", getattr(cal, "minute", 0))
        total = H*60 + Min + hours*60 + minutes
        add_h, new_min = divmod(total, 60)
        new_h = add_h % 24
        add_d = add_h // 24
        y, m, d = _add_days(Y, M, D, add_d)
        schedule_call(who or "unknown", label or "incoming_call", year=y, month=m, day=d, hours=new_h, minutes=new_min)

    def check_calls():
        global _checking_calls
        if _checking_calls:
            return
        _checking_calls = True
        try:
            if not incoming_calls:
                return
            if getattr(store, "phonebroke", False):
                return
            if renpy.get_screen("incoming_call_screen"):
                return
            now = _now_tuple()
            to_fire_idx = None
            to_fire = None

            # Find the first due call
            for idx, call in enumerate(list(incoming_calls)):
                when = _normalize_call_to_when_tuple(call)
                if when is None:
                    renpy.notify(f"[phone] Skipping invalid call: {call}")
                    continue

                if _tuple_le(when, now):
                    to_fire_idx = idx
                    to_fire = call
                    break

            if to_fire is not None:
                # Remove from list BEFORE showing
                incoming_calls.pop(to_fire_idx)
                
                try:
                    # Just show the screen, don't wait
                    renpy.show_screen("incoming_call_screen", to_fire)
                except Exception as e:
                    renpy.notify(f"[phone] incoming call dispatch error: {e}")

        finally:
            _checking_calls = False
            
    def cheat_unlock_all_gallery():
        from renpy.store import GALLERY_SCENES
        for _, entries in GALLERY_SCENES.items():
            for e in entries:
                persistent.gallery_unlocks[e["id"]] = True

        # Mark persistence as updated and save it immediately
        renpy.persistent._changed = True
        renpy.save_persistent()
        renpy.notify("All gallery scenes unlocked!")

    def cheat_lock_all_gallery():
        from renpy.store import GALLERY_SCENES
        for _, entries in GALLERY_SCENES.items():
            for e in entries:
                # Instead of deleting keys, mark them False (safer for reloads)
                persistent.gallery_unlocks[e["id"]] = False

        # Mark persistence as updated and save it immediately
        renpy.persistent._changed = True
        renpy.save_persistent()
        renpy.notify("All gallery scenes locked!")



screen incoming_call_screen(call):
    tag phone
    zorder 200
    modal True

    # Fire once on open/close
    on "show" action [ Play("sound", "audio/phone_vibrate.ogg", loop=True), Function(renpy.vibrate, 0.4) ]
    on "hide" action Stop("sound")

    python:
        who = call.get('who', '')
        photo, _ = resolve_contact_portrait(who)
        if not photo or not renpy.loadable(photo):
            photo = "images/phone/fallback.png"


    use phone_app("Incoming Call", "incoming_call_block", call=call, photo=photo)


screen incoming_call_block(call=None, photo=None):
    vbox:
        spacing 20
        xalign 0.5
        yalign 0.5
        if photo:
            add photo xalign 0.5 yalign 0.5 xsize 180 ysize 180

        text "[call['who']] is calling you." size 28 color "#7ecbff" xalign 0.5

