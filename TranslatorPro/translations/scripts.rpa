label brendabardialogue:
    scene brendabar00 with dissolve
    brenda "[name]! Come here!"
    scene brendabar1 with dissolve
    brenda "Where have you been? I've been looking all over for you after what happened."
    mc "Yeah... it's a long story."
    brenda "After.. You know..."
    brenda "When I woke up, you were.. gone. That thing... gone."
    brenda "I thought I was losing my mind."
    mc "You weren't, or.. maybe you were.. I don't even know."
    scene brendabar2 with dissolve
    "She leans in closer, lowers her volume."
    brenda "What happened?"
    mc "I guess the same happened to me, except I woke up in a different place entirely."
    mc "The veil was there, and so was the witch."
    scene brendabar3 with dissolve
    brenda "Wait, wait... Veil.. witch..?"
    mc "Yeah, I learned some things that I can't even begin to explain to you without sounding like a lunatic."
    brenda "Try anyway."
    scene brendabar4 with dissolve
    "You start explaining your story, the real story."
    scene brendabar5 with dissolve
    "And by the time you're done, Brenda looks at you with pity for the first time since you've known her."
    brenda "Gosh, that's... something."
    mc "Yeah..."
    scene brendabar2 with dissolve
    brenda "So, I guess you've got enough on your plate already."
    mc "I do, but.. is something on your mind?"
    scene brendabar6 with dissolve
    brenda "Well [name], I am going to..."
    brenda "Take over Dictonic's pharma." with vpunch
    pause 0.2
    mc "What?!"
    mc "What do you mean... Take over?"
    scene brendabar7 with dissolve
    brenda "I knew he was going to get arrested sooner or later, and..."
    scene brendabar2 with dissolve
    brenda "I hope you won't take this the wrong way but..."
    brenda "I used your sample to make a safe version of the drug."
    mc "My sample? Safe drug?"
    scene brendabar3 with dissolve
    brenda "You remember our time after the debate in the parking lot of city hall?"
    mc "Of course I remember."
    scene brendabar7 with dissolve
    brenda "Well, you were quite generous with your uhh..."
    brenda "Present shall we say."
    brenda "And I grabbed a sample of what was left and analysed it."
    scene brendabar1 with dissolve
    brenda "By the way, did you know you were immune to the side effects?"
    mc "I first learned about it when I was doing my own research into Dictonic."
    scene brendabar3 with dissolve
    brenda "Right, well [name] long story short, it worked!"
    brenda "I have a completely safe version of Vitalis, ready to be sold."
    mc "That's actually... Impressive."
    scene brendabar5 with dissolve
    brenda "Of course, none of this would've happened without you."
    brenda "So I wanted to ask you for permission first before I..."
    scene brendabar7 with dissolve
    brenda "You know, mass produce it."
    menu:
        "­¤öō Of course, it will save Brightmoor!":
            $ brendalove += 25
            scene brendabar6 with dissolve
            brenda "Thank you [name], that means everything for this city."
            scene brendabar7 with dissolve
            brenda "Of course, I will personally see to it that you will never pay for Vitalis ever again. Should you ever feel the need to use it."
            mc "That sounds good to me."
            scene brendabar8 with dissolve
            brenda "I have to go now, I am actually taking over his offices tomorrow."
            brenda "Feel free to stop by anytime you want [name]."
            mc "(That's amazing, I could go and see Judith again.)"
            $ officeworkunlocked = True
            "{color=#FFD700}Work office is now accessible again.{/color}"
            scene brendabar9 with dissolve
            brenda "Alright then [name], I'll see you around."
            mc "Bye Brenda."
            mc "(Damn, she really took over huh?)"
            mc "(This city went through quite a few changes lately...)"
            $ brendatakeover = True
            return
        "­¤öō Not for free.":
            $ mccorruption += 25
            scene brendabar4 with dissolve
            brenda "You mean you want compensation?"
            mc "I think it's only fair, you used me for an experiment I wasn't aware of and now you're going to cash in big time for it."
            scene brendabar7 with dissolve
            brenda "Fine. You'll get it."
            scene brendabar8 with dissolve
            brenda "Consider this an... investment into our future cooperation."
            $ bag.earn(2000)
            mc "(Damn... that's more than I expected.)"
            mc "(But not really the kind of payment I had in mind.)"
            brenda "And the offices will be open again starting tomorrow."
            brenda "If you ever want more deals like this... you know where to find me."
            $ officeworkunlocked = True
            "{color=#FFD700}Work office is now accessible again.{/color}"
            scene brendabar9 with dissolve
            mc "I'll keep that in mind."
            brenda "Good. Because power changes hands quickly in Brightmoor, and I intend to stay on top."
            mc "(Looks like Judith is back on the board too.)"
            brenda "Take care, [name]."
            $ brendatakeover = True
            return
            
label barkeepdialogue:
    if quest_findtim in questlog.quest_list:
        scene barbg3 with dissolve
        "Dim lights paint everything in a warm, exhausted glow."
        "The jukebox plays old songs, filling the emptiness of the bar."
        scene barbg2 with dissolve
        barkeep "Welcome! Can I get you anything?"
        $ havemet_barkeep = True
        scene barkeepdialogue1 with dissolve
        barkeep "So tell me, what's your poison?"
        jump barkeepmenu
    scene barbg2 with dissolve
    barkeep "Hey [name], what can I get you?"
    jump barkeepmenu

