init python:

    def maybe_trigger_echo():
        global veil_stage, last_echo_trigger
        # Only in Act III
        if not (act3 and quest_theveil.completed):
            return
        # Only after MC becomes unstable
        if not getattr(store, "mc_unstable", False):
            return
        # Cooldown
        if store.interaction_count - last_echo_trigger < echo_cooldown:
            return

        import random

        # Chance based on stage
        chance_map = {0: 0.02, 1: 0.03, 2: 0.06, 3: 0.10}
        chance = chance_map.get(veil_stage, 0.02)

        if random.random() < chance:
            last_echo_trigger = store.interaction_count

            if veil_stage == 0:
                renpy.call("echo_small")
            elif veil_stage == 1:
                renpy.call("echo_medium")
            else:
                renpy.call("echo_large")


    def _echo_callback():
        if not hasattr(store, "interaction_count"):
            store.interaction_count = 0
        store.interaction_count += 1
        maybe_trigger_echo()

    config.interact_callbacks.append(_echo_callback)

