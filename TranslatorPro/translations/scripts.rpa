                # Contacts
                imagebutton:
                    auto "images/gui/massiveMultiplayer_%s.png"
                    action [ Hide("phone_popup"),
                            ShowTransient("phone_app", transition=None,
                                        block_name="phone_call_block",
                                        title="Contacts") ]
                    hovered SetScreenVariable("tooltip", "Contacts")
                    unhovered SetScreenVariable("tooltip", None)

                # Caf├® (gated)
                if managementunlocked and calendar.weekday() not in ("Saturday", "Sunday"):
                    imagebutton:
                        auto "images/phone/coffeeapp_%s.png"
                        action [ Hide("phone_popup"), Show("garden_cafe_management") ]
                        hovered SetScreenVariable("tooltip", "Caf├® management")
                        unhovered SetScreenVariable("tooltip", None)


    use global_tooltip(tooltip, tooltip_portrait)

screen relationship_info(character, love, corruption):
    tag phone
    zorder 102
    $ char_var = character if isinstance(character, str) else None
    $ char_var = char_var if char_var else name_map.get(str(character), str(character).lower())
    frame:
        add "images/phone/phonescralt2.png"
        xalign 0.5
        yalign 0.5
        xsize 900
        ysize 900
        style "no_border_frame"
        vbox:
            xalign 0.5
            yalign 0.5
            spacing 20
            text "[character.capitalize()]" size 36 color "#f8c" xalign 0.5
            text "Relationship: [love]" size 28 xalign 0.5
            text "Corruption: [corruption]" size 28 xalign 0.5
            textbutton "View Gallery" action [ Hide("phone_app"),
                ShowTransient("phone_app", transition=None,
                    block_name="gallery_character_block",
                    title=f"{character.capitalize()} ŌĆö Gallery",
                    data=char_var) ] style "phone_rel_textbutton" xalign 0.5
        imagebutton auto "images/gui/cross_%s.png" action Hide("relationship_info") xalign 0.98 ypos 55   

    
