            SetScreenVariable("tooltip_pos", renpy.get_mouse_pos())
        ]
        unhovered [
            SetScreenVariable("tooltip", None),
            SetScreenVariable("tooltip_portrait", None)
        ]


    use global_tooltip(tooltip, tooltip_portrait)
    $ midnight_opportunity_ping("mall")



