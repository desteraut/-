    returnMade with Ren'Py.init -10 python:
    # Safe, idempotent upgrader: turns plain ints like momlove into Stat objects
    def ensure_relationship_stats_wrapped():
        import renpy.store as store

        def _stat_style_for(varbase):
            color = "#ff94b6"
            try:
                if "character_colors" in globals():
                    color = character_colors.get(varbase, color)
            except Exception:
                pass
            return ("ŌØż’ĖÅ", color)

        d = store.__dict__
        for k, v in list(d.items()):
            if not isinstance(k, str):
                continue
            if k.endswith("love") or k.endswith("corruption"):
                base = k[:-4] if k.endswith("love") else k[:-10]
                # Already a Stat? keep it.
                try:
                    from renpy.store import Stat  # ensure class is visible at runtime
                except Exception:
                    # If Stat isn't compiled yet, skip; the call will run again later
                    continue
                if isinstance(v, Stat):
                    continue
                # Coerce current value safely
                try:
                    curr = int(v)
                except Exception:
                    curr = 0
                emoji, color = _stat_style_for(base)
                d[k] = Stat(base, curr, emoji=emoji, color=color)

# Call it once after Stat is compiled (Stat is usually in init 0)
