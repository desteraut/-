screen gallery_character_block(data):
    default __char = str(data)
    python:
        import renpy.store as store
        cid = store.gallery_canon_id(__char)
        scenes = getattr(store, "GALLERY_SCENES", {}).get(cid, [])

    # Top nav: < Characters (left) ŌĆó Images (right)
    frame:
        background None
        xfill True
        ysize 60

        hbox:
            xfill True
            yalign 0.05
            spacing 20

            # Left-aligned "< Characters" button
            textbutton "< Characters":
                style "gallery_nav_textbutton"
                text_style "gallery_nav_textbutton_text"
                xalign 0.0
                action [ Hide("phone_app"),
                    ShowTransient("phone_app", transition=None,
                        block_name="phone_gallery_block",
                        title="Gallery") ]

            null  # spacer, optional

            # Right-aligned "Images" button
            textbutton "Images":
                style "gallery_nav_textbutton"
                text_style "gallery_nav_textbutton_text"
                xalign 1.0
                action [ Hide("phone_app"),
                    ShowTransient("phone_app", transition=None,
                        block_name="phone_gallery_pictures_block",
                        title="Images") ]




    frame:
        background None
        xalign 0.5
        yalign 0.55
        xpos 480
        ypos 450

        viewport id "gal_scene_view":
            draggable True
            mousewheel True
            xsize 900
            ysize 760
            scrollbars "vertical"
            style_prefix "rel"
            vbox:
                spacing 0
                null height 32
                grid 3 3 spacing 18:
                    xalign 0.5
                    yalign 0.0
                    for entry in scenes:
                        $ locked_thumb = "images/gui/locked.png"
                        $ unlocked_thumb = "images/gui/unlocked.png"
                        $ sid   = entry.get("id")
                        $ title = entry.get("title", sid)
                        $ label = entry.get("label")
                        $ hint  = entry.get("hint", "No hint available.")
                        $ thumb = entry.get("thumb", None)
                        $ unlocked = is_gallery_unlocked(sid)

                        frame:
                            background None
                            xsize 260
                            ysize 180
                            has vbox
                            spacing 8
                            xalign 0.5

                            # Thumbnail area
                            imagebutton:
                                background Solid("#00000093")
                                idle Transform(thumb if thumb else (unlocked_thumb if unlocked else locked_thumb),
                                            xsize=240, ysize=120)
                                sensitive unlocked
                                action ( Show("gallery_scene_confirm", label=label, title=title)
                                        if unlocked else Show("gallery_hint_popup", title=title, hint=hint) )

                            # Title row + hint button
                            hbox:
                                spacing 8
                                xalign 0.5

                                textbutton title:
                                    style "gallery_nav_textbutton"
                                    text_style "gallery_nav_textbutton_text"
                                    action ( Show("gallery_scene_confirm", label=label, title=title)
                                            if unlocked else Show("gallery_hint_popup", title=title, hint=hint) )

                                if not unlocked:
                                    textbutton "(?)" style "gallery_hint_textbutton" action Show("gallery_hint_popup", title=title, hint=hint)


screen gallery_scene_confirm(label, title):
    modal True
    zorder 999
    frame:
        background Solid("#000000CC")
        xalign 0.5
        yalign 0.5
        xsize 520
        ysize 240
        vbox:
            spacing 16
            xalign 0.5
            yalign 0.5
            text "Replay: [title]" size 26 color "#ffe066" xalign 0.5
            text "This is a non-canon gallery replay." size 18 xalign 0.5
            hbox:
                spacing 40
                xalign 0.5
                textbutton "Play" action [
                    Hide("gallery_scene_confirm"),
                    Hide("phone_app"),
                    Call("dispatch_event", event_label=label, restore_worldmap=False)
                ] style "phone_rel_textbutton"
                textbutton "Cancel" action Hide("gallery_scene_confirm") style "phone_rel_textbutton"

screen gallery_hint_popup(title, hint):
    modal True
    zorder 999
    frame:
        background Solid("#000000CC")
        xalign 0.5
        yalign 0.5
        xsize 640
        ysize 300
        vbox:
            spacing 18
            xalign 0.5
            yalign 0.5
            text "[title] ŌĆö How to unlock" size 26 color "#7ecbff" xalign 0.5
            text hint size 18 xalign 0.5
            textbutton "Close" action Hide("gallery_hint_popup") style "phone_rel_textbutton"

