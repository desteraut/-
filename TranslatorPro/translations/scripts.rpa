init python:
    """
    Safety cleanup for old persistent fields that might contain
    unserializable Quest objects from versions < 2.1.
    """
    # Remove scheduled quest backups (always unsafe)
    if hasattr(persistent, 'scheduled_quests_backup'):
        try:
            delattr(persistent, 'scheduled_quests_backup')
        except:
            pass
    
    # Validate or remove incoming_calls backup
    if hasattr(persistent, 'incoming_calls_backup'):
        try:
            # Check if it's a list and contains only serializable types
            if not isinstance(persistent.incoming_calls_backup, list):
                raise ValueError("Not a list")
            # Shallow check - just verify it's not obviously broken
            list(persistent.incoming_calls_backup)
        except:
            try:
                delattr(persistent, 'incoming_calls_backup')
            except:
                pass
    
    # Optional: clean stale new-context data (harmless to delete)
    for field in ("pending_resume", "pending_args"):
        if hasattr(persistent, field):
            try:
                delattr(persistent, field)
            except:
                pass

init python:
    import renpy.exports as renpy_exports
    import renpy.store as store

    def meet_character(varname, moviefile, duration=10.0, whereabouts=None):
        if not getattr(store, varname):
            setattr(store, varname, True)
            store._skipping = False
            renpy.show_screen("unskippable_movie", moviefile=moviefile, duration=duration)
            renpy.pause(duration, hard=True)
            store._skipping = True


    def adult_scene(moviefile, duration=10.0):
        store._skipping = False
        renpy.show_screen("unskippable_movie", moviefile=moviefile, duration=duration)
        renpy.pause(duration, hard=True)
        store._skipping = True


    def adult_scene_looped(moviefile, min_duration=8.0):
        store._skipping = False
        renpy.show_screen("looped_adult_movie", moviefile=moviefile, min_duration=min_duration)
        renpy.pause(min_duration, hard=True)
        renpy.pause()  # Wait for user click after 8 seconds
        store._skipping = True

    def should_show_local_nav():
        hub = getattr(store, "current_hub", None)
        loc = getattr(store, "current_location", None)
        
        if hub not in compound_locations:
            return False
        
        # Special case: if current_location equals the hub name, we're in that hub
        if loc == hub:
            return True

        location_screens = [screen_name for screen_name, display_name in compound_locations[hub]]
        
        return loc in location_screens


    def update_local_nav_button():
        store.show_local_nav_button = should_show_local_nav(getattr(store, "current_room", None))

    def ensure_menu_music_if_needed():
        # This only returns True when weŌĆÖre sitting in the main menu layer
        if renpy.game.context().scene_lists is None:
            if not renpy.music.get_playing():
                renpy.music.play("audio/splashscreen.ogg", loop=True, fadein=1.0)

    def get_splash_image():
        if persistent.act2splash:
            return "images/splashscreen2.png"
        else:
            return "images/splashscreen.png"
    
    def checkpoint_autosave(message="Game progress auto saved"):
        renpy.force_autosave()
        renpy.notify(message)

    def auto_start_after_splash():
        import renpy.store as store
        if store.splash_done and not getattr(store, "_already_autostarted", False):
            store._already_autostarted = True
            renpy.jump("start")

    config.start_callbacks.append(auto_start_after_splash)

init -1 python:
    config.overlay_screens.append("floater_manager")


