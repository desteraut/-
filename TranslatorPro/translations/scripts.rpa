    def current_time_decimal():
        mins = getattr(calendar, "minutes", 0)
        return float(calendar.hours) + float(mins) / 60.0

    def get_next_valid_day_for_npc(npc_key, loc_key, start_day=None):
        import renpy.store as store

        if not hasattr(store, "calendar") or store.calendar is None:
            return None, None

        if start_day is None:
            start_day = store.calendar.day

        # --------------------------------------------------
        #  F L E X I B L E   L O C A T I O N   M A T C H I N G
        # --------------------------------------------------

        valid_sublocs = set()

        valid_sublocs.add(loc_key)

        if loc_key in store.compound_locations:
            for room_key, _desc in store.compound_locations[loc_key]:
                valid_sublocs.add(room_key)

        for parent_key, rooms in store.compound_locations.items():
            for room_key, _desc in rooms:
                if room_key == loc_key:
                    valid_sublocs.add(parent_key)
                    valid_sublocs.add(room_key)

        if hasattr(store, "hub_parents"):
            if loc_key in store.hub_parents:
                valid_sublocs.add(store.hub_parents[loc_key])
            for child, parent in store.hub_parents.items():
                if loc_key == parent:
                    valid_sublocs.add(child)

        # --------------------------------------------------
        #  T I M E   P E R I O D S   T O   C H E C K
        # --------------------------------------------------

        day_periods = [
            ("morning", 9),
            ("afternoon", 12),
            ("evening", 18),
        ]

        # --------------------------------------------------
        #  F I N D   T H E   N E X T   V A L I D   D A Y
        # --------------------------------------------------

        current_weekday_index = store.calendar.days.index(store.calendar.weekday())

        for offset in range(7):
            check_day = start_day + offset
            wk_name = store.calendar.days[(current_weekday_index + (check_day - store.calendar.day)) % len(store.calendar.days)]

            if offset == 0 and check_day == store.calendar.day:
                current_hour = store.calendar.hours
            else:
                current_hour = None

            for period_name, hour in day_periods:

                if current_hour is not None and hour <= current_hour:
                    continue

                npc_loc = store.resolve_location(
                    npc_key,
                    wk_name,
                    hour,
                    store.character_schedules,
                    store.character_hourly,
                    default="unknown",
                    tod_override=period_name
                )

                if npc_loc in valid_sublocs:
                    return offset, wk_name

        return None, None


    def is_location_open(location, hour=None, day=None):
        if day is None:
            day = calendar.weekday()
        if hour is None:
            hour = current_time_decimal()

        hours = location_hours.get(location, {}).get(day)
        if not hours:
            return False

        open_hour, close_hour = hours
        if open_hour == close_hour:
            return False

        epsilon = 1e-6

        if open_hour < close_hour:
            return (open_hour - epsilon) <= hour < (close_hour - epsilon)
        else:
            return (hour >= (open_hour - epsilon)) or (hour < (close_hour - epsilon))

    def will_location_be_open_at_hour(location, hours_from_now):
        target_hour = (calendar.hours + hours_from_now) % 24
        return is_location_open(location, target_hour)

    

