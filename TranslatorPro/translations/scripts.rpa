label perfumemenu:
    scene perfumestore03 with dissolve
    $ havemet_plady = True
    plady "Hello sir, what will it be today?"
    menu:
        "­¤Æ” Approach her." if guardpathlocked == False and boughtcheapperfume == True and boughtexpensiveperfume == True and boughtregularperfume == True:
            jump perfumemenu2
        "ŌŁÉ About the book." if quest_bookhunt2 in questlog.quest_list:
            scene perfumestore02 with dissolve
            plady "I gave that book to my sister Maaike."
            play sound "audio/sigh.ogg"
            mc "*sighs* Of course you did..."
            scene perfumestore04 with dissolve
            plady "She's been trying to write a novel. Thought the book might help her come up with ideas."
            mc "And where can I find her?"
            scene perfumestore21 with dissolve
            plady "She's usually at the hospital's front desk."
            plady "But she always takes her lunch breaks in the general store."
            plady "Cheap coffee, cheap snacksŌĆ” cheap everything."
            mc "(Great, another detour...)"
