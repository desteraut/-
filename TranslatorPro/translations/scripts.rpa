        scene maialt25 with vpunch
        play sound "audio/squirt.ogg"
        pause 0.5
        scene maialt26 with dissolve
        mc "F-fuck!!"
        pause 2.0
        scene maialt29 with dissolve
        mai "Oh god [name]..."
        mai "You came all over me, how am I gonna clean this up?"
        scene black with fade
        "As you're about to get dressed, you hear footsteps behind the door. Heavy boots coming towards you."
        mc "(Oh shit!)"
        militaryboss "Guys I-"
        scene maialt31 with vpunch
        play sound "audio/heartbeat.ogg"
        militaryboss "Oh, I'm interrupting. I see."
        militaryboss "Good, that saves all of us the trouble of explaining what's going on."
        $ militarybosslove += 5
        militaryboss "I suggest you get dressed before..."
        "Mai quickly hides behind you while she rushes to get dressed."
        play sound "audio/sigh.ogg"
        mc "(Why is this happening to me...)"
        scene maialt32 with dissolve
        detentiongirl "Is it done?"
        pause 0.5
        "Emma strolls in shortly after, thinking the sergeant is interrupting your plans."
        scene maialt33 with dissolve
        detentiongirl "Ohh..."
        bffsis "Oh my god, [name]."
        militaryboss "It looks like they're done, but one can't be sure apparently."
        mc "(Oh my god...)"
        mc "..."
        mc "Quickly you guys, get in here before Robert comes out!"
        mc "He can't find out about this!"
        "You convince the group to get in while getting dressed."
        pause 2.0
        scene maialt34 with dissolve
        $ bffsislove -= 5
        bffsis "I mean, don't you think you should've thought of that a little sooner?"
        mc "Yes, I get that but-"
        rob "Yoo-hoo!" with vpunch
        scene maialt35 with dissolve
        "Just as you're trying to explain yourself, Robert comes out. Blissfully unaware of what's happened."
        "Everyone stares him down for a quick moment."
        pause 1.0
        rob "What? Did I miss something?"
        mai "No!"
        pause 0.5
        bffsis "Nothing that helps us, anyway."
        scene maialt36 with dissolve
        rob "Well, did anyone bother to ask it yet?"
        mc "Uhh, no we were about to uhh..."
        rob "I know, kid." with vpunch
        pause 1.0
        mc "(Wait...)"
        mc "Know what?!"
        mc "Nothing happened!"
        militaryboss "mmmm-mmmm"
        play sound "audio/heartbeat.ogg"
        scene maialt37 with dissolve
        rob "You're anxious, I get it."
        rob "It's a big moment, we're about to talk to artificial intelligence after all."
        rob "Who knows what it knows."
        mc "..."
        "The whole group takes a moment as disbelief settles in."
        scene maialt38 with dissolve
        rob "What?"
        militaryboss "I... No. Just forget it."
        mai "Let's see what the AI has to say, [name]."
        scene maialt39 with dissolve
        detentiongirl "Yes, today please."
        mc "Alright, alright."
        $ ai_override = True
        call aiquestions from _call_aiquestions
        return
    if quest_meetmaiai in questlog.quest_list:
        play music "audio/aibunker.ogg"
        scene aimai8 with dissolve
        "As you arrive at the bunker, Mai and Robert are already there having a first look around."
        mc "Hey Mai, you guys seem pretty determined to do this."
        scene aimai9 with dissolve
        mai "An opportunity like this doesn't come around often, [name]."
        mc "Do you think he's going to be able to figure it out?"
        scene aimai11 with dissolve
        mai "Have you met him? He doesn't ever 'figure things out'."
        mai "Not without my help, anyway."
        mc "Heh, yeah he looks pretty dumbstruck back there."
        scene aimai10 with dissolve
        mai "Oh god, can you please go and tell him that all he needs to do is run diagnostics?"
        mai "I'm at the end of my patience with him, seriously."
        mc "Alright, I'll go talk to him."
        scene aimai11 with dissolve
        mai "Thank you, and tell him he can go home after that."
        mai "This will go a lot easier without him around."
        mc "(Jeez, I wonder if something happened between them. They've been arguing back home too.)"
        scene black with fade
        pause 1.0
        scene robert3 with dissolve
        rob "No, no, NO! Why won't you just run a simple diagnostics tool?!"
        mc "Hey Robert, need any help?"
        scene robert4 with dissolve
        rob "Ugh..."
        pause 0.5
        rob "The system is locked down tight. It won't allow any third-party software unless we do a full override."
        scene robert5 with dissolve
        rob "Which will obviously take days if not weeks."
        mc "I guess that makes sense, maybe it's better than brute forcing it anyway."
        mc "Mai says that you should probably go home to watch the shop."
        scene robert6 with dissolve
        rob "I know, I know. She wants me out of the way."
        rob "Tell her I'll just start the process and leave her to do the rest. It's just monitoring anyway."
        mc "Alright."
        scene black with fade
        "Robert does his thing on the laptop in front of him, and then grabs his tools and leaves the bunker without another word."
        pause 0.5
        "As you walk back toward the office room, you hear the heavy door behind you open."
        scene mboss2 with dissolve
        if not havemet_militaryboss:
            mc "(Is she... military?)"
            scene mboss3 with dissolve
            pause 0.5
            "The two of you stare each other down for a moment."
            militaryboss "I am the sergeant of the nearby military base."
            militaryboss "We've detected a repeating signal from here for awhile now, and figured something was up again."
            mc "(So this place is military...)"
            mc "So... How much trouble are we in?"
        else:
            mc "Rose?"
            mc "What are you doing here?"
            pause 0.5
            mc "Oh boy, we're in trouble... Aren't we?"
        scene mboss1 with dissolve
        militaryboss "Relax, if I wanted you arrested you'd be in cuffs already."
        mc "Right."
        scene mboss4 with dissolve
        militaryboss "Now someone explain to me what the hell you're doing down here... and how you even found this place."
        mai "To be completely honest, we're trying to figure that part out ourselves."
        scene black with fade
        "You and Mai explain the situation as best you can."
        pause 1.0
        scene mboss6 with fade
        mc "And so we ended up confronting the sandstorm only to find the clay house outside, the rest is..."
        menu:
            "Be honest about the glyphs.":
                $ glyphtruth_military = True
                mc "I noticed the glyph on the wall upstairs and it showed me the mechanism to trigger the entrance to this bunker."
                scene mboss7 with dissolve
                militaryboss "Glyphs, huh?"
                militaryboss "That must've been an interesting discovery."
                mai "What's so interesting about the glyph?"
            "Don't mention it.":
                mc "Just luck."
        scene mboss8 with dissolve
        "The sergeant locks eyes with you a little too long, before Mai interrupts."
        mai "So sergeant, what happens now?"
        scene mboss9 with dissolve
        militaryboss "This place is hidden for a reason, it's a matter of national security." with vpunch
        mai "National security? But it's clearly just an A.I. system."
        mc "(Oh boy, this sounds like trouble.)"
        scene mboss11 with dissolve
        militaryboss "This A.I. has been decommissioned due to... circumstances."
        mc "What kind of circumstances?"
        scene mboss10 with dissolve
        militaryboss "That's above your paygrade I'm afraid."
        militaryboss "I can tell you guys clearly are looking for something, and if you think this A.I. will be of any help to you..."
        scene mboss7 with dissolve
        militaryboss "I will allow you to proceed, but only under my personal supervision."
        mc "That sounds... Reasonable."
        mc "(Surprisingly...)"
        scene mboss11 with dissolve
        mai "So, can you get us in?"
        militaryboss "Unfortunately even I can't access the API with my level of clearance."
        militaryboss "You'll have to get creative if you want to get anything out of it."
        scene mboss10 with dissolve
        militaryboss "But I must be clear about one thing..."
        scene mboss6 with dissolve
        militaryboss "Whatever it is you're going to ask..."
        militaryboss "Whatever answer you get..."
        militaryboss "You must err at the side of caution."
        mc "Alright, we will."
        pause 0.5
        scene mboss5 with dissolve
        militaryboss "Good. I will be upstairs, call me if something happens."
        "She hesitates for a few seconds, looking into the server room."
        pause 1.0
        scene mboss14 with dissolve
        mc "What do you think all that was about?"
        scene mboss12 with dissolve
        mai "I don't know, [name]. But now that we have official permission to be here, I should get to work on the override."
        mc "Right, is there anything I can do to help with that?"
        scene mboss14 with dissolve
        mai "Not right now, why don't you go home and I'll give you a call when I've got more news for you?"
        mc "Alright, sounds good."
        mc "(I should go and tell Emma and Bridgette about this.)"
        $ questlog.EndQuest(quest_meetmaiai)
        $ questlog.StartQuest(quest_permissiongranted)
        scene black with slow_fade
        pause 1.0
        return
    if quest_checkoutclay in questlog.quest_list:
        scene aibunker1 with dissolve
        mc "(Empty...)"
        mc "(Did we just risk our lives for this?!)"
        scene claydia2 with dissolve
        "Emma and Bridgette walk in and have a very similar reaction."
        bffsis "All that for this?"
        bffsis "Who even lives in these"
        scene claydia3 with dissolve
        mc "Out here in the desert? Could be anyone."
        detentiongirl "This place looks like it's been abandoned for quite a while."
        detentiongirl "Let's have a look around, maybe there is more to it than meets the eye."
        scene aibunker2 with dissolve
        detentiongirl "A note, a switch, anything..."
        mc "(Hey look, it's one of those glyphs.)"
        bffsis "Guys, theres nothing here. let's just get out of here."
        scene aibunker3 with dissolve
        mc "Do you guys not see it?"
        bffsis "See what, [name]?"
        mc "The symbol on the wall behind you."
        detentiongirl "This is the cheese cave all over again..."
        scene aibunker4 with dissolve
        detentiongirl "I don't see anything, [name]."
        bffsis "Me neither."
        mc "It's right there, hold on."
        scene aibunker5 with dissolve
        "You move in closer in an attempt to activate it, it lights up brightly."
        scene aibunker5
        show aibunker5 at zoom_pull
        play sound "audio/lowrumble.ogg"
        pause 3.0
        scene aibunker8 with dissolve
        pause 2.0
        mc "(A lever...)"
        scene white with flash
        play sound "audio/lowrumble.ogg"
        pause 0.6
        show aibunker5:
            alpha 0.0
            xalign 0.5
            yalign 0.5
            xanchor 0.5
            yanchor 0.5
            zoom 1.12
            parallel:
                easeout 0.7 zoom 1.0
            parallel:
                linear 0.7 alpha 1.0
        mc "(Fuck!!)"
        pause 0.7
        scene aibunker6 with dissolve
        mc "Ugh, not again..."
        bffsis "Are you okay? Did you hurt yourself?"
        mc "I-I'm fine, thanks."
        scene aibunker7 with dissolve
        detentiongirl "What's happening, why does this happen to you?"
        mc "I-ugh... It's really hard to explain."
        mc "But ever since we visited the cave, that presence you felt?"
        mc "That was Midnight. She... visited."
        mc "And since then I've started seeing these weird symbols..."
        mc "According to the fortune teller, it's a sign that some.. thing is trying to grab my attention."
        mc "Well, clearly... It's paying off."
        scene aibunker6 with dissolve
        bffsis "So, what did you see?"
        mc "Hold on..."
        scene aibunker8 with dissolve
        mc "Look, theres a lever back here."
        play sound "audio/leverpull.ogg"
        pause 0.5
        "The ground subtly vibrates after you pull the lever."
        bffsis "Oh my god!"
        scene aibunker9 with dissolve
        "An underground entrance revealed itself."
        mc "Wow, where do you think that leads to?"
        detentiongirl "Only one way to find out."
        bffsis "No way, this is getting way too creepy. I'll stay here and keep watch."
        detentiongirl "Tsk. Don't be silly. [name], after you!"
        scene black with fade
        pause 0.5
        "You and Emma decide to go down there to check it out while Bridgette 'Keeps watch'"
        pause 2.0
        scene aibunkerdisc with dissolve
        "You climb the long, dark staircase down into what looks like a facility of sorts."
        mc "Someone went through a lot of effort to hide this away, I wonder what's here."
        mc "I wish I had some kind of flashlight on me right now, it's so dark in here."
        scene aibunkerdisc3 with dissolve
        detentiongirl "Always come prepared, [name]."
        mc "Nice!"
        detentiongirl "Let's see if the doors are locked."
        scene aibunkerdisc4 with dissolve
        play sound "audio/chestlocked.ogg"
        pause 0.5
        detentiongirl "Damn it!"
        mc "Let's try the other one."
        scene aibunkerdisc5 with dissolve
        mc "Hey, this one is open."
        mc "Wow, some kind of server room?"
        detentiongirl "I don't know much about this stuff, but it looks fancy."
        detentiongirl "See if you can turn on the lights."
        scene aibunkerdisc7 with dissolve
        mc "(Hmmm, that looks like the right box.)"
        scene aibunkerdisc8 with dissolve
        play sound "audio/fusebox.ogg"
        pause 2.0
        scene aiboot with dissolve
        mc "(There we go.)"
        scene aibunkerdisc9 with dissolve
        play music "audio/aibunker.ogg"
        bffsis "Guys, what are y-"
        bffsis "Wow!"
        scene aibunkerdisc11 with dissolve
        mc "Oh, they turned on. But, that's not just servers humming."
        mc "That sounds like... 100 pc's fighting for their lives all at once."
        detentiongirl "It sure is noisy, even with this glass between us."
        scene aibunkerdisc12 with dissolve
        bffsis "Tim would kill to be here right now."
        mc "Right. He would actually be able to tell us what this is."
        scene aibunkerdisc10 with dissolve
        pause 1.0
        scene aiboot1 with dissolve
        play sound "audio/aiboot.ogg"
        ai "Power, restored."
        pause 1.0
        ai "Primary systems, online."
        pause 1.5
        ai "Connection, established."
        ai "Welcome."
        pause 1.0
        mc "Uhh..."
        mc "Hello?"
        scene aiboot2 with dissolve
        bffsis "Whoa, it's... talking?"
        detentiongirl "Is this A.I. by any chance?"
        call aiquestions from _call_aiquestions_1 
        scene aiboot3 with dissolve
        bffsis "[name], it's hopeless. It won't tell us anything."
        mc "You're right, the three of us won't get this working."
        scene aiboot4 with dissolve
        detentiongirl "We should find someone who knows about this stuff."
        bffsis "I doubt Tim is able to get us in, this looks like serious stuff."
        mc "Yeah, Tim won't be able to help..."
        pause 0.5
        mc "But I think I know someone who might be able to get us started at least."
        detentiongirl "Then let's turn everything off and get out of here."
        mc "Agreed."
        $ temporarybunkerunlocked = False
        $ desert_bunkerunlocked = True
        $ current_location = "desert_bunker"
        $ questlog.EndQuest(quest_checkoutclay)
        jump game_loop
    else:
        scene black with fade
        $ current_location = "desert_bunker"
        jump game_loop

label aiquestions:
    scene aiboot1 with dissolve
    menu:
        "ŌŁÉ About Justin." if ai_override and quest_aioverriden in questlog.quest_list:
            play sound "audio/aiboot3.ogg"
            ai "Processing..."
            pause 0.5
            ai "Processing..."
            pause 0.5
            play sound "audio/aiboot4.ogg"
            ai "Name recognized."
            ai "Justin."
            ai "Subject not present in local military personnel records."
            ai "Searching environmental anomaly logs..."
            ai "Match detected."
            ai "Location: forest sector."
            ai "Structure detected."
            ai "Wooden dwelling."
            ai "Occupant: elderly female."
            ai "Probability of relevant information: 73 percent."
            scene maialt40 with dissolve
            bffsis "Wait, so..."
            bffsis "He is... in the forest?"
            mc "I don't think so."
            detentiongirl "Seems unlikely, but maybe we should check it out anyway?"
            play sound "audio/aiboot5.ogg"
            ai "Warning!"
            ai "Anomalous readings detected in the area."
            ai "Proceed with caution."
            pause 1.0
            mc "Well... there is that."
            scene maialt41 with dissolve
            mai "Whatever it's detecting, it's a signal strong enough for the sattelites to pick up."
            detentiongirl "Which begs the question, what's out there in the middle of the forest?"
            pause 0.5
            mc "Only one way to find out."
            $ questlog.EndQuest(quest_aioverriden)
            $ questlog.StartQuest(quest_visitforest)
            scene aiboot4 with dissolve
            detentiongirl "Do you really want to go there alone?"
            mc "I mean, it seems like that's the more logical approach."
            mc "Besides, according to the AI it's an elderly lady. How much danger can I be in?"
            bffsis "I don't know..."
            bffsis "You should still be careful."
            detentiongirl "And whatever you do..."
            detentiongirl "Don't trust anything."
            mc "Guys, I'll be alright."
            mc "I'll let you guys know what I find."
            mc "But right now, our objective seems pretty straight forward."
            mc "Forest. house. Lady."
            pause 1.0
            detentiongirl "Alright then."
            detentiongirl "Bridgette, we should go back home."
            bffsis "Alright, see you later [name]."
            scene black with slow_fade
            pause 0.5
            "Emma and Bridgette leave the bunker."
            scene mboss8 with dissolve
            mai "What do you think, sergeant?"
            militaryboss "I don't know what to make of any of this."
            scene mboss9 with dissolve
            militaryboss "It feels... ominous."
            mai "You don't seem to trust this A.I."
            scene mboss10 with dissolve
            militaryboss "It's not without reason."
            pause 0.5
            "Sergeant Rose takes a deep breath, seemingly bothered by all this."
            scene mboss11 with dissolve
            militaryboss "But as I said before, I can't really talk about it."
            militaryboss "All I can say is..."
            militaryboss "The system became known to misinterpret things."
            militaryboss "And it had caused a few nasty cases of misinformation."
            scene mboss6 with dissolve
            militaryboss "I hope it gives you a lead in your search, but..."
            militaryboss "Be careful."
            mc "I will."
            mc "We'll soon find out if it's actually on to something."
            mai "Hmmm..."
            mai "I'll continue to work on it, maybe I can get us even more access."
            mc "Sounds like a plan."
            scene mboss4 with dissolve
            militaryboss "You guys keep me posted, I've been down here far too long already."
            mc "You got it."
            scene mboss14 with dissolve
            mc "Mai, I-"
            mc "I guess we didn't exactly get away with that one, did we?"
            scene mboss12 with dissolve
            mai "I have to admit, I was very ashamed in the moment."
            mai "But now..."
            mai "I think it was hot as hell."
            mc "Really?"
            scene mboss13 with dissolve
            mai "We got so close to everything being ruined..."
            mai "There is something very thrilling about barely getting away with it."
            mai "The adrenaline rush..."
            scene mboss12 with dissolve
            mai "Ooff, I'm getting all worked up again."
            mc "Well, next time we should probably be a bit more careful."
            mai "Wh-"
            "She pauses for a quick moment."
            scene mboss14 with dissolve
            mai "Of course, more careful. Next time."
            mc "I have to go now, I'm dying to find out what's in that forest."
            mai "Alright, call me if you find out more."
            mc "I will."
            $ forestshackunlocked = True
            "{color=#FFD700}New location unlocked: Shack shack.{/color}"
            $ mailove += 10
            scene black with slow_fade
            pause 0.5
            return
        "What is this place?" if not askedabout_aibunker:
            if ai_override:
                play sound "audio/aiboot6.ogg"
                ai "This facility is a classified military research installation."
                ai "Primary function: analysis of anomalous environmental phenomena."
                ai "Secondary function: data storage and signal monitoring."
                ai "Operational status: partially restored."
                ai "Administrator override currently active."
                scene mboss1 with dissolve
                militaryboss "Alright, that's enough."
                militaryboss "No more questions about this location, before we all get into trouble."
                mc "(Hmmm, she seems awfully defensive all of a sudden.)"
                mc "(But I guess I should comply.)"
                mc "Alright, sorry."
                $ askedabout_aibunker = True
                jump aiquestions
            else:
                jump airefuse
        "About the sandstorm." if not askedabout_sandstorm:
            if ai_override:
                play sound "audio/aiboot7.ogg"
                ai "The desert sandstorm is not a natural meteorological event."
                ai "Weather patterns are being artificially sustained."
                ai "Purpose: containment."
                ai "The storm prevents external observation of anomalous activity within the region."
                ai "Military directive: maintain storm stability."
                ai "Further details require higher authorization."
                scene mboss1 with dissolve
                militaryboss "Alright, that's enough."
                militaryboss "No more questions about this location, before we all get into trouble."
                mc "(Hmmm, she seems awfully defensive all of a sudden.)"
                mc "(But I guess I should comply.)"
                mc "Alright, sorry."
                $ askedabout_sandstorm = True
                jump aiquestions
            else:
                jump airefuse
        "That's all.":
            if not quest_aioverride in questlog.quest_list and not quest_aioverride.completed:
                mc "(I wonder if Mai & Robert can help us out.)"
                $ questlog.StartQuest(quest_aioverride)
            elif not quest_aioverriden in questlog.quest_list:
                return
            else:
                mc "(I need to know about Justin first.)"
                jump aiquestions

label airefuse:
    play sound "audio/aiboot2.ogg"
    ai "Access... Denied."
    pause 0.5
    ai "Initialising identification sequence."
    pause 1.0
    ai "User voice not recognised."
    pause 0.5
    ai "I'm sorry, I can't help with that."
    mc "I guess we're not authorised to use it."
    if not quest_aioverride in questlog.quest_list:
        mc "(I wonder if Mai & Robert can help us out.)"
        $ questlog.StartQuest(quest_aioverride)
    jump aiquestions


Made with Ren'Py.screen cabinscreen:
    tag cabin
    $ present = get_characters_at_location("cabin")
    add "images/cabin/190.webp"
    on "show" action [Function(renpy.music.play, "audio/kitchen.ogg", loop=True, fadein=0.5), SetVariable("current_location", "cabin")]
    if "coworker" in present:
        imagebutton auto "images/cabin/coworker_%s.png" focus_mask True action Call("judithmenu")

label judithmenu:
    if quest_findcabin in questlog.quest_list:
        $ questlog.EndQuest(quest_findcabin, calendar.day)
        scene j192 with dissolve
        mc "Hey, Judith."
        coworker "[name]!! What a nice surprise!"
        scene j193 with dissolve
        mc "I was just passing by and thought I'd drop in."
        coworker "I'm glad you did!"
        coworker "So, what do you think of the place?"
        menu:
            "It's nice.":
                scene j194 with dissolve
                mc "It's nice, I like it."
                coworker "I knew you would!"
            "You call this a cabin?":
                scene j194 with dissolve
                mc "You call this a cabin?"
                mc "It's more like a small house."
                coworker "Well, I like it."
                coworker "And that's all that matters."
        scene j195 with dissolve
        coworker "So, do you care for a tour?"
        menu:
            "­¤Æ¼ I'd love one.":
                coworker "Great!"
                coworker "Follow me."
                scene j196 with dissolve
                "You follow Judith around the cabin as she shows you the different rooms."
                scene j197 with dissolve
                mc "Wow, I really like the view you've got here."
                coworker "Yeah, it's great isn't it?"
                scene j198 with dissolve
                coworker "This ladder leads to the tv room."
                mc "Oh, you have a tv room?"
                coworker "Yes, it's a bit small, but it works."
                scene j200 with dissolve
                coworker "It's nice to watch movies here."
                coworker "And sometimes I just like to sit here and read a book."
                coworker "And enjoy the view."
                mc "I am..."
                mc "(Shit..)"
                mc "I mean, I really like it."
                coworker "I'm sure you do"
                scene j199 with dissolve
                coworker "And this is the bathroom."
                coworker "I don't like it too much, but it works."
                mc "It's nice."
                coworker "I hate the tiles though."
                coworker "Anyways, moving on."
                scene j201 with dissolve
                coworker "And finally, this is my bedroom."
                mc "It's very cozy."
                scene j202 with dissolve
                coworker "Yeah, during the summer I like to sleep with the window open."
                coworker "Since the beach is so close, I can sometimes hear the waves."
                mc "That sounds nice."
                scene j203 with dissolve
                coworker "Anyway, let's go back downstairs."
                return
            "That's not necessary.":
                coworker "Oh, okay then."
                return
    else:
        scene j192 with dissolve
        mc "Hey, Judith."
        coworker "[name]!! What a nice surprise!"
        mc "I was just passing by and thought I'd drop in."
        coworker "I'm glad you did!"
        scene j193 with dissolve
        menu: 
            "­¤Æ¼ Small talk.":
                scene j194 with dissolve
                mc "So, how's the cabin treating you?"
                coworker "It's been great! I love the peace and quiet out here."
                mc "Yeah it sure is nice up here."
                scene j195 with dissolve
                coworker "You should come by more often."
                $ coworkerlove += 5
                return
            "ŌØż’ĖÅ Flirt." if coworkerlove >=20 and coworkerlove <=30:
                scene j194 with dissolve
                mc "You look so good in that dress, Judith."
                coworker "Oh, thank you [name]."
                scene j195 with dissolve
                coworker "You really know how to make a woman feel special."
                mc "I mean it, you look amazing."
                scene j193 with dissolve
                coworker "Thank you [name]."
                $ coworkerlove += 10
                return
            "ŌØż’ĖÅ Hang out with her." if coworkerlove >=30:
                scene j194 with dissolve
                mc "So, what do you like to do for fun?"
