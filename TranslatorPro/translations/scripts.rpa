    # MAIN CONTENT FRAME
    frame:
        background None
        xalign 0.5
        yalign 0.45
        xsize 750
        ysize 600

        vbox:
            spacing 20
            text "Inventory & Supplies" size 36 xalign 0.5 color "#ffffff"

            viewport:
                draggable True
                mousewheel True
                ysize 280
                xsize 780

                vbox:
                    spacing 10

                    for item in sorted(cafe_inventory_pending.keys()):
                        $ qty = cafe_inventory_pending[item]

                        hbox:
                            spacing 20

                            vbox:
                                xsize 160
                                text item size 24 color "#ffffff" xalign 0.0
                            vbox:
                                xsize 110
                                text "Stock: %d" % qty size 20 color "#b8b8b8" xalign 0.0
                            vbox:
                                xsize 130
                                text "Unit Price: $%d" % inventory_prices[item] size 18 color "#84ff84" xalign 0.0

                            null width 20

                            vbox:
                                xsize 90
                                textbutton "+10" background None action Function(lambda i=item: restock_item(i, 10)) xalign 0.5 style "menu_button" sensitive not (cafe_auto_mode or (persistent.end_day_results_shown and last_end_day == calendar.day))
                            vbox:
                                xsize 90
                                textbutton "+50" background None action Function(lambda i=item: restock_item(i, 50)) xalign 0.5 style "menu_button" sensitive not (cafe_auto_mode or (persistent.end_day_results_shown and last_end_day == calendar.day))

            null height 20


            textbutton "Reset Inventory Changes" action Function(reset_inventory_changes) xalign 0.5 style "menu_button"

            text "Restock items to avoid running out of supplies. Each sale uses inventory!" size 16 color "#555" xalign 0.5

            if persistent.inventory_empty_warning:
                text persistent.inventory_empty_warning size 16 color "#cc7700" xalign 0.5


