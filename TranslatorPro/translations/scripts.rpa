        spacing 150

        textbutton "­¤æ®ŌĆŹ­¤Ź│ Staff" background None focus_mask True action [ Hide("cafe_inventory"), Hide("cafe_marketing"), Hide("cafe_menu"), Hide("cafe_events"), Hide("cafe_upgrades"), Hide("cafe_staff"), Show("cafe_staff") ]
