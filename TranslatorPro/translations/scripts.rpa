    def try_random_event():
        """
        Decide whether to schedule a random event. Do NOT run it here.
        We only set pending_random_event if something is eligible.
        """
        import renpy.store as store
        if getattr(store, "pending_random_event", None) is not None:
            return

        # Global block?
        if getattr(store, "block_random_events", False):
            return

        # Only one random event per in-game hour
        if store.calendar.hours == store._last_event_hour:
            return

        # RNG gate
        from random import random
        if random() > 0.40:  # 40% chance
            return

        # Build context-aware pool
        candidates = get_random_event_pool()
        if not candidates:
            return

        # Pick but don't runŌĆöqueue it
        store.pending_random_event = renpy.random.choice(candidates)

    def maybe_run_pending_event():
        import renpy.store as store
        if getattr(store, "_in_after_load", False):
            return
        if store.pending_random_event:
            ev = store.pending_random_event
            store.pending_random_event = None
            store._last_event_hour = store.calendar.hours
            store.active_context = ev
            renpy.call("dispatch_event", event_label=ev, restore_worldmap=False)

    def get_random_event_pool():
        import renpy.store as store
        pool = []

        if not store.random_events_fired_today.get("robbery_event", False):
            if getattr(store, "act2", False):
                if not getattr(store, "phonebroke_seen", False):
                    if getattr(store, "travel_context", None) == "bus":
                        pool.append("mcclumsy")

        if not store.random_events_fired_today.get("robbery_event", False):
            if not store.random_events_fired_today.get("mcclumsy", False):
                if getattr(store, "travel_context", None) == "bus":
                    if renpy.random.random() < 0.05:
                        pool.append("robbery_event")

        if store.current_location == "gstore":
            present = store.get_characters_at_location("gstore")
            if "nursesec" in present and not store.maaikefucked and not store.random_events_fired_today.get("maaikealleyfuck", False):
                pool.append("rand_maaikealleyfuck")

        if getattr(store, "bdsmroomunlocked", False):
            if getattr(store, "travel_context", None) == "bus":
                if not getattr(store, "homelessencounter_seen", False):
                    if store.get_time_of_day() == "night":
                        pool.append("rand_homelessencounter")

        if not getattr(store, "cheesecave_seen", False):
            if store.get_time_of_day() == "night":
                if store.current_location in [m[2] for m in store.worldmap_markers_desert]:
                    if quest_findjustin in store.questlog.quest_list:
                        pool.append("caveintro")

        if store.current_location == "mall":
            if getattr(store, "havemet_rob", True):
                if not getattr(store, "cuckoocuffs_unlocked", False):
                    pool.append("cuckoocuffs")

        if store.current_location == "beach":
            if not getattr(store, "feralpicunlocked", False):
                pool.append("mcrelaxbeach")

        return pool



Made with Ren'Py.default boughtmotelkeyday = None

init python:
    store.pending_closed_label = None

    WEEKDAYS = ("Monday","Tuesday","Wednesday","Thursday","Friday")
    WEEKEND  = ("Saturday","Sunday")
    ALLDAYS  = WEEKDAYS + WEEKEND

    def check_event():
        questlog.CheckScheduledQuests()
        check_mom_meals()
        check_detention()
        daily_reset_mischief_flags()
        check_midnight_branch_resolution()
        check_home_rest_quest()
        check_nightclub_events()
        check_sandstorm_events()
        if hasattr(store, "check_calls"):
            store.check_calls()
        if current_location == "mall":
            check_mall_events()
        if act3 and sisterreveal and not timcaught_seen:
            questlog.StartQuest(quest_backtoschool)
        if bag.has_item(motelkey) and get_time_of_day() == "morning" and boughtmotelkeyday is not None and calendar.day > boughtmotelkeyday:
            store.boughtmotelkeyday = None
            bag.remove_item(motelkey)
    
    def check_nightclub_events():
        if is_location_open("nightclub") and quest_helpnightclub.completed_day != calendar.day and not photoevent:
            questlog.ResetQuest(quest_helpnightclub, reset_type="daily")
            questlog.StartQuest(quest_helpnightclub)
        else:
            questlog.EndQuest(quest_helpnightclub)
        renpy.restart_interaction()

    def check_mall_events():
        if (quest_maihubby in questlog.quest_list
            and calendar.hours == 17
            and not store.mai_hubby_17_running
            and not repairroomunlocked):
            store.mai_hubby_17_running = True
            renpy.call("quest_maihubby_1700_event")

    def check_sandstorm_events():
        if (quest_waitoutstorm in questlog.quest_list
            and not bunker_discovered
            and calendar.day >= quest_waitoutstorm.start_day + quest_waitoutstorm.min_wait_days):
            renpy.call("militarycrash")
        else:
            return

    def check_home_rest_quest():
        """
        Appends the 'Go home and rest' quest at 20:00
        and auto-resolves it when the player wakes up (< 07:00).
        Intended to run from check_event or any time-tick function.
        """
        import renpy.store as store
        cal = store.calendar

        # Morning: resolve if still active
        if store.get_time_of_day() == "morning" and quest_homerest2 in questlog.quest_list:
            questlog.EndQuest(quest_homerest2, cal.day)

        # Evening: append if not yet done today
        elif cal.hours >= 20 and not (
            quest_homerest2.completed and quest_homerest2.completed_day == cal.day
        ):
            questlog.ResetQuest(quest_homerest2, reset_type="daily")
            questlog.StartQuest(quest_homerest2)


    # =========================
    # Detention
    # =========================
    def check_detention():
        wd = calendar.weekday()
        hr = calendar.hours
        if wd in WEEKDAYS and hr >= 18:
            if quest_school.started and not quest_school.completed and not store.detention and not timcaught_seen:
                store.detention = True
                if deanlove >= 20 and not deanhj_seen:
                    store.questlog.StartQuest(quest_talkdetention)
                elif mathteachlove >= 20 and not mathteachrevamp:
                    store.questlog.StartQuest(quest_talkdetention2)
            if quest_talkdetention in questlog.quest_list and timcaught_seen:
                store.questlog.EndQuest(quest_talkdetention)
                store.detention = False
            if quest_talkdetention2 in questlog.quest_list and mathteachrevamp:
                store.questlog.EndQuest(quest_talkdetention2)
                store.detention = False
            if quest_school in questlog.quest_list:
                store.questlog.EndQuest(quest_school)
            

    # =========================
    # Mom meals (check-in system)
    # =========================
    def check_mom_meals():
        import renpy.store as S
        hr = S.calendar.hours
        # ­¤¦Ā Skip meal checks entirely if therapy is unlocked
        if not (getattr(S, "quest_momcare", None)
            and S.quest_momcare.completed
            and not getattr(S, "momtherapyunlocked", False)):
                return
        # --- Breakfast cutoff (noon) ---
        if hr >= 12 and not S.action_happened_today("breakfast_resolved"):
            # If player already had breakfast, resolve the quest
            if S.action_happened_today("hadbreakfast_mom"):
                if hasattr(S, "quest_momcheckin"):
                    S.questlog.EndQuest(S.quest_momcheckin, S.calendar.day)

            # mark breakfast window as checked
            S.calendar.record_action("breakfast_resolved")

        # --- Dinner cutoff (20:00) ---
        if hr >= 20 and not S.action_happened_today("dinner_resolved"):
            if S.action_happened_today("hadbreakfast_mom") or S.action_happened_today("haddinner_mom"):
                # Player checked in at least once ŌåÆ resolve quest
                if hasattr(S, "quest_momcheckin"):
                    S.questlog.EndQuest(S.quest_momcheckin, S.calendar.day)
            else:
                # Skipped both ŌåÆ penalty
                S.momlove -= 1
                S.momdrunk = True
                if hasattr(S, "quest_momcheckin"):
                    S.questlog.EndQuest(S.quest_momcheckin, S.calendar.day)

            # mark dinner window as checked
            S.calendar.record_action("dinner_resolved")



    def check_work():
        import renpy.store as S
        hr = S.calendar.hours

        # Resolve once per day at/after 18:00 on weekdays only
        if hr < 18: 
            return
        if S.calendar.weekday() not in ("Monday","Tuesday","Wednesday","Thursday","Friday"):
            return
        if getattr(S, "managementunlocked", False):
            return  # caf├® path active ŌåÆ no office work penalty

        # Already resolved today?
        if S.action_happened_today("work_resolved"):
            return

        # If actually worked or excused, mark resolved
        if S.action_happened_today("worked_today") or S.action_happened_today("work_excused"):
            S.calendar.record_action("work_resolved")
            return

        # Otherwise: used to be a penalty, now just mark resolved
        S.calendar.record_action("work_resolved")





