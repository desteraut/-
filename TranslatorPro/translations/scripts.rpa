default spirit_choices = []

init python:
    import random
    import renpy.store as store

    SPIRIT_IMAGE_BASE = "images/spiritcircle"

    def spirit_image(key, state):
        return f"{SPIRIT_IMAGE_BASE}/{key}_{state}.png"

    def spirit_done(key):
        return getattr(store, f"{key}_spirit_done", False)

    def get_spirit_choices(limit=3):
        eligible = []

        for key, data in CHARACTERS.items():
            if spirit_done(key):
                continue
            if not is_spirit_eligible(key):
                continue
            if not renpy.has_label(f"spiritarc_{key}"):
                continue

            if not renpy.loadable(spirit_image(key, "idle")):
                continue

            eligible.append(key)

        # --- THIS IS THE IMPORTANT PART ---
        groups = {}
        for key in eligible:
            group = CHARACTERS[key].get("render_group", "default")
            groups.setdefault(group, []).append(key)

        # pick ONE per group
        selected = []
        for group_keys in groups.values():
            selected.append(random.choice(group_keys))

        # cap total just in case
        return selected[:limit]

    def is_spirit_eligible(key):
        eligible_flag = f"{key}_spirit_eligible"

        # If the flag exists AND is False ŌåÆ block
        if hasattr(store, eligible_flag) and not getattr(store, eligible_flag):
            return False

        # Otherwise ŌåÆ eligible
        return True

    def heal_spirit_eligibility():
        # Map: eligibility_flag ŌåÆ condition_flag
        rules = {
            "mom_spirit_eligible": "lesbianarc_seen",
        }

        for eligible_flag, condition_flag in rules.items():
            if getattr(store, condition_flag, False):
                if not getattr(store, eligible_flag, False):
                    setattr(store, eligible_flag, True)

    def corruption_bar_color(value):
        if value >= 150:
            return "#ff4444"   # red (danger)
        elif value >= 50:
            return "#66aaff"   # blue (neutral)
        else:
            return "#66ff88"   # green (safe)
    
    def reroll_spirits():
        if bag.get_item_count(cheesetoken) > 0:
            bag.remove_item(cheesetoken, 1)
            store.spirit_choices = get_spirit_choices()
            renpy.restart_interaction()

    def _init_spirit_choices(force=False):
        if force or not store.spirit_choices:
            store.spirit_choices = get_spirit_choices()
    

screen spiritscreen:
    tag spirit
    on "show" action [Function(setattr, store, "spirit_choices", get_spirit_choices()), Function(renpy.restart_interaction)]
    add "images/spiritcircle/spiritcirclebg.png"
    fixed:
        xsize 250
        ysize 38
        xalign 0.02
        yalign 0.05
        bar:
            value mccorruption
            range 200
            xsize 250
            ysize 38
            left_bar Solid(corruption_bar_color(mccorruption))
            right_bar Solid("#222222")

        text "Corruption: [mccorruption]":
            xalign 0.5
            yalign 0.5
            size 24
            color "#ffffffab"
            outlines [(1, "#000000aa", 0, 0)]
    
    fixed:
        xsize 250
        ysize 50
        xalign 0.02
        yalign 0.115

        vbox:
            spacing 14

            hbox:
                spacing 10
                yalign 0.5

                imagebutton:
                    idle "images/spiritcircle/refresh_idle.png"
                    hover "images/spiritcircle/refresh_hover.png"
                    xalign 0.0
                    yalign 0.5
                    sensitive bag.get_item_count(cheesetoken) > 0
                    action [
                        Function(reroll_spirits),
                        Play("sound", "audio/ui_reroll.ogg")
                    ]

                text "[bag.get_item_count(cheesetoken)] Cheese Tokens":
                    size 24
                    color "#ffffffb4"
                    outlines [(1, "#000000aa", 0, 0)]

            textbutton "Leave the spirits":
                xalign 0.5
                text_size 22
                background None
                action [SetVariable("current_location", "trailerpark"), Jump("game_loop")]


    on "show" action [Function(renpy.music.play, "audio/spiritambience.ogg", loop=True), SetVariable("current_location", "spiritrealm")]
    
    default SPIRIT_OFFSETS = {
        "A": {"xoffset": -75, "yoffset": 110},
        "B": {"xoffset": 125, "yoffset": 110},     
        "C": {"xoffset": 185, "yoffset": 110} 
    }

    for key in spirit_choices:
        $ render_group = CHARACTERS[key]["render_group"]
        $ offset = SPIRIT_OFFSETS[render_group]
        
        fixed:
            xalign 0.5
            yalign 0.5
            xoffset offset["xoffset"]
            yoffset offset["yoffset"]
            
            add Transform(spirit_image(key, "idle"), zoom=0.9)

    for key in spirit_choices:
        $ render_group = CHARACTERS[key]["render_group"]
        $ offset = SPIRIT_OFFSETS[render_group]
        
        fixed:
            xalign 0.5
            yalign 0.5
            xoffset offset["xoffset"]
            yoffset offset["yoffset"]
            
            imagebutton:
                idle Solid("#00000000", xysize=(1920, 1080))
                hover Transform(spirit_image(key, "hover"), zoom=0.9)
                focus_mask Transform(spirit_image(key, "idle"), zoom=0.9)
                style "spiritbutton"
                action Return(key)




label spirit_hub:
    python:
        if 'choice' in dir(store):
            try:
                delattr(store, 'choice')
            except:
                pass

    $ _init_spirit_choices(True)

label spirit_hub_loop:
    if spirit_choices:
        call screen spiritscreen
        if _return != "done":
            call expression f"spiritarc_{_return}" from _call_expression_9
            $ store.spirit_choices = get_spirit_choices()
            $ renpy.restart_interaction()
            jump spirit_hub_loop

    hide screen spiritscreen
    return









