    def build_location_pretty_names():
        pretty = {}

        # 1) City markers
        for x, y, key, label, jump_label in worldmap_markers:
            pretty[key] = label

        # 2) Desert markers
        for x, y, key, label, jump_label in worldmap_markers_desert:
            pretty[key] = label

        # 3) Location objects (sublocations / interiors)
        for name, obj in globals().items():
            if name in pretty:
                continue

            if isinstance(obj, Location):
                pretty[name] = obj.name

        return pretty


    # Build once
    location_pretty_names = build_location_pretty_names()

    def get_location_pretty_name(loc_key):
        """Get pretty name for any location key."""

        # ­¤öæ Valid non-location state (worldmap / between travel)
        if not loc_key:
            return "Traveling..."

        # 1) Check city markers
        for x, y, key, label, jump_label in worldmap_markers:
            if key == loc_key:
                return label

        # 2) Check desert markers
        for x, y, key, label, jump_label in worldmap_markers_desert:
            if key == loc_key:
                return label

        # 3) Check Location objects (sublocations)
        loc_obj = globals().get(loc_key)
        if loc_obj and hasattr(loc_obj, "name"):
            return loc_obj.name

        # 4) Fallback
        return loc_key.replace("_", " ").title()

    
    def get_open_worldmap_markers():
        """Return markers for all unlocked locations.
        Closed ones stay visible but are dimmed and flagged as not open.
        """
        result = []

        for m in worldmap_markers:
            loc_key = m[2]
            unlocked_flag = loc_key + "unlocked"

            # Always show home
            if loc_key == "home":
                open_now = is_location_open(loc_key)
                result.append((m[0], m[1], loc_key, m[3], m[4], open_now))
                continue

            # Skip if never unlocked
            if unlocked_flag in globals() and not globals()[unlocked_flag]:
                continue

            open_now = is_location_open(loc_key)
            result.append((m[0], m[1], loc_key, m[3], m[4], open_now))

        return result
    
    def get_opening_hours_text(loc_key):
        day = calendar.weekday()
        hours = location_hours.get(loc_key, {}).get(day)

        if not hours:
            return ""

        open_hour, close_hour = hours

        def fmt(h):
            return f"{int(h):02}:00"

        return f"Open: {fmt(open_hour)} - {fmt(close_hour)}"

    def get_location_display_name(location_key):
        """
        Returns the display name for a given location key.
        Priority:
        1. If a variable with this key exists and is a Location object, use its .name
        2. Else, use worldmap_markers label if present
        3. Else, return the key itself
        """
        # 1. Try Locations.rpy defaulted Location objects
        loc_obj = globals().get(location_key, None)
        if loc_obj is not None and hasattr(loc_obj, "name"):
            return loc_obj.name
        # 2. Try worldmap_markers
        for marker in worldmap_markers:
            if marker[2] == location_key:
                return marker[3]
        # 3. Fallback to key
        return location_key

    def get_open_desert_markers():
        result = []

        for m in worldmap_markers_desert:
            loc_key = m[2]
            unlocked_flag = loc_key + "unlocked"

            if unlocked_flag in globals() and not globals()[unlocked_flag]:
                continue

            open_now = is_location_open(loc_key)
            result.append((m[0], m[1], loc_key, m[3], m[4], open_now))

        return result

Made with Ren'Py.default bookhunt = False
