                scene shomedad04 with dissolve
                mc "Fine."
                mc "I guess I can do that."
                dad "What kind of answer is that?"
                smom "Oh stop it, honey."
                smom "I'm glad he is willing to help."
                scene shomedad05 with dissolve
                smom "And you...!"
                "She points at your stepbrother."
                smom "You better get your act together, or you're out of here!"
                dad "Hes just a kid, honey."
                smom "He's 20 years old, he can take care of himself."
                scene sbrother01 with dissolve
                sbro "So [name], you think you can help me out?"
                mc "I can arrange an interview for you."
                mc "The rest is up to you."
                scene sbrother02 with dissolve
                sbro "Thanks, I guess."
                sbro "Well let's go then."
                mc "Alright, alright."
                scene shomedad07 with dissolve
                mc "I'll take him to the coffeeshop."
                mc "But I can't promise anything."
                smom "That's all I ask, honey."
                scene 221 with dissolve
                smom "Oh and honey, can you bring me back an espresso from there?"
                mc "Sure, no problem."
                smom "Thank you so much!"
                mc "Bye!"
                smom "Bye sweetheart."
                "{color=#FFD700}New location unlocked: Coffeeshop.{/color}"
                $ smomlove += 5
                $ coffeeshopunlocked = True
                $ questlog.EndQuest(quest_familyreunion, calendar.day)
                $ questlog.StartQuest(quest_initcshophelp)
                $ questlog.StartQuest(quest_getcoffee)
                return
            "­¤Äü Give her a espresso." if havemet_smom and bag.has_item("espresso"):
                scene smomcoffee with dissolve
                smom "Ohh, thank you sweetie!"
                $ bag.remove_item("espresso")
                mc "You're welcome, [stepmom_name]!"
                $ questlog.EndQuest(quest_smomcoffee, calendar.day)
                scene smomcoffee2 with dissolve
                smom "I really needed this."
                smom "I love you, honey!"
                mc "I love you too, [stepmom_name]!"
                return
            "­¤ÅĘ’ĖÅ Change her name" if not quest_familyreunion in questlog.quest_list:
                call smom_rename from _call_smom_rename_1
                return
            "ŌØż’ĖÅ Be affectionate" if havemet_smom and smomlove >= 20 and calendar.can_perform_action("smom_affection"):
                $ calendar.record_action("smom_affection")
                jump smomaffection
            "Be affectionate" if havemet_smom and smomlove >= 20 and not calendar.can_perform_action("smom_affection"):
                smom "Let's not overdo it, honey!"
                return
            "­¤Æ¼ Small talk with her." if havemet_smom and calendar.can_perform_action("smom_smalltalk") and quest_familyreunion not in questlog.quest_list:
                $ calendar.record_action("smom_smalltalk")
                jump smomsmall
            "Small talk" if havemet_smom and not calendar.can_perform_action("smom_smalltalk"):
                smom "We already chatted a lot today, sweetie."
                return
            "Nevermind." if quest_familyreunion not in questlog.quest_list:
                return
    if aftermath and quest_visitsmom in questlog.quest_list:
        scene dadpaper2 
        dad "Look here guys..."
        dad "There is an ad saying $300 per night, no experience required. Night shift at the gas station on route 6."
