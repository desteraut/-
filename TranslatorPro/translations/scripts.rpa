Made with Ren'Py.screen courtscreen:
    tag court
    $ current_hub = "court"
    add "images/court/crowdcourt.webp"
    $ present = get_characters_at_location("court")
    on "show" action [Function(renpy.music.play, "audio/ambience.ogg", loop=True, fadein=0.5), SetVariable("current_hub", "court")]
    if (justice_dictonic or leaked_dictonic) and quest_courtdate in questlog.quest_list and calendar.weekday()=="Thursday":
        imagebutton auto "images/court/naomi_%s.png" focus_mask True action Call("naomicourt")
        imagebutton auto "images/court/wife_%s.png" focus_mask True action Call("wifecourt")
        imagebutton auto "images/court/judge_%s.png" focus_mask True action Call("judgecourt")
    else:
        imagebutton auto "images/court/jurydoor_%s.png" style "worldbutton" focus_mask True action [Hide("courtscreen"), SetVariable("current_location", "daoffice"), Return()]
        imagebutton auto "images/court/judgedoor_%s.png" style "worldbutton" focus_mask True action [Hide("courtscreen"), SetVariable("current_location", "judgechamber"), Return()]

screen judgechamberscreen:
    tag court
    $ current_hub = "court"
    add "images/court/judgeschamberbg.webp"
    $ present = get_characters_at_location("judgechamber")
    on "show" action [Function(renpy.music.play, "audio/mayorsoffice.ogg", loop=True, fadein=0.5), SetVariable("current_location", "judgechamber")]
    if "judge" in present:
        imagebutton auto "images/court/judge1_%s.png" focus_mask True action Call("judgemenu")


screen daofficescreen:
    tag court
    $ current_hub = "court"
    add "images/court/daofficebg.webp"
    $ present = get_characters_at_location("daoffice")
    on "show" action [Function(renpy.music.play, "audio/mayorsoffice.ogg", loop=True, fadein=0.5), SetVariable("current_location", "daoffice")]
    if "da" in present:
        imagebutton auto "images/court/da_%s.png" focus_mask True action Call("damenu")


