## Input screen ################################################################
##
## This screen is used to display renpy.input. The prompt parameter is used to
## pass a text prompt in.
##
## This screen must create an input displayable with id "input" to accept the
## various input parameters.
##
## https://www.renpy.org/doc/html/screen_special.html#input
screen input(prompt):
    frame:
        style "custom_input_window"
        xalign 0.5
        yalign 0.8
        padding (40, 30)

        vbox:
            spacing 10
            text prompt
            input

style input_prompt is default

style input_prompt:
    xalign gui.dialogue_text_xalign
    properties gui.text_properties("input_prompt")

style input:
    xalign gui.dialogue_text_xalign
    xmaximum gui.dialogue_width

## Choice screen ###############################################################
##
## This screen is used to display the in-game choices presented by the menu
## statement. The one parameter, items, is a list of objects, each with caption
## and action fields.
##
## https://www.renpy.org/doc/html/screen_special.html#choice
# -------------------------------------------------------------------------
# 1.  All sound path defines first (these are init 0)
# -------------------------------------------------------------------------
# --- UI sound definitions (works with sliders) ---
define ui_hover_sound = "audio/drop_003.ogg"
define ui_click_sound = "audio/select_008.ogg"
define ui_dooropen_sound  = "audio/dooropen.ogg"
define ui_doorclose_sound = "audio/doorclose.ogg"
define lever_hover_sound = "audio/lever_hover.ogg"
define lever_click_sound = "audio/lever_click.ogg"
define firewhoosh_sound = "audio/firewhoosh.ogg"
define whoosh_sound = "audio/whoosh.ogg"
define vendingbuttonhover = "audio/vendhover.ogg"
define vendbuttonsound = "audio/press.ogg"


# -------------------------------------------------------------------------
# 2.  Then your class + style setup (later init)
# -------------------------------------------------------------------------
init 10 python:
    import time

    class DebouncedHover:
        def __init__(self, sound, cooldown=0.2):
            self.sound = sound
            self.cooldown = cooldown
            self.last_time = 0.0

        def __call__(self):
            now = time.time()
            if now - self.last_time > self.cooldown:
                self.last_time = now
                renpy.sound.play(self.sound, channel="sound")

    # create instance *after* lever_hover_sound exists
    play_lever_hover = DebouncedHover(lever_hover_sound, cooldown=0.2)

    # style setup
    style.uibutton = Style(style.image_button)
    style.uibutton.hover_sound = ui_hover_sound
    style.uibutton.activate_sound = ui_click_sound

    style.worldbutton = Style(style.image_button)
    style.worldbutton.hover_sound = ui_dooropen_sound
    style.worldbutton.activate_sound = ui_doorclose_sound

    style.vendingbutton = Style(style.image_button)
    style.vendingbutton.hover_sound = None
    style.vendingbutton.activate_sound = lever_click_sound

    style.spiritbutton = Style(style.image_button)
    style.spiritbutton.hover_sound = whoosh_sound
    style.spiritbutton.activate_sound = firewhoosh_sound

    style.motelvendingbutton = Style(style.image_button)
    style.motelvendingbutton.hover_sound = vendingbuttonhover
    style.motelvendingbutton.activate_sound = vendbuttonsound
    
    style.insolvency_button = Style(style.menu_button)
    style.insolvency_button_text = Style(style.menu_button_text)

    # Make it slightly "danger" without screaming
    style.insolvency_button_text.color = "#b1b1b1"
    style.insolvency_button_text.hover_color = "#ff0000"
    style.insolvency_button_text.idle_color = "#ff7070"

transform menu_fade:
    alpha 0.0
    linear 0.25 alpha 1.0

screen choice(items):
    default lockout = True
    timer 0.25 action SetScreenVariable("lockout", False)

    vbox:
        spacing 1
        xalign 0.50
        yalign 0.5
        at menu_fade

        for i in items:
            if i.caption is not None:
                button:
                    action i.action
                    sensitive not lockout
                    background Frame("gui/button/idle_background.png", 20, 20)
                    hover_background Frame("gui/button/hover_background.png", 20, 20)
                    padding (30, 20)
                    xalign 0.5

                    text i.caption:
                        size 24
                        color "#FFFFFF"
                        hover_color "#66baff"
                        outlines [(1, "#000000", 0, 0)]
                        xalign 0.5
                        yalign 0.5






