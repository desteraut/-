        hooker2 "God he is so out of it already."
        scene clubdrinking3drunk with dissolve
        madame "Yeah, I'm cutting him off after this round."
        scene clubdrinking4drunk with dissolve
        "Unbeknownst to you, the ladies chatter amongst themselves as you toast obnoxiously loud."
        mc "TO ALL THE SEXY LADIES!!!"
        $ hooker1love += 6
        $ hooker2love += 6
        $ madamelove += 6
    elif drinkround > 1:
        scene clubdrinking1 with dissolve
        hooker1 "To friends!"
        scene clubdrinking2 with dissolve
        hooker2 "No, to very hot clients!"
        scene clubdrinking3 with dissolve
        madame "And to the barkeeper who keeps things going!"
        scene clubdrinking4 with dissolve
        mc "To beautiful company!"
        $ hooker1love += 4
        $ hooker2love += 4
        $ madamelove += 4
    else:
        scene clubdrinking1 with dissolve
        hooker1 "So, what are we drinking to, handsome?"
        scene clubdrinking2 with dissolve
        hooker2 "To bad decisions, obviously."
        scene clubdrinking3 with dissolve
        madame "And to whoever's paying for them, cheers!"
        scene clubdrinking4 with dissolve
        mc "That'd be me! Cheers!"
        $ hooker1love += 2
        $ hooker2love += 2
        $ madamelove += 2
    play sound "audio/ahh.ogg"
    "You finish the drink immediatly."
    if drinkround < 3:
        scene clubdrinking2 with dissolve
        madame "Another round, sweetie?"
        hooker1 "Let's see if you can keep up with us, heh."
        hooker2 "Of course we'll do another, right [name]?"
        menu:
            "­¤źé Buy another round ($16)":
                if bag.cash >= 16:
                    $ bag.spend(16)
                    $ drinkround += 1
                    jump drinkinggame
                else:
                    scene clubdrinking1 with dissolve
                    madame "I'm afraid mr. big spender can't afford another round..."
                    hooker1 "Too bad."
                    hooker2 "Just as I was starting to enjoy this a little..."
                    $ hooker1love -= 5
                    $ hooker2love -= 5
                    $ madamelove -= 5
                    return
    else:
        "As you finish your drink, the lights go out."
        madame "Oh boy, here he goes."
        scene black with slow_fade
        hooker1 "What do we do with him?"
        madame "I've got an idea."
        jump blackout

