label justicepath:
    scene judgeverdict with dissolve
    judge "Attention everyone... this court is now in session."
    scene black with slow_fade
    pause 0.5
    "The hearing begins. The District Attorney rises from her seat and adjusts her papers before speaking."
    # DA Opening
    scene courtda1 with dissolve
    da "Your Honor, the State will demonstrate that Mr. Dictonic knowingly distributed an unregulated substance, Vitalis. While concealing its effects from regulatory boards, the general public, and even his own employees."
    da "We will present evidence gathered from his warehouse, witness reports from victims of exposure, and statements from individuals coerced under his instruction."
    da "Furthermore, we intend to prove that the defendant intentionally manipulated both medical data and public officials to avoid oversight."
    scene courtda3 with dissolve
    da "Mr. Dictonic, step forward please."
    scene courtda4 with dissolve
    da "The State calls its first witness."
    mc "(Please don't let this be me...)"
    if justice_dictonic:
        scene courtda1 with dissolve
        da "The court will now review Exhibit C - the warehouse camera stills recovered during the investigation."
        scene courtda3 with dissolve
        mc "(Camera stills? What camera stills?)"
        da "These images show a young woman being escorted back into the warehouse by a male individual."
        mc "(Wait... a woman? Escorted back? By who?)"
        da "The man in question is the witness we're calling today - Timothy Hansen."
        scene timcourt2 with vpunch
        mc "(TIM?! What the hell?!)"
        mc "(He never said a word about this!)"
        judge "Mr. Hansen, please take your place and answer truthfully."
        scene timcourt1 with dissolve
        bff "Yes, your Honor. I always answer truthfully. Except when I'm lying. Which I won't! Today. I meanŌĆö"
        mc "(Tim... please...)"
        scene timcourt2 with dissolve
        da "Mr. Hansen, can you explain why you were seen entering Mr. Dictonic's warehouse on the night of the incident?"
        scene timcourt1 with dissolve
        bff "Right! Okay, funny story actually..."
        da "Just the facts, Mr. Hansen."
        bff "Right! So uh... I was on a date."
        judge "A date."
        bff "Yes! With a woman. An actual human woman. Real one. Verified."
        mc "(Tim...)"  
        bff "And she said she 'got out of the warehouse' so I figured.. wow, long commute, maybe she lives there?"
        scene timcourt2 with dissolve
        bff "So I returned her. Like... politely. Like you return a lost dog. But a person."
        mc "(OH MY GOD TIM.)"
        da "Mr. Hansen, are you stating that you delivered a young woman directly to Mr. Dictonic?"
        scene timcourt1 with dissolve
        bff "Well yeah! He said he was her daddy!"
        "Whispers ripple through the courtroom."
        judge "Mr. Hansen.... daddy?"
        bff "I KNOW! Well I know NOW! At the time I thought he meant... I don't know!"
        mc "(Tim is about to buy himself a first class ticket to jail...)"
        scene timcourt2 with dissolve
        da "The security footage shows you handing this woman to Mr. Dictonic before departing the premises."
        scene timcourt1 with dissolve
        bff "YES! BECAUSE I THOUGHT SHE LIVED THERE!!"
        bff "I didn't know it was likeŌĆöan actual crime scene! I thought it was like... quirky housing!"
        mc "(Quirky housing... kill me.)"
        judge "Mr. Hansen... are you aware that providing false testimony could result in felony obstruction charges?"
        scene timcourt3 with dissolve
        bff "F-F-FELONY?! No! I can't go to jail! I can't! I won't make it in there!"
        bff "I look too... squeezable!!"
        mc "(...What?)"
        mc "(He's gone full meltdown.)"
    pause 0.2
    # Brenda ambush
    brenda "Objection, your Honor!" with vpunch
    pause 0.2
    scene brendaambush1 with dissolve
    mc "(Brenda?!)"
    mc "(Oh boy... here we go again.)"
    judge "...Mrs. Winfield? You are not scheduled to testify today."
    brenda "I apologize, Your Honor, but the court deserves the truth. All of it."
    # CHAOS PATH VERSION
    if leaked_dictonic:
        scene courtdick2 with dissolve
        brenda "The public already knows what happened in that warehouse. The leaks made sure of that."
        brenda "But what they don't know is that Mr. Dictonic didn't act alone."
        judge "Mrs. Winfield... what are you implying?"
        brenda "Vitalis wasn't just a corporate experiment gone wrong. It was protected."
        brenda "Someone helped bury reports. Someone high enough to keep it off every official record."
        mc "(Everyone is staring... This is spiraling fast.)"
        brenda "And if we're dragging Dictonic into the light today, then we should be dragging the rest of them too."
        scene courtdick5 with dissolve
        boss "This is outrageous!"
        scene courtdick3 with dissolve
        da "Your Honor, the State was not aware of any such claim."
        scene courtdick1 with dissolve
        judge "Enough! Mrs. Winfield, you are out of order."
        scene courtdick2 with dissolve
        brenda "Then let me testify under oath."
        scene judgeverdict with dissolve
        judge "... This hearing will recess for thirty minutes."
        play sound "audio/gavel.ogg"
        scene judgelookleft with dissolve
        judge "Mr. Dictonic, you may step down for now."
        judge "Mrs. Winfield, District Attorney, please follow me to my chambers."
        scene judgelookright with dissolve
        judge "Everyone else, please remain seated."
        pause 0.2
        mc "(Brenda... What did you just do?)"
        $ questlog.EndQuest(quest_courtdate)
        scene black with slow_fade
        "Meanwhile in the judge's chamber..."
        scene recess1 with dissolve
        judge "Mrs. Winfield, I will be blunt. Barging into my courtroom with unscheduled testimony is not something I tolerate."
        brenda "Understood, Your Honor. But if I hadn't, the truth would have stayed buried."
        da "Mrs. Winfield, these are serious accusations. If you're claiming a cover-up, you'll need more than dramatic timing."
        brenda "Then let me provide it."
        scene recess2 with dissolve
        judge "Start talking. Clearly."
        brenda "Vitalis didn't just slip through the cracks. Someone held the cracks open. Someone with access to regulatory boards and law enforcement channels."
        scene recess1 with dissolve
        da "Do you have a name?"
        brenda "Fransesco Rodriguez."
        da "The city councilman?"
        brenda "He has worked for Dictonic for years, campaign donations, lobbying efforts... He made sure Vitalis stayed off the books."
        scene recess2 with dissolve
        judge "...Explain."
        brenda "Rodriguez funneled Vitalis reports directly to Dictonic. He suppressed injuries, erased inspections, and bribed two officers to keep the warehouse off record."
        scene recess3 with dissolve
        da "Your Honor... these signaturesŌĆö"
        judge "ŌĆöMatch Mr. Dictonic's financial disclosures."
        brenda "Every page. He wasn't just aware. He paid for the cover-up."
        judge "This is... overwhelming."
        da "Your Honor, this is enough to bypass the remainder of the hearing."
        judge "More than enough."
        judge "Mrs. Winfield, District Attorney, return to the courtroom. I'm delivering a verdict now."
        scene black with fade
        $ calendar.addtime(30)
        pause 0.5
        scene courtdick1 with dissolve
        judge "After reviewing the evidence and testimony presented, this court finds Mr. Dictonic..."
        mc "(Wait... what's happening?)"
        scene judgeverdict with dissolve
        judge "...GUILTY on ALL charges." with vpunch
        play sound "audio/gavel.ogg"
        "The courtroom erupts in a mixture of gasps and cheers."
        scene judgelookleft with dissolve
        pause 0.2
        scene judgelookright with dissolve
        pause 0.2
        mc "(Holy shit, Brenda... What did you just do?)"
        scene courtdick5 with dissolve
        boss "Your honor, this is an outrage!"
        judge "Mr. Dictonic, you will be remanded into custody immediately."
        pause 0.5
        judge "Case closed! Everybody, go home."
        scene black with slow_fade
        "With Dictonic in custody..."
        pause 0.2
        "Justice has been served."
        $ calendar.addtime(30)
        $ questlog.EndQuest(quest_courtdate) 
        $ dictonic_departed = True
        $ insider_departed = True 
        $ brenda_departed = False      
        jump courtaftermath
    # AUTHORITY / JUSTICE PATH VERSION
    elif justice_dictonic:
        scene courtdick1 with dissolve
        brenda "Your Honor, I have additional evidence related to Mr. Dictonic's warehouse operations."
        judge "Mrs. Winfield, this is highly irregular. The DA has not requested your testimony."
        brenda "I know. But the files I recovered were hidden behind a false wall. They weren't part of the original evidence sweep."
        mc "(...She actually found more?)"
        brenda "Your Honor, the documents contain test logs."
        brenda "Actual human test logs. Subjects taken in, dosed, monitoredŌĆ” none of them volunteers."
        scene courtdick2 with dissolve
        boss "LIES! None of that is admissible! I demand this be strickenŌĆö"
        brenda "Then perhaps the signatures will speak for themselves."
        brenda "Every single log is countersigned by Mr. Dictonic."
        brenda "Time, dosage, reactionsŌĆ” all confirmed in his handwriting."
        "Murmurs spread through the courtroom."
        scene courtdick3 with dissolve
        da "Your HonorŌĆ” if these signatures match confirmed samples, the State moves for an immediate ruling."
        judge "These signatures are identical to the defendant's disclosures."
        judge "Combined with the warehouse investigation, this constitutes direct proof of human experimentation and obstruction."
        boss "YOU CAN'TŌĆö"
        scene courtdick1 with dissolve
        judge "Silence."
        scene judgeverdict with dissolve
        judge "Given the defendant's verified signatures and the overwhelming evidence before this courtŌĆ”"
        pause 0.3
        judge "This court finds Mr. Dictonic..."
        judge "GUILTY on all charges."
        play sound "audio/gavel.ogg"
        "Gasps and shouting erupt throughout the courtroom."
        scene courtdick5 with dissolve
        boss "This is a travesty! I refuseŌĆö"
        judge "Bailiff. Take him into custody immediately."
        mc "(Holy shitŌĆ” Brenda really did it.)"
        scene black with slow_fade
        "With Dictonic in custody..."
        pause 0.2
        "Justice has been served."
        $ calendar.addtime(30)
        $ questlog.EndQuest(quest_courtdate)
        $ dictonic_departed = True
        $ insider_departed = True 
        $ brenda_departed = False 
        jump courtaftermath
    else:
        mc "(I shouldn't be here right now.)"
        return

label courtaftermath:
    mc "(I can't believe all that just happened.)"
    mc "(BrendaŌĆ” damn. She really did it.)"
    "As the reporters swarm the courthouse steps, you see Brenda break away from the crowd and head straight for you."
    scene arguement5 with dissolve
    brenda "Hey, [name]. You have a minute?"
    mc "Of course. What's wrong?"
    brenda "ŌĆ”Not out here. Come on."
    scene black with fade
    "You follow her into a nearby alley, away from everyone's eyes and microphones."
    scene alleybrenda1 with dissolve
    mc "Okay. What is it?"
    brenda "The evidence I used in court, it wasn't everything I found at the warehouse."
    mc "You held something back?"
    brenda "No. I just... couldn't figure out what to do with it."
    scene alleybrenda4 with dissolve
    brenda "Because it has nothing to do with Dictonic. Or Vitalis. Or any of this."
    mc "(What?)"
    scene alleybrenda2 with dissolve
    brenda "Behind the false wall, there was an old lockbox. Dusty. Rusted shut."
    brenda "It didn't match anything else in that room. Not the equipment. Not the files. Not the timeline."
    mc "SoŌĆ” what was in it?"
    scene alleybrenda3 with dissolve
    brenda "A map."
    brenda "But not a modern one. This thing lookedŌĆ” ancient."
    brenda "Hand-drawn. With notes from someone who sounded like they were losing their mind."
    mc "(ŌĆ”The desert again.)"
    scene alleybrenda1 with dissolve
    brenda "There was a symbol marked over a specific spot. Like a tear. Or a crack in reality. I don't know."
    brenda "And the person who wrote the notes kept referring to it as 'the veil'."
    brenda "Not a lab. Not a facility. Just... 'the veil'."
    mc "And you think this is important?"
    brenda "I think someone hid it for a reason."
    brenda "And it scares me more than anything Dictonic's done."
    scene alleybrenda4 with dissolve
    brenda "I need to know what's out there."
    brenda "But I can't go alone."
    mc "BrendaŌĆ” this could be dangerous."
    scene alleybrenda3 with dissolve
    brenda "I know."
    brenda "But something about this feels wrong. Older. Bigger. Like it was never meant to be found."
    brenda "Will you come with me?"
    menu:
        "ŌŁÉ Absolutely.":
            $ questlog.StartQuest(quest_portal)
            scene alleybrenda1 with dissolve
            brenda "Thank you."
            brenda "Here. These are the coordinates."
            $ veilunlocked = True
            brenda "Meet me there when you're ready."
            mc "I will."
            scene black with fade
            mc "(An old map. A strange symbol. And a spot out in the desertŌĆ”)"
            mc "(This isn't about Dictonic anymore.)"
            return


label courtclosed:
    hide screen worldmap
    "Court has closed."
    show screen worldmap
    return

label judgechamberclosed:
    hide screen worldmap
    scene judge1dialogue with dissolve
    judge "I'm going to have to ask you to leave."
    show screen worldmap
    return

label nojury:
    scene courtbg 
    mc "(I shouldn't go in there.)"
    returnMade with Ren'Py.default pickedup_coinpurse = False
default sadiediner_day = None

screen dinerscreen:
    tag diner
    $ present = get_characters_at_location("desert_diner")
    add "images/desert/diner/diner.webp"
    on "show" action [Function(renpy.music.play, "audio/diner.ogg", loop=True, fadein=0.5), SetVariable("current_location", "desert_diner")]
    if not pickedup_coinpurse:
        imagebutton auto "images/desert/coinpurse_%s.png" focus_mask True action Call("pickupcoinpurse")
    if "midnight" in present:
        imagebutton auto "images/desert/diner/midnight_%s.png" focus_mask True action Call("midnightinteraction")
    if "waitress" in present:
        imagebutton auto "images/desert/diner/waitressalt_%s.png" focus_mask True action Call("waitressdialogue")
    if sadiediner_day is not None and calendar.day >= sadiediner_day and "pclerk" in present:
        imagebutton auto "images/desert/diner/sadie_%s.png" focus_mask True action Call("sadiedialogue")
    imagebutton auto "images/desert/diner/door_%s.png" focus_mask True action [Hide("dinerscreen"), Show("desertmap")]

label diner_arrival:
    scene mcarrival with fade
    $ renpy.music.stop(fadeout=2.0)
    $ _skipping = True
    $ desert_intro_seen = True
    $ act2 = True
    $ calendar.advance_to_next_period("evening")
    "It's late, you've been driving until late. You arrive at a roadside diner that still seems to be open."
    mc "(Might aswell grab a bite to eat.)"
    scene black with fade
    return

label sadiedialogue:
    scene sadie1 with dissolve
    pclerk "What can I do for you, [name]?"
    menu:
        "­¤Æ” About Justin.":
            scene sadie2 with dissolve
            pclerk "We've pieced together that Justin hitched a ride on a delivery truck leaving the Say When restaurant."
            pclerk "Looked like he was helping out with the load."
            scene sadie3 with dissolve
            pclerk "Since then, we've been tracking his phone."
            pclerk "AndŌĆ” we do have a location."
            mc "Really? That's great news!"
            scene sadie4 with dissolve
            pclerk "Mm-hmŌĆ”"
            mc "So what's the address?"
            pclerk "Hold on now, nothing's free in this world."
            mc "You want money?"
            scene sadie5 with dissolve
            pclerk "Not money. Something else entirely. Come with me, and I'll explain."
            mc "UhŌĆ” okay?"
            jump sadieadult1
        "Nevermind.":
            return

