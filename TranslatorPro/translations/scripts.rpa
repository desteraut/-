    def process_inventory_for_customers():
        # Find max customers that can be served with all required items
        max_served = cafe_customers
        for item in cafe_inventory_pending.keys():
            max_served = min(max_served, cafe_inventory_pending[item])
        # Reduce inventory for each item by max_served
        for item in cafe_inventory_pending.keys():
            if cafe_inventory_pending[item] < max_served:
                renpy.notify(f"Out of {item}! Only {cafe_inventory_pending[item]} served.")
            cafe_inventory_pending[item] -= max_served
        # Update customers to max_served
        global cafe_customers
        cafe_customers = max_served

init python:
    # Fallback initialization for screen variables (prevents missing variable errors if screen is called with call screen)
    if 'new_menu_item_name' not in globals():
        new_menu_item_name = ""
    if 'new_menu_item_price' not in globals():
        new_menu_item_price = "2"

    def is_inventory_empty():
        # Returns True if any required inventory item is zero or less
        for item, qty in cafe_inventory_pending.items():
            if qty <= 0:
                return True
        return False

    def get_missing_inventory_items():
        # Returns a list of items with zero or less quantity
        return [item for item, qty in cafe_inventory_pending.items() if qty <= 0]

    def set_inventory_warning():
        missing = get_missing_inventory_items()
        if missing:
            persistent.inventory_empty_warning = f"Warning: Out of stock for: {', '.join(missing)}. No profit will be made!"
        else:
            persistent.inventory_empty_warning = ""

    # Call this before showing results or simulating
    def apply_inventory_penalty():
        # Only show warning, do not zero out profit/customers
        set_inventory_warning()


