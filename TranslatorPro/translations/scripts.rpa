label fortunedialogue:
    if bag.has_item("Token of Greed"):
        $ bag.remove_item("Token of Greed")
        scene fortuneteller with dissolve
        "The trailer squats at the end of the row, surrounded by broken lawn chairs, beer cans, and a one-legged flamingo wearing shades."
        fortune "If you're selling something, piss off. If you've got a token... get your ass in here."
