init python:
    queued_close_location = None
    queued_close_label = None

    def reset_daily_quests():
        persistent.cheese_call_today = False
        global schoolunlocked, officeworkunlocked, managementunlocked
        import renpy.store as store 
        try:
            from renpy.store import incoming_calls, check_calls
        except Exception as e:
            pass
        store.random_events_fired_today.clear()
        # Only trigger daily quests on weekdays (Monday-Friday)
        weekday = calendar.weekday()
        global has_controlled_weather
        has_controlled_weather = False
        store.momdrunk = False

        if quest_momcare.completed and not momtherapyunlocked and not exposuretherapy_seen:
            if not (quest_momcheckin.completed and quest_momcheckin.completed_day == calendar.day):
                questlog.ResetQuest(quest_momcheckin, reset_type="daily")
                questlog.StartQuest(quest_momcheckin)

        if gasday <= 5 and quest_askjustinshift.completed_day != calendar.day and quest_visitgas.completed:
            questlog.ResetQuest(quest_askjustinshift, reset_type="daily")
            questlog.StartQuest(quest_askjustinshift)
        elif gasday == 6 and not quest_justintrouble.completed:
            questlog.EndQuest(quest_askjustinshift, calendar.day)
            questlog.StartQuest(quest_justintrouble)

        

        # WEEKEND: kill school/work
        if weekday in ("Saturday", "Sunday"):
            if quest_work in questlog.quest_list:
                questlog.EndQuest(quest_work, calendar.day)
            if quest_school in questlog.quest_list:
                questlog.EndQuest(quest_school, calendar.day)
            if quest_inspirenovel in questlog.quest_list:
                questlog.EndQuest(quest_inspirenovel, calendar.day)
            if quest_momweeklytherapy in questlog.quest_list:
                questlog.EndQuest(quest_momweeklytherapy, calendar.day)
            if quest_takemomhome in questlog.quest_list:
                questlog.EndQuest(quest_takemomhome, calendar.day)
            if quest_gardenmanagement in questlog.quest_list:
                questlog.EndQuest(quest_gardenmanagement, calendar.day)
            if beachunlocked and not (feralpicunlocked or is_gallery_unlocked("smom_beach") or mathteachrevamp):
                questlog.ResetQuest(quest_thebeach)
                questlog.StartQuest(quest_thebeach)

        # WEEKDAYS
        else:
            store.worked_today   = False
            store.work_excused   = False
            store.work_resolved  = False
            if quest_thebeach in questlog.quest_list:
                questlog.EndQuest(quest_thebeach)
            # School quest for today (if not already completed today)
            if not (quest_school.completed and quest_school.completed_day == calendar.day):
                if not (timcaught_seen and mathteachrevamp and store.bag.has_item(schoolpass)):
                    questlog.ResetQuest(quest_school, reset_type="daily")
                    questlog.StartQuest(quest_school)
                    # ­¤öō Unlock the location immediately
                    schoolunlocked = True
            # Office job vs Caf├® management (fixed logic)
            if getattr(store, "mcfired", False):
                # Fired: ensure office quest is not active and keep office locked
                if quest_work in questlog.quest_list:
                    questlog.EndQuest(quest_work, calendar.day)
                officeworkunlocked = False

            if managementunlocked:
                # FIRST: Set up pending state from current state
                store.cafe_inventory_pending = dict(store.cafe_inventory)
                store.menu_prices_pending    = dict(store.menu_prices)
                store.cafe_staff_pending     = list(store.cafe_staff)
                store.cafe_marketing_pending = store.cafe_marketing
                store.cafe_event_pending     = store.cafe_event
                store.cafe_upgrade_pending   = store.cafe_upgrade

                # SECOND: Calculate today's customer count
                yesterday_customers = getattr(store, "cafe_customers", store.base_cafe_customers)
                rep = getattr(store, "cafe_reputation", 0)

                # Reputation tiers for momentum
                if rep < 20:
                    momentum_factor = 0.5   # keep 50% of yesterday
                elif rep < 40:
                    momentum_factor = 0.65  # keep 65%
                else:
                    momentum_factor = 0.75  # keep 75%

                # Apply momentum, but clamp between base and max cap
                CAFE_MAX_DAILY_CUSTOMERS = 1000
                store.cafe_customers = max(
                    store.base_cafe_customers,
                    min(int(yesterday_customers * momentum_factor), CAFE_MAX_DAILY_CUSTOMERS)
                )

                # THIRD: Run auto-day with the NEW customer count (this will restock then finalize)
                if cafe_auto_mode and weekday not in ("Saturday", "Sunday"):
                    run_cafe_auto_day()
                    renpy.notify("ŌśĢ Caf├® ran automatically.")

                # Caf├® path active
                if not (quest_gardenmanagement.completed and quest_gardenmanagement.completed_day == calendar.day):
                    questlog.ResetQuest(quest_gardenmanagement, reset_type="daily")
                    questlog.StartQuest(quest_gardenmanagement)

                persistent.end_day_results_shown = False

            else:
                # Office job path (only if NOT fired)
                if not (quest_work.completed and quest_work.completed_day == calendar.day):
                    questlog.ResetQuest(quest_work, reset_type="daily")
                    questlog.StartQuest(quest_work)
                    # ­¤öō Unlock office immediately
                    officeworkunlocked = True

    def check_midnight_branch_resolution():
        if (
            quest_homerest in questlog.quest_list and
            not midnight_branch_seen and
            (
                (quest_naomibait.completed_day and quest_naomibait.completed_day > 0 and calendar.day > quest_naomibait.completed_day + 1) or
                (quest_naomireturn.completed_day and quest_naomireturn.completed_day > 0 and calendar.day > quest_naomireturn.completed_day + 1)
            )
        ):
            print("AUTO RESOLVE TRIGGERED")
            questlog.EndQuest(quest_homerest, calendar.day)
            midnight_branch_locked = True
            questlog.StartQuest(quest_act2finale)




    def reset_weekly_quests():
        # Only trigger Mai's work quest if player has met Mai or completed quest_maihubby4
        if maiworkunlocked and not maifullscene_seen:
            if not quest_maiwork.completed_day == calendar.day:
                questlog.ResetQuest(quest_maiwork, reset_type="weekly")
                questlog.StartQuest(quest_maiwork)

        # mom's therapy trigger
        if momtherapyunlocked and not quest_momweeklytherapy.completed_day == calendar.day and not exposuretherapy_seen:
            questlog.ResetQuest(quest_momweeklytherapy, reset_type="weekly")
            questlog.StartQuest(quest_momweeklytherapy)


    if not hasattr(renpy.store, 'action_timestamps'):
        action_timestamps = {}

    class Calendar(renpy.store.object):
        '''Provides time-related information based on a sequence of day names.
        Most class methods take a daycount parameter, which is assumed to be a count
        of passed days, starting with 1 for the first day.
        newmoonday is the daycount of the first new moon, e.g. 1 for the first
        day.
        Provides date based on different logic (counter).
        '''
        def __init__(self, hours=24, minutes=0, day=1, month=1, year=1):
            self.hours = hours
            self.minutes = minutes
            self.day = day
            self.month = month
            self.year = year

            self.days = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"]
            self.month_names = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July',
                                            'August', 'September', 'October', 'November', 'December']
            self.days_count = [0, 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
            self.mooncycle = 29
            self.newmoonday = 1

        def string(self):
            return "%s %s, %s %d, %d" % (
                self.weekday(),
                get_time_of_day().capitalize(),
                self.month_names[self.month],
                self.day,
                self.year
            )
            
        def addtime(self, minutes):
            global repeatables_enabled
            global day
            self.minutes += minutes
            # Add hours from minutes
            extra_hours = self.minutes // 60
            self.minutes = self.minutes % 60
            prev_hour = self.hours
            prev_day = self.day
            prev_month = self.month
            prev_year  = self.year
            self.hours += extra_hours
            # Add days from hours
            extra_days = self.hours // 24
            self.hours = self.hours % 24
            self.day += extra_days
            day += extra_days
            if not repeatables_enabled and extra_days > 0:
                repeatables_enabled = True
            # Handle month and year rollover
            while self.day > self.days_count[self.month]:
                self.day -= self.days_count[self.month]
                self.month += 1
                if self.month > 12:
                    self.month = 1
                    self.year += 1

            # Trigger event checks for each hour advanced
            import renpy.store as store

            rolled_over_midnight = False

            for i in range(1, extra_hours + 1):
                prev_h = (prev_hour + i - 1) % 24
                new_h  = (prev_hour + i) % 24

                store.calendar.hours = new_h

                # detect midnight tick (00) during this advance
                if new_h == 0:
                    rolled_over_midnight = True

                # your hourly checks
                midnight_deadline_check(prev_h, new_h)

                if hasattr(store, "check_work"):
                    store.check_work()

            # after the loop, fire daily reset once if we crossed 00 at any step
            # after the loop, once:
            if rolled_over_midnight and hasattr(store, 'reset_daily_quests'):
                if not act2:
                    return
                store.reset_daily_quests()
                midnight_last_bark.pop("deadline_warn", None)

                # If one was active/offered, fail it first
                if mischief_current and mischief_current.get("status") in ("offered", "active"):
                    fail_dare()

                # Always assign a new one for the new day
                assign_random_dare()

            if hasattr(store, 'check_event') and repeatables_enabled:
                store.check_event()
                if hasattr(store, "maybe_run_pending_event"):
                    store.maybe_run_pending_event()


            renpy.restart_interaction()
            post_time_change("addtime")

        def skipday(self):
            global repeatables_enabled
            global day
            self.day += 1
            if not repeatables_enabled:
                repeatables_enabled = True
            day += 1
            self.hours = 7
            try:
                pass
            except Exception:
                pass
            if self.day > self.days_count[self.month]:
                self.day = 1
                self.month += 1
            # Trigger event checks at start of new day
            import renpy.store as store
            if hasattr(store, 'check_event'):
                store.check_event()
            
            if self.month > 12:
                self.month = 1
                self.year += 1

            post_time_change("skipday")

        def _date_to_ordinal(y, m, d):
            """Turn (year,month,day) into a simple day index using your calendar table."""
            days = 0
            for yy in range(1, y):
                for mm in range(1, 13):
                    days += calendar.days_count[mm]
            for mm in range(1, m):
                days += calendar.days_count[mm]
            return days + d

        def weekday(self):
            '''Returns the name of the current day according to daycount.'''
            dayidx = day
            daylistidx = dayidx % len(self.days)
            return self.days[daylistidx]

        def short_string(self):
            day = self.weekday()[:3]
            month = self.month_names[self.month][:3]
            daynum = self.day
            t = self.time()
            return f"­¤Ģō {day}, {month} {daynum} ŌĆó {t}"

        def time(self):
            return str(self.hours) + ":" + str(self.minutes).zfill(2)

        def can_perform_action(self, action_name):
            last_day = action_timestamps.get(action_name)
            if last_day is None:
                return True
            return last_day != self.day

        def record_action(self, action_name):
            '''Records that the action was performed at the current day.'''
            action_timestamps[action_name] = self.day
            for npc, rules in schedule_override_rules.items():
                for rule in rules:
                    if rule["flag"] == action_name:
                        setattr(store, action_name, True)

        def advance_to_next_period(self, target="morning"):
            order = ["morning", "afternoon", "evening", "night"]
            now = get_time_of_day()
            if target not in order:
                return
            i_now = order.index(now)
            i_target = order.index(target)
            if i_target <= i_now:
                self.day += 1
            if target == "morning":
                self.hours = 7
            elif target == "afternoon":
                self.hours = 12
            elif target == "evening":
                self.hours = 18
            elif target == "night":
                self.hours = 23
            self.minutes = 0
            post_time_change("advance_to_next_period")

init python:
    import renpy.store as store
    _time_change_lock = False

    # Run once per week (so Monday doesnŌĆÖt double/triple reset).
    if not hasattr(store, "_last_week_reset_key"):
        store._last_week_reset_key = None

    def _week_key():
        # If you don't track years, day//7 is fine as a stable week bucket.
        return store.calendar.day // 7

    def refresh_hud():
        try:
            store.show_date = True             # your HUD gate
            renpy.show_screen("date_overlay")
            renpy.show_screen("tooltips")
            renpy.restart_interaction()        # ensures on-screen data updates
        except Exception as e:
            renpy.log(f"[hud] refresh error: {e}")

    def post_time_change(context="time"):
        global _time_change_lock
        if _time_change_lock:
            return

        _time_change_lock = True
        try:
            # --- Daily reset (once per new day) ---
            if not hasattr(store, "_last_reset_day") or store._last_reset_day != store.calendar.day:
                reset_daily_quests()                  # your existing function
                store._last_reset_day = store.calendar.day

                # (Optional) If you have any "overdue call recovery", do it here.
                # recover_overdue_calls()

            # --- Weekly reset (guarded) ---
            try:
                if store.calendar.weekday() == "Monday":
                    wk = _week_key()
                    if store._last_week_reset_key != wk:
                        reset_weekly_quests()         # your existing function
                        store._last_week_reset_key = wk
            except Exception as e:
                renpy.log(f"[time] weekly reset skipped: {e}")

            # --- Rebuild markers/waypoints ---
            for fn in ("rebuild_all_markers", "rebuild_worldmap_markers", "rebuild_desert_markers"):
                try:
                    getattr(store, fn)()
                except Exception:
                    pass

            # --- (Optional) Recompute schedules if you expose such a function ---
            try:
                if hasattr(store, "recalculate_schedule"):
                    store.recalculate_schedule()
            except Exception as e:
                renpy.log(f"[time] schedule recompute skipped: {e}")

            # --- Process queued/firable calls LAST, on fresh state ---
            try:
                check_calls()
            except Exception as e:
                renpy.log(f"[time] check_calls error: {e}")

            # --- Refresh HUD once per post-time-change ---
            refresh_hud()

        finally:
            _time_change_lock = False

        try:
            check_cheese_call()
        except Exception:
            # fail closed so time changes never crash
            pass





