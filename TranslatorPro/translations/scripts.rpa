    ]
    scene studio2 with dissolve
    photolady "My, my. Who do we have here?!"
    mc "The name is [name]."
    scene studio3 with dissolve
    photolady "Are you here to model, [name]?"
    menu:
        "ŌŁÉ About Mrs. Burley" if quest_catwalk in questlog.quest_list:
            photolady "Oh, a new model?"
            photolady "That sounds interesting."
            mc "She just wants a try-out."
            scene studio5 with dissolve
            photolady "Did you talk to Felicia about it?"
            mc "Who is Felicia?"
            scene studio6 with dissolve
            photolady "She's the boss, you can find her at the Cum'n Go."
            scene studio7 with dissolve
            photolady "Without her approval, I can't do it."
            mc "Right, I'll talk to her first."
