default quests = Questlog()

screen quest_update_tick():
    if _quest_update_pending:
        timer 0.01 action Function(_quest_update_handler)

label _scheduled_quest_runner(varname):

    python:
        import renpy.store as S
        import renpy.exports as rex

        quest_obj = getattr(S, varname, None)

        data = getattr(S, "scheduled_quest_lastdata", None)

        S.questlog._apply_scheduled_quest(quest_obj, data)

    return

init python:
    auto_register_quests()

    def heal_quests():
        import renpy.store as S

        # Ensure quest_list exists
        if not hasattr(S.questlog, "quest_list"):
            S.questlog.quest_list = []
        
        if not ALL_QUESTS:
            auto_register_quests()
        
        # List of deleted quest variable names
        deleted_quest_vars = [
            "quest_elkegarden",
            "quest_maihubbyend",
        ]
        
        # Remove deleted quests
        for quest_var in deleted_quest_vars:
            if hasattr(S, quest_var):
                old_quest = getattr(S, quest_var)
                if old_quest in S.questlog.quest_list:
                    S.questlog.quest_list.remove(old_quest)
                if hasattr(S, 'tracked_quest') and S.tracked_quest is old_quest:
                    S.tracked_quest = None
                delattr(S, quest_var)
        
        renpy.log(f"Quests in list: {len(S.questlog.quest_list)}")
        for q in S.questlog.quest_list:
            renpy.log(f"  - {getattr(q, 'base_name', 'NO NAME')} (id: {id(q)})")
        
        updated_count = 0
        for qname in ALL_QUESTS.keys():
            store_quest = getattr(S, qname, None)
            
            if store_quest and store_quest in S.questlog.quest_list:
                renpy.log(f"Found {qname} in quest list (id: {id(store_quest)})")

                import os, re
                script_path = os.path.join(config.gamedir, "questlog.rpy")
                
                if os.path.exists(script_path):
                    with open(script_path, 'r', encoding='utf-8') as f:
                        content = f.read()
                    
                    pattern = rf'^default\s+{qname}\s*=\s*Quest\((.*?)\)$'
                    match = re.search(pattern, content, re.MULTILINE)
                    
                    if match:
                        quest_params = match.group(1)
                        renpy.log(f"Found definition: Quest({quest_params[:100]}...)")
                        
                        try:
                            # Create fresh quest to get current values
                            new_quest = eval(f"Quest({quest_params})", {"Quest": Quest})
                            
                            old_base_name = store_quest.base_name
                            
                            # Update the stored quest
                            store_quest.base_name = new_quest.base_name
                            store_quest.base_description = new_quest.base_description
                            store_quest.category = new_quest.category
                            store_quest.loc_key = getattr(new_quest, 'loc_key', None)
                            store_quest.npc_key = getattr(new_quest, 'npc_key', None)
                            store_quest.min_wait_days = getattr(new_quest, 'min_wait_days', 0)
                            store_quest.required = getattr(new_quest, 'required', 0)
                            store_quest.checkpoint = getattr(new_quest, "checkpoint", False)
                            store_quest.checkpoint_name = getattr(new_quest, "checkpoint_name", None)

                            renpy.log(f"Updated {qname}: '{old_base_name}' -> '{store_quest.base_name}'")
                            
                            store_quest.update_desc()
                            updated_count += 1
                        except Exception as e:
                            renpy.log(f"Failed to update {qname}: {e}")
        
        renpy.log(f"Updated {updated_count} active quests")
        
        for qname in ALL_QUESTS.keys():
            qobj = getattr(S, qname, None)
            if qobj:
                for attr, default in [
                    ("available", False),
                    ("started", False),
                    ("completed", False),
                    ("completed_day", 0),
                    ("start_day", 0),
                    ("progress", 0),
                ]:
                    if not hasattr(qobj, attr):
                        setattr(qobj, attr, default)
        
        valid_quest_objects = set()
        for qname in ALL_QUESTS.keys():
            q = getattr(S, qname, None)
            if q:
                valid_quest_objects.add(q)
        
        fixed = []
        for q in S.questlog.quest_list:
            if isinstance(q, Quest) and q in valid_quest_objects:
                fixed.append(q)
        
        S.questlog.quest_list = fixed
        
        if hasattr(S, 'tracked_quest') and S.tracked_quest is not None:
            if S.tracked_quest not in valid_quest_objects:
                S.tracked_quest = None

