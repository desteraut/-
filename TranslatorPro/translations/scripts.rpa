label detentiongirlnorespect:
    $ renpy.block_rollback()
    $ detentiongirl_norespect = True
    scene emmadialogue1 with dissolve
    $ detentiongirllove -= 5
    detentiongirl "Ugh, don't be pathetic."
    scene emmadialogue3 with dissolve
    detentiongirl "Don't you think I would have already told the dean if I wanted to?"
    mc "...I guess you're right."
    scene emmadialogue4 with dissolve
    detentiongirl "So here's the deal."
    detentiongirl "I will keep quiet about this, but you owe me."
    detentiongirl "That means, when I call you, you better show up."
    mc "(She means business...)"
    mc "Alright, deal."
    detentiongirl "Good."
    $ questlog.EndQuest(quest_meetdetentiongirl)
    $ questlog.StartQuest(quest_waitdetentiongirl)
    $ schedule_call("detentiongirl", "incomingcall_detentiongirl", day=calendar.day + 2, hours=22)
    return

label detentiongirlrespect:
    $ renpy.block_rollback()
    $ detentiongirl_respect = True
    scene emmadialogue4 with dissolve
    $ detentiongirllove += 5
    detentiongirl "Hmph. I guess I can respect that."
    mc "(She seems surprised.)"
    mc "...So what now?"
    scene emmadialogue2 with dissolve
    detentiongirl "Don't worry, I won't say anything."
    detentiongirl "But you owe me."
    mc "Right."
    scene emmadialogue4 with dissolve
    detentiongirl "Go on now, I've got places to be."
    mc "Alright."
    $ questlog.EndQuest(quest_meetdetentiongirl)
    $ questlog.StartQuest(quest_waitdetentiongirl)
    $ schedule_call("detentiongirl", "incomingcall_detentiongirl", day=calendar.day + 2, hours=22)
    return

label detentiongirlmenu:
    scene emmadialogue3 with dissolve
    detentiongirl "What do you want from me?"
    menu:
        "ŌŁÉ Ask about the cam." if havemet_detentiongirl and quest_meetdetentiongirl in questlog.quest_list and schoolcaminstalled and act2aftermath:
            scene emmadialogue2 with dissolve
            detentiongirl "Oh... you're the one who put that camera in there?"
            menu:
                "­¤Æ¼ Admit it.":
                    $ renpy.block_rollback()
                    scene emmadialogue4 with dissolve
                    mc "Yes, I am."
                    mc "I was hoping to get some spicy footage, but I didn't expect... this."
                    scene emmadialogue2 with dissolve
                    detentiongirl "You pervs are all the same, thinking with your dicks."
                    detentiongirl "What would you have done if I had told the dean about this?"
                    mc "(Damn... I need to think fast.)"
                    $ timed_menu_jump([
                        ("Please don't rat me out!", "detentiongirlnorespect", True),
                        ("I would've denied it.", "detentiongirlrespect", False)
                    ], timeout=3.0)
                "­¤Æ¼ Apologise.":
                    $ renpy.block_rollback()
                    scene emmadialogue1 with dissolve
                    detentiongirl "I don't want your pity."
                    detentiongirl "You should be grateful I didn't report you..."
                    mc "(Damn... She's right.)"
                    mc "(She could have gotten me into a lot of trouble.)"
                    mc "Thank you for that. I appreciate it."
                    mc "And I really am sorry, I didn't mean any harm."
                    $ detentiongirllove -= 5
                    scene emmadialogue3 with dissolve
                    detentiongirl "Then, why would you hang a camera in a bathroom stall?"
                    mc "(She's right... I need to be honest with her.)"
                    return
        "­¤Æ¼ Talk about detention.":
            scene emmadialogue1 with dissolve
            detentiongirl "What's it to you?"
            mc "Nothing, I'm just curious why I keep seeing you in detention."
            scene emmadialogue4 with dissolve
            detentiongirl "Because you keep getting in trouble, duh..."
            mc "(...)"
            mc "Right."
            mc "(I probably shouldn't push this.)"
            return
        "­¤Äü Gift.":
            scene emmadialogue1 with dissolve
            menu:
                "­¤ź¢ Give Emma a cinnamon roll.":
                    if bag.has_item(cinnamonroll):
                        scene emmadialogue2 with dissolve
                        detentiongirl "I love these."
                        mc "I'm glad you like it."
                        $ bag.remove_item(cinnamonroll)
                        $ detentiongirllove += 10
                        return
                    else:
                        mc "(I don't have a cinnamon roll to give her right now.)"
                        jump detentiongirlmenu
                "­¤Ź® Give Emma a donut.":
                    if bag.has_item(donut):
                        scene emmadialogue2 with dissolve
                        detentiongirl "I love these."
                        mc "I'm glad you like it."
                        $ bag.remove_item(donut)
                        $ detentiongirllove += 10
                        return
                    else:
                        mc "(I don't have a donut to give her right now.)"
                        jump detentiongirlmenu
                "Nevermind.":
                    jump detentiongirlmenu
        "Nevermind.":
            return

label deaninterfere:
    scene black with fade
    $ deaninterfere_seen = True
    pause 0.5
    scene deanfollowup1 with dissolve
    "As you walk into the school, you notice Emma walking out of the Dean's office. She winks at you as she passes by."
    mc "(What was that about?)"
    scene deanfollowup2 with dissolve
    dean "[name], can I have a word?"
    mc "(She looks serious, did Emma just... tell her?)"
    scene deanfollowup3 with dissolve
    dean "So [name], I heard what you did and-"
    mc "(Oh no... She knows everything.)"
    $ timed_menu_jump([
        ("Apologise and tell the truth.", "deanpunishment", True),
        ("Don't say a word.", "deanpunishmentalt", False)
    ], timeout=2.0)

label deanpunishment:
    $ renpy.block_rollback()
    scene deanbj8 with dissolve
    dean "You planted a camera in the school bathroom?"
    mc "...Yeah."
    dean "You're a naughty boy, [name]."
    dean "Let me show you what happens to naughty boys."
    $ mccorruption -= 5
    scene black with fade
    "She leaves the room for a moment, returning shortly after wearing a new outfit."
    jump deanspanking

label deanpunishmentalt:
    $ renpy.block_rollback()
    scene deanbj8 with dissolve
    dean "I want to thank you for being such a good friend to Tim."
    mc "(Wait, what?)"
    mc "Tim? Right... of course."
    mc "I mean, he's my best friend after all."
    if dean_silent:
        dean "But you did take advantage of me earlier."
        dean "You're a naughty one, [name]."
        dean "I need to teach you a lesson."
    else:
        dean "But I have to make sure you will keep your end of the bargain."
    $ mccorruption += 5
    dean "Wait here, I have something for you."
    scene black with fade
    "She leaves the room for a moment, returning shortly after wearing a new outfit."
