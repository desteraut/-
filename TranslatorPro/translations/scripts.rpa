    def hire_staff(candidate_name):
        global cafe_money_pending, cafe_staff_pending
        if candidate_name not in cafe_staff_pending and len(cafe_staff_pending) < STAFF_CAP:
            # Find candidate's salary
            salary = 0
            for c in staff_candidates:
                if c["name"] == candidate_name:
                    salary = c["salary"]
                    break
            if cafe_money_pending >= salary:
                cafe_staff_pending.append(candidate_name)
                cafe_money_pending -= salary
            else:
                renpy.notify("Not enough money to hire this staff member!")

    def fire_staff(candidate_name):
        global cafe_money_pending
        if candidate_name != get_cafe_owner() and candidate_name in cafe_staff_pending:
            # Refund salary for fired staff (since not finalized yet)
            salary = 0
            for c in staff_candidates:
                if c["name"] == candidate_name:
                    salary = c["salary"]
                    break
            cafe_staff_pending.remove(candidate_name)
            cafe_money_pending += salary

