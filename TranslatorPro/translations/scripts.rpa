label scienceclass:
    if havemet_scienceteach == False:
        $ meet_character("havemet_scienceteach", "images/school/scienceclass/Scienceteachmeet.webm", 3.0)
    scene sc1 with dissolve
    "You arrive at your science class."
    "Only a few other students are attending the class as you quietly wait for your teacher, Mrs. Russell."
    scene scienceteach5 with dissolve
    mc "There she is..."
    scienceteach "Hello class!"
    "She takes off her white coat, before adressing you."
    scene scienceteach4 with dissolve
    scienceteach "I see a lot of people have shown up for class today."
    scienceteach "You youngsters don't want to know how this world works these days huh?!"
    mc "She is quite sarcastic..."
    scene scienceteach2 with dissolve
    scienceteach "Anyways, class in session!"
    "As she quickly gets to the point you start to realise she is quite passionate about science."
    scene scienceteach3 with dissolve
    "Before you know it, 2 hours have passed and class is ending."
    scene scienceteach4 with dissolve
    play sound "audio/schoolbell.ogg"
    scienceteach "That'll be all for today, I'll see you guys next tuesday!"
    scene expression "images/school/scienceclass/scienceteach.webp" with dissolve
    "Mrs. Russell puts on her white coat and ponders away on the chemical qualities of the extracts in front of her."
    mc "(Damn, I guess she really is passionate about her job...)"
    $ calendar.addtime (120)
    $ scienceteachlove += 5
    $ questlog.EndQuest(quest_school, calendar.day)
    if detention:
        $ current_location = "detentionclass"
        jump detentionclass
    else:
        return



label mathclasses:  
    $ calendar.record_action("mathclasses")
    scene 264 with dissolve
    mathteach "Alright class!"
    mathteach "Open your books and go to page 264"
    scene 265 with dissolve
    mathteach "And then you divide the result by the outcome of the sum and multiply it by the number of people working there."
    mc "(*yawns* so boring!)"
    "You daydream for awhile."
    scene 267 with dissolve
    "As the class goes on, you're barely paying attention."
    "Before you know it, class is over."
    $ calendar.addtime (120)
    scene 266 with dissolve
    play sound "audio/schoolbell.ogg"
    mathteach "Hey! Quit it back there!"
    mathteach "Class is dismissed for the day!"
    mathteach "I will see you guys tomorrow."
    $ mathteachlove += 5
    $ questlog.EndQuest(quest_school, calendar.day)
    if detention:
        $ current_location = "detentionclass"
        jump detentionclass
    else:
        return

label detentionclass:
    scene black with fade
    "The dean takes you to one of the old classrooms."
    scene detention03 with dissolve
    if havemet_dean == False:
        $ meet_character("havemet_dean", "images/school/detention/Deanmeet.webm", 3.0)
    dean "[name], please take a seat."
    dean "I will bring your task shortly."
    mc "Alright."
    scene detention04 with dissolve
    dean "And light up!"
    dean "It's only detention, right?"
    mc "I guess?"
    "You take your seat and wait patiently for the dean to give you something to do."
    scene detention05 with dissolve
    "Contrary to your expectations, she is actually quite pleasant about the detention."
    "And even takes the time to talk to your fellow classmates."
    "Before you know it, 2 hours have passed and detention is over."
    $ calendar.addtime (120)
    scene detention06 with dissolve
    play sound "audio/schoolbell.ogg"
    dean "Right guys, pack your stuff."
    dean "It's time to go home."
    mc "(Why is that girl staring at me as if shes pissed at me?)"
    mc "(Ugh, lets just get out of here.)"
    dean "[name] One moment please!"
    scene detention02 with dissolve
    mc "Yes, Mrs Brown?"
    dean "Look, I don't mind you skipping classes every once in awhile."
    dean "Just don't make it a habit, alright?"
    mc "(What's happening?)"
    mc "Alright?"
    dean "You may go now."
    scene detention01 with dissolve
    mc "(Wasn't that a little weird?)"
    mc "(A dean telling her students its okay to skip class?)"
    mc "(Hmph, let's go home...)"
    $ deanlove += 5
    $ detention = False
    $ questlog.EndQuest(quest_talkdetention, calendar.day)
    return

label deansoffice:
    scene deansoffice with dissolve
    "This is the deans office!"
    mc "I better get out of here before I'm being questioned."
    return

label timdialogue:
    
    if detention and deanlove >= 20 and not sisterreveal:
        scene timevent1 with dissolve
        bff "Bro, did you see the dean around?"
        mc "I didn't, why?"
        scene timevent2 with dissolve
        bff "No reason, I'm just wondering ha ha!"
        mc "(He seems nervous about something...)"
        mc "What's up, Tim?"
        scene timevent3 with dissolve
        bff "Okay look, she can't know that I've been skipping class alright?"
        mc "Tim... She's the dean, I'm pretty sure she knows."
        bff "You don't understand, I..."
        scene timevent4 with dissolve
        dean "Hey Tim, [name]!"
        "Tim freezes..."
        pause 0.5
        mc "Hey ma'am!"
        scene timevent5 with dissolve
        dean "Avoiding me, nephew?"
        mc "(Nephew??)"
        bff "I wasn't... I..."
        dean "Don't bother."
        dean "If you think I don't know what you're doing young man, you're even more na├»ve than my sister."
        dean "By the way, how is Naomi?"
        mc "(Oh wow...)"
        bff "She's doing well, I..."
        scene timevent6 with dissolve
        "Without giving Tim a chance to put another word in, she sends him to class."
        dean "And you better get those grades up if you don't want her knowing!"
        bff "Yes ma'am..."
        scene timevent7 with dissolve
        dean "[name], why don't you join me in my office?"
        dean "We can talk about your detention."
        mc "Alright..."
        $ calendar.record_action("classeswith_bff")
        $ sisterreveal = True
        return
    else:
        scene schoolcorridor2 with dissolve
        bff "[name]!"
        mc "Oh, hey Tim."
        scene schoolcorridor3 with dissolve
        bff "Ready to go to class?"
        mc "Yeah... I guess."
        scene schoolcorridor4 with dissolve
        bff "What are we waiting for, let's go!"
        mc "(Jeez, someone's eager to go...)"
        $ calendar.record_action("classeswith_bff")
        return

label checkbook:
    scene mcread with dissolve

    $ redheadmoneyshot_images = [
        "images/desert/redheadg8glowup.png"
    ]

    $ roll = renpy.random.randint(1, 100)

    # --- MONEY ---
    if roll <= 50:
        $ amount = renpy.random.randint(5, 20)
        $ bag.earn(amount)
        "Tucked between a few books, you find [amount] dollars."

    # --- PICTURE ---
    else:
        $ locked_images = [img for img in redheadmoneyshot_images if img not in unlocked_pictures]

        if locked_images:
            "Something slips out from between the pages of an old book."

            $ img = renpy.random.choice(locked_images)
            $ unlocked_pictures.append(img)

            mc "Whoa, what's this?"
            show redheadg8glowup2
            pause 1.0
            "You've unlocked a new picture in your gallery."
        else:
            "You check the shelves carefully, but there's nothing else hidden here."
    return


label schoolclosed:
    hide screen worldmap
    scene timevent7 with dissolve
    dean "I'm sorry, [name]..."
    dean "I'm afraid I'm gonna have to ask you to leave, the school is closed for today."
    show screen worldmap
    return

