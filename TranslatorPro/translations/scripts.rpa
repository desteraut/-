label scienceteach_incoming_call(call=None):
    scene mccall with dissolve
    scienceteach "[name]!!!"
    mc "What's up? Is something wrong?"
    scienceteach "I need you to cum.. I mean..."
    scienceteach "I need you to come to the pharmacy..."
    mc "What, wh-"
    scienceteach "Ju-just come, please. I can't wait any longer!!"
    "The call ends abruptly."
    mc "(Jeez, I guess I better hurry...)"
    $ questlog.EndQuest(quest_waitscience, calendar.day)
    $ questlog.StartQuest(quest_forscience)
    return

label captivatingscience(call=None):
    scene mccall with dissolve
    scienceteach "[name] I've made a very intriguing discovery since our last... meeting."
    mc "Really? What is it about?"
    scienceteach "Something we shouldn't be discussing over the phone, can you meet me at school?"
    mc "Sure, I'll come see you there."
    $ questlog.EndQuest(quest_waitscience)
    $ questlog.StartQuest(quest_captivatingscience)
