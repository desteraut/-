    if quest_callsmom in questlog.quest_list and not dislike_jazz:
        scene mccall with dissolve
        smom "Hey [name], what's up sweetie?"
        mc "I should be asking you, what's up with these posters at the bar?"
        smom "Haha, you noticed!"
        smom "Look sweetie, ever since Justin isn't here anymore I'm always alone at home."
        smom "Your father doesn't like it, but he doesn't look after me either."
        smom "So I figured I'll start pursuing an old dream of mine."
        mc "A jazz singer, out of all the things..."
        smom "What are you trying to say?"
        smom "Sweetie look, I understand it might be a shock but-"
        menu:
            "It's fucking awesome!" if not dislike_jazz:
                smom "Oh..."
                pause 0.5
                $ smomlove += 10
                smom "Thank you [name]."
                smom "That means... more than you know."
                mc "I will definately be there to see that for my own eyes."
                smom "I have an idea, why don't you come over?"
                smom "I can show you some things so this whole thing makes more sense to you."
                mc "That sounds good, I'll see you soon!"
                smom "Heh, alright. take care!"
                $ questlog.EndQuest(quest_callsmom)
                $ questlog.StartQuest(quest_startjazz)
                return
            "I don't like it." if not dislike_jazz:
                $ dislike_jazz = True
                pause 2.0
                mc "[stepmom_name]?"
                pause 1.0
                mc "Hello?"
                mc "Say something..."
                $ smomlove -= 10
                smom "I'm sorry to hear that, [name]."
                smom "But this is for me."
                smom "I still hope you'll come see me on my opening night."
                smom "But it's up to you."
                "*click*"
                mc "(Damn... she hung up.)"
                mc "(I don't think I handled that very well...)"
                mc "(I better call her back to apologise if I want to be part of this.)"
                return
    if quest_callsmom in questlog.quest_list and dislike_jazz:
        scene mccall with dissolve
        smom "Yes, [name]?"
        mc "[stepmom_name], I'm sorry about earlier."
        mc "It's not that I'm not happy for you, it's just that it's such a big change and you didn't say anything about it."
        mc "I shouldn't have reacted like that."
        smom "It's alright sweetie, I understand this must come as a shock to you."
        smom "But I meant what I said, I'd love nothing more than for you to be there."
        menu:
            "Accept the invitation.":
                mc "Of course I'll be there."
                mc "I wouldn't miss it for the world."
                smom "Heh, alright then."
                smom "I have an idea, why don't you come over?"
                smom "I can show you some things so this whole thing makes more sense to you."
                mc "That sounds good, I'll see you soon!"
                smom "Heh, alright. take care!"
                $ questlog.EndQuest(quest_callsmom)
                $ questlog.StartQuest(quest_startjazz)
                return
            "Decline the invitation.":
                $ smomlove -= 25
                pause 2.0
                mc "[stepmom_name]?"
                pause 1.0
                "*click*"
                play sound "audio/sigh.ogg"
                mc "I guess that's it then..."
                $ questlog.EndQuest(quest_callsmom)
                return
        

label smombeachcall(call=None):
    scene mccall with dissolve
    mc "Hey [stepmom_name], what's up?"
    smom "[name]! It's been awhile since I've heard of you after... Well, you know..."
    mc "Yeah, I've had uhh.. my hands full with mom amongst other things."
    smom "Don't worry sweetie, I get it."
    smom "That's why I'm calling, I was wondering if you'd want to go to the beach with us over the weekend?"
    mc "The beach? What's the occasion?"
    smom "Your dad wants to try and mend things by bonding a little..."
    smom "I figured we coould all go and enjoy a relaxing afternoon on the beach."
    smom "What do you say?"
    menu:
        "ŌŁÉ Sounds good!":
            mc "It's been awhile since I've had a break, let's do it."
            smom "Awesome, we'll see you there then."
            mc "Alright"
        "ŌŁÉ Maybe later.":
            mc "I don't know [stepmom_name], I'm really busy right now."
            smom "That's okay sweetie, the invitation stays open."
            smom "Meet us there anytime you want."
            mc "Alright."
    $ questlog.StartQuest(quest_smombeach)
    $ beachunlocked = True
    return

