                                spacing 20
                                xalign 0.5
                                yalign 0.5
                                add photo xsize 86 ysize 86 yalign 0.5
                                frame:
                                    background None
                                    xsize 140
                                    yalign 0.5
                                    textbutton name action Show(
                                        "relationship_info",
                                        character=char,
                                        love=love,
                                        corruption=corruption
                                    ) style "phone_rel_textbutton" xalign 0.0 yalign 0.5

                    vbox:
                        for name, char, love, corruption, photo, _ in data[(len(data) + 1) // 2:]:
                            if not photo or not renpy.loadable(photo):
                                $ photo = "images/phone/fallback.png"
                            hbox:
                                spacing 20
                                xalign 0.5
                                yalign 0.5
                                add photo xsize 86 ysize 86 yalign 0.5
                                frame:
                                    background None
                                    xsize 140
                                    yalign 0.5
                                    textbutton name action Show(
                                        "relationship_info",
                                        character=char,
                                        love=love,
                                        corruption=corruption
                                    ) style "phone_rel_textbutton" xalign 0.0 yalign 0.5






screen phone_popup():
