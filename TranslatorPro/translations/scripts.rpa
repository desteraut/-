screen cafe_staff():
    on "show" action [Function(renpy.hide_screen, "nav_buttons_overlay"), Function(renpy.restart_interaction)]
    on "hide" action Function(renpy.show_screen, "nav_buttons_overlay")
    modal True
    tag cafe_staff
    zorder 200

    # Main panel (same as master layout)
    add "gui/managementbg.png" size (1400, 800) xalign 0.5 yalign 0.5

    # --- CLOSE BUTTON (top-right, matching new management screen) ---
    imagebutton:
        auto "images/gui/cross_%s.png"
        action [
            Hide("cafe_staff"),
            Hide("cafe_inventory"),
            Hide("cafe_menu"),
            Hide("cafe_marketing"),
            Hide("cafe_events"),
            Hide("cafe_upgrades"),
            Show("garden_cafe_management")
        ]
        xpos 1550
        ypos 190
        xalign 0.5
        yalign 0.5

    # --- LEFT SIDE NAV (same structure & spacing) ---
    vbox:
        xpos 0.15
        ypos 0.25
        spacing 150

        textbutton "­¤æ®ŌĆŹ­¤Ź│ Staff" background None focus_mask True action [
            Hide("cafe_marketing"), Hide("cafe_inventory"), Hide("cafe_menu"),
            Hide("cafe_events"), Hide("cafe_upgrades"), Hide("cafe_staff"),
            Show("cafe_staff")
        ]

        textbutton "­¤ō” Inventory" background None focus_mask True action [
            Hide("cafe_staff"), Hide("cafe_marketing"), Hide("cafe_menu"),
            Hide("cafe_events"), Hide("cafe_upgrades"), Hide("cafe_inventory"),
            Show("cafe_inventory")
        ]

        textbutton "­¤ŹĮ Menu" background None focus_mask True action [
            Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_marketing"),
            Hide("cafe_events"), Hide("cafe_upgrades"), Hide("cafe_menu"),
            Show("cafe_menu")
        ]


    # --- RIGHT SIDE NAV ---
    vbox:
        xpos 0.70
        ypos 0.25
        spacing 150

        textbutton "­¤ōŻ Marketing" background None focus_mask True action [
            Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_menu"),
            Hide("cafe_marketing"), Hide("cafe_events"), Hide("cafe_upgrades"),
            Show("cafe_marketing")
        ]

        textbutton "­¤Ä¤ Events" background None focus_mask True action [
            Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_menu"),
            Hide("cafe_marketing"), Hide("cafe_upgrades"), Hide("cafe_events"),
            Show("cafe_events")
        ]

        textbutton "­¤øĀ Upgrades" background None focus_mask True action [
            Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_menu"),
            Hide("cafe_marketing"), Hide("cafe_events"), Hide("cafe_upgrades"),
            Show("cafe_upgrades")
        ]


    # Money label (kept identical to master layout)
    text "­¤ÆĖ $[cafe_money_pending]" size 28 color "#ffffff" xalign 0.70 yalign 0.19

    # BACK BUTTON
    textbutton "< back to main screen" background None action [Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_menu"), Hide("cafe_marketing"), Hide("cafe_events"), Hide("cafe_upgrades"), Show("garden_cafe_management") ] xalign 0.23 yalign 0.80

    # --- TITLE + INFO ---
    vbox:
        xalign 0.5
        ypos 0.15
        spacing 10

        text "Staff Management" size 40 color "#ffffff" xalign 0.5
        text "Hire or fire staff to improve efficiency." size 18 xalign 0.5 color "#cccccc"
        text "Staff: [len(cafe_staff_pending)] / 2 (including [get_cafe_owner()])" size 16 color "#aaaaaa" xalign 0.5


    # --- MAIN CONTENT FRAME (600x600, same as master screen) ---
    frame:
        background None
        xalign 0.5
        yalign 0.60
        xsize 600
        ysize 600

        vbox:
            spacing 20

            # Scrollable candidate list (kept 1:1)
            viewport:
                draggable True
                mousewheel True
                ysize 400
                xsize 550

                vbox:
                    spacing 15

                    for candidate in get_candidates():
                        $ employed = candidate["name"] in cafe_staff_pending

                        frame:
                            background "#00000020"
                            padding (10, 10)
                            xfill True

                            hbox:
                                spacing 30

                                vbox:
                                    xsize 220
                                    text candidate["name"] size 26 color "#ffffff" xalign 0.0
                                    text candidate["desc"] size 16 color "#dddddd" xalign 0.0
                                    text "Efficiency: [candidate['rating']] / 5" size 14 color "#88bfff" xalign 0.0

                                vbox:
                                    xsize 100
                                    text "Salary: $[candidate['salary']]" size 20 color "#70ff70" xalign 0.5

                                vbox:
                                    xsize 120

                                    if candidate["name"] == get_cafe_owner():
                                        text "Owner" size 18 color "#aaaaaa" xalign 0.5

                                    elif employed:
                                        textbutton "Fire" background None action Function(fire_staff, candidate["name"]) xalign 0.5 style "menu_button" sensitive not (cafe_auto_mode or (persistent.end_day_results_shown and last_end_day == calendar.day))

                                    else:
                                        if len(cafe_staff_pending) < 2:
                                            textbutton "Hire" background None action Function(hire_staff, candidate["name"]) xalign 0.5 style "menu_button" sensitive not (cafe_auto_mode or (persistent.end_day_results_shown and last_end_day == calendar.day))
                                        else:
                                            textbutton "Hire" background None action NullAction() xalign 0.5 style "menu_button" sensitive False




            # --- SUMMARY LINES ---
            null height 10
            text "Current Staff: [', '.join(cafe_staff)]" size 18 color "#7dbeff" xalign 0.5

            if cafe_staff_pending != cafe_staff:
                text "Pending: [', '.join(cafe_staff_pending)]" size 16 color "#ffaa55" xalign 0.5

            null height 10
            text "Total Efficiency: [get_staff_efficiency()] / [len(cafe_staff_pending)*5]" size 16 color "#cccccc" xalign 0.5
            text "Total Salary: $[get_staff_salary()]" size 16 color "#cccccc" xalign 0.5

            null height 20


