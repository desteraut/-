        vbox:
            spacing 25
            xalign 0.5

            text "Declare Insolvency?" size 32 color "#ff5555" xalign 0.5

            text "This will liquidate the caf├®, clear debt, remove upgrades, and restart operations." size 20 xalign 0.5
            text "This action cannot be undone." size 18 color "#aaaaaa" xalign 0.5

            hbox:
                spacing 40
                xalign 0.5

                textbutton "Cancel":
                    action Hide("confirm_insolvency")
                    style "menu_button"

                textbutton "Confirm":
                    action [Hide("confirm_insolvency"), Function(declare_insolvency)]
                    style "insolvency_button"Made with Ren'Py.transform slow_fade_in:
    alpha 0.0
    linear 1.5 alpha 1.0  # fade in over 1.5 seconds

