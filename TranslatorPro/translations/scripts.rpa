    $ questlog.StartQuest(quest_waittim)
    return

label naomiplan2:
    scene naomitim_idle with dissolve
    mc "I guess I can try to talk to Mrs. Russell."
    scene naomichoice with dissolve
    $ bfflove -= 5
    $ bffmomlove += 5
    bff "Seriously?!"
    bffmom "Yesss!"
    bffmom "Finally someone with a brain around here."
    "Tim looks irritated by your decision."
    scene naomidialogue1 with dissolve
    bffmom "So, why don't you call her right now?"
    scene naomidialogue2 with dissolve
    bffmom "Chances are she is miserable about this, and it's all a big misunderstanding."
    mc "I don't know about that, Naomi. But, sure I can call her."
    scene mccall with dissolve
    scienceteach "Hello [name], you must be wondering..."
    mc "I guess you could say that..."
    mc "Why Mrs. Russell?"
    scienceteach "Look, I... couldn't help myself."
    mc "What?! Seriously?"
    scienceteach "You don't understand, I got hooked by the drug on accident..."
    scienceteach "That day at the pharmacy..."
    scienceteach "That wasn't me doing it by choice anymore."
    scienceteach "But because I had to..."
    scienceteach "Nothing worked anymore, I tried so hard... And I just..."
    "Her voice slowly turns into sobs as she tries to explain herself."
    mc "(She actually got addicted to Viralis...)"
    mc "Mrs. Russell, I'm sorry. But this does not explain why you sold me out."
    scienceteach "I needed money... I ran out of the sample you gave me and Viralis is.. expensive."
    scienceteach "I reached out, I explained what happened and they said they'd get me a fix if I..."
    scienceteach "Oh god what have I done?!"
    "She becomes increasingly more hysterical."
    mc "(Damn...)"
    scienceteach "I'm so sorry [name], I should've been better than this..."
    scienceteach "Please... If there is anything I can do to make up for it..."
    mc "I..."
    mc "I don't know..."
    mc "I'm not sure what to do or who to believe anymore."
    scienceteach "I understand, but I may have something that can help."
    scienceteach "I promise I wont make the same mistake twice..."
    scienceteach "But if you trust me, meet me in the science lab..."
    scienceteach "I can still help you."
    mc "I'll think about it."
    scienceteach "I never meant for any of this to happen [name], I'm sorry."
    mc "(Somehow, I kind of want to believe her...)"
    "You hang up the call."
    pause 0.2
    scene naomidialogue3 with dissolve
    bffmom "So, what did she say?"
    "You explain everything to Naomi in detail."
    scene naomidialogue4 with dissolve
    bffmom "If the drug is really that potent..."
    bffmom "It kind of makes sense."
    scene naomidialogue5 with dissolve
    bffmom "But I think I wouldn't trust her this fast either."
    mc "She did say she had something that could help..."
    bffmom "I wonder what it could be... Maybe it's worth checking out, [name]."
    scene naomidialogue4 with dissolve
    mc "Maybe...."
    scene naomidialogue5 with dissolve
    bffmom "How about I come with you?"
    mc "Wait really?"
    bffmom "Yeah, just to make sure you don't end up in some warehouse again or some magical cat teleports you to outer space."
    mc "That would actually make me feel better. Thanks, Naomi."
    $ questlog.EndQuest(quest_timloop, calendar.day)
    $ questlog.StartQuest(quest_talkitout)
    $ chosenaomi += 1
    return

