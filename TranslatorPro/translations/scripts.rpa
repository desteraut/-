        scene momgroupjoinrequest2 with dissolve
        mom "Feel free to join us, sweetie."
        menu:
            "Join their table.":
                $ momlove += 5
                $ mombflove += 5
                $ questlog.EndQuest(quest_pickatable)
                jump jazzperformance
            "Maybe later.":
                scene momgroupjoinrequest1 with dissolve
                mombf "Alright, have fun [name]."
