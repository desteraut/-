    def will_location_be_open(location, periods_from_now):
        """
        Checks if a location will be open after a given number of periods from now.
        """
        # Get current period and day
        day = calendar.weekday()
        periods = ["morning", "afternoon", "evening", "night"]
        current_period = get_time_of_day()
        idx = periods.index(current_period)
        # Advance periods_from_now, rolling over days if needed
        idx_new = idx + periods_from_now
        new_day = day
        while idx_new >= 4:
            idx_new -= 4
            # Advance day (assuming days are strings)
            days = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"]
            new_day = days[(days.index(day) + 1) % 7]
        new_period = periods[idx_new]
        periods_list = location_periods.get(location, {}).get(new_day)
        if not periods_list:
            return False
        return new_period in periods_list

    def _check_pending_close():
        import renpy.store as store
        if getattr(store, "pending_close", None):
            _loc = store.pending_close
            store.pending_close = None
            _label = f"{_loc}closed"
            if renpy.has_label(_label):
                renpy.jump(_label)
            else:
                renpy.call_screen("worldmap")
                
