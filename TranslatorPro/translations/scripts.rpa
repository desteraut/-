default pending_repair_result = None

init python:
    import json

    def load_sponsors():
        try:
            # read file via RenŌĆÖPyŌĆÖs virtual FS (works in dev AND when archived)
            b = renpy.file("sponsor_data.json").read()
            return json.loads(b.decode("utf-8"))
        except Exception as e:
            renpy.log(f"sponsor_data.json error: {e!r}")
            return {}
    
    REPAIR_ORDER = ["phonescreen", "motherboard", "chip", "battery", "phone"]

    def repair_click(part):
        global mairepairstage

        expected = REPAIR_ORDER[mairepairstage]

        if part == expected:
            mairepairstage += 1

            if mairepairstage >= len(REPAIR_ORDER):
                store.pending_repair_result = "repair_success"
                store.phonebroke = False
        else:
            mairepairstage = 0
            store.pending_repair_result = "repair_fail"

label repair_dispatch:
    if store.pending_repair_result:
        $ lbl = store.pending_repair_result
        $ store.pending_repair_result = None
        call expression lbl from _call_expression_7
    return



screen mall:
    tag mall
    default tooltip = None
    default tooltip_portrait = None
    default tooltip_pos = (0, 0)
    $ current_hub = "mall"
    $ present = get_characters_at_location("mall")
    add "images/mall/310.webp"
    on "show" action [Function(renpy.music.play, "audio/mall.ogg", loop=True, fadein=0.5), SetVariable("current_hub", "mall"), SetVariable("current_location", "mall")]
    if "guard" in present:
        imagebutton:
            auto "images/mall/guard_%s.png" 
            focus_mask True 
            action Call("guardmenu")
