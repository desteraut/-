screen sponsor_board_screen():
    tag menu
    modal True
    default sponsors = load_sponsors()

    add "images/mall/sponsorscreen.png"

    frame:
        style_prefix "menu"
        xalign 0.5
        yalign 0.5
        padding (30, 30)

        vbox:
            spacing 20
            xalign 0.5

            text "­¤ÅÖ Brightmoor Sponsors" xalign 0.5 size 40

            if sponsors:

                hbox:
                    spacing 100
                    xalign 0.5

                    if "Bronze" in sponsors:
                        vbox:
                            spacing 5
                            xalign 0.5
                            text "Supporter" size 28 xalign 0.5 color "#3270cd"
                            for name in sponsors["Bronze"]:
                                text "ŌĆó [name]" size 22

                    add Solid("#333333") xsize 2 ysize 400
                    
                    if "Silver" in sponsors:
                        vbox:
                            spacing 5
                            xalign 0.5

                            text "Insider" size 28 xalign 0.35 color "#cd3266"

                            $ insider_list = sponsors["Silver"]
                            $ midpoint = (len(insider_list) + 1) // 2

                            hbox:
                                spacing 60
                                xalign 0.5

                                vbox:
                                    for name in insider_list[:midpoint]:
                                        text "ŌĆó [name]" size 22

                                vbox:
                                    for name in insider_list[midpoint:]:
                                        text "ŌĆó [name]" size 22

            else:
                text "ŌĆó No sponsor data loaded." italic True size 20

            text "Thanks to each and everyone of you for supporting Fractured Veil!" xalign 0.5 color "#ffd000" italic True size 20
            textbutton "Back" xalign 0.5 action Hide("sponsor_board_screen")


