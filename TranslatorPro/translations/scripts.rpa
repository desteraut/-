    def is_gallery_unlocked(scene_id):
        return bool(persistent.gallery_unlocks.get(scene_id, False))

    def unlock_gallery_scene(scene_id):
        persistent.gallery_unlocks[scene_id] = True

        # Look up the display title from GALLERY_SCENES
        scene_title = None
        for category, scenes in GALLERY_SCENES.items():
            for entry in scenes:
                if entry["id"] == scene_id:
                    scene_title = entry["title"]
                    break
            if scene_title:
                break

