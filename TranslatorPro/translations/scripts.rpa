init python:
    import renpy.store as store
    renpy.audio.music.register_channel("bag", "sfx", loop=False)
    class Item:
        def __init__(self, name, cost, quantity=1, icon=None):
            self.name = name
            self.cost = cost         # cost per unit
            self.quantity = quantity # default quantity when buying
            self.icon = icon

            if not hasattr(self, "icon") or icon is None:
                self.icon = None

        def get_icon(self):
            # Returns either a real icon or a safe fallback
            if hasattr(self, "icon") and self.icon:
                return self.icon
            return "ŌĆó"

        def __str__(self):
            return self.name
        __repr__ = __str__

    class Bag(object):
        def __init__(self, cash=10, mischief_points=0, reroll_tokens=0, bank=0):
            self.cash = cash
            self.bank = int(bank)
            self.mischief_points = int(mischief_points)
            self.reroll_tokens = int(reroll_tokens)
            self.items = []  # list of Item objects

        def format_money(self):
            try:
                return "${:,}".format(int(self.cash))
            except:
                return str(self.cash)

        def format_bank_money(self):
            return f"${self.bank:,.0f}"

        def _normalize(self, item):
            return item.name.strip().lower() if isinstance(item, Item) else str(item).strip().lower()

        def _label(self, item):
            return item.name if isinstance(item, Item) else str(item)

        def has_item(self, item, quantity=1):
            normalized = self._normalize(item)
            count = sum(1 for i in self.items if self._normalize(i) == normalized)
            return count >= quantity

        def remove_item(self, item, quantity=1):
            normalized = self._normalize(item)
            removed_count = 0
            for i in list(self.items):  # make a copy to avoid modification issues
                if self._normalize(i) == normalized and removed_count < quantity:
                    self.items.remove(i)
                    renpy.sound.play("audio/bag.ogg")
                    removed_count += 1
            if removed_count > 0:
                show_floater(f"­¤Śæ’ĖÅ Removed {removed_count}x {self._label(item)}", "#ff1e00")
                return True
            return False
        
        def remove_all(self, item_name):
            removed = False
            while self.has_item(item_name):
                self.remove_item(item_name)
                removed = True
            return removed

        def add_item(self, item, quantity=1):
            for _ in range(quantity):
                self.items.append(item)
            renpy.sound.play("audio/bag.ogg")
            show_floater(f"­¤æ£ Added {quantity}x {self._label(item)}", "#00ff00")

        def deposit_to_bank(self, amount):
            """
            Move cash into the bank via an ATM.
            Returns True if successful, False if not enough cash.
            """
            if not hasattr(self, "bank"):
                self.bank = 0
            amt = int(amount)
            if amt <= 0:
                return True

            if self.cash < amt:
                # Not enough physical cash
                show_floater(f"Need ${amt - self.cash:,} cash", "#ff0000")
                return False

            # Move money
            self.cash -= amt
            self.bank += amt

            # SFX + UI feedback
            renpy.sound.play("audio/coins.ogg")
            show_floater(f"­¤Å” Deposited ${amt:,}", "#00ff00")
            return True

        def withdraw_from_bank(self, amount):
            """
            Move money from the bank into cash via an ATM.
            Returns True if successful, False if not enough in bank.
            """
            if not hasattr(self, "bank"):
                self.bank = 0
            amt = int(amount)
            if amt <= 0:
                return True

            if self.bank < amt:
                # Not enough in bank
                show_floater(f"Bank short by ${amt - self.bank:,}", "#ff0000")
                return False

            # Move money
            self.bank -= amt
            self.cash += amt

            # SFX + UI feedback
            renpy.sound.play("audio/coins.ogg")
            show_floater(f"­¤ÆĄ Withdrew ${amt:,}", "#00ff00")
            return True
            
        def buy(self, item, quantity=None):
            if quantity is None:
                quantity = item.quantity
            total_cost = item.cost * quantity
            if self.cash >= total_cost:
                self.cash -= total_cost
                self.add_item(item, quantity)
                renpy.sound.play("audio/coins.ogg")
                return True
            else:
                return False

        def earn(self, amount):
            amt = int(amount)
            if amt <= 0: return
            self.cash += amt
            renpy.sound.play("audio/coins.ogg")
            show_floater(f"­¤Æ░ +${amt:,}", "#00ff00")

        def spend(self, amount):
            amt = int(amount)
            if amt <= 0: return True
            if self.cash < amt:
                show_floater(f"Need ${amt - self.cash:,}", "#ff0000")
                return False
            self.cash -= amt
            renpy.sound.play("audio/coins.ogg")
            show_floater(f"­¤ÆĖ -${amt:,}", "#ff0000")
            return True
        @property
        def money(self):
            return "$" + str(self.cash)

        def get_item_counts(self):
            counts = {}
            for item in self.items:
                if item.name in counts:
                    counts[item.name][1] += 1
                else:
                    counts[item.name] = [item, 1]
            return list(counts.values())
        
        def get_item_count(self, item):
            for entry, count in self.get_item_counts():
                if entry == item:
                    return count
            return 0

        def add_mischief(self, amount, label="Mischief", pos_color="#00ff00", neg_color="#ff0000"):
            amt = int(amount)
            if amt == 0:
                return self.mischief_points

            before = self.mischief_points
            after = max(0, before + amt)
            delta = after - before
            self.mischief_points = after

            try:
                if before < 100 <= after:
                    store.reverse_mode_unlocked = True
                    show_floater("Reverse Dares Unlocked", "#a85bf0")
                if (before < 200 <= after) and not getattr(store, "mischief_200_pending", False):
                    store.mischief_200_pending = True
                    show_floater("Milestone: 200 ŌĆö Buy a gift!", "#8a2be2")
            except Exception:
                pass

            # Floater
            if delta != 0:
                sign = "+" if delta > 0 else ""
                color = pos_color if delta > 0 else neg_color
                show_floater(f"{label} {sign}{delta}", color)

            return self.mischief_points

        def spend_mischief(self, amount, **kw):
            amt = int(amount)
            if amt <= 0:
                return True
            if self.mischief_points < amt:
                # Optional: tease floater for insufficient funds
                show_floater("Not enough Mischief", "#ff0000")
                return False
            self.add_mischief(-amt, **kw)
            return True

        def add_reroll_tokens(self, n, label="Reroll Token", pos_color="#00ff00", neg_color="#ff0000"):
            delta = int(n)
            if delta == 0:
                return self.reroll_tokens

            before = self.reroll_tokens
            after = max(0, before + delta)
            applied = after - before
            self.reroll_tokens = after

            if applied != 0:
                sign = "+" if applied > 0 else ""
                color = pos_color if applied > 0 else neg_color
                # If |applied| > 1 you still get the right count in the floater
                show_floater(f"{label} {sign}{applied}", color)

            return self.reroll_tokens

        def use_reroll_token(self):
            if self.reroll_tokens <= 0:
                show_floater("No Reroll Tokens", "#ff0000")
                return False
            self.add_reroll_tokens(-1)
            return True

init python:
    def patch_old_items():
            """
            Ensures every Item object in old saves has an icon assigned.
            """
            if not hasattr(store, "bag"):
                return

            for i in bag.items:
                if not hasattr(i, "icon") or i.icon is None:
                    i.icon = icon_fixes.get(i.name, "ŌĆó")


                # If the item has a known default icon in definitions, apply it
                name = i.name.strip()

                # Look up the global default item definition:
                default_item = globals().get(name.replace(" ", "").lower() + "_default_icon_fix")
                if default_item and getattr(default_item, "icon", None):
                    i.icon = default_item.icon


    # Run patcher automatically after load
    config.after_load_callbacks.append(patch_old_items)

    def heal_inventory_services():
        removed = False
        for item_name in LEGACY_SERVICE_ITEMS:
            if bag.has_item(item_name):
                bag.remove_all(item_name)
                removed = True

        return removed
    config.after_load_callbacks.append(heal_inventory_services)

