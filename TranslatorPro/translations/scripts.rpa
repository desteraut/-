define current_location = "stephomescreen"
define gui.text_acttitle = Style("text")
default travel_context_done = False
default last_mouse_pos = (0, 0)
default cached_portraits = {}
default worldmap_hud_expanded = False
default FRAUD_ROBBERY_THRESHOLD = 25000
default pending_fraud_amount = 0
default fraud_case_open = False
default handled = False
default custom_travel_image = None
default custom_travel_sound = None
default special_handled = False
define slow_fade = Fade(1.5, 1.0, 1.0)

image birds_up = "flock1.png"
image birds_down = "flock2.png"

image birds_anim:
    "flock1.png"
    pause 0.12
    "flock2.png"
    pause 0.12
    repeat

transform bird_fly_diag(start_x, start_y, end_x, end_y, duration, pause_time):
    xalign start_x
    yalign start_y
    alpha 0.0
    
    linear 0.5 alpha 1.0 
    linear duration xalign end_x yalign end_y
    linear 0.5 alpha 0.0

    xalign start_x
    yalign start_y
    
    pause pause_time 
    
    repeat

transform bird_fly_random():
    # Randomize starting position
    xalign renpy.random.uniform(-0.3, 0.3)
    yalign renpy.random.uniform(0.5, 0.9)
    
    # Randomize which direction (up-right or down-right or straight across)
    block:
        choice:
            # Diagonal up
            linear renpy.random.uniform(7.0, 12.0) xalign renpy.random.uniform(0.9, 1.3) yalign renpy.random.uniform(-0.2, 0.2)
        choice:
            # Diagonal down  
            linear renpy.random.uniform(7.0, 12.0) xalign renpy.random.uniform(0.9, 1.3) yalign renpy.random.uniform(0.8, 1.2)
        choice:
            # More horizontal
            linear renpy.random.uniform(6.0, 10.0) xalign renpy.random.uniform(0.9, 1.3) yalign renpy.random.uniform(0.3, 0.6)
    
    # Random pause between flocks
    pause renpy.random.uniform(8.0, 20.0)
    
    repeat





transform hud_slide_in:
    yoffset -120  # start hidden above screen
    linear 0.2 yoffset 0

transform hud_slide_out:
    yoffset 0
    linear 0.2 yoffset -60

transform null_transform:
    pass

style gui_text_acttitle is text:
    size 70
    color "#FFFFFF"
    outlines [ (2, "#000000", 0, 0) ]
    bold True
    xalign 0.5
    yalign 0.5

screen desertmap():
    tag worldmap
    modal True
    default hover_portraits = []
    default hover_pos = (0, 0)

    on "show" action [
        Function(poker_cleanup),
        Function(renpy.music.play, "audio/desert.ogg", loop=True),
        SetVariable("tooltip", None),
        SetScreenVariable("hover_portraits", []),
        SetScreenVariable("hover_pos", (0, 0)),
        SetScreenVariable("tooltip_pos", (0, 0))
    ]
    on "hide" action [
        SetVariable("tooltip", None),
        SetScreenVariable("hover_portraits", []),
        SetScreenVariable("hover_pos", (0, 0)),
        SetScreenVariable("tooltip_pos", (0, 0)),
        Function(renpy.music.stop, fadeout=0.5),
        Function(lambda: renpy.store.cached_portraits.clear())
    ]

    if has_car:
        add "images/desertmap.png"
        default tooltip = None

        $ open_markers = get_open_desert_markers()
        for x, y, loc_key, label, jump_label, is_open in open_markers:
            $ loc_data = get_location_data(loc_key)
            $ idle_img, hover_img = get_marker_images(loc_key) 
            $ has_tracked_quest = is_loc_tracked(loc_key) 
            if current_location is None or loc_key != current_location:
                $ travel_context_done = False
                imagebutton:
                    xpos x
                    ypos y
                    idle idle_img at (marker_pulse if has_tracked_quest else null_transform)
                    hover hover_img
                    style "uibutton"
                    hovered [
                        SetScreenVariable("tooltip", label),
                        SetScreenVariable("tooltip_pos", renpy.get_mouse_pos()),
                        SetScreenVariable("hover_portraits", loc_data["present_characters"]),
                        SetScreenVariable("hover_pos", (x, y))
                    ]
                    unhovered [
                        SetScreenVariable("tooltip", None),
                        SetScreenVariable("hover_portraits", [])
                    ]
                    action [
                        SetVariable("selected_location", loc_key),
                        Call("worldmaptravel"),
                        Return()
                    ]



        if hover_portraits:
            hbox:
                xpos hover_pos[0] - 20
                ypos hover_pos[1] - 80
                spacing 4
                for char_id in hover_portraits:
                    if char_id not in cached_portraits:
                        $ img_path = get_portrait_path(char_id)
                        if img_path:
                            $ scaled_portrait = im.Scale(img_path, 86, 86)
                            $ scaled_mask = im.Scale("images/gui/circlemask.png", 86, 86)
                            $ outline = im.Composite(
                                (92, 92),
                                (3, 3), im.Blur(im.MatrixColor(scaled_mask, im.matrix.tint(1, 0.95, 0.9) * im.matrix.opacity(0.4)), 3),
                                (0, 0), scaled_portrait
                            )
                            $ cached_portraits[char_id] = AlphaMask(outline, im.Scale("images/gui/circlemask.png", 92, 92))
                    if char_id in cached_portraits:
                        add cached_portraits[char_id]

    if has_car:
        imagebutton auto "images/gui/citybutton_%s.png" focus_mask True xpos 1630 ypos 955 action [Hide("desertmap"), Show("worldmap")]

    # Always show the global tooltip screen on top
    use global_tooltip(tooltip=tooltip)


screen global_tooltip(tooltip=None, tooltip_portrait=None):
    if tooltip:
        # Get fresh mouse position every frame
        $ mx, my = renpy.get_mouse_pos()
        
        # Layout math
        $ screen_w = config.screen_width
        $ screen_h = config.screen_height
        $ tooltip_w = 200
        $ tooltip_h = 80
        
        # Calculate offset to keep tooltip on screen
        $ offset_x = 24 if mx + tooltip_w + 24 < screen_w else -tooltip_w - 24
        $ offset_y = 24 if my + tooltip_h + 24 < screen_h else -tooltip_h - 24

        frame:
            background "#222a"
            padding (20, 10)
            xpos mx + offset_x
            ypos my + offset_y
            vbox:
                spacing 5
                text tooltip:
                    size 22
                    color "#ffffff"
                    outlines [(1, "#000000", 0, 0)]
                if tooltip_portrait:
                    add tooltip_portrait xsize 80 ysize 80




init python:
    class TooltipDisplayable(renpy.Displayable):
        def __init__(self, tooltip, portrait=None):
            super(TooltipDisplayable, self).__init__()
            self.tooltip = tooltip
            self.portrait = portrait

        def render(self, width, height, st, at):
            render = renpy.Render(width, height)

            x, y = renpy.get_mouse_pos()
            x += 24
            y += 24

            # Build the tooltip as a regular frame screen
            tooltip_render = renpy.display.render.render(
                renpy.display.layout.VBox(children=[
                    renpy.text.Text(self.tooltip, size=22, color="#ffffff", outlines=[(1, "#000000", 0, 0)])
                ] + ([renpy.display.image.Image(self.portrait, xsize=80, ysize=80)] if self.portrait else [])),
                800, 600, st, at
            )

            render.blit(tooltip_render, (x, y))
            return render

screen worldmap():
    tag worldmap
    modal True
    
    # Initialize bird data ONCE as screen variables
    default bird_flocks = [
        {
            "start_x": renpy.random.uniform(-0.15, 0.1),     # Less far left (was -0.3 to 0.3)
            "start_y": renpy.random.uniform(0.6, 0.85),      # Tighter vertical range (was 0.5-0.9)
            "end_x": renpy.random.uniform(0.95, 1.15),       # Don't go as far right (was 0.9-1.3)
            "end_y": renpy.random.uniform(0.05, 0.95),       # Keep them on screen (was -0.2 to 1.2)
            "duration": renpy.random.uniform(15.0, 25.0),
            "pause": renpy.random.uniform(25.0, 45.0),
            "zoom": renpy.random.uniform(0.08, 0.14),
            "alpha": renpy.random.uniform(0.3, 0.5)
        }
        for i in range(2)
    ]

    on "show" action [
        Function(poker_cleanup),
        Function(check_calls),
        Function(renpy.music.play, "audio/worldmap.ogg", loop=True, fadein=0.5),
        SetVariable("tooltip", None),
        SetScreenVariable("hover_portraits", []),
        SetScreenVariable("hover_pos", (0, 0))
    ]
    on "hide" action [
        SetVariable("tooltip", None),
        SetScreenVariable("hover_portraits", []),
        SetScreenVariable("hover_pos", (0, 0)),
        Function(renpy.music.stop, fadeout=0.5),
        Function(lambda: renpy.store.cached_portraits.clear())
    ]

    add "images/map.jpg"
    
    # Now loop through the PRE-GENERATED bird data
    for flock in bird_flocks:
        add "birds_anim" at bird_fly_diag(
            start_x = flock["start_x"],
            start_y = flock["start_y"],
            end_x   = flock["end_x"],
            end_y   = flock["end_y"],
            duration   = flock["duration"],
            pause_time = flock["pause"]
        ):
            zoom flock["zoom"]
            alpha flock["alpha"]

    default hover_portraits = []
    default hover_pos = (0, 0)
    $ open_markers = get_open_worldmap_markers()

    for x, y, loc_key, label, jump_label, is_open in open_markers:
        $ loc_data = get_location_data(loc_key)
        $ has_tracked_quest = is_loc_tracked(loc_key) 
        $ idle_img, hover_img = get_marker_images(loc_key)

        # Build tooltip text (closed status + hours)
        $ tooltip_label = label
        if not is_open:
            $ tooltip_label += " {color=#ff4d4d}(Closed){/color}"
            $ _hours = get_opening_hours_text(loc_key)
            if _hours:
                $ tooltip_label += "\n{color=#aaaaaa}%s{/color}" % _hours

        # Build transforms
        if not is_open and has_tracked_quest:
            $ idle_display = Transform(child=idle_img, alpha=0.55)
            $ hover_display = hover_img
        elif not is_open:
            $ idle_display = Transform(child=idle_img, alpha=0.55)
            $ hover_display = hover_img
        elif has_tracked_quest:
            $ idle_display = idle_img
            $ hover_display = hover_img
        else:
            $ idle_display = idle_img
            $ hover_display = hover_img

        if current_location is None or loc_key != current_location:
            $ travel_context_done = False
            $ btn_action = [
                SetVariable("selected_location", loc_key),
                Call("worldmaptravel"),
                Return()
            ]
            imagebutton:
                idle idle_display
                hover hover_display
                xpos x
                ypos y
                at (marker_pulse if has_tracked_quest else null_transform)
                action btn_action
                hovered [
                    SetVariable("tooltip", tooltip_label),
                    SetScreenVariable("hover_portraits", loc_data["present_characters"]),
                    SetScreenVariable("hover_pos", (x, y))
                ]
                unhovered [
                    SetVariable("tooltip", None),
                    SetScreenVariable("hover_portraits", [])
                ]
                style "uibutton"
    if hover_portraits:
        hbox:
            xpos hover_pos[0] - 20
            ypos hover_pos[1] - 80
            spacing 4
            for char_id in hover_portraits:
                if char_id not in cached_portraits:
                    $ img_path = get_portrait_path(char_id)
                    if img_path:
                        $ scaled_portrait = im.Scale(img_path, 86, 86)
                        $ scaled_mask = im.Scale("images/gui/circlemask.png", 86, 86)
                        $ outline = im.Composite(
                            (92, 92),
                            (3, 3), im.Blur(im.MatrixColor(scaled_mask, im.matrix.tint(1, 0.95, 0.9) * im.matrix.opacity(0.4)), 3),
                            (0, 0), scaled_portrait
                        )
                        $ cached_portraits[char_id] = AlphaMask(outline, im.Scale("images/gui/circlemask.png", 92, 92))
                if char_id in cached_portraits:
                    add cached_portraits[char_id]
    if has_car:
        imagebutton auto "images/gui/desertbutton_%s.png" focus_mask True xpos 1630 ypos 955 action [Hide("worldmap"), Show("desertmap")]

    # Always show the global tooltip screen on top
    use global_tooltip(tooltip=tooltip)


label worldmaptravel:
    # Clear any leftover custom travel variables from previous travels
    $ custom_travel_image = None
    $ use_car_sound = False
    
    if callable(pending_resume):
        $ pending_resume(*pending_args)
        if getattr(store, "travel_context_done", False):
            $ store.travel_context_done = False
            $ final_loc = get_post_travel_location()
            $ location_data = get_location_data(final_loc)

            if location_data and location_data["screen_name"]:
                scene black with fade
                call screen expression location_data["screen_name"]
            return

    elif callable(getattr(persistent, "pending_resume", None)):
        $ pending_resume = persistent.pending_resume
        $ pending_args = tuple(persistent.pending_args or [])
        $ pending_resume(*pending_args)
        if getattr(store, "travel_context_done", False):
            $ store.travel_context_done = False
            $ final_loc = get_post_travel_location()
            $ location_data = get_location_data(final_loc)
            if location_data and location_data["screen_name"]:
                scene black with fade
                call screen expression location_data["screen_name"]
            return

    if getattr(store, "_in_after_load", False):
        if getattr(store, "travel_context_done", False):
            $ store.travel_context_done = False
            $ final_loc = get_post_travel_location()
            $ location_data = get_location_data(final_loc)
            if location_data and location_data["screen_name"]:
                scene black with fade
                call screen expression location_data["screen_name"]
            else:
                "Error: No valid screen for this location."
            return
            
    if selected_location:
        # --- Home <-> Neighbours shortcut ---
        if ((current_location == "home" and selected_location == "neighbours") or 
            (current_location == "neighbours" and selected_location == "home")):
            $ store.current_location = selected_location
            $ selected_location = None
            return
        
        # --- Restaurant (Naomi date) ---
        if selected_location == "restaurant" and quest_naomidate in questlog.quest_list:
            $ custom_travel_image = "naomidateride"
            $ use_car_sound = True
        
        # --- Therapy office ---
        if selected_location == "therapyoffice" and quest_momweeklytherapy in questlog.quest_list:
            $ custom_travel_image = "therapytravel01"
            $ use_car_sound = True
        
        # --- Taking mom home from therapy ---
        if selected_location == "home" and quest_takemomhome in questlog.quest_list:
            $ custom_travel_image = "therapytravel01"
            $ use_car_sound = True
        
        # --- Coffeeshop (Justin) ---
        if selected_location == "coffeeshop" and quest_initcshophelp.started:
            $ custom_travel_image = "traveljustin"
        
        # --- Stepbro/Family reunion ---
        if selected_location == "stephome" and (quest_familyreunion.started or quest_sbrohome.started):
            $ custom_travel_image = "traveljustin"
        
        python:
            travel_time = float(get_travel_time(selected_location))
            now_dec = current_time_decimal()
            raw_arrival = now_dec + travel_time
            arrival_hour = round(raw_arrival % 24.0, 6)
            arrival_day = calendar.weekday()
            if raw_arrival >= 24.0:
                days = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"]
                arrival_day = days[(days.index(arrival_day) + 1) % 7]
            store._cant_travel_closed = not is_location_open(
                selected_location, hour=arrival_hour, day=arrival_day
            )

        if _cant_travel_closed:
            $ store._cant_travel_closed = False
            jump cant_get_there_in_time
        
        # Get location data and setup travel
        $ location_data = get_location_data(selected_location)
        $ hide_current_map_screen(selected_location)
        
        
        # Determine travel type (desert vs city)
        $ origin_is_desert = (store.current_location in [m[2] for m in worldmap_markers_desert])
        $ dest_is_desert = (selected_location in [m[2] for m in worldmap_markers_desert])
        
        scene
        if custom_travel_image:
            show expression custom_travel_image
            $ custom_travel_image = None
            $ travel_time = 30
            $ store.travel_context = "custom"
        elif origin_is_desert or dest_is_desert:
            show mccartravel
            $ travel_time = 120
            $ store.travel_context = "truck"
        else:
            show travel03
            $ travel_time = 30
            $ store.travel_context = "bus"
        with dissolve

        # Play sound based on flag
        if use_car_sound:
            $ renpy.sound.play("audio/truckarrive.ogg", loop=False)
            $ use_car_sound = False
        else:
            $ play_travel_sound()
        
        if location_data:
            "You travel to [location_data['label']]."
        else:
            "You travel to your destination."
        
        # Update location and time
        $ store.current_location = selected_location
        $ store.calendar.addtime(travel_time)
        
        # Random events during travel
        $ try_random_event()
        $ store.travel_context = None
        $ maybe_run_pending_event()

        $ selected_location = None
        return
    return







init python:
    def update_tooltip_position():
        x, y = renpy.get_mouse_pos()
        if not hasattr(renpy.store, "last_mouse_pos"):
            renpy.store.last_mouse_pos = (0, 0)

        # update only when moved
        if (x, y) != renpy.store.last_mouse_pos:
            renpy.store.tooltip_pos = (x, y)
            renpy.store.last_mouse_pos = (x, y)
            # schedule another tick since weŌĆÖre still moving
            renpy.restart_interaction()


    def get_location_data(loc_key):
        loc_obj = globals().get(loc_key)

        # Base data from Location object (authoritative)
        if isinstance(loc_obj, Location):
            return {
                "loc_key": loc_key,
                "label": loc_obj.name,
                "screen_name": loc_obj.screen or loc_key,
                "present_characters": get_characters_at_location(loc_key),
            }

        # Fallback: worldmap markers (legacy support)
        for m in worldmap_markers + worldmap_markers_desert:
            if m[2] == loc_key:
                return {
                    "loc_key": m[2],
                    "label": m[3],
                    "screen_name": m[4],
                    "present_characters": get_characters_at_location(loc_key),
                }

        return None



    def get_travel_time(selected_location):
        # If the chosen location is part of desert markers ŌåÆ 2 hours
        if selected_location in [m[2] for m in worldmap_markers_desert]:
            return 2.0
        else:
            return 0.5


    def hide_current_map_screen(selected_location):
        if selected_location in [m[2] for m in worldmap_markers_desert]:
            renpy.hide_screen("desertmap")
        else:
            renpy.hide_screen("worldmap")

    def get_post_travel_location():
        if store.current_location and store.current_location != store.selected_location:
            return store.current_location
        return store.selected_location

    def get_portrait_path(char_id):
        for name, cid, love, corruption, img_path, met in get_relationships_data():
            if cid == char_id:
                return img_path
        return None
    
    def play_travel_sound():
        if selected_location in [m[2] for m in worldmap_markers_desert] or current_location in [m[2] for m in worldmap_markers_desert]:
            renpy.sound.play("audio/truckarrive.ogg", loop=False)
        else:
            renpy.sound.play("audio/bus.ogg", loop=False)
        
    def handle_special_travel(loc_key):
        """
        Runs special-case travel logic.
        Returns True if handled (jumped/called/returned),
        False if we should fall back to standard travel.
        """
        if renpy.get_screen("local_nav"):
            renpy.hide_screen("local_nav")
        hide_current_map_screen(loc_key)

        # --- always on top ---
        if fraud_case_open and pending_fraud_amount > 0:
            if loc_key in [m[2] for m in store.worldmap_markers]:
                store.current_location = loc_key
                renpy.call("fraud_travel_event")
                return True
            else:
                store.current_location = loc_key
                renpy.call("fraud_travel_event2")
                return True
        
        if loc_key == "temporarybunker":
            if quest_conquerthestorm in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("conquerstorm")
                return True
            
            if quest_visitbunker in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("sandstorm")
                return True
        
        # --- Military camp ---
        if loc_key == "desert_military" and quest_infiltratemilitary in questlog.quest_list:
            store.current_location = loc_key
            renpy.call("infiltratemilitary")
            return True
        
        # --- timhome ---
        if loc_key == "timhome":
            if quest_meetdean in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("deanfinale")
                return True
            if quest_cuckoofinale in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("cuckoofinale")
                return True
        
        # --- Gstore ---
        if loc_key == "gstore" and quest_coffeeandmilk in questlog.quest_list:
            store.current_location = loc_key
            renpy.call("midnightcream")
            return True
        
        # --- veil ---
        if quest_explorecity in questlog.quest_list and not quest_theveil.completed:
            if loc_key in [m[2] for m in store.worldmap_markers]:
                store.current_location = loc_key
                renpy.call("clearmind")
                return True

        if loc_key == "veil" and quest_portal in questlog.quest_list:
            store.current_location = loc_key
            renpy.call("veilreveal")
            return True

        # --- Church ---
        if loc_key == "church" and quest_confess in questlog.quest_list:
            store.current_location = loc_key
            renpy.call("confessions")
            return True

        # --- Court ---
        if loc_key == "court" and quest_courtdate in questlog.quest_list and leaked_dictonic:
            store.current_location = loc_key
            renpy.call("courtwalk2")
            return True
        if loc_key == "court" and quest_visitcourt in questlog.quest_list:
            store.current_location = loc_key
            renpy.call("courtwalk")
            return True
        
        # --- Beach ---
        if loc_key == "beach" and quest_smombeach in questlog.quest_list:
            if not bag.has_item(justinscheesetoken):
                store.current_location = loc_key
                run_filtered("ntr", "smombeachbond", "smombeachbondalt")
                return True
        
        # --- Home routine ---
        if loc_key == "home" and quest_homerest2 in questlog.quest_list:
            if exposuretherapy_seen and momlesbian_confirmed and sidedwithelke and not momlesbian_caught:
                store.current_location = loc_key
                run_filtered("lesbian", "momlesbiancaught2", "momaltcaught2")
                return True

            if act2 and not momlesbian_confirmed:
                store.current_location = loc_key
                run_filtered("lesbian", "momlesbiancaught", "momaltcaught")
                return True

        # --- restaurant ---

        if loc_key == "restaurant" and quest_datingadvice in questlog.quest_list:
            store.current_location = loc_key
            renpy.call("timdate")
            return True
        
        # --- Forest shack ---
        if loc_key == "forestshack" and quest_visitforest in questlog.quest_list and not havemet_forestlady:
            store.current_location = loc_key
            renpy.call("forestshackintro")
            return True

        # --- Gas station dare ---
        if loc_key == "gasstation":
            if quest_gasquickie in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("gasdarequickie")
                return True
            if quest_detentiongirlpickup in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("emmapickup")
                return True

        # --- Cabin ---
        if loc_key == "cabin" and quest_visitcabin in questlog.quest_list:
            store.current_location = loc_key
            run_filtered("ntr", "cabindicfuck", "cabindicfuckalt")
            return True

        # --- Therapy ---

        if loc_key == "home" and quest_takemomhome in questlog.quest_list:
            renpy.call("momtherapyhome")
            return False

        # --- Police quest ---
        if loc_key == "policeout" and quest_visitofficers in questlog.quest_list:
            store.current_location = loc_key
            renpy.call("policegrateful")
            return True

        # --- Diner intro ---
        # --- Act 2 Diner intro (Dust for Blood + Midnight cinematic) ---
        if loc_key == "desert_diner" and not desert_intro_seen:
            store.current_location = loc_key
            renpy.call("desert_intro")
            return True

        # --- witch shack reveal ---
        if loc_key in [m[2] for m in store.worldmap_markers]:
            if quest_backhome in questlog.quest_list and not witchshackunlocked and not havemet_witch:
                store.current_location = loc_key
                renpy.call("midnightintro")
                return True
        if loc_key == "witchshack":
            if quest_witchshack in questlog.quest_list and drugcontent_unlocked:
                store.current_location = loc_key
                renpy.call("witchintro")
                return True

            
        

        # --- Bridgette spa clue ---
        if loc_key == "desert_spa":
            if quest_findjustin in questlog.quest_list and not bridgetteclue_seen:
                store.current_location = loc_key
                renpy.call("bridgettemassage")
                return True

        # --- Cheese truck encounter --- 
        if loc_key in [m[2] for m in store.worldmap_markers_desert]:
            if quest_finishjustinarc in questlog.quest_list and not cheese_event_seen:
                store.current_location = loc_key
                renpy.call("cheese_truck_event")
                return True

        # --- Nightclub special ---
        if loc_key == "nightclub" and calendar.can_perform_action("entrancefee"):
            store.current_location = loc_key
            renpy.call("entree")
            return True

        if loc_key == "nightclub":
            if getattr(store, "hooker1snapped_seen", False) and not getattr(store, "photoevent", False):
                store.current_location = loc_key
                renpy.call("nightclub_bouncerfight")
                return True
            
        # --- School event ---
        if loc_key == "school":
            if quest_deaninterfere in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("deaninterfere")
                return True
            if quest_backtoschool in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("timcaught")
                return True
            if detention and deanlove >= 20 and not sisterreveal:
                store.current_location = loc_key
                renpy.call("timdialogue")
                return True

        # --- Coffeeshop quest office ---
        if loc_key == "coffeeshop":
            if aftermath and sidedwithelke:
                store.current_location = loc_key
                renpy.call("coffeeshop_after")
                return True
            if quest_creamer in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("coffeecream")
                return True

        # --- Mall flyers ---
        if loc_key == "mall":
            if quest_cshophelp8 in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("mallflyers")
                return True
            if quest_pharmacycandid in questlog.quest_list:
                store.current_location = loc_key
                renpy.call("pharmacywaiting")
                return True

        # --- Cityhall hooker test ---
        if loc_key == "cityhall" and quest_brendatest in questlog.quest_list and get_time_of_day() == "afternoon":
            renpy.call("hookingthehooker")
            return True

        # --- Aftermath cafe paths ---
        if loc_key == "gardencafe" and aftermath and sidedwithclaire:
            store.current_location = loc_key
            renpy.call("gardencafe_after")
            return True

        return False



    def run_standard_travel(loc_key):
        location_data = get_location_data(loc_key)
        hide_current_map_screen(loc_key)
        if renpy.get_screen("local_nav"):
            renpy.hide_screen("local_nav")
        # --- cross-region timing logic as before ---
        origin_is_desert = (store.current_location in [m[2] for m in worldmap_markers_desert])
        dest_is_desert   = (store.selected_location in [m[2] for m in worldmap_markers_desert])
        if origin_is_desert or dest_is_desert:
            travel_time = 120
            store.travel_context = "truck"
        else:
            travel_time = 30
            store.travel_context = "bus"

        store.current_location = loc_key
        store.calendar.addtime(travel_time)

        # --- travel scene + narration exactly as before ---
        renpy.scene()
        if origin_is_desert or dest_is_desert:
            renpy.show("mccartravel")
            renpy.with_statement(dissolve)
        else:
            renpy.show("travel03")
            renpy.with_statement(dissolve)

        if location_data:
            renpy.say(None, f"You travel to {location_data['label']}.")
            renpy.show("black")
        else:
            renpy.say(None, "You travel to your destination.")
            renpy.show("black")

        # --- random-event dispatch ---
        try_random_event()
        store.travel_context = None
        maybe_run_pending_event()

        # --- fade to black before context hand-off ---
        renpy.show("black")
        renpy.with_statement(fade)

        # --- now mark travel finished ---
        store.travel_context_done = True

        # --- show destination ---
        screen_name = location_data["screen_name"] if location_data else None

        if screen_name:
            renpy.call_screen(screen_name)
        else:
            renpy.say(None, f"Error: No screen defined for location '{loc_key}'.")



        store.travel_context_done = True
        return True


label robbery_event:
    $ random_events_fired_today["robbery_event"] = True
    scene mcrobbed with dissolve
    pause 0.4

    mc "(Ow... What the hell just happened?)"
    "Someone blindsided you, shoved you to the ground, and ran off before you even registered what was happening."

    # Stolen amount = 30ŌĆō60% of current cash
    $ percent = renpy.random.uniform(0.30, 0.60)
    $ stolen = int(bag.cash * percent)
    $ stolen = max(5, stolen)
    $ stolen = min(stolen, bag.cash)

    if stolen > 0:
        $ bag.spend(stolen)
        "You lost [stolen] dollars."
    else:
        "Luckily, you didn't have any cash for them to take."

    mc "(Brightmoor is getting worse...)"

    if stolen >= FRAUD_ROBBERY_THRESHOLD and not fraud_case_open:
        $ pending_fraud_amount = stolen
        $ fraud_case_open = True
    return

label mcclumsy:
    scene mcaccident1 with dissolve
    "You're stuck behind a small crowd squeezing into the bus."
    mc "(Ugh, why is it so busy today?)"
    scene mcaccident2 with dissolve
    mc "(Finally, my turn.)"
    scene mcaccident04 with dissolve
    "Just as you step forward, the doors slam shut a second too early."
    mc "SHIT!"
    scene mcaccident5 with hpunch
    "The driver opens the door a moment later, but the sudden release sends you tumbling into the ground."
    mc "(Perfect... just perfect.)"
    scene mcaccident6 with vpunch
    mc "(No, oh come on!)"
    "You check your phone. The screen is spiderwebbed with cracks."
    mc "...Fucking amazing."
    $ questlog.StartQuest(quest_phonerepair)
    $ phonebroke_seen = True
    $ phonebroke = True
    return

# Label for when you can't get there in time
label cant_get_there_in_time:
    hide screen worldmap
    scene mclate with fade
    "I can't get there in time. The place will be closed by the time I arrive."
    scene black with fade
    $ current_location = None
    return

label desert_intro:
    $ _skipping = False
    $ desert_intro_seen = True
    # Fade out current map/UI
    hide screen worldmap
    scene black with fade
    show expression Text("Whiskey&Lead - Dust for blood", style="gui_text_acttitle", xalign=0.2, yalign=0.85) as acttitle with dissolve
    $ renpy.music.play("audio/dustforblood.ogg", loop=False, fadein=1.0)
    pause 3
    hide acttitle with dissolve
    # Dust for Blood is used under a non-exclusive license for Fractured Veil, with permission from the artist. 
    # If the game goes live commercially, or receives funding terms will be discussed with the artist.
    # Roll cinematic shots in order
    scene mccartravel with dissolve
    pause 3.5

    scene mccartravel2 with dissolve
    pause 3.5

    scene mccartravel3 with dissolve
    pause 3.5

    # Cut to Midnight's trailer cinematic
    $ meet_character("havemet_midnight", "images/desert/midnightintro.webm", 26.0)
    scene radio2 with dissolve
    with Pause(1.0)

    show expression Text("ACT II", style="gui_text_acttitle", xalign=0.5, yalign=0.5) as acttitle with dissolve
    $ renpy.pause(2.0)
    hide acttitle with dissolve

    show expression Text("Welcome to the Desert", style="gui_text_acttitle", xalign=0.5, yalign=0.5) as actsubtitle with dissolve
    $ renpy.pause(3.0)
    hide actsubtitle with dissolve

    scene black with slow_fade
    $ current_location = "desert_diner"
    jump diner_arrival


label dispatch_event(event_label, restore_worldmap=False, force_worldmap=False, event_data=None):
    $ _was_worldmap = renpy.get_screen("worldmap") is not None
    $ _was_desertmap = renpy.get_screen("desertmap") is not None
    
    # Hide maps
    if _was_worldmap:
        hide screen worldmap
    if _was_desertmap:
        hide screen desertmap
    
    # Run the actual event
    call expression event_label from _call_expression_5
    
    if force_worldmap:
        call screen worldmap
    # Otherwise restore what was open
    elif _was_worldmap:
        call screen worldmap
    elif _was_desertmap:
        call screen desertmap
    
    return
Made with Ren'Py.
screen gcafescreen:
    tag gardencafe
    $ present = get_characters_at_location("gardencafe")
    add "images/gardencafe/gardencafe.webp"
    on "show" action [Function(renpy.music.play, "audio/garden.ogg", loop=True, fadein=0.5), SetVariable("current_location", "gardencafe")]
    for char_id in present:
        imagebutton auto "images/gardencafe/%s_%%s.png" % char_id focus_mask True action Call("gardenmenu")
    imagebutton auto "images/gardencafe/door_%s.png" style "worldbutton" focus_mask True action Call("gardenleave")

label gardenmanage:
    scene gardentalk01 with dissolve
    "You and Elke sit down at a table in the garden."
    "Elke looks like she is in deep thought."
    mc "So, you said you needed a manager to help you with the day to day operations?"
    scene gardentalk02 with dissolve
    mombf "Yes, I need someone to help me with the ordering of supplies, managing the staff, and making sure everything runs smoothly."
    mombf "I can't do it all by myself."
    mc "Perfect, I can do that."
    mc "What's the pay?"
    scene gardentalk03 with dissolve
    mombf "I haven't thought about that yet."
    mombf "What do you think is fair?"
    mc "25%% of the profits?"
    scene gardentalk04 with dissolve
    mombf "25%%? That's a lot!"
    mombf "I was thinking more like 10%%."
    mc "Deal."
    scene gardentalk03 with dissolve
    mombf "Gosh [name], you're actually going to be working for me."
    mombf "Is your mom gonna be okay with this?"
    mc "I don't think she will mind."
    mc "Besides, she is dealing with her own problems right now."
    mc "And I want to be able to help her. And you."
    scene gardentalk04 with dissolve
    mombf "Thank you, [name]."
    mombf "I really appreciate it."
    mombf "I will make sure to check in on your mom from time to time."
    mc "Thank you, Elke."       
    scene gardentalk05 with dissolve
    "Elke is suddenly called away by a customer."
    "You decide to leave her to it."
    $ mombflove += 5
    $ managementunlocked = True
    $ questlog.StartQuest(quest_gardenmanagement)
    return
    
label elkecheck:
    if quest_returnmanagement in questlog.quest_list:
        scene gardentalk01 with dissolve
        mombf "So, [name]... have you thought about my offer?"
        mc "Yeah, I've been thinking..."
        menu:
            "­¤øĀ’ĖÅ Agree to help manage the caf├® now.":
                $ questlog.StartQuest(quest_gardenmanagement)
                $ questlog.EndQuest(quest_returnmanagement)
                $ gardenboss = True
                mombf "That's wonderful news!"
                mc "I'm ready to help out."
                jump gardenmanage
            "Not yet.":
                mombf "I understand, take your time."
                return
    if quest_gardensabotage in questlog.quest_list:
        scene gardencafe3 with dissolve
        mombf "[name] what can I do for you?"
        mc "Elke, I wanted to talk to you about Mom again..."
        mombf "Oh, [name]... What is it this time?"
        scene black with fade
        "Before she can say more, shouting erupts outside."
        scene clairesabotage3 with dissolve
        mombf "My garden! No!"
        scene clairesabotage1 with dissolve
        mc "Stay back, I'll handle it!"
        "You rush out, grabbing an extinguisher. In the smoke you catch sight of a woman slipping around the corner."
        scene clairesabotage2 with dissolve
        mc "(Claire...!)"
        mc "(So that's what you were up to...)"
        pause 0.5
        scene clairesabotage4 with dissolve
        "You fight the flames until they're out."
        scene gardencafe15 with dissolve
        mombf "[name]... you saved it. I don't know what I'd do without you."
        mombf "Claire won't stop, can't you see?!"
        mombf "I'll have to close the garden for days, this is bad..."
        mc "(Damn...)"
        scene gardencafe12 with dissolve
        mc "I... I didn't know she was going to do this."
        mombf "I warned you, [name]!"
        mombf "But you wouldn't listen..."
        mombf "You should leave, [name]."
        mc "I'm sorry, Elke."
        mc "(Looks like I really screwed this one up.)"
        $ questlog.EndQuest(quest_gardensabotage, completed_day=calendar.day)
        $ questlog.StartQuest(quest_finishcoffee)
        $ mombflove -= 15
        $ mccorruption += 10
        return
    if sidedwithelke and aftermath and not gardenboss:
        scene gardencafe3 with dissolve
        mombf "Hey [name], how are you doing?"
        mc "We'll have to see about that."
        scene gardencafe7 with dissolve
        mombf "Something the matter, hun?"
        mc "I found [mom_name] drunk on the couch the other day after the election.."
        scene gardencafe4 with dissolve
        mombf "Oh no, is she relapsing?"
        mc "I think so."
        scene gardencafe5 with dissolve
        mombf "You have to talk to her about this."
        mombf "And make sure she gets the help she needs."
        mc "I will, but I need your help."
        mombf "Ofcourse, hun."
        mombf "I will do whatever it takes to help her."
        mc "Thank you, Elke."
        scene gardencafe10 with dissolve
        mombf "I'll stop by later and talk to her."
        mombf "And I wont take her out for drinks anymore."
        mc "That would mean a lot to me."
        $ questlog.EndQuest(quest_findhelp)
        $ questlog.StartQuest (quest_visitsmom)
        scene gardencafe5 with dissolve
        mombf "I don't want her to relapse."
        mc "Indeed."
        mc "Thank you for being so understanding."
        mc "So..."
        mc "How are things going here?"
        # --- Fire retaliation event ---
        scene black with fade
        "Suddenly, shouting erupts outside!"
        scene clairesabotage3 with dissolve
        mombf "My garden! No!"
        scene clairesabotage1 with dissolve
        mc "Stay back, I'll handle it!"
        "You rush out, grabbing an extinguisher. In the smoke you catch sight of a woman slipping around the corner."
        scene clairesabotage2 with dissolve
        mc "(Claire...!)"
        mc "(So that's what you were up to...)"
        pause 0.5
        scene clairesabotage4 with dissolve
        "You fight the flames until they're out."
        scene gardencafe15 with dissolve
        $ mombflove += 10
        mombf "[name]... you saved it. I don't know what I'd do without you."
        mombf "Claire won't stop, will she?"
        mc "Let her try. As long as I'm here, this caf├® isn't going anywhere."
        scene gardencafe12 with dissolve
        mombf "Hun... thank you."
        scene gardencafe6 with dissolve
        mombf "It's so busy here, I can barely keep up."
        mombf "Business is booming, but I can't handle it all by myself."
        mombf "I'm going to need a manager soon."
        mc "A manager?"
        scene gardencafe10 with dissolve
        mombf "Someone to help me run the place."
        mombf "I can't do it all by myself."
        mc "(hmmm, managing this place wouldn't be so bad.)"
        mc "(And since I lost my job...)"
        mc "Maybe I could help you out?"
        scene gardencafe6 with dissolve
        mombf "You?"
        mombf "Do you think you can handle managing a business?"
        mc "I mean, what's it going to take?"
        mc "Ordering supplies, managing the staff, making sure everything runs smoothly?"
        scene gardencafe7 with dissolve
        mombf "Actually... Yes."
        mombf "That's exactly what I need help with."
        mombf "I could use someone to help me with the day-to-day operations."
        mc "Well, I can do that."
        scene gardencafe9 with dissolve
        mombf "Really?"
        menu:
            "­¤øĀ’ĖÅ Agree to help manage the cafe.":
                $ questlog.StartQuest(quest_gardenmanagement)
                if quest_returnmanagement in questlog.quest_list:
                    $ questlog.EndQuest(quest_returnmanagement)
                $ gardenboss = True
                mombf "Great!"
                mombf "Thank you so much, [name]."
                mc "No problem, I'm happy to help."
                mc "Let's talk."
                jump gardenmanage
            "Decline to help manage the cafe.":
                scene gardencafe7 with dissolve
                mombf "I understand."
                mombf "If you change your mind, let me know."
                mc "Sure, I'll let you know."
                $ questlog.StartQuest(quest_returnmanagement)
                return
    if quest_exposed1 in questlog.quest_list:
        scene gardencafe3 with dissolve
        mombf "Hey [name], how are you doing?"
        mc "Hey Elke, listen..."
        mc "I need to talk to you."
        scene gardencafe4 with dissolve
        mombf "[name], no!"
        mombf "You didn't get anyone pregnant, did you?"
        mc "No, no, nothing like that."
        mc "I just need to talk to you about the decoded files."
        scene gardencafe5 with dissolve
        mombf "Oh, those files..."
        mombf "I haven't had a chance to use them yet."
        mc "Good."
        mc "Look, I talked to Brenda."
        mc "She is going to help us take down Claire."
        scene gardencafe6 with dissolve
        mombf "Who is Brenda?"
        mc "The mayor's wife."
        scene gardencafe7 with dissolve
        mombf "You know the mayor's wife?"
        mc "We met at city hall."
        mc "But nevermind that."
        mc "She wants the decoded files you have."
        scene gardencafe10 with dissolve
        mombf "Well, I don't know if I should trust her."
        mombf "I mean, she is the mayor's wife."
        mc "Look, it's a long story."
        mc "But she has been collecting evidence against Claire for years."
        mc "She wants to take her down."
        mc "And her husband too."
        scene gardencafe5 with dissolve
        mombf "[name], this seems like a very dangerous game."
        mombf "Can you trust her?"
        mc "I went to great lengths to figure that out myself."
        mc "And I am pretty sure she is on our side."
        scene gardencafe7 with dissolve
        mombf "Fine, if you trust her, I will give her the files."
        scene gardencafe5 with dissolve
        mombf "But if this goes south, I will hold you responsible."
        mc "Don't worry, I will make sure it goes well."
        scene gardencafe11 with dissolve
        mombf "Alright, I will give you the files."
        scene gardencafe8 with dissolve
        $ bag.add_item(decodedfiles)
        mombf "Here you go."
        mombf "And I hope that witch from the coffeeshop gets what she deserves."
        mc "She will."
        scene gardencafe3 with dissolve
        mombf "Alright [name], I have to get back to work."
        mombf "Come by any time."
        mc "I will."
        $ mombflove += 5
        $ questlog.EndQuest(quest_exposed1, completed_day=calendar.day)
        $ questlog.StartQuest(quest_exposed11)
        $ questlog.StartQuest(quest_brendawait2)
        $ schedule_call("Brenda", "brenda_public_event", day=calendar.day + 1, hours=9)
        return
    if quest_elkehelp3 in questlog.quest_list:
        scene gardencafe3 with dissolve
        mombf "Oh, [name]!"
        mombf "I didn't expect to see you here today."
        scene gardencafe6 with dissolve
        mombf "I was just thinking about you."
        mombf "Didn't you say you were going to help me out?"
        mc "Elke, I did help you out."
        mombf "How so?"
        mc "I just talked to the mayor's wife."
        mc "She is going to talk to the mayor about the coffeeshop."
        scene gardencafe4 with dissolve
        mc "She is going to make sure he retracts the permit."
        mombf "Oh my god, [name]!"
        mombf "You did that for me?"
        mc "Yes, I did."
        scene gardencafe10 with dissolve
        mombf "With her business gone, I will have a lot more customers."
        mombf "I can finally relax and enjoy my work again."
        mombf "Thank you so much, [name]!"
        scene gardencafe11 with dissolve
        mombf "I don't know how to thank you."
        "As Elke prepares her coffee, you take the opportunity to have a good look at her in her dress."
        mc "You know, you look really good in that dress."
        scene gardencafe12 with dissolve
        mombf "[name], if your mom heard you say that, she would be furious."
        mc "I know, but I can't help it."
        mc "You look really good, and you know it."
        mombf "I appreciate the compliment, well since you helped me out so much, I mean nobody is here right now..."
        scene gardencafe13 with dissolve
        "She sneakily takes one of her breasts out of her dress and shows it to you."
        mombf "I guess I can show you a little something in return."
        mombf "But don't tell your mom, okay?"
        mc "I won't, I promise."
        scene gardencafe14 with dissolve
        mombf "[name], it turns me on when you look at me like that."
        mombf "Here, in the garden..."
        mombf "Customers could walk in at any moment."
        mombf "Imagine your mom coming in and seeing me like this."
        mc "I can imagine it, and it turns me on too."
        scene gardencafe16 with dissolve
        "She takes off her dress and bends over, showing off her perfect ass."
        mombf "This turn you on too?!"
        mc "Well... can you blame me?"
        scene gardencafe12 with dissolve
        mombf "Alright, that's enough."
        mc "But..."
        mombf "No buts."
        mombf "I don't actually want to get caught in here."
        mombf "[name] Thanks for all the help!"
        mombf "I'll make it up to you."
        mc "I look forward to it."
        scene gardencafe3 with dissolve
        mc "I'll get going then."
        mombf "Alright, come by any time."
        mombf "I'll make sure to have a special treat for you."
        mc "(God... this is so wrong.)"
        mc "Alright."
        $ mombflove += 10
        $ questlog.EndQuest(quest_elkehelp3, completed_day=calendar.day)
        return
    if quest_elkesabotage in questlog.quest_list and bag.has_item(decodedfiles):
        scene gardencafe3 with dissolve
        mc "Elke, I have something for you."
        mombf "Oh, [name]!"
        mombf "Did you find something?"
        "You hand over the decoded files you found in Claire's office."
        $ bag.remove_item(decodedfiles)
        scene gardencafe4 with dissolve
        mombf "Oh my god, [name]!"
        mombf "This is perfect!"
        mombf "This is exactly what I needed to get back at Claire!"
        mombf "I can't believe you found this!"
        scene gardencafe9 with dissolve
        mombf "I'm thrilled!"
        mombf "This is going to be the end of that coffeeshop!"
        mombf "I will make sure to spread these around city."
        menu:
            "ŌŁÉ Stop her.":
                mc "Elke, calm down."
                mc "I know you're upset, but you can't just spread these around city."
                scene gardencafe10 with dissolve
                mombf "Why not?!"
                mc "Elke, think about it."
                mc "If you spread these around city, Claire will just deny everything."
                mc "She will say you are just jealous of her success."
                mc "She will say you are trying to sabotage her business because you can't compete with her."
                mc "And then you will be the one who gets in trouble."
                scene gardencafe5 with dissolve
                mombf "I... I never thought about it that way."
                mombf "But what do you suggest I do then?"
                mc "I was thinking, the mayor."
                mc "But, he is a corrupt bastard."
                mc "I don't think he will do anything about it."
                scene gardencafe7 with dissolve
                mombf "I guess you're right."
                mc "Give me some time to figure something out."
                mc "Maybe I can find a way to help you out without getting you in trouble."
                scene gardencafe5 with dissolve
                mombf "Alright, but don't get yourself in trouble either."
                mombf "I don't want you to get hurt because of me."
                $ questlog.EndQuest(quest_elkesabotage, completed_day=calendar.day)
                $ questlog.StartQuest(quest_elkehelp2)
                mc "Don't worry, I will be careful."
                mc "(Do I warn Claire about Elke? She seems pretty angry... What if she ends up doing it anyway?)"
                $ questlog.StartQuest(quest_coffeecrossroad)
                $ bffmomlove += 5
                return
            "ŌŁÉ Let her do it.":
                mc "Glad I could help you out, Elke."
                scene gardencafe10 with dissolve
                $ mombflove += 10
                mombf "I wanna see the look on her face when she finds out."
                mombf "I will make sure to spread these around city."
                "She is clearly thrilled with the files you found."
                mc "Alright, I'll leave you to it then."
                scene gardencafe3 with dissolve
                mombf "Thanks for your help, [name]."
                "You feel like you should have stopped her, but you also know that she is upset."
                $ questlog.EndQuest(quest_elkesabotage, completed_day=calendar.day)
                scene gardencafe with dissolve
                mc "(Do I warn Claire, or do I let her do it?)"
                mc "(Either way, one of them is bound to go down...)"
                $ questlog.StartQuest(quest_coffeecrossroad)
                $ questlog.StartQuest(quest_elkehelp2)
                return
    else:
        scene gardencafe4 with dissolve
        mc "Hey Elke! How are you?"
        mombf "Oh hey hun."
        mombf "I think I gave those people the wrong order."
        scene gardencafe
        mombf "Hun, I'm sorry. But I can't talk right now."
        mombf "It's very busy."
        mombf "I'll see you later, alright?"
        scene gardencafe11 with dissolve
        "Elke goes back to work."
        "You think it's best you take your leave now."
        return

label gardenmenu:
    scene gardencafe3 with dissolve
    mombf "[name]! Hi hun!"
    mombf "What will it be today?"
    menu:
        "­¤øÆ Buy something.":
            jump gardenmenu2
        "­¤Æ¼ Talk to her.":
            jump elkecheck
        "­¤Äü Gift" if calendar.can_perform_action("giftelke"):
            menu:
                "­¤¦┤ Cheap perfume.":
                    if bag.has_item(cperfume):
                        $ calendar.record_action("giftelke")
                        $ bag.remove_item(cperfume)
                        "You give her the cheap perfume."
                        mombf "Jee... Thanks [name]."
                        mombf "I love smelling like wet dog all day."
                        $ mombflove += 5
                    else:
                        "You don't have any cheap perfume."
                    jump gardenmenu
                "­¤¦┤ Regular perfume.":
                    if bag.has_item(rperfume):
                        $ calendar.record_action("giftelke")
                        $ bag.remove_item(rperfume)
                        "You give her the regular perfume."
                        mombf "Thanks [name], I like this one."
                        $ mombflove += 10
                    else:
                        "You don't have any regular perfume."
                    jump gardenmenu
                "­¤¦┤ Expensive perfume.":
                    if bag.has_item(eperfume):
                        $ calendar.record_action("giftelke")
                        $ bag.remove_item(eperfume)
                        "You give her the expensive perfume."
                        mombf "Oh wow [name]!"
                        mombf "That must've cost a fortune!"
                        mombf "Thank you so much! I love it!"
                        $ mombflove += 15
                    else:
                        "You don't have any expensive perfume."
                    jump gardenmenu

                "Nevermind.":
                    jump gardenmenu

        "Nevermind.":
            jump gardenleave

label gardenmenu2:
    scene gardencafe10 with dissolve
    mombf "Sure, anything you want."
    menu:
        "­¤ź¢ Cinnamon roll. ($3)":
            if bag.buy (cinnamonroll):
                jump gardenmenu3
            else:
                mc "I can't afford that."
                jump gardenmenu2
        "­¤Ź® Donut. ($2)":
            if bag.buy (donut):
                jump gardenmenu3
            else:
                mc "I can't afford that."
                jump gardenmenu2
        "­¤Ź× Loaf of bread. ($3)":
            if bag.buy (bread):
                jump gardenmenu3
            else:
                mc "I can't afford that."
                jump gardenmenu2
        "That's all.":
            jump gardenleave


label gardenmenu3:
    scene gardencafe11 with dissolve
    skeep "Right away, hun."
    jump gardenmenu

label gardenleave:
    scene gardencafe3 with dissolve
    skeep "Thanks hun, come back anytime you like!"
    return

label gardencafeclosed:
    hide screen worldmap
    scene gardencafe with dissolve
    "The garden is closed right now"
    show screen worldmap
    return

label gardencafe_after:
    scene black with fade
    "You head to the Garden Caf├®, only to find the place shuttered."
    pause 0.5
    scene gardenshutdown with dissolve
    mombf "..."
    scene gardenshutdown2 with dissolve
    mombf "You did this..."
    scene gardenshutdown3 with dissolve
    mombf "Everything I worked forŌĆögone!"
    scene gardenshutdown4 with dissolve
    mombf "I can't believe I trusted you!"
    "Her words cut deep as she storms off, leaving you with the weight of her blame."
    mc "(Damn... I guess I should go to see [stepmom_name] then.)"
    $ gardencafeunlocked = False
    $ questlog.StartQuest (quest_visitsmom)
    if quest_findhelp in questlog.quest_list:
        $ questlog.EndQuest(quest_findhelp)
    $ current_location = None
    jump game_loopMade with Ren'Py.default cafe_money_pending = 5000
