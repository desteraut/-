        renpy.restart_interaction()

    def auto_restock_for_day(expected_customers=None):
        import renpy.store as store

        if expected_customers is not None:
            customers = expected_customers
        else:
            customers = store.cafe_customers
        # SAFETY: ensure pending state exists
        if not hasattr(store, "cafe_money_pending"):
            store.cafe_money_pending = store.cafe_money

        if not hasattr(store, "cafe_inventory_pending"):
            store.cafe_inventory_pending = dict(store.cafe_inventory)

        # Target should match expected customers
        target = max(
            store.base_cafe_customers,
            customers
        )

        
        # Add buffer
        target = int(target * 1.2)

        recipe_items = ["Coffee Beans", "Milk", "Sugar", "Cups"]
        
        # Check what we need
        shopping_list = {}
        for item in recipe_items:
            current = store.cafe_inventory_pending.get(item, 0)
            if current < target:
                needed = target - current
                shopping_list[item] = needed
        
        if not shopping_list:
            renpy.notify(f"Ō£ģ Full stock | Customers: {store.cafe_customers} | Target: {target}")
            return
        
        # Calculate total cost
        total_cost = 0.0
        for item, qty in shopping_list.items():
            unit_price = store.inventory_prices.get(item, 0)
            item_cost = qty * unit_price
            total_cost += item_cost
        
        # Buy items
        if total_cost > store.cafe_money_pending:
            affordable_fraction = store.cafe_money_pending / total_cost
            
            for item, qty in shopping_list.items():
                adjusted_qty = int(qty * affordable_fraction)
                if adjusted_qty > 0:
                    unit_price = store.inventory_prices.get(item, 0)
                    cost = round(adjusted_qty * unit_price, 2)
                    store.cafe_inventory_pending[item] = store.cafe_inventory_pending.get(item, 0) + adjusted_qty
                    store.cafe_money_pending = round(store.cafe_money_pending - cost, 2)
        else:
            for item, qty in shopping_list.items():
                unit_price = store.inventory_prices.get(item, 0)
                cost = round(qty * unit_price, 2)
                store.cafe_inventory_pending[item] = store.cafe_inventory_pending.get(item, 0) + qty
                store.cafe_money_pending = round(store.cafe_money_pending - cost, 2)
        




    def finalize_menu():
        global cafe_menu, cafe_menu_pending, menu_prices, menu_prices_pending
        cafe_menu.clear()
        cafe_menu.update(cafe_menu_pending)
        menu_prices.clear()
        menu_prices.update(menu_prices_pending)

