        xpos 0.70
        ypos 0.25
        spacing 150

        textbutton "­¤ōŻ Marketing" background None focus_mask True action [ Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_menu"), Hide("cafe_marketing"), Hide("cafe_events"), Hide("cafe_upgrades"), Show("cafe_marketing") ]
        textbutton "­¤Ä¤ Events" background None focus_mask True action [ Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_menu"), Hide("cafe_marketing"), Hide("cafe_upgrades"), Hide("cafe_events"), Show("cafe_events") ]
        textbutton "­¤øĀ Upgrades" background None focus_mask True action [ Hide("cafe_staff"), Hide("cafe_inventory"), Hide("cafe_menu"), Hide("cafe_marketing"), Hide("cafe_events"), Hide("cafe_upgrades"), Show("cafe_upgrades") ]

    # MONEY LABEL
    text "­¤ÆĖ $[cafe_money_pending]" size 28 color "#ffffff" xalign 0.70 yalign 0.19 
