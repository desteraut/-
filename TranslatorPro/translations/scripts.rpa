    def process_staff_effects():
        global cafe_reputation, cafe_customers, cafe_income, cafe_costs, cafe_profit, cafe_marketing, cafe_event, cafe_upgrade, bought_upgrades
        # Staff efficiency: each point above 5 (Elke alone) gives +10% customers, each point below 5 gives -10% customers
        base_customers = base_cafe_customers
        efficiency = get_staff_efficiency()
        print(f"DEBUG: Step 1: Staff efficiency = {efficiency}")
        efficiency_delta = efficiency - 5
        customer_multiplier = 1.0 + (efficiency_delta * 0.10)
        customer_multiplier = max(0.5, customer_multiplier)
        cafe_customers = int(base_customers * customer_multiplier)
        # Apply marketing effects
        marketing_effects = {
            "Flyers": {"customers": 2, "reputation": 0},
            "Social Media": {"customers": 3, "reputation": 1},
            # Add more campaigns as needed
        }
        effect = marketing_effects.get(cafe_marketing, {"customers": 0, "reputation": 0})
        cafe_customers += effect["customers"]
        cafe_reputation += effect["reputation"]
        # Apply event effects
        event_effects = {
            "Live Music Night": {"customers": 5, "reputation": 2},
            "Coffee Tasting": {"customers": 0, "reputation": 2},
            "Charity Bake Sale": {"customers": 0, "reputation": 2},
            "Art Exhibition": {"customers": 4, "reputation": 0},
            "Board Game Night": {"customers": 3, "reputation": 0},
            "None": {"customers": 0, "reputation": 0},
        }
        event_effect = event_effects.get(cafe_event, {"customers": 0, "reputation": 0})
        cafe_customers += event_effect["customers"]
        cafe_reputation += event_effect["reputation"]
        # Apply permanent upgrade effects
        all_upgrades = list(bought_upgrades)
        if cafe_upgrade_pending != "None" and cafe_upgrade_pending not in all_upgrades:
            all_upgrades.append(cafe_upgrade_pending)
        for upg in all_upgrades:
            for o in upgrade_options:
                if o["name"] == upg:
                    cafe_reputation += o["reputation"]
                    cafe_customers += o["customers"]
        # Income: assume each customer spends average menu price
        avg_price = sum(menu_prices.values()) / len(menu_prices) if menu_prices else 2.5
        # If average price is high, reduce customers more sharply
        if avg_price > 5.0:
            # For every euro above 5, lose 20% customers (cumulative)
            penalty_factor = 1.0 - min(0.95, (avg_price - 5.0) * 0.20)
            cafe_customers = max(1, int(cafe_customers * penalty_factor))
        cafe_income = int(cafe_customers * avg_price)
        # Costs: staff salary only (other costs can be added later)
        cafe_costs = get_staff_salary()
        # Profit: income minus costs
        cafe_profit = cafe_income - cafe_costs
        
