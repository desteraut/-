    $ contacts = get_contacts_for_phone()
# Add the style at the end of the file
## --- END INCOMING CALL SYSTEM ---

    $ half = (len(contacts) + 1) // 2
    hbox:
        spacing 40
        xalign 0.5
        ypos 75
        vbox:
            spacing 7
            for name, label in contacts[:half]:
                textbutton name action [
                    Hide("phone_call_block"),
                    Call(label) 
                ] style "phone_rel_textbutton" xalign 0.5
        vbox:
            spacing 7
            for name, label in contacts[half:]:
                textbutton name action [
                    Hide("phone_call_block"),
                    Call(label) 
                ] style "phone_rel_textbutton" xalign 0.5

init python:
    def get_relationships_data():
        return get_relationships_data_from_dict()

    def _format_history_row(e):
        verb = {"completed": "Completed", "failed": "Failed", "refused": "Refused"}.get(e.get("result"), str(e.get("result")).title())
        title = e.get("title", "Dare")
        pts = int(e.get("points", 0))
        change = f"{'+' if pts >= 0 else ''}{pts}"
        return f"{verb}: {title}", change

    def mischief_data():
        # Points & streak (live)
        points = mischief_points
        streak = mischief_streak

        # Current dare text (live)
        if mischief_current:
            dare_text = mischief_current.get("desc") or mischief_current.get("title") or ""
        else:
            dare_text = None

        # Leaderboard (stub NPCs for now; MC is live)
        leaderboard = [
            ("Elizabeth", 55),
            ("Brenda", 42),
            ("MC", points),
        ]

        # History (last 5 entries, newest first)
        tail = mischief_history[-5:]  # keep it short for the UI
        history_rows = [_format_history_row(e) for e in tail]

        return {
            "points": points,
            "streak": streak,
            "current_dare": dare_text,
            "leaderboard": leaderboard,
            "history": history_rows,
        }

    def unlock_all_characters():
        for key, data in CHARACTERS.items():
            met_flag = data.get("met_flag")
            if met_flag:
                setattr(renpy.store, met_flag, True)

        renpy.notify("All characters unlocked!")
    
screen phone_mischief():
    modal True
    use phone_app("Midnight's Mischief", "mischief_block", mischief_data())

screen mischief_block(data):
    $ data = mischief_data()
    $ dare = data.get("current_dare", None)
    $ leaderboard = data.get("leaderboard", [])
    $ history = data.get("history", [])
    $ has_dare = bool(mischief_current)
    $ offered  = has_dare and mischief_current.get("status") == "offered"
    $ active   = has_dare and mischief_current.get("status") == "active"
    $ loc_lbl  = mischief_current.get("loc_key").replace("_", " ").title() if has_dare else ""
    $ band     = mischief_current.get("timeband") if has_dare else None
    $ band_lbl = "Any" if band == "any" else (band.title() if band else "")

    # Layout constants (tweak if you want tighter/wider panels)
    $ COL_W = 350
    $ PANEL_W = 250
    $ avail, free = available_rerolls()
    hbox:
            spacing 40
            xalign 0.5
            text ("Mischief points: %d" % bag.mischief_points) size 18 color "#c766ff" outlines [(2, "#000", 0, 0)]
            text ("Reroll tokens: %d" % avail) size 18 color "#ed66ff" outlines [(2, "#000", 0, 0)]
    # Reroll button (wires into the helper above)

    vbox:
        spacing 20
        xalign 0.5
        yalign 0.2

        hbox:
            xalign 0.7

            # LEFT: History
            vbox:
                spacing 6
                xsize COL_W
                xalign 0.5

                text "Dare History" size 24 color "#ffa600" outlines [(2, "#000", 0, 0)] xalign 0.5
                add Solid("#ffa60099") xsize PANEL_W ysize 2 xalign 0.5

                if history:
                    for desc, change in history:
                        $ c = "#66ff66" if "+" in change else "#ff6666"
                        text f"{desc} ({change})" size 18 color c outlines [(1, "#000", 0, 0)] xalign 0.5
                else:
                    text "No history yet." size 18 outlines [(1, "#000", 0, 0)] xalign 0.5

            # RIGHT: Leaderboard + History (both panels same width & centered)
            vbox:
                spacing 22
                xsize COL_W
                xalign 0.5

                # Leaderboard
                vbox:
                    spacing 6
                    xsize PANEL_W
                    xalign 0.5
                    text "Leaderboard" size 24 color "#ff6699" outlines [(2, "#000", 0, 0)] xalign 0.5
                    add Solid("#ff669999") xsize PANEL_W ysize 2 xalign 0.5
                    for name, score in leaderboard:
                        text f"{name}: {score} pts" size 18 outlines [(1, "#000", 0, 0)] xalign 0.5

                null height 20  # visual separation between the two right panels

        # dare
        vbox:
            spacing 6
            xsize 850
            xalign 0.5
            text "Current Dare" size 24 color "#ffcc66" outlines [(2, "#000", 0, 0)] xalign 0.5
            add Solid("#ffcc6699") xsize PANEL_W ysize 2 xalign 0.5

            if dare:
                text dare size 20 outlines [(1, "#000", 0, 0)] xalign 0.5
            else:
                text "No dare assigned today." size 20 outlines [(1, "#000", 0, 0)] xalign 0.5

            if active:
                text "Active ŌĆó Complete by end of day!" size 16 color "#40ff40" outlines [(1, "#000", 0, 0)] xalign 0.5
                text "Where: [loc_lbl] ŌĆó When: [band_lbl]" size 16 color "#9fe0ffcc" outlines [(1, "#000", 0, 0)] xalign 0.5

        # Bottom buttons pushed down a bit
        null height 110
        hbox:
            spacing 60
            xalign 0.5
            if offered:
                imagebutton auto "images/gui/midnightbutton_%s.png" action Function(accept_dare)
                imagebutton auto "images/gui/midnightbutton2_%s.png" action Function(refuse_dare)
                if can_reroll_today():
                    imagebutton auto "images/gui/midnightbutton3_%s.png" action Function(midnight_reroll) sensitive True





screen phone_relationships():
