            return


label vendingmachine:
    if not vendingintro:
        scene vendingmachine1 with dissolve
        mc "(Whoa, look at that!)"
        mc "(It's one of those old vending machines, and it appears to be working still.)"
        "Your eyes glance downwards..."
        mc "(Thazkora... I feel like I've seen that name before.)"
        mc "(Mechanical Item Dispenser, No Inherent Guarantee of Happy Transactions...)"
        mc "(M.I.D.N.I.G.H.T)"
        if havemet_midnight:
            mc "(Midnight...)"
            mc "(Coincidence or not?)"
        mc "(I wonder what it has...)"
        scene vendingmachine2 with dissolve
        mc "(Cigarettes, snacks, cheese tokens and...)"
        mc "(An.. empty bottle?!)"
        mc "(Whoever put an empty bottle in this poor machine?)"
        mc "(I kind of want to try it, for sake of nostalgia.)"
        mc "(I don't have any coins on me though...)"
        mc "(I'll go inside and see if they have some change.)"
        $ questlog.StartQuest(quest_vendingmachine)
        return
    else:
        if bag.has_item(vendingcoins):
            mc "Shall I try to get something?"
            $ vending_done = False
            while not vending_done:
                call screen vendingmachinescreen
            jump vendingleave
        else:
            mc "(I need to get some coins first.)"
            mc "(I'll go in the station and get some.)"
            return

label vendingleave:
    mc "(Alright, I've had quite enough for today.)"
    $ current_location = "gasstation"
    return

label mechanicdialogue:
    scene mechanic1 with dissolve
    $ havemet_clerk = True
    clerk "Yes?"
    menu:
        "ŌŁÉ About skinwalkers." if quest_talktoclerk in questlog.quest_list:
            scene clerk1 with dissolve
            clerk "Skinwalkers...? Hm."
            pause 2.0
            mc "..."
            clerk "Hmmmm..."
            pause 1.0
            mc "Are you... Going to answer me, sir?"
            scene clerk2 with dissolve
            clerk "I have no idea what you're talking about, kid."
            mc "Really? But how did you know about the rules and all that?"
            scene clerk3 with dissolve
            clerk "Rules?"
            mc "My stepbrother worked here for a week, he told me all about those strange rules he was supposed to follow before he just... didn't come home."
            scene clerk4 with dissolve
            clerk "Look... I'm sorry about your brother."
            pause 0.5
            clerk "But I don't know anything about rules."
            scene clerk5 with dissolve
            "He continues to go about his business, visibly preoccupied with something."
            play sound "audio/sigh.ogg"
            mc "*sighs*"
            mc "(I guess he isn't going to talk... what now?)"
            mc "(Ugh... I know he is lying, but why?)"
            mc "(I should call Emma again.)"
            $ questlog.EndQuest(quest_talktoclerk)
            $ questlog.StartQuest(quest_callemma)
            $ schedule_call("detentiongirl", "incomingcall_detentiongirl", day=calendar.day + 1, hours=9)
            return
        "ŌŁÉ Vending coins (x10)" if quest_vendingmachine in questlog.quest_list:
            if bag.buy(vendingcoins, 10):
                mc "Thanks!"
                $ questlog.EndQuest(quest_vendingmachine, calendar.day)
                $ vendingintro = True
                jump mechanicdialogue
            else:
                mc "I can't afford that."
                clerk "..."
                return
        "Vending coins (x10)" if not quest_vendingmachine in questlog.quest_list:
            if bag.buy(vendingcoins, 10):
                mc "Thanks!"
                jump mechanicdialogue
            else:
                mc "I can't afford that."
                clerk "..."
                return
        "Leave.":
            return

label vending_outcome:
    $ slot = vending_slot
    $ vending_roll = renpy.random.randint(0, 99)
    $ bag.remove_item(vendingcoins, 1)
    if slot == 4:
        if cheese_token_claimed != calendar.day:
            $ cheese_token_claimed = calendar.day
            $ renpy.restart_interaction()
            call vending_useful_item from _call_vending_useful_item
        else:
            show screen vendingmachinescreen
            "The slot is empty for today."
            mc "Well, what did I expect..."
            mc "I better wait until the next restock."
            return
    # --- Empty slot:  small chance of selfie ---
    if slot == 5:
        if renpy.random.randint(0, 99) < 10:  # 10% chance
            show screen vendingmachinescreen
            "You pull the lever, but nothing drops out... wait."
            call gallery_unlock from _call_gallery_unlock
        else:
            show screen vendingmachinescreen
            "You pull the lever, you get your hopes up for a second until the machine gives up on you."
            mc "God damn it, I need that picture!!"
        return

    # --- Jammed bottle slot: chaos behavior ---
    elif slot == 6:
        show screen vendingmachinescreen
        "You tug the lever. The bottle rattles violently inside."
        $ chaos_event = renpy.random.choice([
            "fortune_cookie",
            "machine_malfunction",
            "justin_shadow_event",
            "skinwalker_event",
        ])
        call expression chaos_event from _call_expression_2
        return

    # --- All normal slots follow base RNG ---
    if vending_roll < 75:
        show screen vendingmachinescreen
        "You pull lever [slot]."
        call vending_useful_item from _call_vending_useful_item_1
    else:
        $ chaos_event = renpy.random.choice([
            "fortune_cookie",
            "machine_malfunction",
            "justin_shadow_event",
            "skinwalker_event",
        ])
        call expression chaos_event from _call_expression_3

    return

label vending_useful_item:
    show screen vendingmachinescreen
    if slot in (5, 6):
        "You pull the lever, you almost manage to grab it but it's stuck fast behind the glass."
        mc "Come on!!"
        return

    $ slot_data = vending_map.get(slot)
    if slot_data:
        $ img_path = slot_data.get("img")
        $ name_key = slot_data.get("obj_name")
        $ item_obj = getattr(renpy.store, name_key, None) if name_key else None

        if img_path:
            show screen vendingmachinescreen
            show expression img_path

        if item_obj:
            "The machine hums and drops [item_obj.name]."
            $ bag.add_item(item_obj)      # <-- actual Item object, not a string
        else:
            "You pull the lever, but nothing happens."
            mc "Ugh... stupid machine cost me my money!"
    else:
        "You pull the lever, but nothing happens."
        mc "Ugh... stupid machine cost me my money!"
    return



label fortune_cookie:
    show screen vendingmachinescreen
    "The machine rattles and drops a fortune cookie."
    $ local_fortunes = [
        "Midnight says: 'Buy low, sell cheese.'",
        "The cookie is empty. Maybe that's the lesson.",
        "You will meet someone who knows where the spare keys are.",
        "Beware of vending machines bearing fortunes.",
        "Your luck has expired. Insert more coins.",
    ]
    $ cookie_text = renpy.random.choice(local_fortunes)
    "You crack it open. It reads: \"[cookie_text]\""
    return

label gallery_unlock:
    $ vending_images = [
        "images/trailerpark/cathtrailer15.png",
        "images/desert/redheadg8glowup.png",
    ]
    $ unlocked_selfie = renpy.random.choice(vending_images)
    if unlocked_selfie not in unlocked_pictures:
        $ unlocked_pictures.append(unlocked_selfie)
        $ renpy.restart_interaction()
        "You've unlocked a new selfie in the gallery!"
        mc "Finally!!!"
    else:
        "You've already unlocked this selfie."
    return


label machine_malfunction:
    show screen vendingmachinescreen
    play sound "sfx/spark.ogg"
    "The lights flicker and smoke hisses from the coin slot."
    pause 1.0
    "It reboots with a groan..."
    mc "(Damn, don't die on me now!)"
    return

label justin_shadow_event:
    show screen vendingmachinescreen
    "You think you see Justin slip around the corner..."
    "But when you follow, he's gone. The cellar door is open."
    "This scene is under development."
    return

label skinwalker_event:
    show screen vendingmachinescreen
    "A chill runs down your spine. You look up..."
    "A figure walks into the gas station ŌĆö silent, wrong."
    "This scene is under development."
    return

label gasnote1:
    scene gasnote1big with dissolve
    mc "Rule #7 - Do not stare into reflective surfaces."
    mc "(I wonder what that means...)"
    mc "(And who wrote this?)"
    mc "(Justin was talking about these weird, eerie rules every day...)"
    returnMade with Ren'Py.
screen gstorescreen:
    tag generalstore
    $ present = get_characters_at_location("gstore")
    add "images/generalstore/246.webp"
    on "show" action [Function(renpy.music.play, "audio/gstore.ogg", loop=True, fadein=0.5), SetVariable("current_location", "gstore")]
    imagebutton auto "images/generalstore/door_%s.png" focus_mask True style "worldbutton" action Call("gstorebathroom")
