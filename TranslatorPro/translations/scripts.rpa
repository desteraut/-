    # ---------------------------
    # Helpers
    # ---------------------------
    def _get(name, default=0):
        # Return default when name is missing/None/non-string
        if not isinstance(name, str) or not name:
            return default
        return getattr(store, name, default)

    def _flag_true(flag):
        if not isinstance(flag, str) or not flag:
            return False
        return bool(getattr(store, flag, False))

    def characters_visible():
        for key, data in CHARACTERS.items():
            met = _flag_true(data.get("met_flag")) if data.get("met_flag") else True
            if not met:
                continue
            yield key, data

    def get_contacts_for_phone():
        contacts = []
        for key, d in characters_visible():
            display = d.get("display_name", key.title())

            call_label = f"call{key}"
            no_call_label = f"no_call_{key}"

            if renpy.has_label(call_label):
                label = call_label
            elif renpy.has_label(no_call_label):
                label = no_call_label
            else:
                # No callable label for this character; don't show them.
                continue

            contacts.append((display, label))

        contacts.sort(key=lambda x: x[0].lower())
        return contacts

    def get_relationships_data_from_dict():
        rows = []
        for key, d in characters_visible():
            love = int(_get(d.get("love_var"), 0))
            corr = int(_get(d.get("corruption_var"), 0))
            img_path = d.get("portrait")  # now always set by the autowire above
            rows.append((d["display_name"], key, love, corr, img_path, True))
        return rows

    def get_whereabouts_from_dict(key_or_name):
        """
        Uses the dict's 'whereabouts' string to read the current whereabouts variable.
        Falls back to your legacy helpers if needed.
        """
        d = CHARACTERS.get(str(key_or_name))
        if not d:
            # Try reverse lookup by display name
            for k, v in CHARACTERS.items():
                if v.get("display_name") == key_or_name:
                    d = v
                    break
        if d and d.get("whereabouts"):
            varname = d["whereabouts"]
            return getattr(store, varname, "Unknown")
        # Fallbacks for older calls:
        try:
            return get_whereabouts(key_or_name)
        except Exception:
            return "Unknown"

    # Builds a Character object using its name and assigned color
    def character_color(name):
        if name in character_colors:
            return Character(name, who_color=character_colors[name])
        return Character(name)

    # Just returns the color string for that name
    def get_character_color(char_id):
        return character_colors.get(char_id, "#0059ff")  # Default

    def adjust_love(character, delta):
        old_val = getattr(store, f"{character}love", None)
        if old_val is not None:
            new_val = old_val + delta
            setattr(store, f"{character}love", new_val)

            # Auto floater
            emoji = "ŌØż’ĖÅ" if delta > 0 else "­¤Æö"
            color = "#ff94b6" if delta > 0 else "#ff6666"
            show_floater(f"{character.capitalize()} {delta:+} {emoji}", color)
        else:
            renpy.log(f"adjust_love: {character}love not found")

    def adjust_corruption(character, delta):
        old_val = getattr(store, f"{character}corruption", None)
        if old_val is not None:
            new_val = old_val + delta
            setattr(store, f"{character}corruption", new_val)

            emoji = "­¤śł" if delta > 0 else "­¤ść"
            color = "#6b6b6b" if delta > 0 else "#88aaff"
            show_floater(f"{character.capitalize()} {delta:+} {emoji}", color)
        else:
            renpy.log(f"adjust_corruption: {character}corruption not found")

    class Stat:
        def __init__(self, name, value=0, emoji="ŌØż’ĖÅ", color="#ff94b6"):
            self._name = name
            self._value = int(value)
            self._emoji = emoji
            self._color = color
            self._last_value = None  # None = force first change to trigger floater

        def __iadd__(self, amount):
            self._value += int(amount)
            if amount != 0:
                if self._last_value is None or self._value != self._last_value:
                    show_floater(
                        f"{self._name.capitalize()} {amount:+} {self._emoji}  (Total: {self._value})",
                        self._color
                    )
            self._last_value = self._value
            return self


        def __isub__(self, amount):
            self._value -= int(amount)
            if amount != 0:
                if self._last_value is None or self._value != self._last_value:
                    show_floater(
                        f"{self._name.capitalize()} {-amount:+} {self._emoji}  (Total: {self._value})",
                        self._color
                    )
            self._last_value = self._value
            return self

        def __int__(self):
            return self._value

        def __index__(self):
            return self._value

        def __repr__(self):
            return str(self._value)

        def __eq__(self, other):
            return self._value == int(other)

        def __lt__(self, other):
            return self._value < int(other)

        def __le__(self, other):
            return self._value <= int(other)

        def __gt__(self, other):
            return self._value > int(other)

        def __ge__(self, other):
            return self._value >= int(other)

        # Save/load safety
        def __getstate__(self):
            return (self._name, int(self._value), self._emoji, self._color, self._last_value)

        def __setstate__(self, state):
            try:
                if len(state) == 4:  # legacy saves
                    self._name, val, self._emoji, self._color = state
                    try:
                        v = int(val)
                    except (ValueError, TypeError):
                        v = getattr(self, "_value", 0)
                    self._value = v
                    # Preserve baseline so replay/rollback floaters re-trigger correctly
                    self._last_value = v
                else:
                    self._name, val, self._emoji, self._color, last_val = state
                    # Defensive conversion in case old saves stored wrong order
                    try:
                        v = int(val)
                    except (ValueError, TypeError):
                        v = getattr(self, "_value", 0)
                    self._value = v
                    # Use saved last_val when valid; otherwise align to current value
                    self._last_value = last_val if isinstance(last_val, int) else v
            except Exception:
                # Absolute fallback so loading never crashes
                self._name = getattr(self, "_name", "unknown")
                self._emoji = getattr(self, "_emoji", "ŌØż’ĖÅ")
                self._color = getattr(self, "_color", "#ff94b6")
                self._value = getattr(self, "_value", 0)
                self._last_value = self._value
    
    def _ensure_var(name, value):
        if not isinstance(name, str) or not name:
            return
        if not hasattr(store, name):
            setattr(store, name, value)
    
    NUMERIC_ZERO_FLAGS = {"loudmomvisit"} 

    for key, d in CHARACTERS.items():
        for flag in d.get("flags", []):
            if flag in NUMERIC_ZERO_FLAGS:
                _ensure_var(flag, 0)
            else:
                _ensure_var(flag, False)

    for key, d in CHARACTERS.items():
        # 1) met flags (bool)
        met_flag = d.get("met_flag")
        _ensure_var(met_flag, False)

        # 2) love / corruption stats (Stat objects)
        disp = d.get("display_name", key)
        love_var = d.get("love_var")
        corr_var = d.get("corruption_var")

        # 3) knows_*_likes (bool)
        knows = d.get("knows_likes")
        _ensure_var(knows, False)

        # 4) whereabouts_* (string)
        w = d.get("whereabouts")
        _ensure_var(w, "Unknown")

    for key, data in CHARACTERS.items():
        color = get_character_color(data.get("color_key", key))
        display = data["display_name"]
        data.setdefault("portrait", f"images/phone/{key}.png")
        # Build a Character object for this key
        char_obj = Character(display, who_color=color)
        # Bind it into RenŌĆÖPyŌĆÖs store under the short key (smom, bff, etc.)
        setattr(store, key, char_obj)

define mc = Character("[name]", who_color=get_character_color("mc"))
default name = "Benjamin"Made with Ren'Py.transform checkpoint_frame_anim:
    alpha 0.0
    yoffset 14
    easeout 0.6 alpha 1.0 yoffset 0

transform checkpoint_text_anim:
    alpha 0.0
    pause 0.25
    easeout 0.6 alpha 1.0

transform checkpoint_frame_out:
    easein 0.45 alpha 0.0 yoffset -10

transform checkpoint_text_out:
    easein 0.45 alpha 0.0

label checkpoint_banner(text):
    $ _skipping = False
    play sound "audio/whooshin.ogg"
    show screen checkpoint_banner_display(text, phase="in")
    $ renpy.pause(3.1, hard=True)

    show screen checkpoint_banner_display(text, phase="out")
    $ renpy.pause(0.45, hard=True)

    hide screen checkpoint_banner_display
    $ _skipping = True
    return




screen checkpoint_banner_display(text, phase="in"):
    zorder 200
    add Solid("#00000062")

    if phase == "in":
        
        add "gui/checkpoint_frame.png":
            xalign 0.5
            yalign 0.4
            at checkpoint_frame_anim

        text text:
            font "fonts/CormorantGaramond-VariableFont_wght.ttf"
            xalign 0.5
            yalign 0.48
            size 50
            color "#f1ebc5b6"
            outlines [(2, "#00000066", 0, 0)]
            kerning 4
            at checkpoint_text_anim

    else:
        add "gui/checkpoint_frame.png":
            xalign 0.5
            yalign 0.4
            at checkpoint_frame_out

        text text:
            font "fonts/CormorantGaramond-VariableFont_wght.ttf"
            xalign 0.5
            yalign 0.48
            size 50
            color "#f1ebc5b6"
            outlines [(2, "#00000066", 0, 0)]
            kerning 4
            at checkpoint_text_out



init python:
    def show_checkpoint_banner():
        import renpy.store as S
        import renpy.exports as renpy

        quest = getattr(S, "last_checkpoint_quest", None)
        if not quest:
            return

        raw = getattr(quest, "checkpoint_name", None) or quest.base_name

        text = raw.format(
            mom_name=S.mom_name,
            stepmom_name=S.stepmom_name,
        )

        # Call the label instead of the screen
        renpy.call("checkpoint_banner", text=text)

        S.checkpoint_pending = False
        S.last_checkpoint_quest = NoneMade with Ren'Py.

screen confirm(message, yes_action, no_action):
    modal True
    zorder 1001
    add "#000000b7"
    frame:
        xalign 0.5
        yalign 0.5
        padding (20, 20)
        vbox:
            spacing 10
            text message
            hbox:
                spacing 40
                xalign 0.5
                textbutton "Yes" background None action yes_action
                textbutton "No" background None action no_action


label cheese_truck_event:
    $ cheese_event_seen = True
    scene black with fade
    "As you drive deeper into the desert, something catches your eye..."
    scene cheeseencounter2 with dissolve
    mc "That's it, that's the truck Justin must've gotten on."
    "You pull over and decide to investigate it."
    scene cheeseencounter3 with dissolve
    mc "Oh man, this doesn't look good."
    mc "It looks... Abandoned?"
    mc "Let's see if theres any clues inside."
    scene cheeseencounter4 with dissolve
    "As you carefully search the truck, you find Justin's phone under the passangers seat."
    scene cheeseencounter5 with dissolve
    mc "Justin's phone!"
    mc "Hmmm, one missed call."
    mc "Let's see..."
    scene cheeseencounter6 with dissolve
    mc "Huh... That's his... Ex-employer?"
    mc "What the fuck?"
    mc "I guess I'll call him back and see if he knows more..."
    scene cheeseencounter7 with dissolve
    idk "H-hello?"
    mc "Sir, this is [name]. I'm Justin's stepbrother."
    mc "I found his phone in your truck out in the desert."
    idk "Oh god..."
    idk "Are you far from it? Is he there? Are you hurt?"
    "The man's voice shakes, too anxious, too fast."
    mc "I'm fine. But Justin's missing. I was hoping you could tell me more."
    idk "..."
    "You hear only breathing for a moment. Wet, uneven."
    idk "He agreed to help me with an order. A special client... very particular."
    mc "Particular how?"
    idk "The holes."
    mc "...The holes?"
    idk "In the cheese. If they're not perfect, she doesn't let you leave."
    "The line goes dead quiet again. You swear you hear him mutter a prayer."
    idk "If the truck's there and he's not... then he's gone."
    mc "Where's this client?"
    idk "Dust Hollow Road. Two miles off Route 11."
    idk "And listen to meŌĆ” [name], she is not the type to play with."
    mc "Got it. Thanks."
    idk "No. Be careful. Please."
    scene cheeseencounter8 with dissolve
    "You hang up before he can say more. A cold pit forms in your stomach."
    scene cheeseencounter8 with dissolve
    "You get in your truck and speed off."
    mc "God damn it, Justin!"
    scene cheeseencounter9 with dissolve
    mc "What did you get yourself into this time?"
    mc "I hope I'm not too late..."
    scene black with fade
    "You drive off in the midst of night, looking for a secluded house near the end of Dust Hollow road."
    "After approximately 2 hours, you finally found it."
    $ calendar.addtime(120)
    scene cheeseencounter10 with dissolve
    mc "This must be it."
    mc "(Wait, is that... Her?)"
    mc "(She looks... Sexy.)"
    scene cheeseencounter11 with dissolve
    lady "I see you've finally found me."
    mc "Uhh, were you expecting me?"
    scene cheeseencounter12 with dissolve
    lady "I know that you're looking for someone."
    lady "And you're not even sure if you're still looking for Justin, or you're looking for me."
    lady "Either way, you found me."
    mc "(Okay, this feels wrong...)"
    mc "Uhh, yeah. So do you know what happened to him?"
    scene cheeseencounter13 with dissolve
    "She lets out an exaggerated gasp, then smirks and cackles."
    "The whole vibe is off, and you get the same familiar feeling of being watched."
    "Just like back at the gas station."
    scene cheeseencounter12 with dissolve
    lady "Your brother had one job."
    lady "Push. Holes."
    lady "He failed."
    scene cheeseencounter11 with dissolve
    lady "So he became one with the cheese..."
    lady "And the holes..."
    scene cheeseencounter13 with dissolve
    lady "Hahahaha!"
    mc "(Wtf does that even mean?)"
    mc "Look lady, I need to know where he is."
    scene cheeseencounter12 with dissolve
    lady "Deep down, you already know where he is."
    lady "You just need to admit it to yourself."
    scene cheeseencounter14 with dissolve
    "She presses something into your palm. It's warm, tacky, almost pulsing with heat."
    "The faint smell of sour milk clings to your fingers."
    $ bag.add_item(justinscheesetoken)
    mc "(What the hellŌĆ” is this thing?)"
    scene cheeseencounter11 with dissolve
    lady "Think of it as... something to remember him by."
    lady "Now, be a good boy and get out of here before your fate is sealed."
    mc "Are you threatening me?"
    scene cheeseencounter13 with dissolve
    lady "Threats? Hah."
    lady "Why would I threaten you... with a good time?"
    scene cheeseencounter12 with dissolve
    lady "Go on, off you go."
    "You have no clue why, but this place, this lady, the whole vibe gives you the creeps."
    "You decide to follow your judgement, and get in your truck."
    mc "(Justin... what the fuck did they do to you?)"
    $ questlog.EndQuest(quest_finishjustinarc, completed_day=calendar.day)
    $ questlog.StartQuest(quest_backhome)
    return

label use_cheese_token(npc_varname, token_type="cheesetoken"):

    python:
        flag_name = f"{npc_varname}_bukkake_unlocked"
        token_item = justinscheesetoken if token_type == "justin" else cheesetoken
        already_unlocked = getattr(store, flag_name, False)

    if already_unlocked:
        "You offered up Justin's final token..."
        return

    $ confirm = renpy.call_screen("confirm", message="Use your Cheese Token on this character? This can't be undone.", yes_action=True, no_action=False)

    if not confirm:
        return

    if bag.has_item(token_item):
        $ bag.remove_item(token_item)
        $ setattr(store, flag_name, True)
        "You slipped them the cheese."
    else:
        "You don't have the right cheese."

    return
Made with Ren'Py.screen churchscreen:
    tag church
    add "images/church/church_idle.webp"
    on "show" action [Function(renpy.music.play, "audio/church.ogg", loop=True, fadein=0.5), SetVariable("current_location", "church")]
    on "hide" action Function(renpy.music.stop, fadeout=0.5)
    imagebutton auto "images/church/door_%s.png" focus_mask True style "worldbutton" action [Hide("churchscreen"), SetVariable("current_location", "churchinside"), Return()]

screen churchinside:
