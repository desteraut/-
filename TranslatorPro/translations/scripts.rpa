label bffhomemenu:
    if quest_timarcfinale in questlog.quest_list:
        scene timdialogue2 with dissolve
        bff "Bro, what's up?"
        mc "Hey Tim, how are things with Laura?"
        scene timdialogue4 with dissolve
        bff "Bro, she's amazing!"
        bff "She taught me how to eat with sticks!"
        mc "...sticks? Like, chopsticks?"
        mc "Are you sure that's a good idea?"
        scene timdialogue3 with dissolve
        bff "Bro, I said the same thing!"
        bff "But then she took my hotdog and did that thing with her mouth."
        mc "... I'm not sure if I need the rest of the details, honestly."
        pause 0.5
        mc "But so... you're good now?"
        scene timdialogue4 with dissolve
        bff "Mucho bieno petito, bro!"
        play sound "audio/sigh.ogg"
        mc "(I guess hes happy, that should be all that matters.)"
        mc "(...right?)"
        menu:
            "­¤Æ¼ I'm happy for you.":
                $ bfflove += 5
                mc "Then I'm happy for the both of you, at last."
                bff "Thanks man, and uhh..."
                scene timdialogue2 with dissolve
                bff "Don't worry, alright?"
                mc "Worry about what?"
                bff "One day I'll teach you the tricks to properly seduce a woman!"
                mc "..."
                mc "(Ugh, nevermind.)"
                mc "Right."
            "­¤Ś©’ĖÅ Stay silent.":
                pass
        $ questlog.EndQuest(quest_timarcfinale)
        scene timdialogue1 with dissolve
        bff "Anyway, got to go! I'll see you around, [name]!"
        mc "Alright."
        scene black with slow_fade
        pause 0.5
        return
    if quest_datingadvice2 in questlog.quest_list:
        scene naomitim_hover with dissolve
        bff "Dude, what were you thinking out there?!"
        mc "(Is he serious right now...?!)"
        if orderedchampagne:
            bff "Impress her with wine!"
            bff "Next thing I know, I'm hitting on the wrong woman!"
            scene naomitim_idle with dissolve
            bffmom "Somehow I feel like that's not how it went."
            mc "Nope."
            bff "*sighs* whatever dude."
        elif wingedit:
            pass
        scene naomitim_hover with dissolve
        bff "I swear, I'm never following your advice again."
        if orderedfordate:
            bff "Oh yeah, just go ahead and order for her!"
            bff "And like some idiot, I did."
            bff "And then she got mad at me."
            mc "You ordered rice... with shoes."
            scene naomitim_idle with dissolve
            bffmom "Oh god, that must've been rather chewy..."
            mc "Emotionally, maybe."
            bff "Pffft, whatever."
        elif italianaccent:
            pass
        bff "'Oh yeah, just do whatever you want... Trust your gut!'"
        bff "And there I was, in my best italian ordering for a lady in need."
        bff "And what did she do?"
        bff "She left. As usual."
        scene naomitim_idle with dissolve
        bffmom "I mean..."
        mc "My point exactly."
        bff "Ugh, it's no use."
        bff "You guys make fun of me, but you have no idea what it's like."
        scene timchoice with dissolve
        bff "I know!"
        bff "I know you two have a thing for each other, how about you guys go on a date instead?"
        bffmom "Tim that's very inappropriate."
        bff "I could learn from you, see how you do it [name]!"
        menu:
            "ŌŁÉ Agree. (Date with Naomi.)":
                $ questlog.EndQuest(quest_datingadvice2, calendar.day)
                $ questlog.StartQuest(quest_naomidate)
                scene naomitim_hover with dissolve
                bff "It's a deal then."
                bff "Same restaurant."
                mc "Alright."
                mc "I'll come pick you up, Naomi."
                $ bffmomlove += 5
                bffmom "Such a gentleman."
                bff "Pffft, he doesn't even have a car."
                mc "(Just you wait, Tim.)"
                return
            "Disagree. (Skip date.)":
                $ questlog.EndQuest(quest_datingadvice2, calendar.day)
                scene naomitim_hover with dissolve
                bff "Too chicken, huh?"
                mc "No, I respect Naomi enough to take her on a date because of some kind of experiment."
                $ bffmomlove += 5
                bffmom "Awww [name]!"
                "End of content for this patch, more coming soon!"
                return
    if quest_timdicktalk in questlog.quest_list:
        scene timdialogue2 with dissolve
        bff "Hey [name], what's up?"
        bff "You look like you've seen a ghost..."
        scene timdialogue1 with dissolve
        "You tell him about everything that happened with your boss, the mayor and that poor girl."
        pause 1.0
        scene naomidiscuss1 with dissolve
        bff "So this Fransesco guy wont talk to you directly."
        bff "Why don't I hack his computer and dig up some dirt?"
        bff "If we want him to talk business, that's the safest option."
        bff "Hell I could even setup a fake profile to make it look like you're an investor."
        scene naomidiscuss2 with dissolve
        bffmom "That's ridiculous!"
        bffmom "Why go through all the trouble?"
        bffmom "Brenda said he is weak for women..."
        bffmom "I bet he is a real loser."
        bffmom "Why don't you just fuck his wife and rub it in his face?"
        $ questlog.EndQuest(quest_timdicktalk)
        call screen dicdecision
        return
    if quest_confrontclaire3 in questlog.quest_list and quest_confrontclaire2.completed_day != calendar.day:
        scene bffdecoded with dissolve
        bff "I have been working on those files you gave me."
        bff "I think I have decoded them."
        bff "But you got to see this for yourself, bro."
        mc "What am I looking at?"
        bff "This is a list of all the people who shes loaned money to."
        bff "Dates, amounts, names, everything."
        bff "She has been running a loan shark business on the side."
        mc "What?!"
        bff "Yeah, I know right?"
        bff "I couldn't believe it myself."
        bff "And it gets worse."
        scene bffdecoded2 with dissolve
        bff "You know that new drug? It's called 'Vitalis'."
        mc "Yeah, I know bro."
        mc "It's my boss who is selling it."
        bff "Well, Claire has been selling it too."
        bff "But get this..."
        scene bffdecoded3 with dissolve
        bff "She has been adding it to the coffee she serves at the coffeeshop."
        mc "Holy fuck!"
        bff "I know, right?"
        bff "Look, I don't know what to do with this information."
        bff "But I think we need to confront her."
        scene bffdecoded4 with dissolve
        mc "Hold on, Tim."
        mc "We need to think this through."
        mc "We can't just confront her without a plan."
        bff "Yeah, you're right."
        scene bffdecoded5 with dissolve
        mc "Let me take those files."
        bff "Sure, here you go."
        $ bag.add_item(decodedfiles)
        $ questlog.EndQuest(quest_confrontclaire3, calendar.day)
        $ questlog.StartQuest(quest_elkehome1)
        mc "I'm going out for a bit."
        mc "I'll be back later."
        bff "Alright, bro."
        bff "Keep me posted on what you find out."
        return
    elif quest_elkehelp2 in questlog.quest_list:
        scene bffhome01 with dissolve
        mc "Tim, I've brought those files to [mom_name]'s friend."
        bff "Ohh, what did she say?"
        mc "She got very excited."
        mc "She said she will use them to get back at Claire."
        scene bffhome03 with dissolve
        bff "Ohh..."
        bff "I hope she knows what she's doing."
        mc "She doesn't."
        mc "So I offered to figure something out instead."
        bff "And what are you going to do about it?"
        mc "I don't know yet."
        mc "That's why I came to you."
        scene bffhome02 with dissolve
        bff "Well, if she really is trying to sabotage Claire's business, I would perhaps suggest we talk to the mayor."
        mc "Yeah, but he is a corrupt bastard."
        mc "I just went through hell trying to get a permit for Claire."
        bff "Wait what?"
        scene bffhome04 with dissolve
        mc "It's a long story."
        "You briefly explain to Tim what happened with the mayor."
        "Then, it dawns on you."
        scene bffhome03 with dissolve
        mc "Wait a minute, Tim."
        mc "Maybe we don't need to talk to the mayor."
        bff "What do you mean?"
        mc "(I could talk to his wife instead.)"
        mc "You know what, I think I have an idea."
        mc "I will talk to you later."
        scene bffhome05 with dissolve
        bff "Alright, bro."
        $ questlog.EndQuest(quest_elkehelp2, completed_day=calendar.day)
        $ bfflove += 5
        return
    else:
        scene bffhome01 with dissolve
        bff "I'm bored bro!"
        bff "I don't have anything to do today."
        bff "Wanna hang out?"
        if quest_confrontclaire2.started:
            scene bffhome03 with dissolve
            mc "Actually, I have something for you."
            mc "I found these files in Claire's office."
            bff "Ohh, what is it?"
            mc "I don't know, but I think you can decode them."
            bff "It will take me a while, but I can do it."
            bff "Come back tomorrow, I will have it ready for you."
            scene bffhome04 with dissolve
            bff "Thanks for bringing this to me, bro."
            bff "Finally got something to do!!!"
            mc "Yes, louder please."
            bff "I said, finally got something to do!!!"
            mc "I heard you the first time!"
            mc "I will come back tomorrow to pick it up."
            scene bffhome05 with dissolve
            bff "Sure, see you then."
            $ bag.remove_item(cshopfiles)
            $ questlog.EndQuest(quest_confrontclaire2, calendar.day)
            $ questlog.StartQuest(quest_confrontclaire3, calendar.day)
            return
        else:
            scene bffhome01 with dissolve
            menu:
                "ŌŁÉ About the dean." if quest_asktim in questlog.quest_list and not askeddean:
                    $ askeddean = True
                    scene timdialogue1 with dissolve
                    mc "So Naomi and Mrs. Brown are... twins? why didn't you ever talk to me about this?"
                    scene timdialogue3 with dissolve
                    bff "Look bro, it's kind of complicated."
                    bff "I don't even know what happened between my aunt and mom myself."
                    bff "All I know is that mom has kept her distance, although..."
