            mc "(Lauranne sent me on a mini goose hunt for this damn book...)"
            $ hospitalunlocked = True
            "{color=#FFD700}New location unlocked: Hospital.{/color}"
            $ questlog.EndQuest(quest_bookhunt2)
            $ questlog.StartQuest(quest_bookhunt3)
            return
        "Buy cheap perfume. ($20)":
            if not quest_buyscents in questlog.quest_list:
                $ questlog.StartQuest(quest_buyscents)
            if bag.buy(cperfume):
                if not boughtcheapperfume:
                    $ quest_buyscents.increment()
                $ calendar.record_action("boughtcheapperfume")
                scene perfumestore01 with dissolve
                plady "That will be $20, sir."
                scene perfumestore03 with dissolve
                plady "Happy to help, good day to you!"
                $ boughtcheapperfume = True
                jump perfumemenu
            else:
                mc "I can't afford that."
                jump perfumemenu
        "Buy regular perfume. ($50)":
            if not quest_buyscents in questlog.quest_list:
                $ questlog.StartQuest(quest_buyscents)
            if bag.buy(rperfume):
                if not boughtregularperfume:
                    $ quest_buyscents.increment()
                $ calendar.record_action("boughtregularperfume")
                scene perfumestore01 with dissolve
                plady "That will be $50, sir."
                scene perfumestore03 with dissolve
                plady "Happy to help, good day to you!"
                $ boughtregularperfume = True
                jump perfumemenu
            else:
                mc "I can't afford that."
                jump perfumemenu
        "Buy expensive perfume. ($200)":
            if not quest_buyscents in questlog.quest_list:
                $ questlog.StartQuest(quest_buyscents)
            if bag.buy(eperfume):
                if not boughtexpensiveperfume:
