        if item_name and item_name not in cafe_menu_pending:
            cafe_menu_pending[item_name] = max(1, price)

    def adjust_menu_item(item, amount):
        cafe_menu_pending[item] = cafe_menu_pending.get(item, 0) + amount
        if cafe_menu_pending[item] < 0:
            cafe_menu_pending[item] = 0
        renpy.restart_interaction()

    def adjust_menu_price(item, amount):
        # Adjust by fixed step, e.g. 0.50 euros
        max_price = 10.0  # Set maximum price per item
        min_price = 0.5   # Set minimum price per item
        new_price = menu_prices_pending.get(item, 0) + amount * 0.50
        new_price = max(min_price, min(max_price, new_price))
        menu_prices_pending[item] = new_price
        renpy.restart_interaction()

    def reset_menu_changes():
