    from random import choice
    def heal_midnight_dares():
        """
        Ensures all dare quest vars and complete flags exist in old saves.
        Also rebuilds dare_catalog if it's corrupted/outdated from old saves.
        """
        import renpy.store as store
        
        global dare_catalog
        
        renpy.log(f"[MIDNIGHT HEAL] Starting heal. dare_catalog has {len(dare_catalog)} entries")
        
        # NUCLEAR OPTION: If dare_catalog is missing dares, force rebuild it
        # This happens when loading old saves that serialized the catalog
        if len(dare_catalog) < 7:
            renpy.log(f"[MIDNIGHT HEAL] WARNING: Catalog only has {len(dare_catalog)} dares, rebuilding...")
            
            # Rebuild the catalog from scratch
