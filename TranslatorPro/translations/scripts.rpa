label gstoreleave:
    if calendar.weekday() in ["Saturday"]:
        scene gstorelady01 with dissolve
        skeepmom "Thank you, and have a nice day!"
    else:
        scene 242 with dissolve
        skeep "Thank you, and have a nice day!"
    return

label gstoreclosed:
    hide screen worldmap
    scene 240 with dissolve
    "The store is closed right now"
    show screen worldmap
    return

label gstorebathroom:
    scene 246 with dissolve
    mc "(I don't need to go right now.)"
    return
