        mai "What do you need, [name]?"
        mc "I was wondering if you could repair my phone for me."
        scene repairshop03 with dissolve
        "She lets out a deep sigh and looks visibly annoyed with your request for help."
        mai "Seriously?!"
        scene repairshop05 with dissolve
        mai "[name] I don't have time for this, I have work to do over here."
        mai "If you want your phone repaired, you'll have to do it yourself."
        mc "(Oh god...)"
        mc "How?"
        mai "Hold on, I'll set you up."
        scene black with slow_fade
        "You wait for Mai to clean some room on the table behind her so you have enough space to work with."
        pause 1.0
        scene repairscreen3 with dissolve
        mai "There you go."
        mai "I trust you know what you're doing?"
        jump repairinfo
    if quest_maihubby4 in questlog.quest_list:
        scene repairshop01 with dissolve
        mai "What do you need, [name]?"
        mc "What are you doing?"
        scene repairshop02 with dissolve
        mai "I'm keeping an eye on our new camera's."
        mai "To see if they work properly, and perhaps I see something that I shouldn't."
        mc "(Damn, she really is into this huh?)"
        mc "So you've decided to play along, or you actually like this?"
        mai "I had some time to think, and Robert showed me around..."
        mai "I must admit, the business is good."
        mc "I see, well is there anything I can help you with?"
        $ questlog.EndQuest(quest_maihubby4)
        scene repairshop03 with dissolve
        mai "Ugh... That reminds me Rob made a mess earlier."
        mc "A mess?"
        mc "(I hope she isn't talking about what I think she is talking about.)"
        scene repairshop04 with dissolve
        mai "Yes [name], he said he would help me install those cameras at the clothing store. But he didn't."
        menu:
            "ŌŁÉ Help her.":
                scene repairshop05 with dissolve
                mai "Great! I'll meet you there, I have to go get them first."
                mc "Sounds good."
                $ questlog.StartQuest(quest_spyintro)
                return
            "Don't help.":
                scene repairshop03 with dissolve
                mai "Fine, I guess I'll have to do it myself then."
                return
    if quest_spyware in questlog.quest_list:
        scene repairshop01 with dissolve
        mc "What did you say to Kendra?"
        scene repairshop02 with dissolve
        mai "Relax. She'll forget about it soon enough. I had to improvise, she was about to walk in there."
        mai "But you did a great job with the installment, I can see everything clearly."
        mc "Glad I could help."
        scene repairshop05 with dissolve
        mai "If you want, we can provide you with cameras and bugs from now on."
        mai "They'll come in handy in situations where you can't be present but still want to listen in or have eyes."
        mc "That sounds great."
        $ spywareunlocked = True
        scene repairshop07 with dissolve
        mai "I'll just tune this and..."
        mai "Shit... I dropped the sensor."
        scene repairshop06 with dissolve
        mai "Ugh, come here you stubborn little...!"
        mc "(Damn Mai...)"
        scene repairshop07 with dissolve
        mai "There! All done!"
        scene repairshop05 with dissolve
        mai "Here you go, [name]!"
        mai "This one's a demo unit..."
        mai "Call it a free sample. Consider it a thank you gift for not screwing up my wiring."
        $ bag.add_item(webcam)
        mai "If you want more of those, you'll have to buy them from our store and I'll tune them so you can watch the feed from your laptop at home."
        mc "That is... Awesome!"
        scene repairshop04 with dissolve
        mai "Alright, I have to get back to work now."
        mai "Enjoy that camera, and don't be a stranger!"
        mai "And hey... if you ever catch something *really juicy* on those feeds, maybe share it with me?"
        $ mailove += 10
        $ questlog.EndQuest(quest_spyware)
        $ questlog.StartQuest(quest_installspy)
        return

label repairinfo:
    scene repairscreen4 with dissolve
    menu:
        "­¤Æ¼ Explain please!" if phonebroke and not repair_resolved:
            scene repairscreen5 with dissolve
            mai "Come on, it's simple!"
            show phonescreen_hover
            mai "First, you grab the screen off this one. It's the exact model of the phone you have."
            scene repairscreen1 with dissolve
            pause 0.2
            scene repairscreen5 with dissolve
            show motherboard_hover
            mai "Then, you start by placing the motherboard."
            scene repairscreen1 with dissolve
            pause 0.2
            scene repairscreen5 with dissolve
            show chip_hover
            mai "After that, you attach the chip."
            scene repairscreen1 with dissolve
            pause 0.2
            scene repairscreen5 with dissolve
            show battery_hover
            mai "The next step is adding power, so you want to insert the battery."
            scene repairscreen1 with dissolve
            pause 0.2
            scene repairscreen5 with dissolve
            show phonerepair_hover
            mai "And finally, you place the new screen onto your phone."
            mc "Okay, got it."
            call screen repairscreen
            call repair_dispatch from _call_repair_dispatch
        "ŌŁÉ Of course, I got this!" if phonebroke and not repair_resolved:
            call screen repairscreen
            call repair_dispatch from _call_repair_dispatch_1
        "ŌŁÉ I'm done!" if mairepairstage >= 4:
            call repair_dispatch from _call_repair_dispatch_2
            $ questlog.EndQuest(quest_phonerepair)
            scene repairshop02 with dissolve
            mai "Try not to break it this time, hmmm?"
            mc "Right..."
            mc "(As if I did it on purpose!)"
            mc "Thanks Mai!"
            $ mailove += 10
            $ check_calls()
            jump game_loop

    

label robertrepair:
    if quest_maihubby in questlog.quest_list:
        scene repairshop09 with dissolve
        mc "So this is what you're hiding here."
        "Robert looks terrified and surprised."
        rob "Y-you're not supposed to be back here!"
        mc "I know, and I can see why."
        mc "Just a repair room, huh?"
        scene repairshop10 with dissolve
        mc "What is it you do here?"
        rob "Yeah alright... I'll admit I lied."
        scene repairshop11 with dissolve
        rob "We just... Setup cameras, provide people with information,..."
        mc "(More like blackmailing them I guess...)"
        mc "So, don't people find your camera's at some point?"
        scene repairshop12 with dissolve
        rob "Yes, ofcourse they do."
        rob "But we always find a way to install new ones."
        rob "And usually, by the time they found out you already have what you wanted."
        mc "Right."
        mc "(He is weirdly alright with the fact I just walked in on all of this.)"
        scene repairshop13 with dissolve
        rob "Look at this, I would've never been able to hide this code in the framework of FeralCams if it wasn't for planting that bug in their servers when I installed them."
        mc "So what does the code do?"
        scene repairshop10 with dissolve
        rob "It filters and stores all the private shows where people spent over $1000 in one session."
        mc "People actually spend that much in one go?"
        scene repairshop14 with dissolve
        rob "Oh yeah, and you'd be surprised about the things those girls do if they get that much money."
        mc "(I can only imagine...)"
        mc "That's... Genius and troubling."
        mc "But you do realise this is illegal right?"
        scene repairshop12 with dissolve
        rob "I know what it looks like, but the truth is..."
        rob "People are willing to pay a lot of money for stuff like this."
        rob "And all we're doing is record what's already happened and sell it again."
        scene repairshop14 with dissolve
        mc "Look Robert..."
        mc "Mai asked me to find out what you're doing here."
        mc "She was worried that you were cheating on her because you spend so much time back here."
        scene repairshop12 with dissolve
        rob "I'm not cheating on her."
        rob "This is our livelihood."
        mc "Well I propose that you talk to her, or I will."
        scene repairshop11 with dissolve
        rob "Ofcourse, I'll talk to her."
        rob "She will understand, you'll see."
        $ questlog.EndQuest(quest_maihubby, calendar.day)
        $ questlog.StartQuest(quest_maihubby3)
        return
    else: 
        menu:
            "ŌŁÉ Get in on it." if mccorruption >= 35:
                rob "Ugh..."
                rob "Fine."
                # flags and more story here.
                "{color=#ff0000}This arc's content ends here, please wait for an update.{/color}"
                return
            "Leave.":
                scene repairshop15 with dissolve
                rob "Alright then [name], I'll tell Mai you came by."
                mc "Alright."
                return

