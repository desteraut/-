default detentiongirl_respect = False

screen school:
    tag school
    $ current_hub = "school"
    $ present = get_characters_at_location("school")
    add "images/school/school_idle.webp"
    on "show" action [Function(renpy.music.play, "audio/school.ogg", loop=True, fadein=0.5), SetVariable("current_hub", "school"), SetVariable("current_location", "school")]
    on "hide" action Function(renpy.music.stop, fadeout=0.5)
    imagebutton auto "images/school/bathroomdoor_%s.png" style "worldbutton"  focus_mask True action [SetVariable("current_hub", "school"), SetVariable("current_room", "schoolbathroom"), SetVariable("current_location", "schoolbathroom"), Jump("game_loop")]
    if "detentiongirl" in present:
        imagebutton auto "images/school/detentiongirl_%s.png" focus_mask True action [SetVariable("current_hub", "school"), Call("detentiongirlmenu")]
    if not quest_deantalk in questlog.quest_list:
        imagebutton auto "images/school/deandoor_%s.png" style "worldbutton" focus_mask True action [SetVariable("current_hub", "school"), SetVariable("current_room", "deansofficescreen"), SetVariable("current_location", "deansoffice"), Jump("game_loop")]
    else:
        imagebutton auto "images/school/deandoor_%s.png" style "worldbutton" focus_mask True action [SetVariable("current_hub", "school"), SetVariable("current_room", "deansofficescreen"), Call("deandeal")]
    
    if "bff" in present:
        imagebutton auto "images/school/tim_%s.png" focus_mask True action [SetVariable("current_hub", "school"), Call("timdialogue")]
    if libraryunlocked:
        imagebutton auto "images/school/librarydoor_%s.png" style "worldbutton" focus_mask True action [SetVariable("current_location", "library"), Jump("game_loop")]
    if calendar.weekday() == "Tuesday" or quest_captivatingscience in questlog.quest_list or quest_dicinvest in questlog.quest_list or quest_sciencevitalis in questlog.quest_list or quest_haunted in questlog.quest_list or quest_talkitout in questlog.quest_list:
        imagebutton auto "images/school/scienceclassdoor_%s.png" style "worldbutton" focus_mask True action [SetVariable("current_hub", "school"), SetVariable("current_location", "scienceclass"), Jump("game_loop")]
