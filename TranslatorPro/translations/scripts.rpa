################################################################################
## In-game screens
################################################################################


## Say screen ##################################################################
##
## The say screen is used to display dialogue to the player. It takes two
## parameters, who and what, which are the name of the speaking character and
## the text to be displayed, respectively. (The who parameter can be None if no
## name is given.)
##
## This screen must create a text displayable with id "what", as Ren'Py uses
## this to manage text display. It can also create displayables with id "who"
## and id "window" to apply style properties.
##
## https://www.renpy.org/doc/html/screen_special.html#say

screen say(who, what):
    # Handle screen state changes
    on "show":
        action If(not what or not what.strip(), Hide("say"), NullAction()), Hide("worldmap"), Hide("desertmap")
    
    # Only show the window if we actually have dialogue
    if what and what.strip():
        window:
            id "window"
            style "custom_say_window"

            vbox:
                spacing 5
                xfill False

                if who is not None:
                    vbox:
                        xalign 0.5
                        spacing 6
                        
                        text who id "who" style "custom_name" xalign 0.5
                        add Solid("#74747463") ysize 3 xsize 200 xalign 0.5

                text what id "what" style "custom_dialogue"





define gui.textbox_yalign = 0.95
define gui.textbox_height = None  # Don't force height if using dynamic vbox



screen quick_menu():
    # Empty screen to silence Ren'Py's automatic overlay call
    pass

init -1 python:
    if "quick_menu" in config.overlay_screens:
        config.overlay_screens.remove("quick_menu")

## Make the namebox available for styling through the Character object.
init python:
    config.character_id_prefixes.append('namebox')

style window is default
