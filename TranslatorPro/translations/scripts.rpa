                    mc "Alright."
                    return
        "­¤øÆ Buy mrs. Burleys photos ($100)" if quest_teachphotoshoot.completed and mathpicsunlocked == False:
            if bag.cash >= 100:
                        scene studio2 with dissolve
                        photolady "Here you go."
