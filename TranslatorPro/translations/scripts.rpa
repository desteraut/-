        # Log all current dares
        renpy.log("[MIDNIGHT HEAL] Current dare catalog:")
        for dare in dare_catalog:
            renpy.log(f"  - {dare['id']}")
        
        # Now heal quest variables and completion flags
        for dare in dare_catalog:
            quest_var = dare.get("quest_var")
            complete_flag = dare.get("complete_flag")
            
            # Heal complete_flag
            if complete_flag and not hasattr(store, complete_flag):
                setattr(store, complete_flag, False)
                renpy.log(f"[MIDNIGHT HEAL] Created flag: {complete_flag} = False")
            
            # Heal quest_var
            if quest_var and not hasattr(store, quest_var):
                if quest_var in store.ALL_QUESTS:
                    setattr(store, quest_var, store.ALL_QUESTS[quest_var])
                    renpy.log(f"[MIDNIGHT HEAL] Created quest: {quest_var}")
                else:
                    setattr(store, quest_var, None)
                    renpy.log(f"[MIDNIGHT HEAL] WARNING: Quest not found in ALL_QUESTS: {quest_var}")
        
        # Clean up stale current dare
        if store.mischief_current:
            dare_id = store.mischief_current.get("id")
            dare_exists = any(d["id"] == dare_id for d in dare_catalog)
            if not dare_exists:
                renpy.log(f"[MIDNIGHT HEAL] Clearing stale current dare: {dare_id}")
                store.mischief_current = None
                store.mischief_last_assigned_day = None
                store.mischief_last_assigned_id = None
        
        renpy.log("[MIDNIGHT HEAL] Heal complete")


    def assign_random_dare():
        global mischief_current, mischief_last_assigned_day, mischief_last_assigned_id
        
        # No new dare if one is active/offered
        if mischief_current and mischief_current.get("status") in ("offered", "active"):
            return
        
        day_num = calendar.day
        day_name = calendar.weekday()
        now_band = get_time_of_day()
        
        # Prevent multiple rolls in the same day
        if mischief_last_assigned_day == day_num:
            return
        
        _mdbg(f"day_num={day_num} day_name={day_name} time={now_band}")
        
        LOC_ALIAS = {
            "spa": "desert_spa",
            "diner": "desert_diner",
            "weatherroom": "desert_radio",
        }
        
        eligible = []
        
        for dare in dare_catalog:
            loc_key = LOC_ALIAS.get(dare["loc_key"], dare["loc_key"])
            reasons = []
            
            # Skip one-time dares that are completed
            if dare.get("unique_once", False):
                flag = dare.get("complete_flag")  # Fixed key name
                if flag and getattr(store, flag, False):
                    reasons.append(f"done:{flag}")
            
            # Will this location be open during the requested band today?
            if not will_open_today(loc_key, dare["timeband"], day_name):
                reasons.append(f"schedule:{loc_key}:{dare['timeband']}")
            
            # Requirements
            if dare.get("requirements"):
                for req in dare["requirements"]:
                    if not getattr(store, req, False):
                        reasons.append(f"req:{req}")
                        break
            
            if reasons:
                _mdbg(f"{dare['id']} reject -> {', '.join(reasons)}")
                continue
            
            _mdbg(f"{dare['id']} OK")
            eligible.append(dare)
        
        if not eligible:
            _mdbg("eligible=0 (no assignment)")
            return
        
        # Prefer not to repeat yesterday if we have options
        candidates = [d for d in eligible if d["id"] != mischief_last_assigned_id] or eligible
        
        dare = renpy.random.choice(candidates)
        
        # Assign
        mischief_current = dict(dare)
        mischief_current["status"] = "offered"
        mischief_current["assigned_on"] = day_num
        mischief_current["deadline"] = day_num
        mischief_last_assigned_day = day_num
        mischief_last_assigned_id = dare["id"]
        
        _mbark("assigned", cooldown=1)


    def accept_dare():
        global mischief_current
        if not mischief_current or mischief_current.get("status") != "offered":
            return
        # Start the linked Quest now
        qname = mischief_current.get("quest_var")
        quest_obj = getattr(store, qname, None) if qname else None
        if quest_obj:
            questlog.StartQuest(quest_obj, start_day=calendar.day)
        mischief_current["status"] = "active"
        _mbark("accept", cooldown=1)

    def refuse_dare():
        import renpy.store as S
        global mischief_current, mischief_history
        if not mischief_current or mischief_current.get("status") != "offered":
            return

        # half penalty on refuse
        penalty = int(mischief_current.get("penalty_points", 0)) // 2
        if penalty > 0:
            S.bag.add_mischief(-penalty)

        # refusing breaks momentum
        S.mischief_streak = 0

        mischief_history.append({
            "day": S.calendar.day,
            "id": mischief_current["id"],
            "title": mischief_current["title"],
            "result": "refused",
            "points": -penalty
        })
        mischief_current = None
        _mbark("refuse", cooldown=1)

    def complete_dare(success=True):
        import renpy.store as S
        global mischief_current, mischief_history, mischief_last_completed
        if not mischief_current or mischief_current.get("status") != "active":
            return

        # --- reward points first, through Bag (fires milestones/floaters)
        reward = int(mischief_current.get("reward_points", 0))
        if reward:
            S.bag.add_mischief(reward)

        # --- streak + daily spark once, only on success
        if success:
            today = S.calendar.day
            if S.last_dare_day != today:
                S.bag.add_mischief(+1, label="Daily Spark")
            S.mischief_streak += 1
            S.last_dare_day = today
            renpy.sound.play("audio/midnightcute.ogg")
        else:
            S.mischief_streak = 0

        # --- quest + flags
        qname = mischief_current.get("quest_var")
        quest_obj = getattr(store, qname, None) if qname else None
        if quest_obj and quest_obj.started:
            questlog.EndQuest(quest_obj, completed_day=S.calendar.day)

        flag = mischief_current.get("complete_flag")
        if flag:
            setattr(store, flag, True)

        # --- history
        mischief_history.append({
            "day": S.calendar.day,
            "id": mischief_current["id"],
            "title": mischief_current["title"],
            "result": "completed" if success else "failed",
            "points": reward if success else 0
        })
        mischief_last_completed[mischief_current["id"]] = S.calendar.day

        mischief_current = None
        _mbark("complete", cooldown=1)

    def fail_dare():
        import renpy.store as S
        global mischief_current, mischief_history
        if not mischief_current or mischief_current.get("status") not in ("offered", "active"):
            return

        # If it was accepted, reset the linked quest
        if mischief_current["status"] == "active":
            qname = mischief_current.get("quest_var")
            quest_obj = getattr(store, qname, None) if qname else None
            if quest_obj and (getattr(quest_obj, "started", False) or getattr(quest_obj, "available", False)):
                try:
                    questlog.ResetQuest(quest_obj)
                except Exception:
                    pass

        penalty = int(mischief_current.get("penalty_points", 0))
        if penalty > 0:
            S.bag.add_mischief(-penalty)

        # failing always nukes streak
        S.mischief_streak = 0
        renpy.sound.play("audio/midnighthiss.ogg")
        mischief_history.append({
            "day": S.calendar.day,
            "id": mischief_current["id"],
            "title": mischief_current["title"],
            "result": "failed",
            "points": -penalty
        })
        mischief_current = None
        _mbark("fail", cooldown=1)

    def is_dare_active(dare_id):
        return bool(
            mischief_current
            and mischief_current.get("id") == dare_id
            and mischief_current.get("status") == "active"
        )

    def schedule_is_open(loc_key, band, day):
        # normalize to your dict keys
        loc = str(loc_key).lower()
        periods_today = location_periods.get(loc, {}).get(day, [])
        return band in periods_today

    def will_open_today(loc_key, timeband, day):
        if timeband == "any":
            periods_today = location_periods.get(str(loc_key).lower(), {}).get(day, [])
            # open if ANY band today is open
            return bool(periods_today)
        else:
            return schedule_is_open(loc_key, timeband, day)

    def _abs_minutes():
        # 24h absolute minutes; adjust if you track minutes differently
        mins = getattr(calendar, "minutes", 0)
        return calendar.day * 1440 + calendar.hours * 60 + mins

    def midnight_say(text, category=None, cooldown_minutes=45, duration=2.8):
        """
        Queue a Midnight popup with optional per-category cooldown.
        """
        if not store.mischief_activated:
            return
        if category:
            now = _abs_minutes()
            last = midnight_last_bark.get(category)
            if last is not None and (now - last) < cooldown_minutes:
                return
            midnight_last_bark[category] = now

        midnight_popup_queue.append({"text": text, "duration": duration})
        renpy.exports.restart_interaction()

    def _midnight_pop():
        if not store.mischief_activated:
            return

        if midnight_popup_queue:
            midnight_popup_queue.pop(0)

        renpy.restart_interaction()


    # Quip pools ŌĆō keep them short/snappy; add more lines whenever
    midnight_barks = {
        "assigned": [
            "New dare, kitten. Try not to bore me.",
            "Let's see some chaos today~",
            "I spun the wheel. You're up."
        ],
        "accept": [
            "There's my troublemaker.",
            "Good. Make it count.",
            "Now don't wimp out."
        ],
        "refuse": [
            "Oh? Cold feet already?",
            "Tsk. I expected more.",
            "Next time, say yes."
        ],
        "complete": [
            "MmmŌĆ” that's the spark I like.",
            "You actually pulled it off. Cute.",
            "Points well earned, kitty."
        ],
        "fail": [
            "Close doesn't count.",
            "You blinked. I noticed.",
            "Try embarrassing yourself less next time."
        ],
        "opportunity": [
            "Psst. Right place, right time.",
            "Everything you need is here. Don't stall.",
            "This is it. Make them stare."
        ],
        "deadline": [
            "Clock's ticking.",
            "Almost out of timeŌĆ” move.",
            "Do it now or lose the points."
        ],
    }

    def _mbark(kind, cooldown=45):
        pool = midnight_barks.get(kind, ["..."])
        midnight_say(renpy.random.choice(pool), category=kind, cooldown_minutes=cooldown)

    def _mdbg(msg):
        try:
            renpy.log(f"[MIDNIGHT] {msg}")
        except Exception:
            pass
    
    def midnight_opportunity_ping(loc_key):
        if not mischief_current or mischief_current.get("status") != "active":
            return
        if mischief_current.get("loc_key") != loc_key:
            return
        tb = mischief_current.get("timeband", "any")
        if tb != "any" and get_time_of_day() != tb:
            return
        _mbark("opportunity", cooldown=120)  #  120 minute cooldown so it won't spam

    def _band_end_hour(band):
        return {"morning": 12, "afternoon": 18, "evening": 23, "night": 24}.get(band, None)
    
    def _latest_end_for_today(loc_key):
        # uses your location_periods + _band_end_hour
        wd = calendar.weekday()  # e.g., "Tuesday"
        periods_today = location_periods.get(str(loc_key).lower(), {}).get(wd, [])
        if not periods_today:
            return 24  # treat as all-day fallback
        ends = [_band_end_hour(b) for b in periods_today if _band_end_hour(b) is not None]
        return max(ends) if ends else 24

    # replace your current midnight_deadline_check with:
    def midnight_deadline_check(prev_hour, new_hour):
        if not mischief_current or mischief_current.get("status") != "active":
            return

        band = mischief_current.get("timeband", "any")
        loc  = mischief_current.get("loc_key")

        # Determine the effective end hour
        if band == "any":
            endh = _latest_end_for_today(loc)  # <- NEW
        else:
            endh = _band_end_hour(band)

        if endh is None:
            return

        # choose 1h (or 2h) before end for the nudge
        warn_hour = (endh - 1) % 24

        # crossing detection (unchanged)
        if prev_hour <= new_hour:
            crossed = prev_hour < warn_hour <= new_hour
        else:
            crossed = (warn_hour > prev_hour) or (warn_hour <= new_hour)

        if not crossed:
            return

        midnight_say("Tick-tockŌĆ” dare window's almost shut.", category="deadline_warn", cooldown_minutes=0)

    def daily_reset_mischief_flags():
        if not hasattr(store, "last_mischief_reset_day"):
            store.last_mischief_reset_day = calendar.day

        if store.last_mischief_reset_day != calendar.day:
            store.last_mischief_reset_day = calendar.day
            store.reroll_used_today = False


    def try_reroll_current_dare():
        import renpy.store as S
        if not S.reroll_used_today:
            S.reroll_used_today = True
            return ("free", True)
        if S.bag.use_reroll_token():
            return ("token", True)
        # No free, no token
        return ("none", False)

    def can_reroll_today():
        return (not store.reroll_used_today) or (store.bag.reroll_tokens > 0)

    def perform_reroll(assign_func, pick_func, prev_dare):
        import renpy.store as S

        # Quick pre-check so we can bail early with a nice floater
        if not can_reroll_today():
            show_floater("No rerolls available", "#ff0000")
            return ("none", False)

        # Try to find a valid new dare first
        new_dare = pick_func(prev_dare)
        if not new_dare:
            show_floater("No valid dares right now", "#ff0000")
            return ("none", False)

        # Now consume currency
        how = "free"
        if not S.reroll_used_today:
            S.reroll_used_today = True
            show_floater("Free Reroll!", "#00ff00")
        else:
            if not S.bag.use_reroll_token():
                # Shouldn't happen, but guard against race conditions
                show_floater("No rerolls available", "#ff0000")
                return ("none", False)
            how = "token"
            # Optional: tiny mischief drip to discourage fishing
            # S.bag.add_mischief(-1, label="Mischief")

        # Assign the dare
        assign_func(new_dare)
        return (how, True)
    
    def _midnight_click_reroll():
        import renpy.store as S

        how, ok = perform_reroll(assign_func=assign_random_dare, pick_func=S.pick_random_dare, prev_dare=S.current_dare)


        if ok:
            if how == "free":
                show_floater("Free Reroll!", "#00ff00")
            else:
                show_floater("Reroll Token -1", "#ff8c00")
        else:
            show_floater("No rerolls available", "#ff0000")

    def midnight_reroll():
        import renpy
        import renpy.store as S

        # Currency pre-check
        free_avail = not getattr(S, "reroll_used_today", False)
        token_avail = hasattr(S, "bag") and getattr(S.bag, "reroll_tokens", 0) > 0
        if not free_avail and not token_avail:
            show_floater("No rerolls available", "#ff0000")
            return

        # Stash current state so we can roll back on failure or no change
        prev_state = (
            S.mischief_current,
            S.mischief_last_assigned_day,
            S.mischief_last_assigned_id,
        )
        prev_id = prev_state[2]

        # Let assignment happen again today and not be blocked by an offered/active dare
        S.mischief_current = None
        S.mischief_last_assigned_day = None

        # Try to assign something new using your existing logic
        assign_random_dare()

        # Did we actually get a different dare?
        new_id = getattr(S, "mischief_last_assigned_id", None)
        got_new = new_id is not None and new_id != prev_id

        if not got_new:
            # Restore and inform player
            (S.mischief_current,
            S.mischief_last_assigned_day,
            S.mischief_last_assigned_id) = prev_state
            show_floater("No valid new dares right now", "#ff0000")
            renpy.exports.restart_interaction()
            return

        # Consume currency *after* success
        if free_avail:
            S.reroll_used_today = True
            show_floater("Free Reroll!", "#00ff00")
        else:
            if not S.bag.use_reroll_token():
                # Couldn't payŌĆörevert the reroll
                (S.mischief_current,
                S.mischief_last_assigned_day,
                S.mischief_last_assigned_id) = prev_state
                show_floater("No rerolls available", "#ff0000")
                renpy.exports.restart_interaction()
                return
            show_floater("Reroll Token -1", "#ff8c00")

        # Refresh the UI
        renpy.exports.restart_interaction()

    def available_rerolls():
        import renpy.store as S
        free = 0 if S.reroll_used_today else 1
        return free + S.bag.reroll_tokens, free

screen midnight_popup_manager():
    tag midnight
    zorder 200

    if midnight_popup_queue:
        $ msg = midnight_popup_queue[0]

        frame:
            style "midnight_popup_frame"
            at midnight_slide_in

            button:
                action Function(_midnight_pop)
                style "midnight_popup_button"
                focus_mask True

                hbox:
                    spacing 12
                    xalign 0.5
                    yalign 0.0
                    add MIDNIGHT_PORTRAIT xsize 84 ysize 84
                    vbox:
                        spacing 4
                        text "Midnight" style "midnight_popup_title"
                        text msg["text"] style "midnight_popup_text"

        timer max(0.01, msg.get("duration", 2.8)) action Function(_midnight_pop)


style midnight_popup_button is default:
    background None
    hover_background None
    insensitive_background None



transform midnight_slide_in:
    on show:
        alpha 0.0 yoffset -20
        linear 0.20 alpha 1.0 yoffset 0
    on hide:
        linear 0.18 alpha 0.0 yoffset -20

style midnight_popup_frame:
    background "#0B0E1ACC"
    padding (12, 10)
    xalign 0.5
    ypos 90
    xmaximum 720

style midnight_popup_title:
    size 22
    color "#9fe0ff"
    outlines [(1, "#000", 0, 0)]

style midnight_popup_text:
    size 20
    color "#FFFFFF"
    outlines [(1, "#000", 0, 0)]Made with Ren'Py.default talkedabout_april = False
default jail_access_unlocked = False
default aprilsaved = False
default aprilescaped = False
default aprilfucked = False

screen militaryscreen:
