        "espresso": {"bean": "es", "milk": False, "cream": False, "liquor": False},
        "lat├®": {"bean": "late", "milk": True, "cream": False, "liquor": False},
        "Irish coffee": {"bean": "es", "milk": False, "cream": True, "liquor": True}
    }

screen cshopoffice:
    tag coffeeshop
    on "show" action [Function(renpy.music.play, "audio/cshopoffice.ogg", loop=True, fadein=0.5), SetVariable("current_location", "cshopoffice")]
    if quest_cshophelp3 in questlog.quest_list:
        add "images/coffeeshop/cshopoffice2.webp"
        imagebutton auto "images/coffeeshop/officeclaire_%s.png" focus_mask True action Call("cshopoffice")
    elif quest_confrontclaire in questlog.quest_list:
        add "images/coffeeshop/cshopoffice.webp"
        imagebutton auto "images/coffeeshop/cshopofficepc_%s.png" focus_mask True action Call("cshopwait")
    else:
        add "images/coffeeshop/cshopoffice.webp"
        imagebutton auto "images/coffeeshop/cshopofficepc_%s.png" focus_mask True action Call("cshopnothere")

screen coffeeshop:
    tag coffeeshop
    $ present = get_characters_at_location("coffeeshop")
    add "images/coffeeshop/cshop.webp"
    on "show" action [Function(renpy.music.play, "audio/coffeeshop.ogg", loop=True, fadein=0.5), SetVariable("current_location", "coffeeshop")]
    if quest_cshophelp3 in questlog.quest_list:
        imagebutton auto "images/coffeeshop/door_%s.png" style "worldbutton" focus_mask True action [Hide("coffeeshop"), SetVariable("current_location", "cshopoffice"), Return()]
    else:
        imagebutton auto "images/coffeeshop/door_%s.png" style "worldbutton" focus_mask True action Call("cshopnothere")
    for char_id in present:
            imagebutton auto "images/coffeeshop/%s_%%s.png" % char_id focus_mask True action Call("%smenu" % char_id)

screen coffeemaking:
    tag coffeeshop
    add "images/coffeeshop/coffee1.webp"

    # --- RESET STATE ---
    $ coffee_timeout = False
    $ capu = False
    $ es = False
    $ late = False

    # --- CAPPUCCINO ---
    imagebutton auto "images/coffeeshop/capu1_%s.png" focus_mask True action [
        SetVariable("capu", True),
        Hide("coffeemaking"),
        Show("coffeeserve")

    ]

    imagebutton auto "images/coffeeshop/capu2_%s.png" focus_mask True action [
        SetVariable("capu", True),
        Hide("coffeemaking"),
        Show("coffeeserve")

    ]

    imagebutton auto "images/coffeeshop/capu3_%s.png" focus_mask True action [
        SetVariable("capu", True),
        Hide("coffeemaking"),
        Show("coffeeserve")

    ]

    # --- ESPRESSO ---
    imagebutton auto "images/coffeeshop/es1_%s.png" focus_mask True action [
        SetVariable("es", True),
        Hide("coffeemaking"),
        Show("coffeeserve")

    ]

    imagebutton auto "images/coffeeshop/es2_%s.png" focus_mask True action [
        SetVariable("es", True),
        Hide("coffeemaking"),
        Show("coffeeserve")

    ]

    imagebutton auto "images/coffeeshop/es3_%s.png" focus_mask True action [
        SetVariable("es", True),
        Hide("coffeemaking"),
        Show("coffeeserve")

    ]

    # --- LATTE ---
    imagebutton auto "images/coffeeshop/late1_%s.png" focus_mask True action [
        SetVariable("late", True),
        Hide("coffeemaking"),
        Show("coffeeserve")

    ]

    imagebutton auto "images/coffeeshop/late2_%s.png" focus_mask True action [
        SetVariable("late", True),
        Hide("coffeemaking"),
        Show("coffeeserve")

    ]

    # --- CHECK ORDER (NO TIMER START) ---
    imagebutton auto "images/coffeeshop/order_%s.png" focus_mask True action [
        Hide("coffeemaking"),
        Show("coffeeorder", coffee_choice=coffee_choice, return_to="coffeemaking")
    ]


screen coffeeorder(coffee_choice, return_to):
    tag coffeeshop
    button:
        background None
        action [
            Hide("coffeeorder"),
            Show(return_to)
        ]
        xysize (1920, 1080)
        xpos 0
        ypos 0

    frame:
        background None
        padding (0, 0)
        margin (0, 0)
        xpos 0
        ypos 0
        add (
            "images/coffeeshop/coffee3.webp" if coffee_choice == "espresso" else
            "images/coffeeshop/coffee4.webp" if coffee_choice == "lat├®" else
            "images/coffeeshop/coffee5.webp" if coffee_choice == "Irish coffee" else
            "images/coffeeshop/coffee6.webp"
        ) xpos 0 ypos 0
        # Block clicks from passing through this area
        button:
            background None
            xysize (870, 1050)
            xpos 525
            ypos 25
            action NullAction()

    textbutton "Back" xpos 10 ypos 10 action [
        Hide("coffeeorder"),
        Show(return_to)
    ]



screen coffeeserve(timeout=10.0):
    tag coffeeshop
    add "images/coffeeshop/coffee2.webp"

    on "show" action Function(
        renpy.sound.play,
        "audio/coffeemachine.ogg",
        loop=False
    )

    # Timer setup
    default remaining = timeout
    default timer_paused = False
    # Feedback message + timestamp
    default feedback_text = ""
    default feedback_time = 0.0

    # --- TIMER UPDATE (every 0.05s) ---
    timer 0.05 repeat True action If(
        not timer_paused,
        true=SetScreenVariable(
            "remaining",
            max(0.0, remaining - 0.05)
        ),
        false=None
    )


    # --- TIMEOUT CHECK ---
    timer 0.05 repeat True action If(
        remaining <= 0.0,
        true=[
            SetVariable("coffee_timeout", True),
            Hide("coffeeserve"),
            Call("coffeeserving")
        ],
        false=None
    )

    # --- FEEDBACK AUTO-HIDE (after ~1 second) ---
    timer 0.1 repeat True action If(
        (feedback_text != "") and (time.time() - feedback_time >= 1.0),
        true=SetScreenVariable("feedback_text", ""),
        false=None
    )

    # --- CENTERED UI BLOCK ---
    vbox:
        xalign 0.5
        yalign 0.5
        spacing 15

        # Ingredient buttons
        textbutton "­¤źø Add milk" action [
            SetVariable("milk", True),
            SetScreenVariable("feedback_text", "You add milk to the coffee."),
            SetScreenVariable("feedback_time", time.time())
        ]:
            background Frame("gui/button/idle_background.png", 20, 20)
            hover_background Frame("gui/button/hover_background.png", 20, 20)
            padding (20, 10)
            xalign 0.5

        textbutton "­¤źā Add liquor" action [
            SetVariable("liquor", True),
            SetScreenVariable("feedback_text", "You add a splash of liquor."),
            SetScreenVariable("feedback_time", time.time())
        ]:
            background Frame("gui/button/idle_background.png", 20, 20)
            hover_background Frame("gui/button/hover_background.png", 20, 20)
            padding (20, 10)
            xalign 0.5

        textbutton "Ōśü’ĖÅ Add cream" action [
            SetVariable("cream", True),
            SetScreenVariable("feedback_text", "You add a swirl of cream."),
            SetScreenVariable("feedback_time", time.time())
        ]:
            background Frame("gui/button/idle_background.png", 20, 20)
            hover_background Frame("gui/button/hover_background.png", 20, 20)
            padding (20, 10)
            xalign 0.5
        if elispecial:
            textbutton "­¤ÆŖ Add Vitalis" action [
                SetVariable("vitalis_added", True),
                If(
                    bag.has_item(dicdrug),
                    true=Function(bag.remove_item, dicdrug, 1),
                    false=None
                ),
                SetScreenVariable("feedback_text", "You add a dose of Vitalis."),
                SetScreenVariable("feedback_time", time.time())
            ]:
                background Frame("gui/button/idle_background.png", 20, 20)
                hover_background Frame("gui/button/hover_background.png", 20, 20)
                padding (20, 10)
                xalign 0.5
        textbutton "­¤¦Š Check recipe again" action [
            SetScreenVariable("timer_paused", True),
            Show("coffeeorder", coffee_choice=coffee_choice, return_to="coffeeserve")
        ]

        

        # Serve button
        button:
            action [Hide("coffeeserve"), Call("coffeeserving")]
            sensitive remaining > 0
            background Frame("gui/button/idle_background.png", 20, 20)
            hover_background Frame("gui/button/hover_background.png", 20, 20)
            padding (30, 20)
            xalign 0.5

            vbox:
                spacing 10
                xalign 0.5

                text "Serve!":
                    size 24
                    xalign 0.5

                if remaining > 0:
                    frame:
                        background None
                        padding (0, 0)
                        xalign 0.5
                        xmaximum 150

                        bar:
                            value remaining
                            range timeout
                            ysize 8
                            xfill True
                            left_bar ("#FFD700" if remaining > timeout * 0.33 else "#FF3C3C")
                            right_bar "#222"

    # --- FEEDBACK AT BOTTOM OF SCREEN ---
    if feedback_text:
        text feedback_text:
            size 24
            xalign 0.5
            yalign 0.92
            outlines [(1, "#000", 0, 0)]




# This is the tiny label that fades out the feedback text
label _fade_feedback:
    pause 1.0
    $ feedback_opacity = 0.0
    return






label coffeeserving:

    # If timer ran out
    if coffee_timeout:
        $ result = "timeout"

    else:
        # Snapshot all ingredient states at the moment of serving
        $ player_selection = {
            "bean":  ("capu" if capu else "es" if es else "late" if late else None),
            "milk":  milk,
            "cream": cream,
            "liquor": liquor
        }

        # Grab correct recipe
        $ correct = recipes.get(coffee_choice, {})

        # ----- Evaluate -----
        $ correct_bean   = correct.get("bean")
        $ correct_milk   = correct.get("milk", False)
        $ correct_cream  = correct.get("cream", False)
        $ correct_liquor = correct.get("liquor", False)

        # First, require exact bean match
        $ bean_match = (player_selection["bean"] == correct_bean)

        # Exact additive match
        $ milk_match   = (player_selection["milk"]   == correct_milk)
        $ cream_match  = (player_selection["cream"]  == correct_cream)
        $ liquor_match = (player_selection["liquor"] == correct_liquor)

        if bean_match and milk_match and cream_match and liquor_match:
            $ result = "perfect"
            $ coffeehelped = True
        else:
            $ result = "fail"

    # ----- Result dialogue -----
    if not coffeearc_finished:
        scene mcwait5 with dissolve

        if result == "perfect":
            lady "Wow, this is delicious!"
            mc "Glad you like it!"
            $ coffeegirllove += 10
            $ coffeeownerlove += 5

        elif result == "timeout":
            lady "Thanks, but you took a really long time!"
            lady "I'll go somewhere else next time. Bye!"
            $ coffeegirllove -= 10

        else:  # fail
            lady "Uh... what *is* this?"
            mc "Uh... experimental roast?"
            $ coffeegirllove -= 5

        # reset timeout flag
        $ coffee_timeout = False

        jump justininterviewend
    elif not elispecial:
        scene laurecoffee2 with dissolve
        if result == "perfect":
            laura "Thank you [name], this is exactly what I needed."
            mc "Glad I could help!"
            $ lauralove += 10
        elif result == "timeout":
            laura "Thanks, but you took a really long time!"
            laura "Good thing my sister doesn't do this at the bar."
            play sound "audio/sigh.ogg"
            mc "*sighs* I'm sorry, I'm still new to this."
            $ lauralove -= 10
        else:  # fail
            laura "Uh... what *is* this?"
            mc "Uh... experimental roast?"
            $ lauralove -= 5
        $ coffee_timeout = False
        call coffeespirit2 from _call_coffeespirit2
        return
    else:
        scene coffeedare11 with dissolve
        if result == "perfect":
            eli "Haha, wow [name], you really outdid yourself!"
            eli "This is perfect!"
            mc "Glad you like it!"
            $ trailerdaughterlove += 10
            $ mccorruption += 20
        elif result == "timeout":
            eli "Thanks, but you took a really long time!"
            eli "I'll go somewhere else next time. Bye!"
            $ trailerdaughterlove -= 10
            $ mccorruption += 10
        else:  # fail
            eli "Uh... what *is* this?"
            mc "Uh... experimental roast?"
            $ trailerdaughterlove -= 5
            $ mccorruption += 5
        $ coffee_timeout = False
        jump coffeearcfinish

label coffeespirit2:
    scene officer11 with dissolve
    "The coffee shop goes quiet for a moment as Laura takes her coffee and leaves."
    if vitalis_added:
        mc "(Man, I can't believe Claire is really doing this...)"
        mc "(Spiking customers' drinks with that stuff...)"
        mc "(I hope she knows what she's doing...)"
    "Another customer quickly shows up."
    scene coffeedare10 with dissolve
    $ milk = False
    $ liquor = False
    $ cream = False
    $ vitalis_added = False
    eli "Hey [name], you serving today?"
    mc "Yeah, just finished up with the last customer."
    eli "Awesome, I could use a pick-me-up... If you know what I mean?"
    menu:
        "Serve Eli a spiked coffee.":
            $ elispecial = True
            $ coffee_choice = renpy.random.choice(["lat├®", "espresso", "cappuccino", "Irish coffee"])
            eli "Can you make it a {color=#82a1ff}special [coffee_choice]{/color} please?"
            mc "Sure, coming right up."
            call screen coffeemaking
        "Refuse.":
            eli "Ah, never mind then."
            eli "I'll just come back later."
            $ trailerdaughterlove -= 5
    call coffeearcfinish from _call_coffeearcfinish
    return

label coffeearcfinish:
    scene officer11 with dissolve
    "The coffee shop goes quiet for a moment as Eli takes her coffee and leaves."
    mc "(I didn't know she took that stuff...)"
    mc "(I can't believe I enabled her either...)"
    scene officer1 with dissolve
    "The door chimes as 2 officers walk in." with vpunch
    mc "(Oh boy...)"
    mc "Hello officer Sadie, officer Roxy!"
    mc "What can I get you?"
    pclerk "Hey [name], we're here on official business."
    mc "(Uh oh...)"
    mc "About what?"
    scene officer2 with dissolve
    pclerk2 "We're investigating a report involving a drink that may have been spiked with an illegal substance."
    mc "(Oh no...)"
    pclerk2 "We have reason to believe that this may have occurred here at the coffeeshop."
    mc "I uhh-"
    coffeeowner "And I suppose you brought proof of this?" with vpunch
    scene officer4 with dissolve
    "Claire shows up out of nowhere, taking over the conversation."
    pclerk2 "We've been onto you for a while now, Claire."
    pclerk2 "You've been spiking customers' drinks with Vitalis in order to boost sales."
    coffeeowner "Look, I don't know what you're talking about. I run a legitimate business here."
    scene officer3 with dissolve
    pclerk "We've collected enough evidence to prove otherwise."
    mc "(This is bad...)"
    scene officer5 with dissolve
    coffeeowner "Feel free to search the premises then."
    coffeeowner "I can assure you that if you do find evidence of wrongdoing..."
    coffeeowner "Well... I'm not the one serving, am I?" with vpunch
    mc "(Wait... what?!)"
    mc "(Is she seriously trying to pin this on me?!)"
    if vitalis_added or elispecial:
        scene officer6 with dissolve
        pclerk2 "Sir, please come with us for questioning."
        mc "Uhh... okay..."
        "Claire looks at you, a sly smile on her face."
        mc "(I can't believe she did this...)"
        coffeeowner "Officers, may I have a word with [name] before you take him?"
        scene officer7 with dissolve
        coffeeowner "Listen [name], I will make bail for you."
        coffeeowner "Just... Keep my name out of any of this."
        coffeeowner "Okay?"
        mc "I don't appreciate this, Claire."
        mc "You better get me out of this mess."
        scene officer8 with dissolve
        coffeeowner "Don't worry, I will."
        coffeeowner "And when all this blows over, I'll make sure to reward you for your loyalty."
        mc "Fine..."
        scene black with fade
        $ renpy.music.stop(fadeout=1.0)
        "You are taken to the police station for questioning."
        scene policeblackout1 with dissolve
        $ renpy.music.play("audio/policestation.ogg", loop=True, fadein=0.5)
        pause 0.5
        "After a few hours, Claire manages to post bail for you."
        scene policeblackout4 with dissolve
        "You are released, but with a warning to stay out of trouble."
        pclerk2 "Consider yourself lucky this time, [name]."
        mc "Yeah, I know."
        $ calendar.addtime(360)
        call coffeesex from _call_coffeesex
        return
    pclerk2 "Look, we know [name] works here."
    pclerk2 "Don't try to pin this on him." 
    mc "(Thank god...)"
    scene officer9 with dissolve
    coffeeowner "I can't believe this is happening."
    coffeeowner "I don't deserve this."
    mc "(Right...)"
    pclerk "Alright, it's time to go."
    scene officer10 with dissolve
    "You watch as the officers escort Claire out of the coffeeshop."
    mc "(I can't believe she tried to pin this on me...)"
    mc "(I wonder what will happen to the coffeeshop now...)"
    $ questlog.EndQuest(quest_coffeearcfinale)
    scene black with slow_fade
    $ mccorruption -= 20
    return


label coffeesex:
    $ renpy.music.play("audio/coffeeshop.ogg", loop=True, fadein=0.5)
    "You return to the coffeeshop, Claire locks the door behind you and flips the sign to closed."
    scene officer7 with dissolve
    coffeeowner "Hey [name], thanks for keeping my name out of it."
    coffeeowner "I promised you a reward, didn't I?"
    scene officer8 with dissolve
    coffeeowner "So... here I am."
    scene black with fade
    "She strips slowly, eyes locked on yours, then steps close."
    if not is_gallery_unlocked("roughcoffee"):
        $ unlock_gallery_scene("roughcoffee")
    mc "You tried to throw me under the bus, Claire."
    scene clairesex1 with dissolve
    coffeeowner "[name]! I-"
    mc "Shut up!"
    "You grab her from behind and pull her closer, holding her tightly."
    scene clairesex2 with dissolve
    "Without another word, you slam into her, hard."
    coffeeowner "Ah-fuck!"
    scene clairesex3 with dissolve
    "You don't hold back, taking her roughly while she gasps and claws at the counter."
    coffeeowner "Oh godŌĆö[name]!"
    scene clairesex4 with dissolve
    "Her protests melt into moans as you grip tighter."
    coffeeowner "Ahh-AHH-AHHHHHH!!"
    scene clairesex5 with dissolve
    mc "This what you wanted? To be used?"
    scene clairesex6 with dissolve
    "Suddenly she throws her arms around you and begs you for it."
    coffeeowner "Yes [name], breed me!"
    coffeeowner "Use me! Oh god YES!!!" with vpunch
    mc "FU-CK!!!" with vpunch
    scene clairesex7 with dissolve
    pause 0.5
    "You finish deep inside her. She slumps against the counter, breathless and trembling."
    coffeeowner "Gosh [name], I haven't been fucked like this in quite a while..."
    coffeeowner "Please use me again like this?"
    mc "You're sick, Claire."
    $ questlog.EndQuest(quest_coffeearcfinale)
    scene black with slow_fade
    pause 0.5
    "You've corrupted Claire."
    $ mccorruption += 30
    $ coffeeownercorruption += 100
    return
    


label coffeeownermenu:
    if havemet_coffeeowner:
        scene cshop5 with dissolve
        coffeeowner "Welcome! What can I do you for?"
        menu:
            "ŌŁÉ Interview for Justin." if quest_initcshophelp in questlog.quest_list:
                jump cshopinterview
            "­¤Æ¼ Talk to her.":
                jump coffeeownertalk
            "­¤øÆ Buy.":
                menu:
                    "Espresso. ($3)":
                        if bag.buy (espresso):
                            jump cshopmenu01
                        else:
                            mc "I can't afford that."
                            jump coffeeownermenu
                    "Cappuccino. ($5)":
                        if bag.buy (cappuccino):
                            jump cshopmenu02
                        else:
                            mc "I can't afford that."
                            jump coffeeownermenu
                    "Macchiato. ($5)":
                        if bag.buy (macchiato):
                            jump cshopmenu03
                        else:
                            mc "I can't afford that."
                            jump coffeeownermenu
                    "Irish coffee. ($7)":
                        if bag.buy (irish):
                            jump cshopmenu04
                        else:
                            mc "I can't afford that."
                            jump coffeeownermenu
                    "­¤ź¢ Cinnamon roll. ($3)" if sidedwithclaire:
                        if bag.buy (cinnamonroll):
                            jump cshopmenu01
                        else:
                            mc "I can't afford that."
                            jump coffeeownermenu
                    "­¤Ź× Loaf of bread. ($3)" if sidedwithclaire:
                        if bag.buy (bread):
                            jump cshopmenu01
                        else:
                            mc "I can't afford that."
                            jump coffeeownermenu
                    "Nevermind.":
                        jump coffeeownermenu
            "Nevermind.":
                jump cshopleave2
    else:
        $ meet_character("havemet_coffeeowner", "images/coffeeshop/clairemeet.webm", 3.0, "At the coffeeshop Monday, Wednesday and Friday.")
        jump coffeeownermenu

label cshopinterview:
    if quest_initcshophelp in questlog.quest_list:
        scene cshop10 with dissolve
        coffeeowner "So, you want to work here?"
        sbro "Yes, I do."
        scene justininterview with dissolve
        coffeeowner "Alright, let's go to the back office and talk there."
        sbro "Sure."
        mc "Good luck, Justin."
        scene mcwait with dissolve
        coffeegirl "Hey, since Claire is in the office with your brother right now, how about you help me out here while you wait?"
        menu:
            "ŌŁÉ I'd love to.":
                $ milk = False
                $ liquor = False
                $ cream = False
                mc "Sure, what do you need help with?"
                scene mcwait2 with dissolve
                coffeegirl "Just some basic tasks, like taking orders and serving customers."
                coffeegirl "It'll be a good way to pass the time."
                coffeegirl "Just get behind the counter and if a customer comes, serve them."
                mc "Sounds easy enough."
                scene mcwait3 with dissolve
                "You observe from behind the counter as customers are finishing their drinks and leaving."
                mc "(I guess that lady wants to order something.)"
                mc "(Here we go.)"
                scene mcwait4 with dissolve
                $ coffee_choice = renpy.random.choice(["lat├®", "espresso", "cappuccino", "Irish coffee"])
                lady "Excuse me, can I get a {color=#82a1ff}[coffee_choice]{/color} please?"
                mc "Sure, coming right up."
                call screen coffeemaking
                return
            "Refuse.":
                mc "Sorry, I can't help you."
                scene mcwait2 with dissolve
                coffeegirl "Ugh.. fine."
                scene black with fade
                mc "I sure hope Justin is doing well in there."
                mc "(It would be good for him...)"
                mc "(For all of us...)"
                $ coffeegirllove -= 1
                $ coffeeownerlove -= 1
                jump justininterviewend


label justininterviewend:
    scene justininterview with dissolve 
    play sound "audio/doorclose.ogg"
    "After a while, Justin and Claire come out of the office."
    coffeeowner "I'm sorry, Justin."
    coffeeowner "I just don't think this is the right job for you."
    sbro "Fine, whatever."
    scene cshop8 with dissolve
    mc "Wait, hold on."
    mc "Why not?"
    coffeeowner "I'm sorry, [name], but he doesn't seem to be a good fit for this job."
    coffeeowner "I need someone who is responsible, but also friendly towards customers."
    scene justininterview2 with dissolve
    sbro "I am friendly!!!"
    mc "(Ugh...)"
    scene cshop9 with dissolve
    coffeeowner "And that right there, is exactly what I mean."
    coffeeowner "I need someone who is calm and collected, not someone who gets angry at the slightest inconvenience."
    mc "I understand, I'm sorry to have wasted your time."
    scene cshop10 with dissolve
    coffeeowner "Now see, that is someone who is calm and collected."
    coffeeowner "Someone I can work with."
    coffeeowner "Thank you for understanding, [name]."
    mc "No problem, I guess we better go now."
    $ questlog.EndQuest (quest_initcshophelp, calendar.day)
    $ questlog.StartQuest (quest_sbrohome)
    if coffeehelped:
        scene cshop6 with dissolve
        coffeeowner "Alright, no problem."
        coffeeowner "Here, take this since you helped while I was interviewing Justin."
        $ bag.add_item(espresso)
        mc "Oh right, thank you."
        $ questlog.EndQuest(quest_getcoffee, calendar.day)
        $ questlog.StartQuest(quest_smomcoffee)
    play music "audio/police.ogg"
    scene cshopout with dissolve
    "As you leave the coffeeshop, another customer enters talking on the phone."
    lady "I know, I know, it's like this place wants to fail."
    lady "No flyers, no social media, no nothing."
    lady "They say that her permit is being denied."
    lady "Yeah."
    mc "(Huh...)"
    $ questlog.StartQuest(quest_cshoppermit)
    mc "(Maybe she needs help after all...)"
    mc "(Oh well, I better go home and tell stepmom about what happened first.)"
    $ current_location = None
    return

label cshopsneak:
    if quest_confrontclaire in questlog.quest_list:
        scene cshoploans with dissolve
        mc "Alright, I need to be careful."
        mc "I don't want to get caught."
