Made with Ren'Py.init python:
    import time

    def timed_menu_jump(choices, timeout=5.0, timeout_label=None, timeout_returns=False):
        global timed_menu_expire_time

        # Disable rollback for the entire timed menu
        renpy.block_rollback()

        # Set timestamp once
        timed_menu_expire_time = time.time() + timeout

        result = renpy.call_screen(
            "timed_menu_screen",
            choices, timeout, timeout_returns
        )

        timed_menu_expire_time = None

        if result == "__timeout__":
            if timeout_label:
                store.dialogue_active = False
                renpy.jump(timeout_label)
        else:
            store.dialogue_active = False
            renpy.jump(result)







screen timed_menu_screen(items, timeout, timeout_returns=False):
    on "show" action SetVariable("dialogue_active", True)
    $ renpy.block_rollback()
    # Remaining time = absolute expiration - real time (rollback-proof)
    $ remaining = max(0, timed_menu_expire_time - time.time())

    default lockout = True

    # Prevent fast accidental click
    timer 0.25 action SetScreenVariable("lockout", False)

    # Update the visible countdown bar
    timer 0.05 repeat True action SetScreenVariable(
        "remaining", max(0, timed_menu_expire_time - time.time())
    )

    # Timeout behavior
    if timeout_returns:
        timer timeout action Return("__timeout__")
    else:
        timer timeout action SetScreenVariable("remaining", 0)

    # UI
    vbox:
        spacing 1
        xalign 0.5
        yalign 0.5

        for caption, value, is_timed in items:

            $ expired = is_timed and remaining <= 0

            button:
                action Return(value)
                sensitive (not lockout and not expired)
                background Frame("gui/button/idle_background.png", 20, 20)
                hover_background Frame("gui/button/hover_background.png", 20, 20)
                padding (30, 20)
                xalign 0.5

                vbox:
                    spacing 10

                    text caption:
                        size 24
                        color ("#666" if expired else "#FFF")
                        hover_color ("#666" if expired else "#66baff")
                        outlines [(1, "#000", 0, 0)]
                        xalign 0.5

                    # Timed bar only on timed options
                    if is_timed and not expired:
                        frame:
                            background None
                            padding (0, 0)
                            xalign 0.5
                            xmaximum 150

                            bar:
                                value remaining
                                range timeout
                                ysize 8
                                xfill True
                                left_bar ("#FFD700" if remaining > timeout * 0.33 else "#FF3C3C")
                                right_bar "#222"

Made with Ren'Py.default circle_dim = False
default glyphs_unlocked = False

screen trailerpark:
    tag trailer
    $ present = get_characters_at_location("trailerpark")

    if get_time_of_day() == "night":
        add "images/trailerpark/trailerparknightbg.png"

        on "show" action [
            SetVariable("circle_dim", False),  # reset hover-driven state
            Function(renpy.music.play, "audio/trailersound.ogg", loop=True, fadein=0.5),
            SetVariable("current_location", "trailerpark")
        ]

        add ConditionSwitch(
            "circle_dim",  "images/trailerpark/circlenight_hover.png",
            "True",        "images/trailerpark/trailerparknightbg.png"
        )

        imagebutton auto "images/trailerpark/circle_%s.png" focus_mask True:
            hovered SetVariable("circle_dim", True)
            unhovered SetVariable("circle_dim", False)
            action Jump("spiritactivation")

        if quest_goodbye.completed:
            imagebutton auto "images/trailerpark/trailer3night_%s.png" style "worldbutton" focus_mask True action Call("famdialogue")

            if (bag.has_item("Token of Greed") or bag.has_item("Token of Power") or bag.has_item("Token of Lust") or quest_veilrepair in questlog.quest_list or quest_fortuneglyphs in questlog.quest_list):
                imagebutton auto "images/trailerpark/trailer2night_%s.png" style "worldbutton" focus_mask True action [Hide("trailerpark"), Show("trailerscreen2")]

            if quest_feralintro in questlog.quest_list or quest_feralgirlintro in questlog.quest_list:
                imagebutton auto "images/trailerpark/trailer1night_%s.png" style "worldbutton" focus_mask True action Call("feraldialogue")

            if quest_loudintro in questlog.quest_list:
                imagebutton auto "images/trailerpark/trailer4night_%s.png" style "worldbutton" focus_mask True action Call("loudmouthdialogue")

            if quest_drained in questlog.quest_list:
                imagebutton auto "images/trailerpark/trailer4night_%s.png" style "worldbutton" focus_mask True action Call("maydrain")

            if has_car:
                imagebutton auto "images/trailerpark/carnight_%s.png" focus_mask True:
                    hovered [ Play("sound", "audio/caropen.ogg") ]
                    unhovered [ Play("sound", "audio/carclose.ogg") ]
                    action [
                        Play("sound", "audio/carstart.ogg"),
                        Hide("trailerpark"),
                        Show("desertmap")
                    ]

        elif quest_feralintro.completed:
            imagebutton auto "images/trailerpark/trailer1night_%s.png" style "worldbutton" focus_mask True action [Hide("trailerpark"), Show("trailerscreen1")]
        elif quest_loudintro.completed:
            imagebutton auto "images/trailerpark/trailer4_%s.png" style "worldbutton" focus_mask True action [Hide("trailerpark"), Show("trailerscreen4")]

    else:
        add "images/trailerpark/trailerparknew2.webp"
        on "show" action [Function(renpy.music.play, "audio/trailersound.ogg", loop=True, fadein=0.5), SetVariable("current_location", "trailerpark")]
        if "homeless" in present:
                imagebutton auto "images/trailerpark/homeless_%s.png" focus_mask True action Call("homelessdialogue")
        if quest_goodbye.completed:
            
            imagebutton auto "images/trailerpark/trailer3_%s.png" style "worldbutton" focus_mask True action [Hide("trailerpark"), Call("famdialogue")]
            if (bag.has_item("Token of Greed") or bag.has_item("Token of Power") or bag.has_item("Token of Lust") or quest_veilrepair in questlog.quest_list or quest_fortuneglyphs in questlog.quest_list):
                imagebutton auto "images/trailerpark/trailer2_%s.png" style "worldbutton" focus_mask True action [Hide("trailerpark"), Show("trailerscreen2")]
            if quest_feralintro in questlog.quest_list or quest_feralgirlintro in questlog.quest_list:
                imagebutton auto "images/trailerpark/trailer1_%s.png" style "worldbutton" focus_mask True action Call("feraldialogue")
            if quest_loudintro in questlog.quest_list:
                imagebutton auto "images/trailerpark/trailer4_%s.png" style "worldbutton" focus_mask True action Call("loudmouthdialogue")
            if quest_drained in questlog.quest_list:
                imagebutton auto "images/trailerpark/trailer4_%s.png" style "worldbutton" focus_mask True action Call("maydrain")

            if has_car:
                imagebutton auto "images/trailerpark/car_%s.png" focus_mask True:
                    hovered [ Play("sound", "audio/caropen.ogg") ]
                    unhovered [ Play("sound", "audio/carclose.ogg") ]
                    action [
                        Play("sound", "audio/carstart.ogg"),
                        Hide("trailerpark"),
                        Show("desertmap")
                    ]
        elif quest_feralintro.completed:
            imagebutton auto "images/trailerpark/trailer1_%s.png" style "worldbutton" focus_mask True action [Hide("trailerpark"), Show("trailerscreen1")]
        elif quest_loudintro.completed:
            imagebutton auto "images/trailerpark/trailer4_%s.png" style "worldbutton" focus_mask True action [Hide("trailerpark"), Show("trailerscreen4")]

screen trailerscreen1:
    tag trailer
    add "images/trailerpark/trailerparkferal2.webp"
    on "show" action SetVariable("current_location", "feraltrailer")
    imagebutton auto "images/trailerpark/feral1_%s.png" focus_mask True action Call("feraldialogue")
    imagebutton auto "images/trailerpark/feral2_%s.png" focus_mask True action Call("feraldialogue")

screen trailerscreen2:
    tag trailer
    add "images/trailerpark/fortuneteller2.webp"
    on "show" action SetVariable("current_location", "fortunetrailer")
    imagebutton auto "images/trailerpark/fortuneteller_%s.png" focus_mask True action Call("fortunedialogue")

screen trailerscreen3:
    tag trailer
    add "images/trailerpark/trailerfam.webp"
    on "show" action SetVariable("current_location", "cathtrailer")
    imagebutton auto "images/trailerpark/cathmom_%s.png" focus_mask True action Call("famdialogue")
    imagebutton auto "images/trailerpark/cathbf_%s.png" focus_mask True action Call("famdialogue")
    imagebutton auto "images/trailerpark/cathdaughter_%s.png" focus_mask True action Call("famdialogue")

screen trailerscreen4:
    tag trailer
    add "images/trailerpark/loudtrailerout2.webp"
    on "show" action SetVariable("current_location", "loudmomtrailer")
    imagebutton auto "images/trailerpark/loudmouth_%s.png" focus_mask True action Call("loudmouthdialogue")

