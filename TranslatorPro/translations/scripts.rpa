        imagebutton auto "images/poker/laundromat/naomi_%s.png" focus_mask True action Call("naomipoker")
    if quest_spanked in questlog.quest_list:
        imagebutton auto "images/poker/laundromat/vivianne_%s.png" focus_mask True action Call("vividialogue")

screen pokerroom:
    tag laundromat
    $ present = get_characters_at_location("pokerroom")
    on "show" action SetVariable("current_location", "pokerroom")
    add "images/poker/naomitalk05.png"
    imagebutton auto "images/poker/chair_%s.png" focus_mask True action Call("poker_check")

screen laundroatm:
    tag laundromat
    add "images/poker/laundromat/atmlaundromat.png"
    text "Balance: $[bag.bank]" xalign 0.45 ypos 0.38 color "#000000"
    hbox:
        xanchor 0.5
        yanchor 0.0
        xpos 0.450
        ypos 0.45
        spacing 50
        textbutton "Deposit" background None action Call("depositmenu")
        textbutton "Withdraw" background None action Call("withdrawmenu")
        textbutton "Leave" background None action [Hide("laundroatm"), Show("laundromatscreen")]
    

label depositmenu:
    scene atmlaundromat
    menu:
        "Deposit $[bag.cash]":
            if bag.deposit_to_bank(bag.cash):
                scene atmlaundromat3 with dissolve
                mc "Better safe than sorry..."
                jump depositmenu
        "Deposit $500" if bag.cash >= 500:
            if bag.deposit_to_bank(500):
                scene atmlaundromat3 with dissolve
                "You've deposited 500 dollars into your bank account."
                jump depositmenu
        "Deposit $100" if bag.cash >= 100:
            if bag.deposit_to_bank(100):
                scene atmlaundromat3 with dissolve
                "You've deposited 100 dollars into your bank account."
                jump depositmenu
        "Deposit $50" if bag.cash >= 50:
            if bag.deposit_to_bank(50):
                scene atmlaundromat3 with dissolve
                "You've deposited 50 dollars into your bank account."
                jump depositmenu
        "Deposit $20" if bag.cash >= 20:
            if bag.deposit_to_bank(20):
                scene atmlaundromat3 with dissolve
                "You've deposited 20 dollars into your bank account."
                jump depositmenu
        "Back.":
            return

label withdrawmenu:
    scene atmlaundromat
    menu:
        "Withdraw $[bag.bank]":
            if bag.withdraw_from_bank(bag.bank):
                scene atmlaundromat3 with dissolve
                mc "I'll need all of this, thank you."
                jump withdrawmenu
        "Withdraw $500" if bag.bank >= 500:
            if bag.withdraw_from_bank(500):
                scene atmlaundromat3 with dissolve
                "You've withdrawn 500 dollars from your bank account."
                jump withdrawmenu
        "Withdraw $100" if bag.bank >= 100:
            if bag.withdraw_from_bank(100):
                scene atmlaundromat3 with dissolve
                "You've withdrawn 100 dollars from your bank account."
                jump withdrawmenu
        "Withdraw $50" if bag.bank >= 50:
            if bag.withdraw_from_bank(50):
                scene atmlaundromat3 with dissolve
                "You've withdrawn 50 dollars from your bank account."
                jump withdrawmenu
        "Withdraw $20" if bag.bank >= 20:
            if bag.withdraw_from_bank(20):
                scene atmlaundromat3 with dissolve
                "You've withdrawn 20 dollars from your bank account."
                jump withdrawmenu
        "Back.":
            return
                


label vividialogue:
    if not is_dare_active("spanking_laundry"):
        $ renpy.notify("This isn't your current dare. Check Midnight's app.")
        $ current_location = "mall"
        return
    scene viviannedare1 with dissolve
    mc "(I shouldn't be doing this, this is wrong.)"
    mc "(She is hot though...)"
    menu:
        "Spank her.":
            $ complete_dare()
            scene viviannedare2 with dissolve
            "You sneak up behind her, steadying your nerves."
            mc "(I'm about to get in so much trouble...)"
            scene viviannedare3 with dissolve
            lady "Oh my- What the hell?!"
            mc "(Yep, here we go.)"
            scene viviannedare4 with dissolve
            lady "Young man, how dare you?!"
            lady "This is assault, I-"
            scene viviannedare5 with dissolve
            "She stops mid-sentence, giving you a long look up and down."
            mc "I'm so sorry, I.."
            mc "You looked so hot and I..."
            lady "Oh, you're actually kind of cute..."
            lady "You really think I'm still hot?"
            mc "God, yes..."
            scene viviannedare6 with dissolve
            "Her demeanor changes, she looks flattered."
            lady "Well then... next time, buy me a coffee first!"
            mc "Heh, I'd love to."
            scene black with slow_fade
            pause 0.5
            "She hands you her number before walking off with her laundry basket."
            $ havemet_vivi = True
            $ vivspanked = True
            return
        "Don't do it.":
            mc "(Nope. Too risky, too wrong.)"
            $ fail_dare()
            return
            

label naomipoker:
    scene naomitalk01 with dissolve
    bffmom "[name]! How good to see you here."
    bffmom "How are you?"
    mc "Hey Naomi, I'm fine."
    mc "What about you, what are you doing here?"
    scene naomitalk02 with dissolve
    bffmom "Don't tell anyone..."
    bffmom "I'm here to play poker."
    mc "(Wait, poker in a laundromat?)"
    mc "Uhh, what?"
    scene naomitalk03 with dissolve
    bffmom "I guess I shouldn't have told you."
    mc "But naomi, we're in a laundromat."
    scene naomitalk04 with dissolve
    bffmom "Follow me [name]..."
    "You follow Naomi in the room with a sign that says 'Staff only'"
    scene naomitalk05 with dissolve
    bffmom "So? What do you think?"
    mc "Uhh... A gambling room?"
    mc "(Behind a laundromat?)"
    mc "(I've heard of this before, it's apparently not that uncommon.)"
    bffmom "Genius right?"
    bffmom "And the cops are pretty much okay with it."
    bffmom "So what do you say? Care for a game or two?"
    jump poker_check

label poker_check:
    menu:
        "Play poker ($100)":
            if bag.cash >= 100:
                $ poker_quit = False
                jump poker_table
            else:
                mc "I don't have enough money right now."
                $ current_location = "pokerroom"
                return
        "No thanks.":
            bffmom "Suit yourself."
            return
