        "images/cityhall/124.webp",
        "images/cityhall/125.webp"
    ]
    $ embpics_index = 0
    while embpics_index < len(embpics_images):
        scene expression embpics_images[embpics_index] with dissolve
        "(Click to continue...)"
        $ embpics_index += 1
    "The pictures have been added to your phone gallery."
    # Add images to unlocked_pictures if not already present
    python:
        for img in embpics_images:
            if img not in unlocked_pictures:
                unlocked_pictures.append(img)
    # Remove embpics from inventory
    while bag.remove_item("Embarrassing pictures of Mr. Mayor"):
        pass
    return

init -1:
    default floaters = []

screen floater_manager():
    zorder 200

    timer 0.1 repeat True action Function(remove_expired_floaters)

    fixed:
        xpos 0.98
        xanchor 1.0
        ypos 0.35
        yanchor 0.0

        vbox:
            spacing 10
            xalign 1.0
            for f in floaters[-4:]:

                frame:
                    background Frame("gui/notify.png" ,1)
                    padding (10, 6)

                    hbox:
                        spacing 6

                        text f["text"]:
                            size 24
                            color f["color"]
                            outlines [(1, "#000", 0, 0)]

                    at floater_anim

transform floater_anim:
    xoffset 40
    alpha 0
    linear 0.15 xoffset 0 alpha 1
    pause 1.6
    linear 0.4 alpha 0

transform floater_stack_anim:
    easein 0.3 yoffset 0

screen _floater_timer(text, fid=None):
    timer 2.3 action Function(remove_floater, fid if fid else text)

init python:
    import time
    import uuid

    config.overlay_screens.append("floater_manager")

    def show_floater(text, color="#7ecbff"):
        if store.floater_suppressed:
            return

        fid = str(uuid.uuid4())

        store.floaters.append({
            "id": fid,
            "text": text,
            "color": color,
            "expires": time.time() + 2.3,
        })

        renpy.restart_interaction()

    def hide_floater(text):
        store.floaters[:] = [f for f in store.floaters if f["text"] != text]

    def remove_floater(key):
        store.floaters[:] = [
            f for f in store.floaters
            if f.get("id") != key and f.get("text") != key
        ]
        
    def remove_expired_floaters():
        now = time.time()

        before = len(store.floaters)

        store.floaters[:] = [
            f for f in store.floaters
            if f.get("expires", now + 1) > now
        ]

        if len(store.floaters) != before:
            renpy.restart_interaction()

