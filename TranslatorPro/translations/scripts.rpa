label midnightinteraction:
    scene diner3 with dissolve
    play sound "audio/midnightmeow.ogg"
    midnight "*Meow*"
    mc "Huh.. You look like the cat at the trailer park."
    mc "(That can't be.)"
    mc "(Probably just a stray looking for food.)"
    menu:
        "ŌØż’ĖÅ Feed the cat." if bag.has_item(pie) and calendar.can_perform_action("feed_midnight"):
            $ calendar.record_action("feed_midnight")
            "You offer the cat a slice of pie."
            $ bag.remove_item(pie)
            mc "Huh, you like pie?"
            play sound "audio/midnightcute.ogg"
            mc "(Something is off about this cat...)"
            $ midnightlove += 10
            return
        "ŌØż’ĖÅ Pet the cat" if calendar.can_perform_action("pet_midnight"):
            $ calendar.record_action("pet_midnight")
            scene petmidnight with dissolve
            play sound "audio/midnightpurr.ogg"
            mc "Oh, you're a friendly one."
            mc "(You pet the cat for a while, it seems to enjoy the attention.)"
            $ midnightlove += 5
            return
        "Meow back at her.": 
            mc "Meow."
            play sound "audio/midnighthiss.ogg"
            $ midnightlove -= 2
            mc "(Oh damn, she clearly didn't like that.)"
            return
        "Leave her alone.":
            return

label waitressdialogue:
    if not havemet_waitress:
        scene diner4 with dissolve
        mc "(Is she.. Serving food to an empty booth?)"
        scene diner5 with dissolve
        waitress "Well now... you look like you crawled outta the dust just to find me."
        mc "Heh, is it that obvious?"
        scene diner6 with dissolve
        waitress "Honey, everything's obvious out here. That's the curse of too much sunlight and not enough secrets."
        mc "And which one are you?"
        waitress "Depends on the day. Today? I'm the one bringing coffee, not answers."
        mc "I'll take both, if you're offering."
        scene diner7 with dissolve
        waitress "Mmhm. You'll get one. The other? You'll have to earn."
        $ havemet_waitress = True
        $ waitresslove += 1
        $ questlog.EndQuest(quest_desertintro)
        $ questlog.EndQuest(quest_roadtrip)
        $ questlog.StartQuest(quest_askwaitress)
        jump waitressdialogue
    else:
        scene diner5 with dissolve
        waitress "Back already huh?"
        waitress "You get a taste for heat or just the pie?"
        menu: 
            "ŌŁÉ Stay the night." if quest_askwaitress in questlog.quest_list or quest_askwaitress.completed:
                jump dinersleep
            "ŌŁÉ About Justin." if quest_findjustin in questlog.quest_list:
                waitress "[name], any luck on your investigation?"
                mc "Not really, it's tough out there."
                scene diner6 with dissolve
                waitress "Maybe this will help."
                "She hands you a note from Sadie."
                mc "Oh, this is from the officers back in the city."
                waitress "They told me to only give it to you."
                "The note says..."
                "Hey [name], if you're still looking for Justin meet me at the diner before my shift starts."
                $ questlog.StartQuest(quest_meetofficer)
                mc "Huh... It's worth hearing her out I guess."
                waitress "Glad to help."
                $ sadiedinerunlocked = True
                $ sadiediner_day = calendar.day + 1
                return
            "Buy":
                menu:
                    "ŌśĢ Get coffee. ($3)":
                        if bag.spend(3):
                            jump waitressdialogue2
                        else:
                            mc "I can't afford that."
                            jump waitressdialogue
                    "­¤ź¦ Get pie. ($3)":
                        if bag.spend(3):
                            $ bag.add_item(pie)
                            jump waitressdialogue2
                        else:
                            mc "I can't afford that."
                            jump waitressdialogue
                    "­¤źÉ Get breakfast. ($6)" if get_time_of_day() == "morning":
                        if bag.spend(6):
                            jump mcbooth
                        else:
                            mc "I can't afford that."
                            jump waitressdialogue
                    "­¤ź¬ Get lunch. ($8)" if get_time_of_day() == "afternoon":
                        if bag.spend(8):
                            jump mcbooth
                        else:
                            mc "I can't afford that."
                            jump waitressdialogue
                    "­¤ŹĢ Get dinner. ($10)" if get_time_of_day() == "evening":
                        if bag.spend(10):
                            jump mcbooth
                        else:
                            mc "I can't afford that."
                            jump waitressdialogue
                    "Nevermind.":
                        return
            "Nevermind.":
                return

label dinersleep:
    if quest_askwaitress in questlog.quest_list:
        scene diner6 with dissolve
        waitress "A place to sleep?"
        waitress "We don't really have rooms for rent."
        scene diner5 with dissolve
        waitress "I mean, we have a room but it ain't much."
        mc "That's okay, it's better than sleeping in my truck."
        mc "How much would it cost me?"
        scene diner7 with dissolve
        waitress "For that dump?"
        waitress "It'd be criminal to charge you for that."
        mc "Really? That's so helpful, thanks."
        waitress "This way, sir."
        scene black with fade
        "You follow the waitress to your room."
        scene dinerbedroom with dissolve
        mc "(Damn, she didn't lie.)"
        mc "(This place is a dump...)"
        mc "(But, it gets me through the night at least.)"
        scene dinerbedroom2 with dissolve
        mc "(What's this?)"
        mc "(Must be an old map or something.)"
        pause 1.0
        scene dinerbedroom5 with dissolve
        "You get settled and prepare for bed."
        pause 0.5
        scene dinerbedroom4 with dissolve
        "You quickly drift asleep..."
        $ calendar.skipday()
        scene dinerbedroom5 with dissolve
        "You wake up the next morning."
        mc "(Might aswell grab a bite to eat before I go and look for Justin.)"
        mc "(I wonder if the waitress can point me in the right direction.)"
        scene black with fade
        "You make your way to the diner and order breakfast."
        scene booth1 with dissolve
        waitress "Here you go, sir."
        mc "Thank you so much."
        scene diner11 with dissolve
        "She serves your food, you can't help but notice there is another plate across the table from you."
        mc "Uhh, I think you're mistaken."
        mc "I didn't order a burger & fries, and I'm eating alone."
        scene diner9 with dissolve
        waitress "I know, but that's how she likes her breakfast."
        mc "..."
        mc "She?"
        scene diner8 with dissolve
        waitress "Midnight."
        mc "Excuse me, but I don't know who you are talking about."
        scene diner9 with dissolve
        waitress "I know, sir."
        waitress "It's just how things work around here."
        mc "(Okay... this is creeping me out now.)"
        scene diner10 with dissolve
        waitress "Do not be alarmed, sir."
        waitress "As long as she is fed in time, she is harmless."
        mc "But we're the only ones here."
        scene diner9 with dissolve
        waitress "It appears that way doesn't it?"
        waitress "Just eat, it's on the house."
        scene diner11 with dissolve
        "The waitress leaves abruptly as you stare down at your... breakfast."
        mc "(Burgers and fries for breakfast... great.)"
        scene diner12 with dissolve
        $ calendar.addtime(30)
        "After about 30 minutes, you finish your food."
        "The plate in front of you, still untouched."
        mc "What a waste of food..."
