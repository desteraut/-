init python:
    import renpy.store as store
    import renpy.exports as renpy

    ALL_QUESTS = {}

    if "quest_update_tick" not in config.overlay_screens:
        config.overlay_screens.append("quest_update_tick")

    def get_installspy_required():
        total = 3

        if sidedwithelke and not coffeeshopunlocked:
            total -= 1

        return total

    def _quest_update_handler():
        import renpy.store as S
        import renpy.exports as renpy

        S._quest_update_pending = False

        # Force a safe-frame UI refresh *after* the screen is stable
        renpy.restart_interaction()

    def get_return_label(start_day, current_day, loc_key=None, npc_key=None, min_wait_days=0):
        import renpy.store as store

        if not hasattr(store, "calendar") or store.calendar is None:
            return "{color=#82a1ff}later{/color}"

        def blue(msg):
            return "{color=#82a1ff}%s{/color}" % msg
        # Handle RevertableList and other iterable types
        if hasattr(loc_key, '__iter__') and not isinstance(loc_key, str):
            labels = []

            for single_loc in loc_key:
                label = get_return_label(
                    start_day,
                    current_day,
                    loc_key=single_loc,
                    npc_key=npc_key,
                    min_wait_days=min_wait_days
                )
                if label:
                    labels.append(label)

            # Priority ordering
            priority_order = [
                "right now",
                "today",
                "later today",
                "tomorrow",
            ]

            for priority in priority_order:
                for l in labels:
                    if priority in l:
                        return l

            if labels:
                return labels[0]

            return blue("later")

        if not npc_key and loc_key:

            earliest_allowed = max(current_day, start_day + min_wait_days)
            current_weekday_index = store.calendar.days.index(store.calendar.weekday())

            for offset in range(0, 8):
                day_index = earliest_allowed + offset
                weekday = store.calendar.days[
                    (current_weekday_index + (day_index - current_day)) % len(store.calendar.days)
                ]

                # --- Check location_hours ---
                if loc_key in store.location_hours:
                    if weekday not in store.location_hours[loc_key]:
                        continue
                    open_hour, close_hour = store.location_hours[loc_key][weekday]
                    if day_index == current_day:
                        current_hour = store.current_time_decimal()
                        if open_hour < close_hour:
                            if current_hour >= close_hour:
                                continue
                        else:
                            if close_hour <= current_hour < open_hour:
                                continue

                # --- Check location_periods ---
                if loc_key in store.location_periods:
                    if weekday not in store.location_periods[loc_key]:
                        continue

                # Valid open day found
                if day_index == current_day:
                    return blue("today")
                if day_index == current_day + 1:
                    return blue("tomorrow")
                return blue("on %s" % weekday)

            return blue("later")

        # ============================================================
        # 2) Build valid sublocations
        # ============================================================
        def build_valid_sublocs(lk):
            vs = set([lk])
            if lk in store.compound_locations:
                for room_key, _desc in store.compound_locations[lk]:
                    vs.add(room_key)
            for parent_key, rooms in store.compound_locations.items():
                for room_key, _desc in rooms:
                    if room_key == lk:
                        vs.add(parent_key)
            if hasattr(store, "hub_parents"):
                if lk in store.hub_parents:
                    vs.add(store.hub_parents[lk])
                for child, parent in store.hub_parents.items():
                    if lk == parent:
                        vs.add(child)
            return vs

        valid_sublocs = build_valid_sublocs(loc_key)

        # ============================================================
        # 3) RIGHT NOW
        # ============================================================
        earliest_allowed = max(current_day, start_day + min_wait_days)

        now_loc = store.get_scheduled_location(npc_key)
        if now_loc in valid_sublocs and earliest_allowed <= current_day:
            return blue("right now")

        # ============================================================
        # 4) Dynamic scheduler logic
        # ============================================================
        earliest_allowed = max(current_day, start_day + min_wait_days)

        offset, weekday_name = get_next_valid_day_for_npc(
            npc_key,
            loc_key,
            start_day=earliest_allowed
        )

        if offset is None:
            return blue("later")

        actual_day_index = earliest_allowed + offset

        # ============================================================
        # 5) Later today
        # ============================================================
        if actual_day_index == current_day:
            return blue("later today")

        # ============================================================
        # 6) Find arrival hour
        # ============================================================
        day_periods = [
            ("morning", 9),
            ("afternoon", 12),
            ("evening", 18),
        ]

        current_weekday_index = store.calendar.days.index(store.calendar.weekday())
        target_wday = store.calendar.days[
            (current_weekday_index + (actual_day_index - current_day)) % len(store.calendar.days)
        ]
        display_hour = None

        for period_name, hour in day_periods:
            npc_loc = store.resolve_location(
                npc_key,
                target_wday,
                hour,
                store.character_schedules,
                store.character_hourly,
                default="unknown",
                tod_override=period_name
            )
            if npc_loc in valid_sublocs:
                display_hour = hour
                break

        # ============================================================
        # 7) Tomorrow
        # ============================================================
        if actual_day_index == current_day + 1:
            if display_hour is not None:
                return blue("tomorrow at %02d:00" % display_hour)
            return blue("tomorrow")

        # ============================================================
        # 8) Later weekday
        # ============================================================
        if display_hour is not None:
            return blue("on %s at %02d:00" % (target_wday, display_hour))
        return blue("on %s" % target_wday)





    class Quest (renpy.store.object):
        def __init__(self, name, description, category="Side", available=False, started=False, completed=False, completed_day=0, hidden=False, start_day=0, loc_key=None, npc_key=None, required=0, progress=0, min_wait_days=0, checkpoint=False, checkpoint_name=None):
            self.base_name = name
            self.name = name
            self.base_description = description
            self.description = description
            self.category = category
            self.available = available
            self.started = started
            self.completed = completed
            self.completed_day = completed_day
            self.hidden = hidden
            self.start_day = start_day
            self.loc_key = loc_key
            self.npc_key = npc_key
            self.required = required
            self.progress = progress
            self.min_wait_days = min_wait_days
            self.checkpoint = checkpoint
            self.checkpoint_name = checkpoint_name
            self.update_desc()

        

        def update_desc(self):
            import renpy.store as store
            if not hasattr(self, "base_description"):
                self.base_description = self.description
            current_day = getattr(getattr(store, "calendar", None), "day", 0)
            return_label = get_return_label(
                self.start_day, 
                current_day, 
                loc_key=getattr(self, "loc_key", None),
                npc_key=getattr(self, "npc_key", None),
                min_wait_days=getattr(self, "min_wait_days", 0)
            )

            # Name
            if getattr(self, "required", 0) > 0:
                self.name = self.base_name.format(
                    progress=self.progress,
                    required=self.required,
                    mom_name=store.mom_name,
                    stepmom_name=store.stepmom_name,
                    return_label=return_label,
                )
            else:
                self.name = self.base_name.format(
                    mom_name=store.mom_name,
                    stepmom_name=store.stepmom_name,
                    return_label=return_label,
                )

            # Description ŌĆö IMPORTANT: use the template, not the already-formatted text
            self.description = self.base_description.format(
                mom_name=store.mom_name,
                stepmom_name=store.stepmom_name,
                return_label=return_label,
            )


        def increment(self, amount=1):
            if self.required <= 0 or self.completed:
                return
            self.progress = min(self.progress + amount, self.required)
            self.update_desc()
            if self.progress >= self.required:
                self.completed = True
                self.available = False
                self.started = False
                try:
                    self.completed_day = store.calendar.day
                except Exception:
                    self.completed_day = 0
                if self is quest_findjustin:
                    if quest_finishjustinarc not in questlog.quest_list:
                        questlog.StartQuest(quest_finishjustinarc)
                if self is quest_buyscents:
                    if quest_meetperfume not in questlog.quest_list:
                        questlog.StartQuest(quest_meetperfume)
                if self is quest_installspy:
                    if quest_watchspyware not in questlog.quest_list:
                        quest_watchspyware.required = 2 if (sidedwithelke and not coffeeshopunlocked) else 3
                        questlog.StartQuest(quest_watchspyware)
                

        @property
        def should_show(self):
            if self.hidden:
                return False
            if self.available and not self.completed:
                return True
            return False

    class Questlog (store.object):
        def __init__(self):
            self.quest_list = []

        def StartQuest(self, quest, start_day=None):
            import renpy.store as S

            if quest not in self.quest_list:
                self.quest_list.append(quest)

            quest.available = True
            quest.started = True
            quest.completed = False
            quest.completed_day = 0

            if start_day is not None:
                quest.start_day = start_day
            else:
                try:
                    quest.start_day = S.calendar.day
                except Exception:
                    quest.start_day = 0

            quest.update_desc()

            # --- NEW: auto-track logic (category-aware) ---
            try:
                tq = getattr(S, "tracked_quest", None)

                if tq is None:
                    S.tracked_quest = quest

                elif tq.completed and tq.category == quest.category:
                    S.tracked_quest = quest

            except Exception:
                pass

            # ­¤öź Mark that quest data changed ŌåÆ safe refresh next frame
            S._quest_update_pending = True

            return True



        def EndQuest(self, quest, completed_day=None):
            import renpy.store as S

            if quest in self.quest_list:
                self.quest_list.remove(quest)

            quest.completed = True
            quest.available = False
            quest.started = False
            quest.update_desc()

            if completed_day is not None:
                quest.completed_day = completed_day
            else:
                try:
                    quest.completed_day = S.calendar.day
                except Exception:
                    quest.completed_day = 0

            # --- NEW: if this quest was being tracked, untrack it
            try: 
                if getattr(S, "tracked_quest", None) is quest: 
                    S.tracked_quest = None 
            except Exception:
                pass

            # ­¤öź Mark quest update pending
            S._quest_update_pending = True

            # --- CHECKPOINT HANDLING ---
            if getattr(quest, "checkpoint", False):
                S.last_checkpoint_quest = quest
                S.checkpoint_pending = True
                checkpoint_autosave()
                show_checkpoint_banner()

            return



        def StartDare(self, dare_id, title, desc, loc_key, start_day=None):
            """
            Creates and starts a Dare quest, flagged via category.
            """
            quest_name = "dare_{dare_id}_{calendar.day}"
            quest = Quest(
                name=quest_name,
                description=desc,
                category="Dare",   # distinguishes from 'Main', 'Side', etc.
                available=True
            )
            # You might store loc_key on the Quest if your UI/logic needs it
            quest.loc_key = loc_key

            self.StartQuest(quest, start_day=start_day)
            return quest

        def ResetQuest(self, quest, reset_type=None):
            # Resets quest state for daily/weekly resets
            quest.available = False
            quest.started = False
            quest.completed = False
            quest.completed_day = 0
            if quest in self.quest_list:
                self.quest_list.remove(quest)

        def get_visible_quests(self, category=None):
            # Returns only Quest objects that are available and not completed, optionally filtered by category
            if category:
                return [q for q in self.quest_list if hasattr(q, 'should_show') and q.should_show and q.category == category]
            return [q for q in self.quest_list if hasattr(q, 'should_show') and q.should_show]

        def ScheduleQuest(self, quest, days_from_now):
            import renpy.store as S
            for varname, obj in vars(S).items():
                if obj is quest:
                    target_day = S.calendar.day + days_from_now
                    y, m, d = S.calendar.year, S.calendar.month, target_day

                    while d > _days_in_month(y, m):
                        d -= _days_in_month(y, m)
                        m += 1
                        if m > 12:
                            m = 1
                            y += 1

                    S.scheduled_quests[varname] = {
                        "year": y,
                        "month": m,
                        "day": d
                    }
                    S._quest_update_pending = True
                    return
            raise ValueError(f"Quest object {quest} not found in store.")



        def _apply_scheduled_quest(self, quest_obj, data):
            if not quest_obj.completed:
                self.StartQuest(quest_obj)


        def CheckScheduledQuests(self):
            import renpy.store as S
            # Safe check - if somehow still missing, create it
            if not hasattr(S, 'scheduled_quests'):
                S.scheduled_quests = {}
                return
            
            to_start = [varname for varname, data in S.scheduled_quests.items() 
                        if S.calendar.day >= data["day"]]
            
            for varname in to_start:
                data = S.scheduled_quests[varname]
                quest_obj = getattr(S, varname, None)

                # Defer actual quest processing to next interaction
                renpy.ui.timer(
                    0.01,
                    action=Function(self._apply_scheduled_quest, quest_obj, data)
                )

                del S.scheduled_quests[varname]
                # return here so we don't process multiple in same frame
                return






    def check_trailer_quests():
        # All three must be completed
        if (quest_feralintro.completed and quest_loudintro.completed and quest_fortuneintro.completed):
            if not quest_trailerhub.started and not quest_trailerhub.completed:
                questlog.StartQuest(quest_trailerhub)

    def show_quest_hint_for(quest):
        if quest and getattr(quest, "description", None):
            renpy.show_screen("quest_hint_popup", text=quest.description)
        else:
            renpy.notify("This quest has no hints yet.")

    

    CATEGORY_COLORS = {
        "Main": "#FFD700",       # matches 'Main Story' header
        "Character": "#87CEEB",  # matches 'Character Arcs' header
        "Side": "#90EE90",       # matches 'Side Quests' header
        "Event": "#FFB6C1",      # matches 'Events' header
        "Dare": "#b54dfa",       # matches 'Midnight's Dares' header
    }

    def is_loc_tracked(loc_key):
        try:
            tq = store.tracked_quest
            if tq is None:
                return False
            if tq.completed or tq not in store.questlog.quest_list:
                store.tracked_quest = None
                return False
            q_loc = getattr(tq, "loc_key", None)
            if isinstance(q_loc, (list, tuple)):
                return loc_key in q_loc
            return q_loc == loc_key
        except Exception:
            return False

        

    def get_tracked_category_color():
        # Returns the hex color for the currently tracked quest's category, or None
        tq = getattr(store, "tracked_quest", None)
        if tq:
            return CATEGORY_COLORS.get(getattr(tq, "category", ""), None)
        return None

    def get_marker_images(loc_key):
        try:
            if is_loc_tracked(loc_key):
                # Category ŌåÆ filename key mapping
                tq = store.tracked_quest
                if (tq is None) or tq.completed or (tq not in store.questlog.quest_list):
                    return "images/gui/marker_idle.png", "images/gui/marker_hover.png"
                cat = getattr(tq, "category", None)
                cat_key = None
                if cat == "Main":
                    cat_key = "main"
                elif cat == "Character":
                    cat_key = "character"
                elif cat == "Side":
                    cat_key = "side"
                elif cat == "Event":
                    cat_key = "event"
                elif cat == "Dare":
                    cat_key = "dare"


                if cat_key:
                    idle = f"images/gui/{cat_key}marker_idle.png"
                    hover = f"images/gui/{cat_key}marker_hover.png"
                    if renpy.loadable(idle) and renpy.loadable(hover):
                        return idle, hover

                # Fallback: generic "tracked" variant, if you add it
                idle_t = "images/gui/marker_idle_tracked.png"
                hover_t = "images/gui/marker_hover_tracked.png"
                if renpy.loadable(idle_t) and renpy.loadable(hover_t):
                    return idle_t, hover_t

            # Default (untracked)
            return "images/gui/marker_idle.png", "images/gui/marker_hover.png"
        except Exception:
            # Absolute fallback so we never crash
            return "images/gui/marker_idle.png", "images/gui/marker_hover.png" 

init python:
    import renpy.store as S

    def auto_register_quests():
        global ALL_QUESTS
        ALL_QUESTS = {}

        for varname, value in vars(S).items():
            # Must be Quest instance AND named "quest_*"
            if isinstance(value, Quest) and varname.startswith("quest_"):
                ALL_QUESTS[varname] = value


default questlog_collapsed_main = False
default questlog_collapsed_character = False
default questlog_collapsed_side = False
default questlog_collapsed_event = False
default questlog_collapsed_dare = False
default tracked_quest = None

screen quest_entry(quest):

    hbox:
        spacing 4
        yminimum 24

        # --- Checkbox stays EXACTLY the same ---
        if tracked_quest is quest:
            textbutton "Ōśæ" action SetVariable("tracked_quest", None):
                background None
                padding (0, 0)
                xminimum 0
                xmaximum 20
                text_size 16
        else:
            if hasattr(quest, "loc_key") and quest.loc_key:
                textbutton "ŌśÉ" action SetVariable("tracked_quest", quest):
                    background None
                    padding (0, 0)
                    xminimum 0
                    xmaximum 20
                    text_size 16
            else:
                text "ŌśÉ" size 16 color "#888888"

        # --- NEW: make the TEXT clickable as well ---
        textbutton quest.name:
            action SetVariable("tracked_quest", quest if tracked_quest is not quest else None)
            background None
            text_color "#FFFFFF"
            text_size 16
            padding (0, 0)
            xmaximum 600


screen myquests():
    zorder 120 
    $ in_transition = (renpy.get_mode() != "screen")
    $ should_hide = dialogue_active or in_transition

    python:
        try:
            current_day = getattr(calendar, "day", 0)
            for q in questlog.quest_list:
                if q.started and not q.completed:
                    q.update_desc()
        except Exception:
            pass

    # --- Questlog frame ---
    fixed at ui_fade(0.0 if should_hide else 1.0):
        frame:
            style "questlog_panel"

            xalign 0.0
            ypos 300
            xpos -28
            padding (35, 35)
            style_prefix "ql"

            vbox:
                spacing 8
                $ main_quests = questlog.get_visible_quests(category="Main")
                if main_quests:
                    $ main_label = "­¤ææ {b}Main Story{/b} [-]" if not questlog_collapsed_main else "­¤ææ {b}Main Story{/b} [+]"
                    textbutton "[main_label]" action ToggleVariable("questlog_collapsed_main") background None text_color "#FFD700" text_size 16      
                    if not questlog_collapsed_main:
                        for quest in main_quests:
                            hbox:
                                spacing 4
                                use quest_entry(quest)
                                textbutton "(?)" action Function(show_quest_hint_for, quest) style "quest_hint_textbutton"

                $ char_quests = questlog.get_visible_quests(category="Character")
                if char_quests:
                    $ char_label = "ŌØż’ĖÅ {b}Character Arcs{/b} [-]" if not questlog_collapsed_character else "ŌØż’ĖÅ {b}Character Arcs{/b} [+]"
                    textbutton "[char_label]" action ToggleVariable("questlog_collapsed_character") background None text_color "#87CEEB" text_size 16
                    if not questlog_collapsed_character:
                        for quest in char_quests:
                            hbox:
                                spacing 4
                                use quest_entry(quest)
                                textbutton "(?)" action Function(show_quest_hint_for, quest) style "quest_hint_textbutton"

                $ side_quests = questlog.get_visible_quests(category="Side")
                if side_quests:
                    $ side_label = "­¤ō£ {b}Side Quests{/b} [-]" if not questlog_collapsed_side else "­¤ō£ {b}Side Quests{/b} [+]"
                    textbutton "[side_label]" action ToggleVariable("questlog_collapsed_side") background None text_color "#90EE90" text_size 16
                    if not questlog_collapsed_side:
                        for quest in side_quests:
                            hbox:
                                spacing 4
                                use quest_entry(quest)
                                textbutton "(?)" action Function(show_quest_hint_for, quest) style "quest_hint_textbutton"

                $ event_quests = questlog.get_visible_quests(category="Event")
                if event_quests:
                    $ event_label = "­¤Ä¬ {b}Events{/b} [-]" if not questlog_collapsed_event else "­¤Ä¬ {b}Events{/b} [+]"
                    textbutton "[event_label]" action ToggleVariable("questlog_collapsed_event") background None text_color "#FFB6C1" text_size 16
                    if not questlog_collapsed_event:
                        for quest in event_quests:
                            hbox:
                                spacing 4
                                use quest_entry(quest)
                                textbutton "(?)" action Function(show_quest_hint_for, quest) style "quest_hint_textbutton"

                $ dare_quests = questlog.get_visible_quests(category="Dare")
                if dare_quests:
                    $ dare_label = "Ō£©{b}Midnight's Dares{/b} [-]" if not questlog_collapsed_dare else "Ō£©{b}Midnight's Dares{/b} [+]"
                    textbutton "[dare_label]" action ToggleVariable("questlog_collapsed_dare") background None text_color "#b54dfa" text_size 16
                    if not questlog_collapsed_dare:
                        for quest in dare_quests:
                            hbox:
                                spacing 4
                                use quest_entry(quest)
                                textbutton "(?)" action Function(show_quest_hint_for, quest) style "quest_hint_textbutton"


screen quest_hint_popup(text):
    modal True
    zorder 120
    frame:
        background "#000a"
        xalign 0.5
        yalign 0.5
        xmaximum 800
        ymaximum 300
        padding (30, 30)
        vbox:
            spacing 20
            text "{b}Hint{/b}" size 28 color "#82a1ff" xalign 0.5
            text text size 22 color "#fff" xalign 0.5
            textbutton "Close" action Hide("quest_hint_popup") xalign 0.5

