    $ blackout_outcome = renpy.random.choice(["funny", "humiliating", "angry", "weird", "sexy"])

    if blackout_outcome == "funny":
        jump blackout_funny
    elif blackout_outcome == "humiliating":
        jump blackout_humiliating
    elif blackout_outcome == "angry":
        jump blackout_angry
    elif blackout_outcome == "weird":
        jump blackout_weird
    elif blackout_outcome == "sexy":
        jump blackout_sexy

