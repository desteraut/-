Made with Ren'Py.default askeddean = False
default bridgettebreakdown_seen = False

screen timhome:
    tag bffhome
    $ present = get_characters_at_location("timhome")  
    add "images/bffhome/bffhome.webp"
    on "show" action [Function(renpy.music.play, "audio/kitchen.ogg", loop=True, fadein=0.5), SetVariable("current_location", "timhome")]
    if "bffmom" in present:
        if quest_naomibait in questlog.quest_list:
            imagebutton auto "images/bffhome/naomidress_%s.png" focus_mask True action Call("bffmommenu") 
        if not "bffsis" in present or quest_timloop in questlog.quest_list:
            if not quest_naomibait in questlog.quest_list:
                imagebutton auto "images/bffhome/bffmom_%s.png" focus_mask True action Call("bffmommenu") 
        else:
            if not quest_naomibait in questlog.quest_list:
                imagebutton auto "images/bffhome/naomikitchen_%s.png" focus_mask True action Call("bffmommenu")
    if "dean" in present and calendar.can_perform_action("deantalk"):
        imagebutton auto "images/bffhome/bffdean_%s.png" focus_mask True action Call("deanbffmenu")
    if "bff" in present and quest_naomidate.completed_day != calendar.day:
        imagebutton auto "images/bffhome/bff_%s.png" focus_mask True action Call("bffhomemenu") 
    if "bffsis" in present:
        imagebutton auto "images/bffhome/bffsis_%s.png" focus_mask True action Call("bffsismenu") 
        

screen dicdecision:
    tag bffhome
    add "images/bffhome/decisionbg.webp"
    if quest_timloop in questlog.quest_list:
        imagebutton auto "images/bffhome/naomi_%s.png" focus_mask True action Call("naomiplan2")
        imagebutton auto "images/bffhome/tim_%s.png" focus_mask True action Call("timplan2")
    else:
        imagebutton auto "images/bffhome/naomi_%s.png" focus_mask True action Call("naomiplan")
        imagebutton auto "images/bffhome/tim_%s.png" focus_mask True action Call("timplan")

label deanfinale:
    scene black with fade
    "You arrive at Tim's place, Mrs. Brown is here talking to Naomi about her husband."
    scene bffdean1 with dissolve
    if deantruth_told:
        dean "And all he has been doing this entire time was take pictures... of birds!"
        bffmom "Sis, listen to me I-"
        scene deanargue1 with dissolve
        dean "No!"
        dean "For years I've doubted him, because of what you said."
        dean "Well no more! He proved himself."
        scene deanargue2 with dissolve
        bffmom "Oh please, just because [name] overheard him talking about birds doesn't mean anything."
        bffmom "As if the store clerk is the only one he ever meets to talk about anything."
        scene deanargue3 with dissolve
        dean "Hmph..."
        bffmom "Look sis, I never meant to come between the two of you..."
        bffmom "I just want what's best for you."
        pause 1.0
        dean "I know..."
    else:
        dean "They had setup some kind of deal and-"
        dean "And then he-"
        dean "He..."
        bffmom "Oh sis..."
    scene bffdean4 with dissolve
    pause 3.0
    scene deanargue4 with dissolve
    dean "Maybe it's time we moved on, huh?"
    bffmom "We should take it slow, why don't you come over for dinner sometime?"
    dean "Sounds good to me sis."
    scene bffdean5 with dissolve
    dean "[name], thanks for everything you did for us."
    mc "Uhh..."
    mc "You're welcome, Mrs. Brown."
    $ deanlove += 10
    play sound "audio/doorclose.ogg"
    pause 0.5
    if deanlie_told:
        "Naomi looks at you with a knowing smirk."
        mc "(Uh-oh... Did she realise what I did?)"
